{%- liquid
  assign s = s
  assign has_filters = has_filters
  assign filter_mode = filter_mode | default: 'sidebar'

  assign show_title = s.show_title
  assign show_desc = s.show_description
  assign desc_trunc = false
  if show_desc and s.description_style == 'truncated'
    assign desc_trunc = true
  endif

  assign show_sort = s.show_sort
  assign show_count = s.show_result_count
  assign show_active = s.show_active_filters
  assign show_clear = s.show_clear_all
  assign sticky_toolbar = sticky_toolbar

  assign active_count = 0
  if has_filters and filters != blank
    for f in filters
      if f.type == 'price_range'
        if f.min_value.value != blank or f.max_value.value != blank
          assign active_count = active_count | plus: 1
        endif
      else
        assign active_count = active_count | plus: f.active_values.size
      endif
    endfor
  endif
-%}

<div class="qcmToolbar{% if sticky_toolbar %} qcmToolbar--sticky{% endif %}">
  <div class="qcmToolbar__top">
    <div class="qcmToolbar__left">
      {%- if show_title -%}
        <h1 class="qcmToolbar__title">{{ results_title }}</h1>
      {%- endif -%}

      {%- if show_desc and results_description != blank -%}
        <p class="qcmToolbar__desc{% if desc_trunc %} qcmToolbar__desc--trunc{% endif %}">{{ results_description }}</p>
      {%- endif -%}
    </div>

    <div class="qcmToolbar__controls">
      {%- if has_filters and filter_mode == 'drawer' -%}
        <button class="qcm__btn" type="button" data-qcm-open-drawer aria-label="Open filters">
          Filters
          {%- if active_count > 0 -%} ({{ active_count }}){%- endif -%}
        </button>
      {%- endif -%}

      {%- if show_sort and sort_options != blank and sort_options.size > 0 -%}
        {%- if s.sort_style == 'pills' -%}
          <div class="qcmSortPills" role="group" aria-label="Sort">
            {%- for opt in sort_options -%}
              {%- liquid
                assign is_active = false
                if sort_by == opt.value
                  assign is_active = true
                elsif sort_by == blank and default_sort_by == opt.value
                  assign is_active = true
                endif

                assign sort_url = ''
                if is_search_context
                  assign sort_url = routes.search_url | append: '?q=' | append: terms_q | url_encode | append: '&sort_by=' | append: opt.value
                else
                  assign sort_url = results_url | append: '?sort_by=' | append: opt.value
                endif
              -%}
              <a class="qcm__btn{% if is_active %} qcm__btn--active{% endif %}" href="{{ sort_url }}">
                {{ opt.name }}
              </a>
            {%- endfor -%}
          </div>
        {%- else -%}
          <form method="get" action="{% if is_search_context %}{{ routes.search_url }}{% else %}{{ results_url }}{% endif %}">
            {%- if is_search_context -%}
              <input type="hidden" name="q" value="{{ terms_q | escape }}">
            {%- endif -%}
            <label class="visually-hidden" for="SortBy-{{ section.id }}">Sort</label>
            <select id="SortBy-{{ section.id }}" name="sort_by" onchange="this.form.submit()">
              {%- for opt in sort_options -%}
                {%- liquid
                  assign selected = false
                  if sort_by == opt.value
                    assign selected = true
                  elsif sort_by == blank and default_sort_by == opt.value
                    assign selected = true
                  endif
                -%}
                <option value="{{ opt.value }}" {% if selected %}selected{% endif %}>{{ opt.name }}</option>
              {%- endfor -%}
            </select>
          </form>
        {%- endif -%}
      {%- endif -%}

      {%- if show_count -%}
        <span class="qcmCount" aria-label="Result count">
          {%- if is_search_context -%}
            {{ search.results_count }} results
          {%- else -%}
            {{ collection.products_count }} products
          {%- endif -%}
        </span>
      {%- endif -%}

      {%- if show_clear and active_count > 0 -%}
        <a class="qcm__btn qcm__btn--link" href="{% if is_search_context %}{{ routes.search_url }}?q={{ terms_q | url_encode }}{% else %}{{ results_url }}{% endif %}">
          Clear all
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if show_active and has_filters and active_count > 0 -%}
    <div class="qcmChips" aria-label="Active filters">
      {%- for f in filters -%}
        {%- if f.type == 'price_range' -%}
          {%- if f.min_value.value != blank or f.max_value.value != blank -%}
            <a class="qcmChip" href="{{ f.url_to_remove }}">
              Price
              <span class="qcmChip__x" aria-hidden="true">×</span>
              <span class="visually-hidden">Remove</span>
            </a>
          {%- endif -%}
        {%- else -%}
          {%- for v in f.active_values -%}
            <a class="qcmChip" href="{{ v.url_to_remove }}">
              {{ v.label }}
              <span class="qcmChip__x" aria-hidden="true">×</span>
              <span class="visually-hidden">Remove</span>
            </a>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>