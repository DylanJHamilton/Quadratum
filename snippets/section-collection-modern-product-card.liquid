{%- comment -%}
  Quadratum — Collection Modern Product Card (optional engine)
  File: snippets/collection-modern-product-card.liquid

  Inputs:
  - product (required)
  - s (section.settings)
  - section (for IDs if needed)

  Notes:
  - Web3-ish / futuristic: subtle glass/outline via CSS class hooks
  - Quick add:
    - single-variant => add-to-cart form
    - multi-variant => "Choose options" link
{%- endcomment -%}

{%- liquid
  assign p = product
  if p == blank
    break
  endif

  assign show_vendor = s.show_vendor
  assign show_price = s.show_price
  assign show_badges = s.show_badges
  assign show_rating = s.show_rating
  assign show_quick_add = s.show_quick_add
  assign show_second = s.show_second_image

  assign ratio = s.image_ratio | default: 'adapt'

  assign media = p.featured_media
  assign img = media.preview_image

  assign second_img = nil
  if show_second and p.media != blank and p.media.size > 1
    for m in p.media
      if m.media_type == 'image' and m.id != media.id
        assign second_img = m.preview_image
        break
      endif
    endfor
  endif

  assign is_sold_out = false
  if p.available == false
    assign is_sold_out = true
  endif

  assign is_on_sale = false
  if p.compare_at_price_max > p.price
    assign is_on_sale = true
  endif
-%}

<article class="qcmCard qcmCard--{{ s.card_style | default: 'glass' }}">
  <a class="qcmCard__media" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
    <div class="qcmCard__mediaInner qcmRatio qcmRatio--{{ ratio }}">
      {%- if img != blank -%}
        {{ img
          | image_url: width: 900
          | image_tag:
              widths: '240, 360, 540, 720, 900',
              sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
              loading: 'lazy',
              class: 'qcmCard__img qcmCard__img--primary',
              alt: img.alt | default: p.title | escape
        }}
      {%- else -%}
        <div class="qcmCard__imgPlaceholder" aria-hidden="true"></div>
      {%- endif -%}

      {%- if second_img != blank -%}
        {{ second_img
          | image_url: width: 900
          | image_tag:
              widths: '240, 360, 540, 720, 900',
              sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
              loading: 'lazy',
              class: 'qcmCard__img qcmCard__img--secondary',
              alt: second_img.alt | default: p.title | escape
        }}
      {%- endif -%}
    </div>

    {%- if show_badges -%}
      <div class="qcmCard__badges" aria-hidden="true">
        {%- if is_sold_out -%}
          <span class="qcmBadge">Sold out</span>
        {%- elsif is_on_sale -%}
          <span class="qcmBadge">Sale</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </a>

  <div class="qcmCard__content">
    {%- if show_vendor -%}
      <div class="qcmCard__vendor">{{ p.vendor }}</div>
    {%- endif -%}

    <h3 class="qcmCard__title">
      <a href="{{ p.url }}">{{ p.title }}</a>
    </h3>

    {%- if show_rating -%}
      <div class="qcmCard__rating" aria-label="Rating">
        <span class="qcmRatingDot" aria-hidden="true"></span>
        <span class="qcmRatingText">Rating</span>
      </div>
    {%- endif -%}

    {%- if show_price -%}
      <div class="qcmCard__price">
        {%- if p.compare_at_price_max > p.price -%}
          <span class="qcmPrice qcmPrice--sale">{{ p.price | money }}</span>
          <span class="qcmPrice qcmPrice--compare">{{ p.compare_at_price_max | money }}</span>
        {%- else -%}
          <span class="qcmPrice">{{ p.price | money }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if show_quick_add -%}
      <div class="qcmCard__actions">
        {%- if p.available -%}
          {%- if p.has_only_default_variant -%}
            <form method="post" action="/cart/add" class="qcmCard__form">
              <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
              <button type="submit" class="qcmCard__btn" aria-label="Add {{ p.title | escape }} to cart">
                Add to cart
              </button>
            </form>
          {%- else -%}
            <a class="qcmCard__btn" href="{{ p.url }}" aria-label="Choose options for {{ p.title | escape }}">
              Choose options
            </a>
          {%- endif -%}
        {%- else -%}
          <span class="qcmCard__btn qcmCard__btn--disabled" aria-disabled="true">Unavailable</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</article>

{%- comment -%} Minimal styles for modern card (still scoped by parent section) {%- endcomment -%}
<style>
  .q-collection-modern .qcmCard{
    border-radius: var(--qcm-radius);
    border: 1px solid var(--qcm-border);
    overflow: hidden;
    background: color-mix(in srgb, var(--qcm-bg) 70%, transparent);
  }
  .q-collection-modern .qcmCard--none{ border: none; background: transparent; }
  .q-collection-modern .qcmCard--outline{ background: transparent; }
  .q-collection-modern .qcmCard--solid{ background: var(--qcm-bg); }
  .q-collection-modern .qcmCard--glass{ backdrop-filter: blur(10px); }

  .q-collection-modern .qcmCard__media{ display:block; text-decoration:none; color:inherit; position:relative; }
  .q-collection-modern .qcmRatio{ position:relative; width:100%; }
  .q-collection-modern .qcmRatio--square{ aspect-ratio: 1/1; }
  .q-collection-modern .qcmRatio--portrait{ aspect-ratio: 4/5; }
  .q-collection-modern .qcmRatio--landscape{ aspect-ratio: 16/10; }
  .q-collection-modern .qcmRatio--adapt{ aspect-ratio: 1/1; }

  .q-collection-modern .qcmCard__img,
  .q-collection-modern .qcmCard__imgPlaceholder{
    position:absolute; inset:0;
    width:100%; height:100%;
    object-fit: cover;
  }
  .q-collection-modern .qcmCard__img--secondary{
    opacity: 0;
    transition: opacity .18s ease;
  }
  @media (prefers-reduced-motion: reduce){
    .q-collection-modern .qcmCard__img--secondary{ transition:none; }
  }
  .q-collection-modern .qcmCard__media:hover .qcmCard__img--secondary{ opacity: 1; }

  .q-collection-modern .qcmCard__badges{
    position:absolute; left:10px; top:10px;
    display:flex; gap:8px; flex-wrap:wrap;
  }
  .q-collection-modern .qcmBadge{
    border: 1px solid var(--qcm-border);
    border-radius: 999px;
    padding: 6px 10px;
    font-size: .85em;
    background: color-mix(in srgb, var(--qcm-bg) 70%, transparent);
    backdrop-filter: blur(8px);
  }

  .q-collection-modern .qcmCard__content{
    padding: 14px 14px 16px;
    display:grid;
    gap: 8px;
  }
  .q-collection-modern .qcmCard__vendor{ opacity:.8; font-size:.9em; }
  .q-collection-modern .qcmCard__title{ margin:0; font-size: 1em; line-height:1.25; }
  .q-collection-modern .qcmCard__title a{ color:inherit; text-decoration:none; }
  .q-collection-modern .qcmCard__title a:hover{ text-decoration:underline; }

  .q-collection-modern .qcmCard__price{ display:flex; gap:10px; align-items:baseline; flex-wrap:wrap; }
  .q-collection-modern .qcmPrice--compare{ opacity:.7; text-decoration: line-through; }

  .q-collection-modern .qcmCard__actions{ margin-top: 6px; }
  .q-collection-modern .qcmCard__btn{
    display:inline-flex; align-items:center; justify-content:center;
    width:100%;
    border: 1px solid var(--qcm-border);
    border-radius: calc(var(--qcm-radius) * 0.75);
    padding: 10px 12px;
    background: transparent;
    color: inherit;
    text-decoration:none;
    cursor:pointer;
    font: inherit;
  }
  .q-collection-modern .qcmCard__btn--disabled{ opacity:.6; cursor:not-allowed; }
</style>