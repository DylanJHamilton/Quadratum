{%- comment -%}
  Quadratum — Collection Modern — Compare Tray
  File: snippets/collection-modern-compare-tray.liquid
{%- endcomment -%}

{%- if s.enable_compare -%}
  <div class="qcm__compare" hidden data-qcm-compare>
    <div class="qcm__compareInner">
      <div class="qcm__compareLeft">
        <strong data-qcm-compare-count>0</strong>
        <span class="qcm__compareTxt">selected</span>
      </div>
      <div class="qcm__compareRight">
        <button class="qcm__btn qcm__btn--ghost" type="button" data-qcm-compare-clear>Clear</button>
        <button class="qcm__btn" type="button" data-qcm-compare-open>{{ s.compare_label }}</button>
      </div>
    </div>
  </div>
{%- endif -%}