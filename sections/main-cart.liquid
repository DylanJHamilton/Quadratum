{{ 'section-main-cart.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-main-cart.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign continue_shopping_url = section.settings.continue_shopping_url
  if continue_shopping_url == blank
    assign continue_shopping_url = routes.all_products_collection_url
  endif
-%}

<section
  id="QtmMainCart-{{ section.id }}"
  class="
    qtm-main-cart
    qtm-main-cart--{{ section.settings.cart_style }}
    qtm-main-cart--layout-{{ section.settings.cart_layout }}
    qtm-main-cart--line-item-{{ section.settings.line_item_style }}
    qtm-main-cart--summary-{{ section.settings.summary_style }}
    qtm-main-cart--quantity-{{ section.settings.quantity_style }}
    qtm-main-cart--rewards-{{ section.settings.rewards_style }}
    qtm-main-cart--addons-{{ section.settings.addons_style }}
    qtm-main-cart--empty-{{ section.settings.empty_state_style }}
    qtm-main-cart--density-{{ section.settings.cart_density }}
    qtm-main-cart--image-{{ section.settings.cart_image_size }}
    {% if section.settings.sticky_summary_desktop %}qtm-main-cart--sticky-summary{% endif %}
  "
  data-section-id="{{ section.id }}"
  style="
    --qcart-title-size: {{ section.settings.title_font_size }}px;
    --qcart-price-size: {{ section.settings.price_font_size }}px;
    --qcart-meta-size: {{ section.settings.meta_font_size }}px;

    --qcart-button-bg: {{ section.settings.checkout_button_color }};
    --qcart-button-text: {{ section.settings.checkout_button_text_color }};
    --qcart-button-border-width: {{ section.settings.checkout_button_border_width }}px;
    --qcart-button-radius: {{ section.settings.checkout_button_radius }}px;
    --qcart-button-padding-y: {{ section.settings.checkout_button_padding }}px;

    --qcart-item-gap: {{ section.settings.cart_item_spacing }}px;
    --qcart-section-padding-y: {{ section.settings.section_padding }}px;

    --qcart-rewards-bg: {{ section.settings.rewards_background }};
    --qcart-rewards-border: {{ section.settings.rewards_border_color }};
    --qcart-rewards-progress: {{ section.settings.rewards_progress_color }};
    --qcart-rewards-progress-track: {{ section.settings.rewards_progress_track_color }};
    --qcart-rewards-unlocked-bg: {{ section.settings.rewards_unlocked_background }};
    --qcart-rewards-radius: {{ section.settings.rewards_radius }}px;
    --qcart-rewards-padding: {{ section.settings.rewards_padding }}px;

    --qcart-addons-bg: {{ section.settings.addons_background }};
    --qcart-addons-border: {{ section.settings.addons_border_color }};
    --qcart-addons-radius: {{ section.settings.addons_radius }}px;
    --qcart-addons-padding: {{ section.settings.addons_padding }}px;
    --qcart-addons-columns-desktop: {{ section.settings.addons_columns_desktop }};
    --qcart-addons-columns-mobile: {{ section.settings.addons_columns_mobile }};

    --qcart-rewards-bar-bg: {{ section.settings.rewards_bar_background }};
    --qcart-rewards-bar-fill: {{ section.settings.rewards_bar_fill_color }};
    --qcart-rewards-bar-text: {{ section.settings.rewards_bar_text_color }};
    --qcart-rewards-bar-radius: {{ section.settings.rewards_bar_radius }}px;
    --qcart-rewards-bar-height: {{ section.settings.rewards_bar_height }}px;
  "
>
  <div class="qtm-main-cart__inner">
    {%- if section.settings.show_cart_title -%}
      <header class="qtm-main-cart__header">
        <h1 class="qtm-main-cart__title">Your Cart</h1>
      </header>
    {%- endif -%}

    <div class="qtm-main-cart__live-region visually-hidden" aria-live="polite" data-cart-live-region></div>

    {%- if cart.item_count > 0 -%}
      {%- if section.settings.show_rewards_progress_bar and section.settings.rewards_progress_bar_position == 'above_layout' -%}
        <div class="qtm-main-cart__progress-bar-row">
          {% render 'cart-rewards-progress-bar',
            cart: cart,
            section: section,
            section_id: section.id
          %}
        </div>
      {%- endif -%}

      <div class="qtm-main-cart__layout">
        <div class="qtm-main-cart__items-column">
          {%- if section.settings.show_rewards_progress_bar and section.settings.rewards_progress_bar_position == 'above_items' -%}
            <div class="qtm-main-cart__progress-bar-row">
              {% render 'cart-rewards-progress-bar',
                cart: cart,
                section: section,
                section_id: section.id
              %}
            </div>
          {%- endif -%}

          <div class="qtm-main-cart__items">
            <form action="{{ routes.cart_url }}" method="post" novalidate class="qtm-main-cart__form" data-cart-form>
              <div class="qtm-main-cart__items-list">
                {%- for item in cart.items -%}
                  {% render 'cart-line-item',
                    item: item,
                    line_index: forloop.index,
                    section_id: section.id,
                    section: section
                  %}
                {%- endfor -%}
              </div>

              <div class="qtm-main-cart__fallback-actions">
                <button type="submit" name="update" class="qtm-main-cart__update-button">
                  Update cart
                </button>
              </div>
            </form>
          </div>

          {%- if section.settings.rewards_position == 'below_items' -%}
            <div class="qtm-main-cart__items-extras">
              {% render 'cart-progress-rewards',
                cart: cart,
                section: section,
                section_id: section.id
              %}
            </div>
          {%- endif -%}

          {%- if section.settings.addons_position == 'below_items' -%}
            <div class="qtm-main-cart__items-extras">
              {% render 'cart-addons',
                section: section,
                section_id: section.id
              %}
            </div>
          {%- endif -%}
        </div>

        <aside class="qtm-main-cart__summary-column" aria-label="Cart summary">
          <div class="qtm-main-cart__summary">
            {% render 'cart-summary',
              cart: cart,
              section: section,
              section_id: section.id,
              continue_shopping_url: continue_shopping_url
            %}
          </div>

          {%- if section.settings.show_rewards_progress_bar and section.settings.rewards_progress_bar_position == 'below_summary' -%}
            <div class="qtm-main-cart__summary-extras">
              {% render 'cart-rewards-progress-bar',
                cart: cart,
                section: section,
                section_id: section.id
              %}
            </div>
          {%- endif -%}

          {%- if section.settings.rewards_position == 'below_summary' -%}
            <div class="qtm-main-cart__summary-extras">
              {% render 'cart-progress-rewards',
                cart: cart,
                section: section,
                section_id: section.id
              %}
            </div>
          {%- endif -%}

          {%- if section.settings.addons_position == 'below_summary' -%}
            <div class="qtm-main-cart__summary-extras">
              {% render 'cart-addons',
                section: section,
                section_id: section.id
              %}
            </div>
          {%- endif -%}
        </aside>
      </div>

      {%- if section.settings.show_rewards_progress_bar and section.settings.rewards_progress_bar_position == 'below_layout' -%}
        <div class="qtm-main-cart__progress-bar-row qtm-main-cart__progress-bar-row--below">
          {% render 'cart-rewards-progress-bar',
            cart: cart,
            section: section,
            section_id: section.id
          %}
        </div>
      {%- endif -%}

      {%- if section.settings.rewards_position == 'full_width' or section.settings.addons_position == 'full_width' -%}
        <div class="qtm-main-cart__secondary">
          {%- if section.settings.rewards_position == 'full_width' -%}
            {% render 'cart-progress-rewards',
              cart: cart,
              section: section,
              section_id: section.id
            %}
          {%- endif -%}

          {%- if section.settings.addons_position == 'full_width' -%}
            {% render 'cart-addons',
              section: section,
              section_id: section.id
            %}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="qtm-main-cart__empty">
        <div class="qtm-main-cart__empty-inner">
          <h2 class="qtm-main-cart__empty-title">Your cart is empty</h2>

          {%- if section.settings.empty_cart_message != blank -%}
            <div class="qtm-main-cart__empty-text rte">
              {{ section.settings.empty_cart_message }}
            </div>
          {%- endif -%}

          {%- if section.settings.show_continue_shopping -%}
            <a href="{{ continue_shopping_url }}" class="qtm-main-cart__continue-button">
              Continue shopping
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main Cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_cart_title",
      "label": "Show cart title",
      "default": true
    },
    {
      "type": "text",
      "id": "shipping_notice",
      "label": "Shipping notice",
      "default": "Shipping calculated at checkout."
    },
    {
      "type": "url",
      "id": "continue_shopping_url",
      "label": "Continue shopping URL"
    },
    {
      "type": "checkbox",
      "id": "show_continue_shopping",
      "label": "Show continue shopping link",
      "default": true
    },
    {
      "type": "richtext",
      "id": "empty_cart_message",
      "label": "Empty cart message",
      "default": "<p>Looks like you have not added anything yet.</p>"
    },
    {
      "type": "header",
      "content": "Overall style"
    },
    {
      "type": "select",
      "id": "cart_style",
      "label": "Cart style",
      "default": "clean",
      "options": [
        { "value": "clean", "label": "Clean" },
        { "value": "soft", "label": "Soft" },
        { "value": "outline", "label": "Outline" },
        { "value": "editorial", "label": "Editorial" },
        { "value": "compact", "label": "Compact" },
        { "value": "premium", "label": "Premium" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "cart_layout",
      "label": "Cart layout",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "wide_summary", "label": "Wide summary" },
        { "value": "editorial", "label": "Editorial" },
        { "value": "compact", "label": "Compact" }
      ]
    },
    {
      "type": "checkbox",
      "id": "sticky_summary_desktop",
      "label": "Sticky summary on desktop",
      "default": true
    },
    {
      "type": "select",
      "id": "rewards_position",
      "label": "Rewards position",
      "default": "full_width",
      "options": [
        { "value": "below_summary", "label": "Below summary" },
        { "value": "below_items", "label": "Below items" },
        { "value": "full_width", "label": "Full width" },
        { "value": "hidden", "label": "Hidden" }
      ]
    },
    {
      "type": "select",
      "id": "addons_position",
      "label": "Add-ons position",
      "default": "full_width",
      "options": [
        { "value": "below_summary", "label": "Below summary" },
        { "value": "below_items", "label": "Below items" },
        { "value": "full_width", "label": "Full width" },
        { "value": "hidden", "label": "Hidden" }
      ]
    },
    {
      "type": "header",
      "content": "Standalone rewards bar"
    },
    {
      "type": "checkbox",
      "id": "show_rewards_progress_bar",
      "label": "Show standalone rewards progress bar",
      "default": true
    },
    {
      "type": "select",
      "id": "rewards_progress_bar_position",
      "label": "Standalone rewards bar position",
      "default": "above_layout",
      "options": [
        { "value": "above_layout", "label": "Above cart layout" },
        { "value": "below_layout", "label": "Below cart layout" },
        { "value": "above_items", "label": "Above cart items" },
        { "value": "below_summary", "label": "Below summary" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_rewards_progress_percentage",
      "label": "Show rewards progress percentage",
      "default": true
    },
    {
      "type": "color",
      "id": "rewards_bar_background",
      "label": "Rewards bar background",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "rewards_bar_fill_color",
      "label": "Rewards bar fill color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "rewards_bar_text_color",
      "label": "Rewards bar text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "rewards_bar_radius",
      "label": "Rewards bar radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "rewards_bar_height",
      "label": "Rewards bar height",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "Component styles"
    },
    {
      "type": "select",
      "id": "line_item_style",
      "label": "Line item style",
      "default": "card",
      "options": [
        { "value": "card", "label": "Card" },
        { "value": "soft", "label": "Soft" },
        { "value": "outline", "label": "Outline" },
        { "value": "compact", "label": "Compact" },
        { "value": "editorial", "label": "Editorial" }
      ]
    },
    {
      "type": "select",
      "id": "summary_style",
      "label": "Summary style",
      "default": "card",
      "options": [
        { "value": "card", "label": "Card" },
        { "value": "soft", "label": "Soft" },
        { "value": "outline", "label": "Outline" },
        { "value": "elevated", "label": "Elevated" },
        { "value": "minimal", "label": "Minimal" }
      ]
    },
    {
      "type": "select",
      "id": "quantity_style",
      "label": "Quantity style",
      "default": "segmented",
      "options": [
        { "value": "segmented", "label": "Segmented" },
        { "value": "pill", "label": "Pill" },
        { "value": "outline", "label": "Outline" },
        { "value": "minimal", "label": "Minimal" }
      ]
    },
    {
      "type": "select",
      "id": "rewards_style",
      "label": "Rewards style",
      "default": "progress",
      "options": [
        { "value": "progress", "label": "Progress" },
        { "value": "steps", "label": "Steps" },
        { "value": "cards", "label": "Cards" }
      ]
    },
    {
      "type": "select",
      "id": "addons_style",
      "label": "Add-ons style",
      "default": "cards",
      "options": [
        { "value": "cards", "label": "Cards" },
        { "value": "soft", "label": "Soft" },
        { "value": "compact", "label": "Compact" }
      ]
    },
    {
      "type": "select",
      "id": "empty_state_style",
      "label": "Empty cart style",
      "default": "centered",
      "options": [
        { "value": "centered", "label": "Centered" },
        { "value": "minimal", "label": "Minimal" },
        { "value": "editorial", "label": "Editorial" }
      ]
    },
    {
      "type": "header",
      "content": "Density and media"
    },
    {
      "type": "select",
      "id": "cart_density",
      "label": "Cart density",
      "default": "comfortable",
      "options": [
        { "value": "compact", "label": "Compact" },
        { "value": "comfortable", "label": "Comfortable" },
        { "value": "spacious", "label": "Spacious" }
      ]
    },
    {
      "type": "select",
      "id": "cart_image_size",
      "label": "Cart image size",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 20,
      "max": 60,
      "step": 1,
      "default": 34
    },
    {
      "type": "range",
      "id": "price_font_size",
      "label": "Price font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "meta_font_size",
      "label": "Meta font size",
      "min": 11,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "select",
      "id": "checkout_button_style",
      "label": "Checkout button style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" },
        { "value": "soft", "label": "Soft" }
      ]
    },
    {
      "type": "color",
      "id": "checkout_button_color",
      "label": "Checkout button color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "checkout_button_text_color",
      "label": "Checkout button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "checkout_button_border_width",
      "label": "Checkout button border width",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "checkout_button_radius",
      "label": "Checkout button radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "checkout_button_padding",
      "label": "Checkout button vertical padding",
      "min": 8,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "header",
      "content": "Rewards styling"
    },
    {
      "type": "color",
      "id": "rewards_background",
      "label": "Rewards background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "rewards_border_color",
      "label": "Rewards border color",
      "default": "#dddddd"
    },
    {
      "type": "color",
      "id": "rewards_progress_color",
      "label": "Rewards progress color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "rewards_progress_track_color",
      "label": "Rewards progress track color",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "rewards_unlocked_background",
      "label": "Unlocked tier background",
      "default": "#eaf5ef"
    },
    {
      "type": "range",
      "id": "rewards_radius",
      "label": "Rewards radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "rewards_padding",
      "label": "Rewards padding",
      "min": 8,
      "max": 40,
      "step": 1,
      "default": 24
    },
    {
      "type": "header",
      "content": "Add-ons styling"
    },
    {
      "type": "color",
      "id": "addons_background",
      "label": "Add-ons background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "addons_border_color",
      "label": "Add-ons border color",
      "default": "#dddddd"
    },
    {
      "type": "range",
      "id": "addons_radius",
      "label": "Add-ons radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "addons_padding",
      "label": "Add-ons padding",
      "min": 8,
      "max": 40,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "addons_columns_desktop",
      "label": "Add-ons columns desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "addons_columns_mobile",
      "label": "Add-ons columns mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "cart_item_spacing",
      "label": "Cart item spacing",
      "min": 8,
      "max": 48,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "reward_tier",
      "name": "Reward tier",
      "settings": [
        {
          "type": "number",
          "id": "threshold_amount",
          "label": "Threshold amount",
          "default": 50
        },
        {
          "type": "text",
          "id": "locked_text",
          "label": "Locked text",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "unlocked_text",
          "label": "Unlocked text",
          "default": "Free Shipping unlocked"
        },
        {
          "type": "select",
          "id": "reward_type",
          "label": "Reward type",
          "default": "shipping",
          "options": [
            { "value": "shipping", "label": "Free shipping" },
            { "value": "gift", "label": "Free gift" },
            { "value": "bonus", "label": "Bonus item" },
            { "value": "custom", "label": "Custom" }
          ]
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon text",
          "default": "★"
        }
      ]
    },
    {
      "type": "addon_product",
      "name": "Add-on product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_label",
          "label": "Custom label"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main Cart"
    }
  ]
}
{% endschema %}