{% liquid
  assign footer_cols = settings.footer_columns | default: 4
  assign announce_text = settings.footer_announce_text
%}

<footer
  id="FooterOne-{{ section.id }}"
  class="q-footer-one"
  aria-label="Site footer"
>
  <style>
    #shopify-section-{{ section.id }}{
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      max-width: none !important;
    }

    #FooterOne-{{ section.id }}{
      --qf-bg: {{ section.settings.bg_color }};
      --qf-text: {{ section.settings.text_color }};
      --qf-muted: {{ section.settings.muted_color }};
      --qf-border: {{ section.settings.border_color }};
      --qf-heading: {{ section.settings.heading_color }};
      --qf-link: {{ section.settings.link_color }};
      --qf-link-hover: {{ section.settings.link_hover_color }};
      --qf-announce-bg: {{ section.settings.announce_bg }};
      --qf-announce-text: {{ section.settings.announce_text }};
      --qf-bottom-bg: {{ section.settings.bottom_bg }};
      --qf-bottom-text: {{ section.settings.bottom_text }};
      --qf-radius: {{ section.settings.radius }}px;

      width: 100%;
      margin: 0;
      padding: 0;
      background: var(--qf-bg);
      color: var(--qf-text);
      border-top: 1px solid var(--qf-border);
    }

    #FooterOne-{{ section.id }},
    #FooterOne-{{ section.id }} *{
      box-sizing: border-box;
    }

    #FooterOne-{{ section.id }} .qf__announce{
      width: 100%;
      margin: 0;
      padding: 0;
      background: var(--qf-announce-bg);
      color: var(--qf-announce-text);
      border-bottom: 1px solid var(--qf-border);
    }

    #FooterOne-{{ section.id }} .qf__announce-inner{
      width: 100%;
      margin: 0;
      padding: 12px 20px;
      text-align: center;
    }

    #FooterOne-{{ section.id }} .qf__announce-text{
      margin: 0;
      color: var(--qf-announce-text) !important;
      font-size: .95rem;
      line-height: 1.35;
    }

    #FooterOne-{{ section.id }} .qf__main{
      width: 100%;
      margin: 0;
      padding: 48px 20px;
    }

    #FooterOne-{{ section.id }} .qf__inner{
      width: 100%;
      max-width: 1440px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(220px, 1.2fr) minmax(0, 3fr);
      gap: 32px;
      align-items: start;
    }

    #FooterOne-{{ section.id }} .qf__brand{
      display: grid;
      gap: 14px;
      align-content: start;
    }

    #FooterOne-{{ section.id }} .qf__brand-link{
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      color: inherit;
      width: fit-content;
    }

    #FooterOne-{{ section.id }} .qf__logo{
      display: block;
      width: auto;
      max-width: 100%;
      height: {{ section.settings.logo_height }}px;
      object-fit: contain;
    }

    #FooterOne-{{ section.id }} .qf__brand-name{
      margin: 0;
      font-size: 1.1rem;
      font-weight: 700;
      line-height: 1.1;
      color: var(--qf-heading);
    }

    #FooterOne-{{ section.id }} .qf__tagline{
      margin: 0;
      color: var(--qf-muted);
      font-size: .96rem;
      line-height: 1.6;
      max-width: 32ch;
    }

    #FooterOne-{{ section.id }} .qf__menus{
      display: grid;
      grid-template-columns: repeat({{ footer_cols }}, minmax(0, 1fr));
      gap: 24px;
      min-width: 0;
    }

    #FooterOne-{{ section.id }} .qf__menu{
      min-width: 0;
    }

    #FooterOne-{{ section.id }} .qf__menu-title{
      margin: 0 0 12px;
      color: var(--qf-heading);
      font-size: .95rem;
      font-weight: 700;
      line-height: 1.2;
    }

    #FooterOne-{{ section.id }} .qf__menu-list{
      display: grid;
      gap: 10px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    #FooterOne-{{ section.id }} .qf__menu-list a{
      color: var(--qf-link);
      text-decoration: none;
      line-height: 1.45;
      transition: color .18s ease, transform .18s ease;
      display: inline-block;
      width: fit-content;
      max-width: 100%;
      overflow-wrap: anywhere;
    }

    #FooterOne-{{ section.id }} .qf__menu-list a:hover{
      color: var(--qf-link-hover);
      transform: translateX(2px);
    }

    #FooterOne-{{ section.id }} .qf__bottom{
      width: 100%;
      margin: 0;
      padding: 14px 20px;
      background: var(--qf-bottom-bg);
      color: var(--qf-bottom-text);
      border-top: 1px solid var(--qf-border);
    }

    #FooterOne-{{ section.id }} .qf__bottom-inner{
      width: 100%;
      max-width: 1440px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    #FooterOne-{{ section.id }} .qf__bottom-text{
      margin: 0;
      font-size: .9rem;
      line-height: 1.45;
      color: var(--qf-bottom-text);
    }

    #FooterOne-{{ section.id }} .qf__payments{
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    #FooterOne-{{ section.id }} .qf__payment-pill{
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 30px;
      padding: 6px 10px;
      border: 1px solid var(--qf-border);
      border-radius: 999px;
      font-size: .78rem;
      line-height: 1;
      background: rgba(255,255,255,.04);
      color: var(--qf-bottom-text);
    }

    @media (max-width: 1100px){
      #FooterOne-{{ section.id }} .qf__inner{
        grid-template-columns: 1fr;
      }

      #FooterOne-{{ section.id }} .qf__menus{
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px){
      #FooterOne-{{ section.id }} .qf__main{
        padding: 36px 14px;
      }

      #FooterOne-{{ section.id }} .qf__announce-inner,
      #FooterOne-{{ section.id }} .qf__bottom{
        padding-left: 14px;
        padding-right: 14px;
      }

      #FooterOne-{{ section.id }} .qf__menus{
        grid-template-columns: 1fr;
        gap: 20px;
      }

      #FooterOne-{{ section.id }} .qf__bottom-inner{
        align-items: flex-start;
        justify-content: flex-start;
      }
    }

    {{ settings.footer_custom_css }}
  </style>

  {% if settings.footer_announce_enable and announce_text != blank %}
    <div class="qf__announce">
      <div class="qf__announce-inner">
        <p class="qf__announce-text">{{ announce_text }}</p>
      </div>
    </div>
  {% endif %}

  <div class="qf__main">
    <div class="qf__inner">
      <div class="qf__brand">
        <a class="qf__brand-link" href="{{ routes.root_url }}">
          {% if settings.logo_primary != blank %}
            <img
              class="qf__logo"
              src="{{ settings.logo_primary | image_url: width: 600 }}"
              alt="{{ shop.name | escape }}"
              loading="lazy"
            >
          {% elsif settings.logo_mobile != blank %}
            <img
              class="qf__logo"
              src="{{ settings.logo_mobile | image_url: width: 600 }}"
              alt="{{ shop.name | escape }}"
              loading="lazy"
            >
          {% endif %}
        </a>

        <p class="qf__brand-name">{{ shop.name }}</p>

        {% if settings.site_tagline != blank %}
          <p class="qf__tagline">{{ settings.site_tagline }}</p>
        {% endif %}
      </div>

      <div class="qf__menus">
        {% for block in section.blocks %}
          {% if block.type == 'menu_column' %}
            <div class="qf__menu" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h3 class="qf__menu-title">{{ block.settings.heading }}</h3>
              {% endif %}

              {% if block.settings.menu != blank %}
                <ul class="qf__menu-list">
                  {% for link in block.settings.menu.links %}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="qf__bottom">
    <div class="qf__bottom-inner">
      <p class="qf__bottom-text">
        {{ settings.footer_bottom_text }}
      </p>

      {% if section.settings.show_payment_pills %}
        <div class="qf__payments" aria-label="Accepted payments">
          <span class="qf__payment-pill">Visa</span>
          <span class="qf__payment-pill">Mastercard</span>
          <span class="qf__payment-pill">Amex</span>
          <span class="qf__payment-pill">PayPal</span>
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer One",
  "settings": [
    {
      "type": "header",
      "content": "Footer colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#b8b8b8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#dddddd"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#2a2a2a"
    },

    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "color",
      "id": "announce_bg",
      "label": "Announcement background",
      "default": "#0b0b0b"
    },
    {
      "type": "color",
      "id": "announce_text",
      "label": "Announcement text",
      "default": "#ffffff"
    },

    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "color",
      "id": "bottom_bg",
      "label": "Bottom background",
      "default": "#0b0b0b"
    },
    {
      "type": "color",
      "id": "bottom_text",
      "label": "Bottom text",
      "default": "#d4d4d4"
    },

    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 20,
      "max": 120,
      "step": 2,
      "default": 34,
      "unit": "px"
    },

    {
      "type": "header",
      "content": "Extras"
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "show_payment_pills",
      "label": "Show payment pills",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer One",
      "blocks": [
        { "type": "menu_column", "settings": { "heading": "Shop" } },
        { "type": "menu_column", "settings": { "heading": "Company" } },
        { "type": "menu_column", "settings": { "heading": "Support" } },
        { "type": "menu_column", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}