{%- comment -%}
  Quadratum — Collection Modern (Max Capability)
  File: sections/collection-modern.liquid
{%- endcomment -%}

{{ 'section-collection-modern.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings

  assign is_search_context = false
  if request.page_type == 'search' and search != blank
    assign is_search_context = true
  endif

  assign use_alt = false
  if s.use_alt_collection and s.alt_collection != blank
    assign use_alt = true
  endif

  assign results_title = ''
  assign results_url = ''
  assign results_description = ''

  assign products = nil
  assign filters = nil
  assign sort_options = nil
  assign sort_by = ''
  assign default_sort_by = ''

  assign terms_q = ''
  if is_search_context
    assign terms_q = search.terms | default: ''
  endif

  if use_alt
    assign c = s.alt_collection
    assign products = c.products
    assign filters = c.filters
    assign sort_options = c.sort_options
    assign sort_by = c.sort_by
    assign default_sort_by = c.default_sort_by
    assign results_title = c.title
    assign results_url = c.url
    assign results_description = c.description
  elsif is_search_context
    assign products = search.results
    assign filters = search.filters
    assign sort_options = search.sort_options
    assign sort_by = search.sort_by
    assign default_sort_by = search.default_sort_by
    assign results_title = 'Search results'
    assign results_url = routes.search_url
    assign results_description = ''
  else
    assign c = collection
    assign products = c.products
    assign filters = c.filters
    assign sort_options = c.sort_options
    assign sort_by = c.sort_by
    assign default_sort_by = c.default_sort_by
    assign results_title = c.title
    assign results_url = c.url
    assign results_description = c.description
  endif

  assign layout = s.layout_preset | default: 'modern_grid'
  assign filter_mode = s.filter_presentation | default: 'sidebar'
  assign pagination_style = s.pagination_style | default: 'numbered'
  assign per_page = s.products_per_page | default: 24

  assign scope_id = section.id
  assign root_id = 'QtmCollectionModern-' | append: scope_id

  assign grid_cols_desktop = s.columns_desktop | default: 4
  assign grid_cols_tablet  = s.columns_tablet  | default: 3
  assign grid_cols_mobile  = s.columns_mobile  | default: 2

  assign has_filters = false
  if s.show_filters and filters != blank and filters.size > 0
    assign has_filters = true
  endif

  assign sticky_toolbar = false
  if s.sticky_toolbar
    assign sticky_toolbar = true
  endif

  assign enable_drawer = false
  if s.show_filters and filter_mode == 'drawer'
    assign enable_drawer = true
  endif

  assign enable_drawer_str = 'false'
  if enable_drawer
    assign enable_drawer_str = 'true'
  endif

  assign effective_mode = filter_mode
  if has_filters == false
    assign effective_mode = 'none'
  endif

  assign card_engine = s.card_engine | default: 'default_theme_card'

  assign qv_enabled = false
  if s.enable_quick_view and card_engine == 'modern_card'
    assign qv_enabled = true
  endif

  assign qv_enabled_str = 'false'
  if qv_enabled
    assign qv_enabled_str = 'true'
  endif

  assign qv_show_add = 'true'
  if s.qv_show_add_to_cart == false
    assign qv_show_add = 'false'
  endif

  assign qv_show_view = 'true'
  if s.qv_show_view_product == false
    assign qv_show_view = 'false'
  endif

  assign qv_show_buy = 'false'
  if s.show_buy_now
    assign qv_show_buy = 'true'
  endif

  assign qv_gallery_mode = s.qv_gallery_mode | default: 'slider'
  assign slider_arrow_position = s.slider_arrow_position | default: 'bottom'
  assign qv_arrow_position = s.qv_arrow_position | default: 'bottom'
-%}

<section
  id="{{ root_id }}"
  class="q-collection-modern qcm layout-{{ layout }} cardstyle-{{ s.card_style }} density-{{ s.card_density }} hover-{{ s.hover_effects }} slider-arrows-{{ slider_arrow_position }} qv-arrows-{{ qv_arrow_position }}"
  data-section-id="{{ scope_id }}"
  data-layout="{{ layout }}"
  data-pagination-style="{{ pagination_style }}"
  data-filter-mode="{{ filter_mode }}"
  data-enable-drawer="{{ enable_drawer_str }}"
  data-sticky-toolbar="{{ sticky_toolbar }}"
  data-sticky-offset="{{ s.sticky_toolbar_offset | default: 0 }}"
  data-qcm-qv-enabled="{{ qv_enabled_str }}"
  data-qcm-qv-show-add="{{ qv_show_add }}"
  data-qcm-qv-show-view="{{ qv_show_view }}"
  data-qcm-qv-show-buy="{{ qv_show_buy }}"
  data-qcm-qv-gallery-mode="{{ qv_gallery_mode }}"
  data-qcm-add-label="{{ s.add_to_cart_label | default: 'Add to cart' | escape }}"
  data-qcm-opts-label="{{ s.choose_options_label | default: 'Choose options' | escape }}"
  data-qcm-buy-label="{{ s.buy_now_label | default: 'Buy now' | escape }}"
  data-qcm-view-label="{{ s.qv_view_product_label | default: 'View product' | escape }}"
  data-qcm-enable-compare="{% if s.enable_compare %}true{% else %}false{% endif %}"
>
  <style>
    #{{ root_id }}{
      --qcm-maxw: {{ s.max_width }};
      --qcm-gap: {{ s.gap }}px;
      --qcm-radius: {{ s.border_radius }}px;

      --qcm-cols-d: {{ grid_cols_desktop }};
      --qcm-cols-t: {{ grid_cols_tablet }};
      --qcm-cols-m: {{ grid_cols_mobile }};

      --qcm-truncate-lines: {{ s.truncated_lines }};
      --qcm-sticky-offset: {{ s.sticky_toolbar_offset | default: 0 }}px;

      --qcm-vendor-color: {{ s.vendor_color }};
      --qcm-title-color: {{ s.title_color }};
      --qcm-price-color: {{ s.price_color }};

      --qcm-vendor-size-set: {{ s.vendor_font_size }}px;
      --qcm-title-size-set: {{ s.title_font_size }}px;
      --qcm-price-size-set: {{ s.price_font_size }}px;

      --qcm-card-bg: {{ s.card_bg }};
      --qcm-card-border: {{ s.card_border }};
      --qcm-card-border-style: {{ s.card_border_style }};

      --qcm-btn-bg: {{ s.button_bg }};
      --qcm-btn-text: {{ s.button_text }};
      --qcm-btn-bg-hover: {{ s.button_bg_hover }};
      --qcm-btn-text-hover: {{ s.button_text_hover }};
      --qcm-btn-border: {{ s.button_border }};

      --qcm-rating-star-color: {{ s.rating_star_color }};
      --qcm-rating-text-color: {{ s.rating_text_color }};

      /* NEW: card slider controls */
      --qcm-slider-arrow-inset: {{ s.slider_arrow_inset | default: 10 }}px;

      /* NEW: quick view controls */
      --qcm-qv-maxw: {{ s.qv_max_width | default: 980 }}px;
      --qcm-qv-bg: {{ s.qv_bg | default: '#FFFFFF' }};
      --qcm-qv-text: {{ s.qv_text | default: '#111111' }};
      --qcm-qv-title-size: {{ s.qv_title_size | default: 22 }}px;
      --qcm-qv-desc-size: {{ s.qv_desc_size | default: 14 }}px;

      --qcm-qv-arrow-inset: {{ s.qv_arrow_inset | default: 10 }}px;

      --qcm-qv-btn-radius: {{ s.qv_btn_radius | default: 12 }}px;
      --qcm-qv-btn-font: {{ s.qv_btn_font_size | default: 14 }}px;
      --qcm-qv-btn-py: {{ s.qv_btn_padding_y | default: 10 }}px;
      --qcm-qv-btn-px: {{ s.qv_btn_padding_x | default: 14 }}px;
    }
  </style>

  <div class="qcm__container {% if s.max_width_toggle == 'contained' %}qcm__container--contained{% endif %}">
    {% render 'collection-modern-toolbar',
      section: section,
      s: s,
      is_search_context: is_search_context,
      results_title: results_title,
      results_url: results_url,
      results_description: results_description,
      terms_q: terms_q,
      has_filters: has_filters,
      filters: filters,
      sort_options: sort_options,
      sort_by: sort_by,
      default_sort_by: default_sort_by,
      sticky_toolbar: sticky_toolbar,
      filter_mode: filter_mode
    %}

    <div class="qcm__body qcm__body--mode-{{ effective_mode }}">
      {%- if has_filters and filter_mode == 'sidebar' -%}
        <aside class="qcm__sidebar" aria-label="Filters">
          {% render 'collection-modern-facets',
            section: section,
            s: s,
            is_search_context: is_search_context,
            results_url: results_url,
            terms_q: terms_q,
            filters: filters,
            sort_options: sort_options,
            sort_by: sort_by,
            default_sort_by: default_sort_by,
            placement: 'sidebar'
          %}
        </aside>
      {%- endif -%}

      <div class="qcm__main">
        {%- if has_filters and filter_mode == 'drawer' -%}
          {% render 'collection-modern-facets',
            section: section,
            s: s,
            is_search_context: is_search_context,
            results_url: results_url,
            terms_q: terms_q,
            filters: filters,
            sort_options: sort_options,
            sort_by: sort_by,
            default_sort_by: default_sort_by,
            placement: 'drawer'
          %}

          <noscript>
            <details class="qcm__drawer-noscript">
              <summary class="qcm__btn">Filters</summary>
              {% render 'collection-modern-facets',
                section: section,
                s: s,
                is_search_context: is_search_context,
                results_url: results_url,
                terms_q: terms_q,
                filters: filters,
                sort_options: sort_options,
                sort_by: sort_by,
                default_sort_by: default_sort_by,
                placement: 'drawer_noscript'
              %}
            </details>
          </noscript>
        {%- endif -%}

        {%- paginate products by per_page -%}
          {%- assign page_has_products = false -%}
          {%- if products != blank and products.size > 0 -%}
            {%- assign page_has_products = true -%}
          {%- endif -%}

          {%- if page_has_products -%}
            <div class="qcm__gridWrap">
              <div class="qcm__grid" data-qcm-grid aria-live="{% if pagination_style == 'infinite_scroll' %}polite{% else %}off{% endif %}">
                {%- for item in products -%}
                  {%- liquid
                    assign p = item
                    if is_search_context
                      if item.object_type != 'product'
                        continue
                      endif
                      assign p = item
                    endif
                  -%}

                  <div class="qcm__item" data-qcm-item>
                    {%- if card_engine == 'modern_card' -%}
                      {% render 'collection-modern-product-card', product: p, s: s, section: section %}
                    {%- else -%}
                      {% render 'product-card', product: p %}
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            </div>

            {%- if s.show_pagination -%}
              {% render 'collection-modern-pagination',
                section: section,
                s: s,
                paginate: paginate,
                pagination_style: pagination_style
              %}
            {%- endif -%}
          {%- else -%}
            {% render 'collection-modern-empty-state',
              section: section,
              s: s,
              results_url: results_url,
              is_search_context: is_search_context,
              terms_q: terms_q
            %}
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>

  {%- comment -%} QUICK VIEW HOST (required for Quick View to work) {%- endcomment -%}
  <div class="qcm__qv" data-qcm-qv hidden aria-hidden="true">
    <div class="qcm__qvOverlay" data-qcm-qv-close tabindex="-1"></div>
    <div class="qcm__qvDialog" role="dialog" aria-modal="true" aria-label="Quick view">
      <button type="button" class="qcm__qvClose" data-qcm-qv-close aria-label="Close">×</button>
      <div class="qcm__qvInner" data-qcm-qv-inner></div>
    </div>
  </div>

  <script src="{{ 'section-collection-modern.js' | asset_url }}" defer></script>
</section>

<style>
/* Quadratum — Collection Modern (Max Capability)
   File: assets/section-collection-modern.css
   RULE: scoped to .q-collection-modern
*/

/* ===========================
   KEEP: your existing styles
   =========================== */

.q-collection-modern .qcm__count{
  opacity: .75;
  font-size: 13px;
}

/* Layout prefs */
.q-collection-modern .qcm__layout{
  display: inline-flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}

.q-collection-modern .qcm__colsReadout{
  font-size: 13px;
  opacity: .75;
  padding-inline: 4px;
}

/* List view */
.q-collection-modern.is-list .qcm__grid{
  grid-template-columns: 1fr !important;
}

.q-collection-modern.is-list .qcmc{
  grid-template-columns: minmax(140px, 220px) 1fr;
  align-items: stretch;
}

.q-collection-modern.is-list .qcmc__media{
  height: 100%;
}

.q-collection-modern.is-list .qcmc__img--primary{
  height: 100%;
  object-fit: cover;
}

/* Card style variants */
.q-collection-modern .qcmc--glass{
  background: rgba(255,255,255,.75);
  backdrop-filter: blur(10px);
}
.q-collection-modern .qcmc--solid{ background: var(--qcm-card-bg, #fff); }
.q-collection-modern .qcmc--outline{ background: transparent; }
.q-collection-modern .qcmc--none{ border-color: transparent; background: transparent; }

/* Compare tray */
.q-collection-modern .qcm__compareBar{
  position: sticky;
  bottom: 0;
  z-index: 40;
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 12px;
  border: 1px solid var(--qcm-card-border, #00000026);
  background: var(--qcm-card-bg, #fff);
  border-radius: 16px;
  margin-top: 16px;
}
.q-collection-modern .qcm__compareBar.is-active{
  display: flex;
}

/* =========================================================
   HARD PATCH — Modern Card styles must NOT require ancestor
   ========================================================= */
.qcmc a{ color: inherit; text-decoration: none; }
.qcmc a:hover{ text-decoration: underline; }
.qcmc a:focus-visible,
.qcmc button:focus-visible{
  outline: 2px solid currentColor;
  outline-offset: 3px;
}

.qcmc{
  display: grid;
  gap: 10px;
  border-radius: var(--qcm-radius, 16px);
  border: 1px solid var(--qcm-card-border, #00000026);
  background: var(--qcm-card-bg, #fff);
  overflow: hidden;
}

.qcmc__media{ position: relative; }
.qcmc__mediaLink{ display:block; position:relative; }
.qcmc__img{ display:block; width:100%; height:auto; }
.qcmc__img--placeholder{ width:100%; aspect-ratio:1/1; background: rgba(0,0,0,.06); }

/* Second image hover */
.qcmc__img--second{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:0;
  transition: opacity .22s ease;
}
.qcmc__mediaLink:hover .qcmc__img--second{ opacity:1; }

/* Badges */
.qcmc__badges{
  position:absolute;
  top:10px;
  left:10px;
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  z-index:2;
}
.qcmc__badge{
  display:inline-flex;
  align-items:center;
  padding:7px 10px;
  border-radius:999px;
  font-size:12px;
  line-height:1;
  border:1px solid var(--qcm-card-border, #00000026);
  background: rgba(255,255,255,.9);
  backdrop-filter: blur(10px);
}
.qcmc__badge--sale{
  background: var(--qcm-btn-bg, #10B981);
  color: var(--qcm-btn-text, #fff);
  border-color: transparent;
}
.qcmc__badge--soldout{
  background: rgba(0,0,0,.75);
  color:#fff;
  border-color: transparent;
}

/* Body */
.qcmc__body{
  padding: 12px 12px 14px;
  display:grid;
  gap:8px;
}
.qcmc__vendor{
  color: var(--qcm-vendor-color, currentColor);
  font-size: var(--qcm-vendor-size-set, 12px);
  opacity:.8;
  line-height:1.2;
}
.qcmc__title{
  margin:0;
  line-height:1.15;
  font-size: var(--qcm-title-size-set, 16px);
  color: var(--qcm-title-color, currentColor);
}
.qcmc__price{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  align-items:baseline;
  color: var(--qcm-price-color, currentColor);
  font-size: var(--qcm-price-size-set, 16px);
}
.qcmc__priceWas{
  opacity:.6;
  font-size: calc(var(--qcm-price-size-set, 16px) * .9);
}

/* Buttons */
.qcmc__actions{ margin-top: 4px; display:grid; gap: 10px; }
.qcmc__btn{
  width:100%;
  appearance:none;
  border:1px solid var(--qcm-btn-border, #00000026);
  background: var(--qcm-btn-bg, #10B981);
  color: var(--qcm-btn-text, #fff);
  border-radius: 999px;
  padding: 10px 14px;
  font-size: 14px;
  line-height: 1;
  cursor: pointer;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
}
.qcmc__btn:hover{
  background: var(--qcm-btn-bg-hover, #000);
  color: var(--qcm-btn-text-hover, #fff);
}
.qcmc__btn--ghost{
  background: transparent;
  color: currentColor;
}

/* Density */
.density-compact .qcmc__body{ padding:10px 10px 12px; }
.density-roomy  .qcmc__body{ padding:14px 14px 16px; }

/* =========================================================
   FIX: slider must actually slide
   - overflow hidden
   - track flex
   - each slide is 100%
   ========================================================= */
.qcmc__slider{
  position: relative;
  overflow: hidden;
}
.qcmc__track{
  display:flex;
  width:100%;
  transform: translateX(0);
  transition: transform .22s ease;
  will-change: transform;
}
.qcmc__img--slide{
  flex: 0 0 100%;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display:block;
}

/* =========================================================
   NEW: card arrow positioning (section-controlled)
   ========================================================= */
.qcmc__arrow{
  position:absolute;
  width: 34px;
  height: 34px;
  border-radius: 999px;
  border: 1px solid var(--qcm-card-border, #00000026);
  background: rgba(255,255,255,.9);
  backdrop-filter: blur(10px);
  cursor: pointer;
  display:grid;
  place-items:center;
  z-index: 3;
}

.qcmc__arrow--prev{ left: var(--qcm-slider-arrow-inset, 10px); }
.qcmc__arrow--next{ right: var(--qcm-slider-arrow-inset, 10px); }

.q-collection-modern.slider-arrows-bottom .qcmc__arrow{ bottom: var(--qcm-slider-arrow-inset, 10px); top: auto; transform: none; }
.q-collection-modern.slider-arrows-top .qcmc__arrow{ top: var(--qcm-slider-arrow-inset, 10px); bottom: auto; transform: none; }
.q-collection-modern.slider-arrows-center .qcmc__arrow{ top: 50%; bottom: auto; transform: translateY(-50%); }

/* =========================================================
   Quick View host + fragment styling
   ========================================================= */
.qcm-scroll-lock{ overflow: hidden; }

#{{ root_id }} .qcm__qv{
  position: fixed;
  inset: 0;
  z-index: 999;
  display: block;
}
#{{ root_id }} .qcm__qv[hidden]{ display:none !important; }

#{{ root_id }} .qcm__qvOverlay{
  position:absolute;
  inset:0;
  background: rgba(0,0,0,.55);
}
#{{ root_id }} .qcm__qvDialog{
  position:absolute;
  top: 50%;
  left: 50%;
  width: min(var(--qcm-qv-maxw, 980px), calc(100vw - 24px));
  max-height: calc(100vh - 24px);
  transform: translate(-50%, -50%);
  overflow: auto;
  border-radius: 18px;
  border: 1px solid var(--qcm-card-border, #00000026);
  background: var(--qcm-qv-bg, #fff);
  color: var(--qcm-qv-text, #111);
}
#{{ root_id }} .qcm__qvClose{
  position: sticky;
  top: 10px;
  margin-left: auto;
  margin-right: 10px;
  width: 38px;
  height: 38px;
  border-radius: 999px;
  border: 1px solid var(--qcm-card-border, #00000026);
  background: rgba(255,255,255,.9);
  cursor: pointer;
  z-index: 2;
  display: grid;
  place-items: center;
}
#{{ root_id }} .qcm__qvInner{ padding: 16px; }

/* Quick view fragment layout */
#{{ root_id }} .qcmQv__grid{
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  align-items:start;
}
@media (max-width: 860px){
  #{{ root_id }} .qcmQv__grid{ grid-template-columns: 1fr; }
}

#{{ root_id }} .qcmQv__media{
  position: relative;
  border-radius: 16px;
  overflow:hidden;
  border: 1px solid var(--qcm-card-border, #00000026);
}

#{{ root_id }} .qcmQv__title{
  margin: 0 0 10px;
  font-size: var(--qcm-qv-title-size, 22px);
  line-height: 1.1;
}
#{{ root_id }} .qcmQv__title a{ color: inherit; text-decoration:none; }
#{{ root_id }} .qcmQv__title a:hover{ text-decoration: underline; }

#{{ root_id }} .qcmQv__price{ display:flex; gap:10px; align-items:baseline; margin-bottom: 10px; }
#{{ root_id }} .qcmQv__priceWas{ opacity:.6; }
#{{ root_id }} .qcmQv__desc{ opacity:.85; line-height:1.45; font-size: var(--qcm-qv-desc-size, 14px); margin-bottom: 12px; }

#{{ root_id }} .qcmQv__select{
  width: 100%;
  border: 1px solid var(--qcm-card-border, #00000026);
  border-radius: 12px;
  padding: 10px 12px;
  background: #fff;
  margin-bottom: 12px;
}

/* Buttons: never off-screen, always full width */
#{{ root_id }} .qcmQv__actions{
  display:grid;
  gap: 10px;
}
#{{ root_id }} .qcmQv__btn{
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  border-radius: var(--qcm-qv-btn-radius, 12px);
  padding: var(--qcm-qv-btn-py, 10px) var(--qcm-qv-btn-px, 14px);
  font-size: var(--qcm-qv-btn-font, 14px);
  border: 1px solid var(--qcm-btn-border, #00000026);
  background: var(--qcm-btn-bg, #10B981);
  color: var(--qcm-btn-text, #fff);
  text-align:center;
  display:inline-flex;
  justify-content:center;
  align-items:center;
  gap: 8px;
}
#{{ root_id }} .qcmQv__btn:hover{
  background: var(--qcm-btn-bg-hover, #000);
  color: var(--qcm-btn-text-hover, #fff);
}
#{{ root_id }} .qcmQv__btn--view{
  background: transparent;
  color: currentColor;
}

/* Show/hide buttons based on section flags */
#{{ root_id }}[data-qcm-qv-show-add="false"] .qcmQv__btn--atc{ display:none; }
#{{ root_id }}[data-qcm-qv-show-view="false"] .qcmQv__btn--view{ display:none; }
#{{ root_id }}[data-qcm-qv-show-buy="false"] .qcmQv__form--buy{ display:none; }
/* If buy-now is ON, hide other CTAs (your rule) */
#{{ root_id }}[data-qcm-qv-show-buy="true"] .qcmQv__btn--atc,
#{{ root_id }}[data-qcm-qv-show-buy="true"] .qcmQv__btn--view{ display:none; }

/* Quick view slider mechanics */
#{{ root_id }} .qcmQv__slider{ position: relative; overflow:hidden; }
#{{ root_id }} .qcmQv__track{
  display:flex;
  width:100%;
  transform: translateX(0);
  transition: transform .22s ease;
  will-change: transform;
}
#{{ root_id }} .qcmQv__img--slide{
  flex: 0 0 100%;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display:block;
}

/* QV arrows position controlled by section setting */
#{{ root_id }} .qcmQv__arrow{
  position:absolute;
  width: 38px;
  height: 38px;
  border-radius: 999px;
  border: 1px solid var(--qcm-card-border, #00000026);
  background: rgba(255,255,255,.9);
  cursor: pointer;
  display:grid;
  place-items:center;
  z-index: 3;
}
#{{ root_id }} .qcmQv__arrow--prev{ left: var(--qcm-qv-arrow-inset, 10px); }
#{{ root_id }} .qcmQv__arrow--next{ right: var(--qcm-qv-arrow-inset, 10px); }

#{{ root_id }}.qv-arrows-bottom .qcmQv__arrow{ bottom: var(--qcm-qv-arrow-inset, 10px); top: auto; transform:none; }
#{{ root_id }}.qv-arrows-top .qcmQv__arrow{ top: var(--qcm-qv-arrow-inset, 10px); bottom: auto; transform:none; }
#{{ root_id }}.qv-arrows-center .qcmQv__arrow{ top: 50%; bottom:auto; transform: translateY(-50%); }

/* QV gallery mode switch (JS sets [data-qcm-qv-mode]) */
#{{ root_id }} .qcmQv[data-qcm-qv-mode="slider"] .qcmQv__hoverLink{ display:none; }
#{{ root_id }} .qcmQv[data-qcm-qv-mode="hover"] .qcmQv__slider{ display:none; }

/* Hover image swap in QV */
#{{ root_id }} .qcmQv__hoverLink{ display:block; position:relative; }
#{{ root_id }} .qcmQv__img--second{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:0;
  transition: opacity .22s ease;
}
#{{ root_id }} .qcmQv__hoverLink:hover .qcmQv__img--second{ opacity:1; }

/* =========================================================
   Card Style Engine (driven by section class cardstyle-*)
   ========================================================= */
.qcm.cardstyle-glass{
  --qcm-card-bg: rgba(255,255,255,.72);
  --qcm-toolbar-bg: rgba(255,255,255,.72);
  backdrop-filter: blur(12px);
}
.qcm.cardstyle-solid{
  --qcm-card-bg: var(--qcm-card-bg, #fff);
  --qcm-toolbar-bg: var(--qcm-toolbar-bg, #fff);
}
.qcm.cardstyle-outline{
  --qcm-card-bg: transparent;
  --qcm-toolbar-bg: transparent;
  --qcm-card-border-style: solid;
}
.qcm.cardstyle-none{
  --qcm-card-bg: transparent;
  --qcm-toolbar-bg: transparent;
  --qcm-card-border: transparent;
  --qcm-card-border-style: none;
}
.qcm .qcmc,
.qcm .qcm__toolbar.is-sticky,
.qcm .qcm__empty,
.qcm .qcm__page,
.qcm .qcm__pill,
.qcm .qcm__chip,
.qcm .qcm__sort select{
  border-style: var(--qcm-card-border-style, solid);
}
</style>

