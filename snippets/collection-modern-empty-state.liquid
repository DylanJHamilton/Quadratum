{%- comment -%}
  Collection Modern — Empty State
  File: snippets/collection-modern-empty-state.liquid
{%- endcomment -%}

{%- render 'collection-modern-utils',
  results_url: results_url,
  is_search_context: is_search_context,
  terms_q: terms_q
-%}

<div class="qcm__empty" role="status">
  <p class="qcm__emptyTitle">No products found.</p>

  {%- if s.show_clear_all -%}
    <a class="qcm__btn qcm__btn--ghost" href="{{ qcm_base_url }}">Clear all filters</a>
  {%- endif -%}
</div>