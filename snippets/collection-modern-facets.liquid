{%- liquid
  assign s = s
  assign placement = placement | default: 'sidebar'
  assign has_filters = false
  if filters != blank and filters.size > 0
    assign has_filters = true
  endif
-%}

{%- if has_filters == false -%}
  {%- break -%}
{%- endif -%}

{%- if placement == 'drawer' -%}
  <div class="qcmDrawer" data-qcm-drawer hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Filters">
    <div class="qcmDrawer__overlay" data-qcm-drawer-overlay></div>
    <div class="qcmDrawer__panel">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:10px;">
        <strong>Filters</strong>
        <button class="qcm__btn" type="button" data-qcm-close-drawer aria-label="Close filters">Close</button>
      </div>

      <div class="qcmFacet">
        {% render 'collection-modern-facets',
          section: section,
          s: s,
          is_search_context: is_search_context,
          results_url: results_url,
          terms_q: terms_q,
          filters: filters,
          sort_options: sort_options,
          sort_by: sort_by,
          default_sort_by: default_sort_by,
          placement: 'sidebar'
        %}
      </div>
    </div>
  </div>

{%- elsif placement == 'drawer_noscript' -%}
  <div class="qcmFacet">
    {% render 'collection-modern-facets',
      section: section,
      s: s,
      is_search_context: is_search_context,
      results_url: results_url,
      terms_q: terms_q,
      filters: filters,
      sort_options: sort_options,
      sort_by: sort_by,
      default_sort_by: default_sort_by,
      placement: 'sidebar'
    %}
  </div>

{%- else -%}
  <form class="qcmFacet" method="get" action="{% if is_search_context %}{{ routes.search_url }}{% else %}{{ results_url }}{% endif %}">
    {%- if is_search_context -%}
      <input type="hidden" name="q" value="{{ terms_q | escape }}">
    {%- endif -%}

    {%- if sort_by != blank -%}
      <input type="hidden" name="sort_by" value="{{ sort_by | escape }}">
    {%- endif -%}

    {%- for filter in filters -%}
      <details open>
        <summary>{{ filter.label }}</summary>

        {%- if filter.type == 'list' or filter.type == 'boolean' -%}
          <div class="qcmFacet__list">
            {%- for value in filter.values -%}
              <label class="qcmFacet__row">
                <input
                  type="checkbox"
                  name="{{ value.param_name }}"
                  value="{{ value.value }}"
                  {% if value.active %}checked{% endif %}
                >
                <span>{{ value.label }}</span>
              </label>
            {%- endfor -%}
          </div>

        {%- elsif filter.type == 'price_range' -%}
          <div class="qcmFacet__price">
            <input
              type="number"
              inputmode="numeric"
              name="{{ filter.min_value.param_name }}"
              value="{% if filter.min_value.value != blank %}{{ filter.min_value.value }}{% endif %}"
              placeholder="Min"
            >
            <input
              type="number"
              inputmode="numeric"
              name="{{ filter.max_value.param_name }}"
              value="{% if filter.max_value.value != blank %}{{ filter.max_value.value }}{% endif %}"
              placeholder="Max"
            >
            <button class="qcm__btn" type="submit">Apply</button>
          </div>
        {%- endif -%}
      </details>
    {%- endfor -%}

    <div style="display:flex; gap:10px; margin-top:12px; flex-wrap:wrap;">
      <button class="qcm__btn" type="submit">Apply filters</button>

      {%- if s.show_clear_all -%}
        <a class="qcm__btn qcm__btn--link" href="{% if is_search_context %}{{ routes.search_url }}?q={{ terms_q | url_encode }}{% else %}{{ results_url }}{% endif %}">
          Clear all
        </a>
      {%- endif -%}
    </div>
  </form>
{%- endif -%}