{%- comment -%}
  Quadratum — Collection List Card (MVP)
  File: snippets/collection-list-card.liquid

  Inputs:
  - s: section.settings
  - c: collection object (required)
  - img_override: optional image object
  - title_override: optional text
  - shopify_attributes: optional string (block.shopify_attributes)
{%- endcomment -%}

{%- liquid
  if c == blank
    break
  endif

  assign img = img_override
  if img == blank
    assign img = c.image
  endif

  assign title_txt = title_override | default: ''
  if title_txt == blank
    assign title_txt = c.title
  endif
-%}

<article class="qcl__item qcl-card" {{ shopify_attributes }}>
  <a class="qcl-card__link" href="{{ c.url }}" aria-label="{{ title_txt | escape }}">
    {%- if s.show_image -%}
      <div class="qcl-card__media" data-ratio="{{ s.image_ratio }}">
        {%- if img != blank -%}
          <img
            src="{{ img | image_url: width: 1200 }}"
            alt="{{ img.alt | default: title_txt | escape }}"
            loading="lazy"
            width="{{ img.width | default: 1200 }}"
            height="{{ img.height | default: 800 }}"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'qcl-card__placeholder' }}
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="qcl-card__body">
      {%- if s.show_title -%}
        <h3 class="qcl-card__title">{{ title_txt }}</h3>
      {%- endif -%}

      {%- if s.show_count -%}
        <div class="qcl-card__meta">{{ c.products_count }} products</div>
      {%- endif -%}

      {%- if s.show_description and c.description != blank -%}
        <div class="qcl-card__desc">{{ c.description | strip_html | truncate: s.description_truncate }}</div>
      {%- endif -%}

      {%- if s.show_button -%}
        <span class="qcl-card__btn" role="button" aria-hidden="true">{{ s.button_label }}</span>
      {%- endif -%}
    </div>
  </a>
</article>