<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js" data-theme="{{ settings.color_scheme | default: 'default' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">


    {%- liquid
      assign qtm_page_title = page_title | default: shop.name
      assign qtm_meta_description = page_description | default: shop.description | default: settings.site_tagline
      assign qtm_canonical_url = canonical_url | default: request.origin
    -%}

    <title>
      {{ qtm_page_title | escape }}
      {%- unless qtm_page_title contains shop.name -%}
        · {{ shop.name | escape }}
      {%- endunless -%}
    </title>

    <link rel="canonical" href="{{ qtm_canonical_url }}">

    {%- if qtm_meta_description != blank -%}
      <meta name="description" content="{{ qtm_meta_description | strip_html | escape }}">
    {%- endif -%}

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      {% render 'theme-tokens' %}
      {% render 'utilities.css' %}
    </style>

    {{ 'cart-drawer.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>

    {% render 'cart-drawer', section: section %}

    {% assign font_strategy = settings.font_loading | default: 'swap' %}

    {% if font_strategy == 'swap' %}
      <style>@font-face{font-display:swap}</style>
    {% elsif font_strategy == 'fallback' %}
      <style>@font-face{font-display:fallback}</style>
    {% elsif font_strategy == 'async' %}
    {% endif %}

    {% if settings.preconnect_hosts %}
      {% assign hosts = settings.preconnect_hosts | split: ',' %}
      {% for host in hosts %}
        {% assign url = host | strip %}
        {% if url != blank %}
          <link rel="preconnect" href="{{ url }}" crossorigin>
        {% endif %}
      {% endfor %}
    {% endif %}

    {{ 'tailwind.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}

    {{ 'q-base.css' | asset_url | stylesheet_tag }}
    {{ 'q-quick-view.css' | asset_url | stylesheet_tag }}

    {%- if settings.enable_predictive_search -%}
      {{ 'predictive-search.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if settings.enable_search_popup -%}
      {{ 'search-popup.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'search-popup.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
  </head>

  <body class="q-typography" {% if settings.enable_dark_mode %}data-theme="light"{% endif %}>
    {% section 'header-one' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% section 'footer-one' %}

    {%- if settings.enable_search_popup -%}
      {% render 'search-popup' %}
    {%- endif -%}

    {% render 'q-quick-view-host' %}
    {{ content_for_footer }}
    {{ 'q-quick-view.js' | asset_url | script_tag }}
  </body>
</html>