{{ '404.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign qtm_404_heading = settings['notfound_heading'] | default: 'Page not found'
  assign qtm_404_message = settings['notfound_body'] | default: "We couldn’t find what you were looking for."

  assign qtm_404_primary_label = settings['notfound_cta_label'] | default: 'Back to home'
  assign qtm_404_primary_link = settings['notfound_cta_link'] | default: routes.root_url

  assign qtm_404_show_continue_shopping = settings['notfound_show_continue_shopping']
  assign qtm_404_continue_shopping_label = settings['notfound_continue_shopping_label'] | default: 'Continue shopping'
  assign qtm_404_continue_shopping_link = settings['notfound_continue_shopping_link'] | default: '/collections'

  assign qtm_404_show_search = settings['notfound_show_search']
  assign qtm_404_search_label = settings['notfound_search_label'] | default: 'Search store'
  assign qtm_404_search_placeholder = settings['notfound_search_placeholder'] | default: 'Search our store'
  assign qtm_404_search_button_label = settings['notfound_search_button_label'] | default: 'Search'

  assign qtm_404_layout = settings['notfound_layout'] | default: 'centered'
  assign qtm_404_image = settings['notfound_image']
  assign qtm_404_bg_image = settings['notfound_bg_image']
  assign qtm_404_show_image = settings['notfound_show_image']
  assign qtm_404_show_bg_image = settings['notfound_show_bg_image']
  assign qtm_404_overlay = settings['notfound_overlay']

  assign qtm_404_padding_top = settings['notfound_section_padding_top'] | default: 64
  assign qtm_404_padding_bottom = settings['notfound_section_padding_bottom'] | default: 64

  assign qtm_404_has_media = false
  if qtm_404_show_image and qtm_404_image != blank and qtm_404_layout != 'centered'
    assign qtm_404_has_media = true
  endif
-%}

<section
  id="QtmMain404-{{ section.id }}"
  class="qtm404 qtm404--{{ qtm_404_layout }}{% if qtm_404_has_media %} qtm404--has-media{% endif %}{% if qtm_404_show_bg_image and qtm_404_bg_image != blank %} qtm404--has-bg{% endif %}"
  aria-labelledby="QtmMain404Heading-{{ section.id }}"
  style="
    --qtm404-padding-top: {{ qtm_404_padding_top }}px;
    --qtm404-padding-bottom: {{ qtm_404_padding_bottom }}px;
    {% if qtm_404_show_bg_image and qtm_404_bg_image != blank %}
      --qtm404-bg-image: url('{{ qtm_404_bg_image | image_url: width: 2400 }}');
    {% endif %}
  "
>
  {%- if qtm_404_show_bg_image and qtm_404_bg_image != blank and qtm_404_overlay -%}
    <div class="qtm404__bg-overlay"></div>
  {%- endif -%}

  <div class="qtm404__inner page-width">
    <div class="qtm404__grid">
      <div class="qtm404__content">
        <h1 id="QtmMain404Heading-{{ section.id }}" class="qtm404__heading">
          {{ qtm_404_heading }}
        </h1>

        <div class="qtm404__message rte">
          <p>{{ qtm_404_message }}</p>
        </div>

        <div class="qtm404__actions">
          <a href="{{ qtm_404_primary_link }}" class="qtm404__button qtm404__button--primary">
            {{ qtm_404_primary_label }}
          </a>

          {%- if qtm_404_show_continue_shopping -%}
            <a href="{{ qtm_404_continue_shopping_link }}" class="qtm404__button qtm404__button--secondary">
              {{ qtm_404_continue_shopping_label }}
            </a>
          {%- endif -%}
        </div>

        {%- if qtm_404_show_search -%}
          <div class="qtm404__search">
            <form action="{{ routes.search_url }}" method="get" role="search" class="qtm404__search-form">
              <label class="visually-hidden" for="Qtm404Search-{{ section.id }}">
                {{ qtm_404_search_label }}
              </label>

              <div class="qtm404__search-field">
                <input
                  id="Qtm404Search-{{ section.id }}"
                  class="qtm404__search-input"
                  type="search"
                  name="q"
                  placeholder="{{ qtm_404_search_placeholder }}"
                  aria-label="{{ qtm_404_search_label }}"
                  autocorrect="off"
                  autocomplete="off"
                  autocapitalize="off"
                  spellcheck="false"
                >
                <button
                  type="submit"
                  class="qtm404__search-button"
                  aria-label="{{ qtm_404_search_button_label }}"
                >
                  {{ qtm_404_search_button_label }}
                </button>
              </div>
            </form>
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <nav class="qtm404__links" aria-label="Helpful links">
            <ul class="qtm404__links-list" role="list">
              {%- for block in section.blocks -%}
                {%- if block.type == '404_link' and block.settings.label != blank and block.settings.url != blank -%}
                  <li class="qtm404__links-item" {{ block.shopify_attributes }}>
                    <a href="{{ block.settings.url }}" class="qtm404__link">
                      {{ block.settings.label }}
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}
      </div>

      {%- if qtm_404_has_media -%}
        <div class="qtm404__media">
          {{
            qtm_404_image
            | image_url: width: 1200
            | image_tag:
              class: 'qtm404__image',
              loading: 'lazy',
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw',
              alt: qtm_404_heading
          }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main 404",
  "tag": "section",
  "class": "qtm-main-404",
  "blocks": [
    {
      "type": "404_link",
      "name": "404 Link",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop All"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main 404"
    }
  ]
}
{% endschema %}