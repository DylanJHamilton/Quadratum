{%- comment -%}
  Quadratum — Collection Modern Sort
  File: snippets/collection-modern-sort.liquid
  Inputs: s, sort_options, sort_by, default_sort_by, results_url, is_search_context, terms_q
{%- endcomment -%}

{%- liquid
  assign current = sort_by
  if current == blank
    assign current = default_sort_by
  endif

  assign base_url = results_url
  if is_search_context and terms_q != blank
    assign base_url = routes.search_url | append: '?q=' | append: terms_q | url_encode
  endif
-%}

<div class="qcm__sort" data-qcm-sort>
  {%- if s.sort_style == 'dropdown' -%}
    <label class="qcm__srOnly" for="QcmSort-{{ section.id }}">Sort</label>
    <select id="QcmSort-{{ section.id }}" name="sort_by" data-qcm-sort-select>
      {%- for opt in sort_options -%}
        <option value="{{ opt.value }}" {% if opt.value == current %}selected{% endif %}>{{ opt.name }}</option>
      {%- endfor -%}
    </select>
    <noscript>
      <button class="qcm__btn qcm__btn--ghost" type="submit">Apply</button>
    </noscript>
  {%- else -%}
    <div class="qcm__sortPills" role="list">
      {%- for opt in sort_options -%}
        {%- liquid
          assign href = base_url
          if href contains '?'
            assign href = href | append: '&sort_by=' | append: opt.value
          else
            assign href = href | append: '?sort_by=' | append: opt.value
          endif
        -%}
        <a class="qcm__pill"
           role="listitem"
           href="{{ href }}"
           aria-current="{% if opt.value == current %}true{% else %}false{% endif %}">
          {{ opt.name }}
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>