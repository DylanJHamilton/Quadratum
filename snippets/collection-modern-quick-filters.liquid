{%- comment -%}
  Quick filter chips: uses blocks (filter_label + value_label)
  Finds matching Shopify filter + value, then uses value.url_to_add / url_to_remove
{%- endcomment -%}

{%- if section.blocks.size == 0 -%}{% break %}{%- endif -%}

<div class="qcm__quickFilters" data-qcm-quick-filters>
  {%- for block in section.blocks -%}
    {%- if block.type != 'quick_filter' -%}{% continue %}{%- endif -%}
    {%- liquid
      assign want_f = block.settings.filter_label | default: '' | downcase | strip
      assign want_v = block.settings.value_label  | default: '' | downcase | strip
      assign chip_url = blank
      assign chip_active = false

      if want_f != blank and want_v != blank
        for f in filters
          assign f_label_norm = f.label | default: '' | downcase | strip
          if f_label_norm == want_f
            for v in f.values
              assign v_label_norm = v.label | default: '' | downcase | strip
              if v_label_norm == want_v
                if v.active
                  assign chip_active = true
                  assign chip_url = v.url_to_remove
                else
                  assign chip_url = v.url_to_add
                endif
                break
              endif
            endfor
          endif
          if chip_url != blank
            break
          endif
        endfor
      endif
    -%}

    {%- if chip_url != blank -%}
      <a
        class="qcm__pill {% if chip_active %}is-active{% endif %}"
        href="{{ chip_url }}"
        aria-current="{% if chip_active %}true{% else %}false{% endif %}"
        {{ block.shopify_attributes }}
      >
        {{ block.settings.value_label | default: block.settings.filter_label }}
      </a>
    {%- endif -%}
  {%- endfor -%}
</div>