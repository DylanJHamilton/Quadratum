{%- comment -%}
  Q ADD-ON: Wishlist Button (Classic)
  Inputs:
    - product
    - variant
    - style: 'icon' | 'button'
    - label
    - section_id (optional)
{%- endcomment -%}

{%- liquid
  assign p = product
  assign v = variant
  assign style_mode = style | default: 'icon'
  assign btn_label = label | default: 'Add to wishlist'
  assign sid = section_id | default: ''
-%}

<button
  type="button"
  class="p-wl {% if style == 'button' %}p-wl--button{% else %}p-wl--icon{% endif %}"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ variant.id }}"
  data-section-id="{{ section_id }}"
  aria-pressed="false"
  aria-label="{{ label | default: 'Add to wishlist' | escape }}"
>
  <span class="p-wl__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="20" height="20" class="p-wl__svg" role="presentation" focusable="false">
      <path d="M12 21s-7.2-4.35-9.6-8.55C.6 9.3 2.1 6 5.7 6c2 0 3.4 1.2 4.3 2.3C10.9 7.2 12.3 6 14.3 6c3.6 0 5.1 3.3 3.3 6.45C19.2 16.65 12 21 12 21z"
            fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
    </svg>
  </span>

  {%- if style == 'button' -%}
    <span class="p-wl__label">{{ label | default: 'Add to wishlist' }}</span>
  {%- endif -%}
</button>