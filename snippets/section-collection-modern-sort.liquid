{%- comment -%}
  Collection Modern — Sort UI
  File: snippets/collection-modern-sort.liquid
{%- endcomment -%}

{%- if sort_options == blank or sort_options.size == 0 -%}
  {%- break -%}
{%- endif -%}

{%- liquid
  assign current_sort = sort_by | default: default_sort_by
-%}

{%- if s.sort_style == 'pills' -%}
  <div class="qcm__sortPills" role="list">
    {%- for opt in sort_options -%}
      {%- liquid
        assign is_active = false
        if current_sort == opt.value
          assign is_active = true
        endif
      -%}
      <a
        role="listitem"
        class="qcm__pageLink"
        {% if is_active %}aria-current="page"{% endif %}
        href="{{ opt.url }}"
      >
        {{ opt.name }}
      </a>
    {%- endfor -%}
  </div>
{%- else -%}
  <label class="visually-hidden" for="QcmSort-{{ section.id }}">Sort</label>
  <select class="qcm__select" id="QcmSort-{{ section.id }}" data-qcm-sort>
    {%- for opt in sort_options -%}
      <option value="{{ opt.url }}" {% if current_sort == opt.value %}selected{% endif %}>
        {{ opt.name }}
      </option>
    {%- endfor -%}
  </select>

  <script>
    document.addEventListener('DOMContentLoaded', function(){
      var root = document.getElementById('QtmCollectionModern-{{ section.id }}');
      if(!root) return;
      var sel = root.querySelector('[data-qcm-sort]');
      if(!sel) return;
      sel.addEventListener('change', function(){
        if(sel.value) window.location.href = sel.value;
      });
    });
  </script>
{%- endif -%}