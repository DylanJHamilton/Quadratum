{%- liquid
  assign form_context = form_context | default: 'site'
  assign input_id = input_id | default: 'QtmPredictiveSearchInput'
  assign panel_id = panel_id | default: 'QtmPredictiveSearchPanel'
  assign placeholder = placeholder | default: settings.search_placeholder | default: 'Search products, articles, and pages'
  assign submit_label = submit_label | default: settings.search_submit_label | default: 'Search'
  assign form_action = form_action | default: routes.search_url
  assign query_value = query_value | default: search.terms
  assign extra_class = extra_class | default: ''
  assign show_button = show_button
  if show_button == nil
    assign show_button = true
  endif

  assign show_group_headings = settings.predictive_search_show_group_headings
  assign show_thumbnails = settings.predictive_search_show_thumbnails
  assign show_view_all = settings.predictive_search_show_view_all

  assign allow_products = settings.search_src_products
  assign allow_collections = settings.search_src_collections
  assign allow_articles = settings.search_src_articles
  assign allow_pages = settings.search_src_pages

  assign limit_products = settings.predictive_search_products_limit | default: 4
  assign limit_collections = settings.predictive_search_collections_limit | default: 3
  assign limit_articles = settings.predictive_search_articles_limit | default: 3
  assign limit_pages = settings.predictive_search_pages_limit | default: 3

  assign min_chars = settings.predictive_search_min_chars | default: 2
  assign debounce = settings.predictive_search_debounce | default: 250

  assign panel_style = settings.predictive_search_panel_style | default: 'soft'
  assign products_layout = settings.predictive_search_products_layout | default: 'list'
-%}

<div
  class="qtm-search-form qtm-search-form--predictive qtm-search-form--predictive-{{ panel_style }} {{ extra_class }}"
  data-qtm-predictive-search
  data-search-context="{{ form_context }}"
  data-min-chars="{{ min_chars }}"
  data-debounce="{{ debounce }}"
  data-products-enabled="{{ allow_products }}"
  data-collections-enabled="{{ allow_collections }}"
  data-articles-enabled="{{ allow_articles }}"
  data-pages-enabled="{{ allow_pages }}"
  data-products-limit="{{ limit_products }}"
  data-collections-limit="{{ limit_collections }}"
  data-articles-limit="{{ limit_articles }}"
  data-pages-limit="{{ limit_pages }}"
  data-products-layout="{{ products_layout }}"
  data-show-group-headings="{{ show_group_headings }}"
  data-show-thumbnails="{{ show_thumbnails }}"
  data-show-view-all="{{ show_view_all }}"
  data-view-all-label="{{ settings.search_view_all_label | default: 'View all results' | escape }}"
  style="
    --qtm-ps-panel-bg: {{ settings.predictive_search_panel_bg | default: settings.bg_base }};
    --qtm-ps-panel-border: {{ settings.predictive_search_panel_border | default: settings.bg_contrast }};
    --qtm-ps-item-bg: {{ settings.predictive_search_item_bg | default: settings.bg_contrast }};
    --qtm-ps-item-hover-bg: {{ settings.predictive_search_item_hover_bg | default: settings.bg_contrast }};
    --qtm-ps-heading-color: {{ settings.predictive_search_heading_color | default: settings.text_muted }};
    --qtm-ps-title-color: {{ settings.predictive_search_title_color | default: settings.text_base }};
    --qtm-ps-meta-color: {{ settings.predictive_search_meta_color | default: settings.text_muted }};
    --qtm-ps-price-color: {{ settings.predictive_search_price_color | default: settings.color_primary }};
    --qtm-ps-panel-radius: {{ settings.predictive_search_panel_radius | default: 18 }}px;
    --qtm-ps-item-radius: {{ settings.predictive_search_item_radius | default: 14 }}px;
    --qtm-ps-panel-padding: {{ settings.predictive_search_panel_padding | default: 14 }}px;
    --qtm-ps-item-padding: {{ settings.predictive_search_item_padding | default: 10 }}px;
    --qtm-ps-thumb-size: {{ settings.predictive_search_thumbnail_size | default: 56 }}px;
  "
>
  <form
    class="qtm-search-form__form"
    action="{{ form_action }}"
    method="get"
    role="search"
  >
    <label class="visually-hidden" for="{{ input_id }}">Search store</label>

    <div class="qtm-search-form__field">
      <input
        id="{{ input_id }}"
        class="qtm-search-form__input qtm-search-form__input--predictive"
        type="search"
        name="q"
        value="{{ query_value | escape }}"
        placeholder="{{ placeholder | escape }}"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="Search store"
        aria-expanded="false"
        aria-controls="{{ panel_id }}"
        aria-autocomplete="list"
        role="combobox"
        data-qtm-predictive-input
      >
    </div>

    {%- if show_button -%}
      <div class="qtm-search-form__actions">
        <button class="qtm-search-form__submit button" type="submit">
          {{ submit_label }}
        </button>
      </div>
    {%- endif -%}
  </form>

  <div
    id="{{ panel_id }}"
    class="qtm-search-predictive__panel"
    role="listbox"
    aria-label="Search suggestions"
    hidden
    data-qtm-predictive-panel
  ></div>
</div>