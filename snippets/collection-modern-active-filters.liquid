{%- comment -%}
  Collection Modern — Active Filters
  File: snippets/collection-modern-active-filters.liquid
{%- endcomment -%}

{%- if filters == blank or filters.size == 0 -%}{%- break -%}{%- endif -%}

{%- liquid
  assign has_active = false
  for f in filters
    if f.active_values != blank and f.active_values.size > 0
      assign has_active = true
      break
    endif
    if f.type == 'price_range'
      if f.min_value.value != blank or f.max_value.value != blank
        assign has_active = true
        break
      endif
    endif
  endfor
-%}

{%- if has_active == false -%}{%- break -%}{%- endif -%}

<div class="qcm__chips" aria-label="Active filters">
  {%- for f in filters -%}
    {%- if f.active_values != blank and f.active_values.size > 0 -%}
      {%- for av in f.active_values -%}
        <a class="qcm__chip" href="{{ av.url_to_remove }}">
          {{ f.label }}: {{ av.label }} <span aria-hidden="true">×</span>
        </a>
      {%- endfor -%}
    {%- endif -%}

    {%- if f.type == 'price_range' -%}
      {%- if f.min_value.value != blank or f.max_value.value != blank -%}
        <a class="qcm__chip" href="{{ f.url_to_remove }}">
          {{ f.label }}:
          {%- if f.min_value.value != blank -%}{{ f.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}
          –
          {%- if f.max_value.value != blank -%}{{ f.max_value.value | money }}{%- else -%}∞{%- endif -%}
          <span aria-hidden="true">×</span>
        </a>
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if s.show_clear_all -%}
    {%- render 'collection-modern-utils',
      results_url: results_url,
      is_search_context: is_search_context,
      terms_q: terms_q
    -%}
    <a class="qcm__chip" href="{{ qcm_base_url }}">
      Clear all <span aria-hidden="true">↺</span>
    </a>
  {%- endif -%}
</div>