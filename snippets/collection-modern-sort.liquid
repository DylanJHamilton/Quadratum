{% comment %}
  Quadratum — Collection Modern Sort UI
  File: snippets/collection-modern-sort.liquid
{% endcomment %}

{%- liquid
  assign current = sort_by | default: default_sort_by | default: ''
-%}

<div class="qcm__sort" data-qcm-sort>
  {%- if s.sort_style == 'dropdown' -%}
    <label class="visually-hidden" for="QcmSort-{{ section.id }}">Sort</label>
    <select id="QcmSort-{{ section.id }}" data-qcm-sort-select>
      {%- for opt in sort_options -%}
        <option value="{{ opt.value }}" {% if current == opt.value %}selected{% endif %}>{{ opt.name }}</option>
      {%- endfor -%}
    </select>
  {%- else -%}
    <div class="qcm__sortPills" aria-label="Sort options">
      {%- for opt in sort_options -%}
        {%- liquid
          assign active = false
          if current == opt.value
            assign active = true
          endif

          capture href
            if is_search_context
              if terms_q != blank
                echo routes.search_url
                echo '?q='
                echo terms_q | url_encode
                echo '&type=product&options[prefix]=last&sort_by='
                echo opt.value | url_encode
              else
                echo routes.search_url
                echo '?type=product&options[prefix]=last&sort_by='
                echo opt.value | url_encode
              endif
            else
              echo results_url
              echo '?sort_by='
              echo opt.value | url_encode
            endif
          endcapture
        -%}

        <a class="qcm__pill{% if active %} is-active{% endif %}" href="{{ href | strip }}" aria-current="{% if active %}true{% else %}false{% endif %}">
          {{ opt.name }}
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>