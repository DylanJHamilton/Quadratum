{%- liquid
  assign context = context | default: 'header'
  assign input_id = input_id | default: 'QtmPredictiveSearchInput'
  assign panel_id = panel_id | default: 'QtmPredictiveSearchPanel'
  assign placeholder = placeholder | default: settings.search_page_placeholder | default: 'Search products, articles, and pages'
  assign submit_label = settings.search_submit_label | default: 'Search'

  assign allow_products = settings.search_src_products
  assign allow_collections = settings.search_src_collections
  assign allow_articles = settings.search_src_articles
  assign allow_pages = settings.search_src_pages

  assign limit_products = settings.predictive_search_products_limit | default: settings.search_results_limit | default: 8
  assign limit_collections = settings.predictive_search_collections_limit | default: settings.search_results_limit | default: 8
  assign limit_articles = settings.predictive_search_articles_limit | default: settings.search_results_limit | default: 8
  assign limit_pages = settings.predictive_search_pages_limit | default: settings.search_results_limit | default: 8

  assign min_chars = settings.predictive_search_min_chars | default: 2
  assign debounce = settings.predictive_search_debounce | default: 250
-%}

<div
  class="qtm-search-predictive"
  data-qtm-predictive-search
  data-context="{{ context }}"
  data-min-chars="{{ min_chars }}"
  data-debounce="{{ debounce }}"
  data-products-enabled="{{ allow_products }}"
  data-collections-enabled="{{ allow_collections }}"
  data-articles-enabled="{{ allow_articles }}"
  data-pages-enabled="{{ allow_pages }}"
  data-products-limit="{{ limit_products }}"
  data-collections-limit="{{ limit_collections }}"
  data-articles-limit="{{ limit_articles }}"
  data-pages-limit="{{ limit_pages }}"
  data-view-all-label="{{ settings.search_view_all_label | default: 'View all results' | escape }}"
>
  <form class="qtm-search-predictive__form" action="{{ routes.search_url }}" method="get" role="search">
    <label class="visually-hidden" for="{{ input_id }}">Search store</label>

    <input
      id="{{ input_id }}"
      class="qtm-search-predictive__input"
      type="search"
      name="q"
      placeholder="{{ placeholder | escape }}"
      autocomplete="off"
      aria-label="Search store"
      aria-expanded="false"
      aria-controls="{{ panel_id }}"
      aria-autocomplete="list"
      role="combobox"
      data-qtm-predictive-input
    >

    <button class="qtm-search-predictive__submit" type="submit">
      {{ submit_label }}
    </button>
  </form>

  <div
    id="{{ panel_id }}"
    class="qtm-search-predictive__panel"
    role="listbox"
    aria-label="Search suggestions"
    hidden
    data-qtm-predictive-panel
  ></div>
</div>