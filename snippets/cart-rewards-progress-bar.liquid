{%- liquid
  assign context = context | default: 'page'
  assign compact = compact | default: false
  assign addon_count = 0

  for block in section.blocks
    if block.type == 'addon_product' and block.settings.product != blank
      assign addon_count = addon_count | plus: 1
    endif
  endfor
-%}

{%- if addon_count > 0 -%}
  <div class="qtm-cart-addons qtm-cart-addons--{{ context }} {% if compact %}qtm-cart-addons--compact{% endif %}" data-cart-addons>
    <div class="qtm-cart-addons__header">
      <h2 class="qtm-cart-addons__title">Recommended add-ons</h2>
    </div>

    <div class="qtm-cart-addons__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'addon_product' and block.settings.product != blank -%}
          {%- assign addon_product = block.settings.product -%}
          {%- assign addon_variant = addon_product.selected_or_first_available_variant -%}

          {%- if addon_variant != blank and addon_variant.available -%}
            <article class="qtm-cart-addon-card" {{ block.shopify_attributes }}>
              <a href="{{ addon_product.url }}" class="qtm-cart-addon-card__media">
                {%- if addon_product.featured_image -%}
                  {{
                    addon_product.featured_image
                    | image_url: width: 320
                    | image_tag:
                      loading: 'lazy',
                      widths: '160,240,320',
                      class: 'qtm-cart-addon-card__image',
                      alt: addon_product.featured_image.alt | escape
                  }}
                {%- else -%}
                  <div class="qtm-cart-addon-card__image-placeholder"></div>
                {%- endif -%}
              </a>

              <div class="qtm-cart-addon-card__content">
                <h3 class="qtm-cart-addon-card__title">
                  <a href="{{ addon_product.url }}">
                    {{ block.settings.custom_label | default: addon_product.title }}
                  </a>
                </h3>

                {%- if block.settings.custom_description != blank -%}
                  <div class="qtm-cart-addon-card__description">
                    {{ block.settings.custom_description }}
                  </div>
                {%- endif -%}

                <div class="qtm-cart-addon-card__price">
                  {{ addon_variant.price | money }}
                </div>

                <form
                  action="{{ routes.cart_add_url }}"
                  method="post"
                  enctype="multipart/form-data"
                  class="qtm-cart-addon-card__form"
                  data-addon-form
                >
                  <input type="hidden" name="id" value="{{ addon_variant.id }}">
                  <button type="submit" class="qtm-cart-addon-card__button">
                    Add to cart
                  </button>
                </form>
              </div>
            </article>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}