{%- comment -%}
  Collection Modern — Pagination
  File: snippets/collection-modern-pagination.liquid
  Always renders numbered pagination (Liquid-first)
  Enhances with load more / infinite scroll via JS
{%- endcomment -%}

{%- if paginate == blank -%}{%- break -%}{%- endif -%}

{%- liquid
  assign next_url = ''
  if paginate.next
    assign next_url = paginate.next.url
  endif
-%}

<div class="qcm__pagination" data-qcm-pagination>
  <div class="qcm__pager" aria-label="Pagination">
    {%- if paginate.previous -%}
      <a class="qcm__pageLink" href="{{ paginate.previous.url }}">Prev</a>
    {%- endif -%}

    {%- for part in paginate.parts -%}
      {%- if part.is_link -%}
        <a class="qcm__pageLink" href="{{ part.url }}">{{ part.title }}</a>
      {%- else -%}
        <span class="qcm__pageLink" {% if part.title == paginate.current_page %}aria-current="page"{% endif %}>
          {{ part.title }}
        </span>
      {%- endif -%}
    {%- endfor -%}

    {%- if paginate.next -%}
      <a class="qcm__pageLink" href="{{ paginate.next.url }}">Next</a>
    {%- endif -%}
  </div>

  {%- if pagination_style == 'load_more' and paginate.next -%}
    <div data-qcm-next-url data-qcm-next-url-holder data-qcm-next-url="{{ next_url }}"></div>
    <button class="qcm__btn" type="button" data-qcm-load-more aria-busy="false">
      Load more
    </button>
  {%- elsif pagination_style == 'infinite_scroll' and paginate.next -%}
    <div data-qcm-next-url data-qcm-next-url-holder data-qcm-next-url="{{ next_url }}"></div>
    <div data-qcm-sentinel style="height:1px;"></div>
  {%- else -%}
    {%- if paginate.next -%}
      <div data-qcm-next-url data-qcm-next-url="{{ next_url }}" style="display:none;"></div>
    {%- endif -%}
  {%- endif -%}
</div>