{%- comment -%}
  Quadratum — Main Collection Classic
  File: sections/main-collection-classic.liquid

  Rules honored:
  - Product rendering ONLY via: {% render 'product-card', product: product, ... %}
  - Filters + Sorting + Pagination required
  - 3 layouts: grid, two_column_sidebar, top_controls
  - Custom colors only (no theme color_scheme dependency)
  - Section-scoped CSS only
  - Minimal JS (only for infinite scroll, progressive enhancement)
{%- endcomment -%}

{%- liquid
  assign s = section.settings

  assign layout = s.layout | default: 'grid'
  assign filters_enabled = s.filters_enabled
  assign sorting_enabled = s.sorting_enabled

  assign has_filters = false
  if collection.filters != blank and collection.filters.size > 0
    assign has_filters = true
  endif

  assign show_title = s.show_title
  assign show_description = s.show_description
  assign description_position = s.description_position | default: 'above_grid'
  assign description_collapse = s.description_collapse

  assign content_width = s.content_width | default: 'page'
  assign title_size = s.title_size | default: 'md'

  assign pagination_type = s.pagination_type | default: 'numbers'
  assign per_page = s.products_per_page | default: 24

  assign clear_all_url = collection.url
  if collection.sort_by != blank
    assign clear_all_url = clear_all_url | append: '?sort_by=' | append: collection.sort_by
  endif

  comment
    Pass-through controls to product-card snippet (match existing pattern).
  endcomment
  assign pc_enable_quick_add = s.enable_quick_add
  assign pc_enable_quick_view = s.enable_quick_view
  assign pc_quick_add_mode = s.quick_add_mode
  assign pc_quick_view_mode = s.quick_view_mode
  assign pc_show_action_row = s.show_action_row
  assign pc_show_secondary_row_cta = s.show_secondary_row_cta
  assign pc_show_row_quick_view = s.show_row_quick_view
  assign pc_quick_view_placement = s.quick_view_placement

  assign pc_primary_cta_label = s.primary_cta_label
  assign pc_secondary_cta_label = s.secondary_cta_label
  assign pc_label_select_options = s.label_select_options
  assign pc_label_sold_out = s.label_sold_out
  assign pc_qv_label = s.qv_label

  assign pc_button_style = s.button_style
  assign pc_button_size = s.button_size
  assign pc_button_full_width = s.button_full_width
  assign pc_button_hover_strength = s.button_hover_strength

  assign show_header = false
  if show_title
    assign show_header = true
  endif
  if show_description and description_position == 'above_grid'
    assign show_header = true
  endif

  comment
    CSS vars (includes product-card button vars used by your theme).
  endcomment
  assign mcc_style = ''
  assign mcc_style = mcc_style | append: '--mcc-pt:' | append: s.padding_top | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-pb:' | append: s.padding_bottom | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-gap:' | append: s.grid_gap | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-cols-mobile:' | append: s.columns_mobile | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-cols-tablet:' | append: s.columns_tablet | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-cols-desktop:' | append: s.columns_desktop | append: ';'

  assign mcc_style = mcc_style | append: '--mcc-bg:' | append: s.bg_color | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-text:' | append: s.text_color | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-heading:' | append: s.heading_color | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-muted:' | append: s.muted_text_color | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-border:' | append: s.border_color | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-surface:' | append: s.surface_color | append: ';'

  assign mcc_style = mcc_style | append: '--mcc-bar-bg:' | append: s.controls_bg | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-bar-text:' | append: s.controls_text | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-bar-border:' | append: s.controls_border | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-bar-radius:' | append: s.controls_radius | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-bar-pad-y:' | append: s.controls_pad_y | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-bar-pad-x:' | append: s.controls_pad_x | append: 'px;'

  assign mcc_style = mcc_style | append: '--mcc-input-bg:' | append: s.input_bg | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-input-text:' | append: s.input_text | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-input-border:' | append: s.input_border | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-input-radius:' | append: s.input_radius | append: 'px;'

  assign mcc_style = mcc_style | append: '--mcc-chip-bg:' | append: s.chip_bg | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-chip-text:' | append: s.chip_text | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-chip-border:' | append: s.chip_border | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-chip-radius:' | append: s.chip_radius | append: 'px;'

  assign mcc_style = mcc_style | append: '--mcc-apply-bg:' | append: s.apply_bg | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-apply-text:' | append: s.apply_text | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-apply-border:' | append: s.apply_border | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-apply-bg-hover:' | append: s.apply_bg_hover | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-apply-text-hover:' | append: s.apply_text_hover | append: ';'

  comment
    Product item wrapper border controls (outside card).
  endcomment
  assign mcc_style = mcc_style | append: '--mcc-frame-bg:' | append: s.card_frame_bg | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-frame-border:' | append: s.card_frame_border | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-frame-bw:' | append: s.card_frame_border_width | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-frame-bs:' | append: s.card_frame_border_style | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-frame-radius:' | append: s.card_frame_radius | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-frame-pad:' | append: s.card_frame_padding | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-frame-shadow:' | append: s.card_frame_shadow | append: ';'

  comment
    Title/price styling vars (best-effort).
  endcomment
  assign mcc_style = mcc_style | append: '--mcc-title-size:' | append: s.product_title_size | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-title-weight:' | append: s.product_title_weight | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-title-color:' | append: s.product_title_color | append: ';'

  assign mcc_style = mcc_style | append: '--mcc-price-size:' | append: s.product_price_size | append: 'px;'
  assign mcc_style = mcc_style | append: '--mcc-price-weight:' | append: s.product_price_weight | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-price-color:' | append: s.product_price_color | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-compare-color:' | append: s.product_compare_color | append: ';'

  comment
    IMPORTANT: set the SAME vars your product-card system expects.
  endcomment
  assign mcc_style = mcc_style | append: '--q-btn-bg:' | append: s.btn_bg | append: ';'
  assign mcc_style = mcc_style | append: '--q-btn-text:' | append: s.btn_text | append: ';'
  assign mcc_style = mcc_style | append: '--q-btn-border:' | append: s.btn_border | append: ';'
  assign mcc_style = mcc_style | append: '--q-btn-bg-hover:' | append: s.btn_bg_hover | append: ';'
  assign mcc_style = mcc_style | append: '--q-btn-text-hover:' | append: s.btn_text_hover | append: ';'

  assign mcc_style = mcc_style | append: '--pr-btn-radius:' | append: s.btn_radius | append: 'px;'
  assign mcc_style = mcc_style | append: '--pr-btn-font-size:' | append: s.btn_font_size | append: 'px;'
  assign mcc_style = mcc_style | append: '--pr-btn-pad-y:' | append: s.btn_padding_y | append: 'px;'
  assign mcc_style = mcc_style | append: '--pr-btn-pad-x:' | append: s.btn_padding_x | append: 'px;'

  assign mcc_style = mcc_style | append: '--mcc-badge-sale-bg:' | append: s.badge_sale_bg | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-badge-sale-text:' | append: s.badge_sale_text_color | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-badge-soldout-bg:' | append: s.badge_soldout_bg | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-badge-soldout-text:' | append: s.badge_soldout_text_color | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-badge-custom-bg:' | append: s.badge_custom_bg | append: ';'
  assign mcc_style = mcc_style | append: '--mcc-badge-custom-text:' | append: s.badge_custom_text_color | append: ';'
-%}

<style>
  .main-collection-classic{
    background: var(--mcc-bg, #fff);
    color: var(--mcc-text, #111);
    padding-top: var(--mcc-pt, 32px);
    padding-bottom: var(--mcc-pb, 32px);
  }
  .main-collection-classic *{ box-sizing:border-box; }
  .main-collection-classic__inner{ overflow-x: hidden; }
  .main-collection-classic__form,
  .main-collection-classic__layout,
  .main-collection-classic__main{ min-width: 0; }

  .main-collection-classic__inner--page{
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 16px;
    padding-right: 16px;
  }
  .main-collection-classic__inner--full{
    width: 100%;
    margin: 0 auto;
    padding-left: 16px;
    padding-right: 16px;
  }

  .main-collection-classic__title{
    color: var(--mcc-heading, #111) !important;
    margin: 0;
    line-height: 1.15;
  }
  .main-collection-classic__title--sm{ font-size: 1.35rem !important; }
  .main-collection-classic__title--md{ font-size: 1.8rem !important; }
  .main-collection-classic__title--lg{ font-size: 2.25rem !important; }

  .main-collection-classic__description{ margin-top: 10px; color: var(--mcc-muted, rgba(0,0,0,.72)) !important; }
  .main-collection-classic__desc-details{ margin-top: 8px; }
  .main-collection-classic__desc-summary{ cursor:pointer; user-select:none; }

  .main-collection-classic__controls{
    display:flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    justify-content: space-between;
    margin: 12px 0 14px;
    padding: var(--mcc-bar-pad-y, 10px) var(--mcc-bar-pad-x, 12px);
    background: var(--mcc-bar-bg, rgba(0,0,0,0.03));
    color: var(--mcc-bar-text, inherit);
    border: 1px solid var(--mcc-bar-border, rgba(0,0,0,0.10));
    border-radius: var(--mcc-bar-radius, 12px);
    min-width: 0;
  }
  .main-collection-classic__controls--top{ margin-top: 10px; }

  .main-collection-classic__sort{
    display:flex;
    gap: 8px;
    align-items:center;
    flex: 1 1 260px;
    min-width: 0;
    max-width: 100%;
  }
  .main-collection-classic__sort-label{
    font-size: 0.9rem;
    color: var(--mcc-muted, rgba(0,0,0,.72)) !important;
    white-space: nowrap;
  }
  .main-collection-classic__sort-select{
    width: 100%;
    max-width: 100%;
    min-width: 0;
    background: var(--mcc-input-bg, #fff);
    color: var(--mcc-input-text, #111);
    border: 1px solid var(--mcc-input-border, rgba(0,0,0,0.14));
    border-radius: var(--mcc-input-radius, 10px);
    padding: 9px 10px;
    line-height: 1.2;
  }

  .main-collection-classic__drawer-toggle{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap: 8px;
    padding: 9px 12px;
    border-radius: var(--mcc-input-radius, 10px);
    border: 1px solid var(--mcc-input-border, rgba(0,0,0,0.14));
    background: var(--mcc-input-bg, #fff);
    color: var(--mcc-input-text, #111);
    cursor:pointer;
    user-select:none;
    white-space: nowrap;
  }

  .main-collection-classic__layout{ display:block; min-width: 0; }
  .main-collection-classic__sidebar{ min-width: 0; }
  .main-collection-classic__main{ min-width: 0; }

  @media (min-width: 990px){
    .main-collection-classic--layout-two_column_sidebar .main-collection-classic__layout{
      display:grid;
      grid-template-columns: minmax(240px, 320px) minmax(0, 1fr);
      gap: 16px;
      align-items:start;
    }
    .main-collection-classic--layout-two_column_sidebar .main-collection-classic__sidebar{
      position: sticky;
      top: 16px;
      align-self:start;
    }
  }

  .main-collection-classic__filters{
    background: var(--mcc-surface, #f7f7f7);
    border: 1px solid var(--mcc-border, rgba(0,0,0,0.10));
    border-radius: var(--mcc-bar-radius, 12px);
    padding: 12px;
  }

  .main-collection-classic__filter{
    border: 0;
    border-radius: 12px;
    padding: 12px;
    margin: 0 0 10px 0;
    background: rgba(255,255,255,0.55);
  }
  .main-collection-classic__filter-title{
    font-weight: 700;
    color: var(--mcc-heading, #111) !important;
    padding: 0 0 6px 0;
  }

  .main-collection-classic__filter-options{
    display:grid;
    gap: 8px;
    margin-top: 8px;
  }

  .main-collection-classic__filter-option{
    display:flex;
    align-items:center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px solid var(--mcc-input-border, rgba(0,0,0,0.14));
    background: var(--mcc-input-bg, #fff);
    color: var(--mcc-input-text, #111);
    cursor: pointer;
    min-width: 0;
  }
  .main-collection-classic__filter-option input{ flex:0 0 auto; }
  .main-collection-classic__filter-option-text{ display:flex; gap: 8px; align-items: baseline; min-width:0; }
  .main-collection-classic__filter-count{ color: var(--mcc-muted, rgba(0,0,0,.62)) !important; font-size: .9em; }

  .main-collection-classic__price-range{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 8px;
  }
  .main-collection-classic__price-field label{
    display:block;
    font-size: .85rem;
    color: var(--mcc-muted, rgba(0,0,0,.72)) !important;
    margin-bottom: 6px;
  }
  .main-collection-classic__price-field input{
    width: 100%;
    background: var(--mcc-input-bg, #fff);
    color: var(--mcc-input-text, #111);
    border: 1px solid var(--mcc-input-border, rgba(0,0,0,0.14));
    border-radius: var(--mcc-input-radius, 10px);
    padding: 9px 10px;
  }

  .main-collection-classic__filters-actions{
    display:flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items:center;
    justify-content: space-between;
    margin-top: 12px;
  }
  .main-collection-classic__filters-apply{
    appearance:none;
    border: 1px solid var(--mcc-apply-border, rgba(0,0,0,0.15));
    background: var(--mcc-apply-bg, #111);
    color: var(--mcc-apply-text, #fff);
    border-radius: 12px;
    padding: 10px 12px;
    cursor: pointer;
  }
  .main-collection-classic__filters-apply:hover{
    background: var(--mcc-apply-bg-hover, #000);
    color: var(--mcc-apply-text-hover, #fff);
  }
  .main-collection-classic__filters-clear{
    color: var(--mcc-muted, rgba(0,0,0,.72)) !important;
    text-decoration: underline;
    padding: 6px 2px;
  }

  .main-collection-classic__drawer{ position: relative; }
  .main-collection-classic__drawer-panel{
    margin-top: 10px;
    max-width: 100%;
    width: min(520px, 92vw);
    background: var(--mcc-surface, #f7f7f7);
    border: 1px solid var(--mcc-border, rgba(0,0,0,0.10));
    border-radius: var(--mcc-bar-radius, 12px);
    padding: 12px;
    overflow: auto;
  }
  @media (min-width: 990px){
    .main-collection-classic__drawer--desktop .main-collection-classic__drawer-panel{ width: 100%; max-width: 100%; }
    .main-collection-classic--layout-two_column_sidebar .main-collection-classic__drawer--mobile{ display:none; }
  }

  .main-collection-classic__active-filters-inner{
    display:flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items:center;
    margin: 6px 0 14px;
  }
  .main-collection-classic__active-label{
    color: var(--mcc-muted, rgba(0,0,0,.72)) !important;
    font-size: .95rem;
  }
  .main-collection-classic__active-chips{
    display:flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items:center;
  }
  .main-collection-classic__chip{
    display:inline-flex;
    align-items:center;
    gap: 6px;
    background: var(--mcc-chip-bg, #111);
    color: var(--mcc-chip-text, #fff);
    border: 1px solid var(--mcc-chip-border, rgba(0,0,0,0.12));
    border-radius: var(--mcc-chip-radius, 30px);
    padding: 7px 10px;
    text-decoration:none;
    font-size: .9rem;
    white-space: nowrap;
  }
  .main-collection-classic__active-clear{
    color: var(--mcc-muted, rgba(0,0,0,.72)) !important;
    text-decoration: underline;
    padding: 6px 2px;
  }

  .main-collection-classic__grid{
    display:grid;
    gap: var(--mcc-gap, 16px);
    grid-template-columns: repeat(var(--mcc-cols-mobile, 2), minmax(0, 1fr));
  }
  @media (min-width: 750px){
    .main-collection-classic__grid{
      grid-template-columns: repeat(var(--mcc-cols-tablet, 3), minmax(0, 1fr));
    }
  }
  @media (min-width: 990px){
    .main-collection-classic__grid{
      grid-template-columns: repeat(var(--mcc-cols-desktop, 4), minmax(0, 1fr));
    }
  }

  .main-collection-classic__item{
    position: relative;
    min-width: 0;
    background: var(--mcc-frame-bg, transparent);
    border-width: var(--mcc-frame-bw, 1px);
    border-style: var(--mcc-frame-bs, solid);
    border-color: var(--mcc-frame-border, rgba(0,0,0,0.10));
    border-radius: var(--mcc-frame-radius, 14px);
    padding: var(--mcc-frame-pad, 0px);
    overflow: hidden;
    box-shadow: var(--mcc-frame-shadow, none);
  }

  .main-collection-classic__badge{
    position:absolute;
    top: 10px;
    left: 10px;
    z-index: 2;
    display:inline-flex;
    align-items:center;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 12px;
    line-height: 1;
    border: 1px solid rgba(0,0,0,0.12);
    backdrop-filter: blur(4px);
  }
  .main-collection-classic__badge--sale{ background: var(--mcc-badge-sale-bg, #111); color: var(--mcc-badge-sale-text, #fff); }
  .main-collection-classic__badge--soldout{ background: var(--mcc-badge-soldout-bg, #f1f1f1); color: var(--mcc-badge-soldout-text, #111); }
  .main-collection-classic__badge--custom{ background: var(--mcc-badge-custom-bg, #111); color: var(--mcc-badge-custom-text, #fff); }

  .main-collection-classic .q-product-card__title,
  .main-collection-classic .q-product-card__title a,
  .main-collection-classic .card__heading,
  .main-collection-classic .card__heading a{
    color: var(--mcc-title-color, inherit) !important;
    font-size: var(--mcc-title-size, 16px) !important;
    font-weight: var(--mcc-title-weight, 700) !important;
    line-height: 1.25;
  }
  .main-collection-classic .q-product-card__price,
  .main-collection-classic .price,
  .main-collection-classic .price__container{
    color: var(--mcc-price-color, inherit) !important;
    font-size: var(--mcc-price-size, 14px) !important;
    font-weight: var(--mcc-price-weight, 600) !important;
  }
  .main-collection-classic .price__sale .price-item--regular,
  .main-collection-classic .price-item--regular{
    color: var(--mcc-compare-color, rgba(0,0,0,.55)) !important;
  }

  .main-collection-classic .q-product-card__action,
  .main-collection-classic .q-product-card__rowbtn,
  .main-collection-classic .q-product-card__below-qv{
    border-radius: var(--pr-btn-radius, 12px) !important;
    font-size: var(--pr-btn-font-size, 14px) !important;
    padding: var(--pr-btn-pad-y, 9px) var(--pr-btn-pad-x, 12px) !important;
  }

  .main-collection-classic__pagination{ margin-top: 18px; }
  .main-collection-classic__pager{
    display:flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items:center;
  }
  .main-collection-classic__page-link,
  .main-collection-classic__page-current{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border-radius: 12px;
    border: 1px solid var(--mcc-border, rgba(0,0,0,0.12));
    background: var(--mcc-input-bg, #fff);
    color: var(--mcc-input-text, #111);
    text-decoration:none;
  }
  .main-collection-classic__page-current{
    background: var(--mcc-chip-bg, #111);
    color: var(--mcc-chip-text, #fff);
    border-color: var(--mcc-chip-border, rgba(0,0,0,0.12));
  }
  .main-collection-classic__infinite-status{
    margin-top: 12px;
    color: var(--mcc-muted, rgba(0,0,0,.72)) !important;
    font-size: .95rem;
  }

  @media (max-width: 749px){
    .main-collection-classic__controls{ justify-content: flex-start; }
    .main-collection-classic__sort{ flex: 1 1 100%; }
    .main-collection-classic__sort-select{ width: 100%; }
    .main-collection-classic__drawer-panel{ width: 92vw; }
  }
</style>

{%- capture filters_markup -%}
  {%- if filters_enabled and has_filters -%}
    {%- for filter in collection.filters -%}
      {%- liquid
        assign filter_label_id = 'FilterLabel-' | append: section.id | append: '-' | append: forloop.index
        assign filter_key = filter.label | handleize
      -%}

      <fieldset class="main-collection-classic__filter" aria-labelledby="{{ filter_label_id }}">
        <legend id="{{ filter_label_id }}" class="main-collection-classic__filter-title">
          {{ filter.label | escape }}
        </legend>

        {%- case filter.type -%}
          {%- when 'list' -%}
            <div class="main-collection-classic__filter-options">
              {%- for value in filter.values -%}
                {%- liquid
                  assign input_id = 'Filter-' | append: section.id | append: '-' | append: filter_key | append: '-' | append: forloop.index
                -%}
                <label class="main-collection-classic__filter-option" for="{{ input_id }}">
                  <input
                    id="{{ input_id }}"
                    type="checkbox"
                    name="{{ value.param_name }}"
                    value="{{ value.value | escape }}"
                    {% if value.active %}checked{% endif %}
                    {% if value.count == 0 and value.active == false %}disabled{% endif %}
                  >
                  <span class="main-collection-classic__filter-option-text">
                    {{ value.label | escape }}
                    {%- if s.show_count and value.count != blank -%}
                      <span class="main-collection-classic__filter-count" aria-hidden="true">({{ value.count }})</span>
                    {%- endif -%}
                  </span>
                </label>
              {%- endfor -%}
            </div>

          {%- when 'boolean' -%}
            {%- liquid
              assign bool_id = 'Filter-' | append: section.id | append: '-' | append: filter_key
            -%}
            <label class="main-collection-classic__filter-option" for="{{ bool_id }}">
              <input
                id="{{ bool_id }}"
                type="checkbox"
                name="{{ filter.param_name }}"
                value="1"
                {% if filter.active_values.size > 0 %}checked{% endif %}
              >
              <span class="main-collection-classic__filter-option-text">
                {{ s.boolean_filter_label | escape }}
              </span>
            </label>

          {%- when 'price_range' -%}
            <div class="main-collection-classic__price-range" role="group" aria-label="{{ filter.label | escape }}">
              <div class="main-collection-classic__price-field">
                <label for="PriceMin-{{ section.id }}">{{ s.price_min_label | escape }}</label>
                <input
                  id="PriceMin-{{ section.id }}"
                  name="{{ filter.min_value.param_name }}"
                  type="number"
                  inputmode="numeric"
                  placeholder="0"
                  {% if filter.min_value.value != blank %}value="{{ filter.min_value.value }}"{% endif %}
                >
              </div>
              <div class="main-collection-classic__price-field">
                <label for="PriceMax-{{ section.id }}">{{ s.price_max_label | escape }}</label>
                <input
                  id="PriceMax-{{ section.id }}"
                  name="{{ filter.max_value.param_name }}"
                  type="number"
                  inputmode="numeric"
                  placeholder=""
                  {% if filter.max_value.value != blank %}value="{{ filter.max_value.value }}"{% endif %}
                >
              </div>
            </div>

          {%- else -%}
            <p role="note">{{ s.unsupported_filter_label | escape }}</p>
        {%- endcase -%}
      </fieldset>
    {%- endfor -%}

    <div class="main-collection-classic__filters-actions">
      <button type="submit" class="main-collection-classic__filters-apply" aria-label="Apply filters">
        {{ s.apply_filters_label | escape }}
      </button>
      {%- if s.show_clear_all -%}
        <a class="main-collection-classic__filters-clear" href="{{ clear_all_url }}" aria-label="Clear all filters">
          {{ s.clear_all_label | escape }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endcapture -%}

{%- capture active_filters_markup -%}
  {%- if s.show_active_filters and filters_enabled and has_filters -%}
    {%- liquid
      assign has_active = false
      for filter in collection.filters
        if filter.active_values != blank and filter.active_values.size > 0
          assign has_active = true
          break
        endif
        if filter.type == 'price_range'
          if filter.min_value.value != blank or filter.max_value.value != blank
            assign has_active = true
            break
          endif
        endif
      endfor
    -%}

    {%- if has_active -%}
      <div class="main-collection-classic__active-filters-inner">
        {%- if s.active_filters_label != blank -%}
          <span class="main-collection-classic__active-label">{{ s.active_filters_label | escape }}</span>
        {%- endif -%}

        <div class="main-collection-classic__active-chips" role="list" aria-label="Active filters">
          {%- for filter in collection.filters -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                <a class="main-collection-classic__chip" href="{{ filter.url_to_remove }}" role="listitem" aria-label="Remove price filter">
                  {{ filter.label | escape }}:
                  {%- if filter.min_value.value != blank -%}{{ filter.min_value.value }}{%- else -%}0{%- endif -%}
                  –
                  {%- if filter.max_value.value != blank -%}{{ filter.max_value.value }}{%- else -%}∞{%- endif -%}
                </a>
              {%- endif -%}
            {%- else -%}
              {%- for av in filter.active_values -%}
                <a class="main-collection-classic__chip" href="{{ av.url_to_remove }}" role="listitem" aria-label="Remove {{ av.label | escape }}">
                  {{ filter.label | escape }}: {{ av.label | escape }}
                </a>
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if s.show_clear_all -%}
          <a class="main-collection-classic__active-clear" href="{{ clear_all_url }}" aria-label="Clear all filters">
            {{ s.clear_all_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endif -%}
{%- endcapture -%}

{%- paginate collection.products by per_page -%}
  <section
    class="main-collection-classic main-collection-classic--layout-{{ layout }}"
    id="main-collection-classic"
    data-section-id="{{ section.id }}"
    data-pagination="{{ pagination_type }}"
    style="{{ mcc_style }}"
  >
    <div class="main-collection-classic__inner main-collection-classic__inner--{{ content_width }}">
      {%- if show_header -%}
        <header class="main-collection-classic__header">
          {%- if show_title -%}
            <h1 class="main-collection-classic__title main-collection-classic__title--{{ title_size }}">
              {{ collection.title | escape }}
            </h1>
          {%- endif -%}

          {%- if show_description and description_position == 'above_grid' and collection.description != blank -%}
            <div class="main-collection-classic__description rte">
              {%- if description_collapse -%}
                <details class="main-collection-classic__desc-details">
                  <summary class="main-collection-classic__desc-summary" aria-label="Toggle collection description">
                    {{ s.description_toggle_label | escape }}
                  </summary>
                  <div class="main-collection-classic__desc-content">
                    {{ collection.description }}
                  </div>
                </details>
              {%- else -%}
                {{ collection.description }}
              {%- endif -%}
            </div>
          {%- endif -%}
        </header>
      {%- endif -%}

      <form class="main-collection-classic__form" method="get" action="{{ collection.url }}">
        {%- if layout == 'top_controls' -%}
          <div class="main-collection-classic__controls main-collection-classic__controls--top" role="region" aria-label="Collection controls">
            {%- if filters_enabled and has_filters and s.show_filters_button -%}
              <details class="main-collection-classic__drawer">
                <summary class="main-collection-classic__drawer-toggle" aria-label="Open filters">
                  {{ s.filters_button_label | escape }}
                </summary>
                <div class="main-collection-classic__drawer-panel">
                  <div class="main-collection-classic__filters" aria-label="Collection filters">
                    {{ filters_markup }}
                  </div>
                </div>
              </details>
            {%- endif -%}

            {%- if sorting_enabled and s.show_sort -%}
              <div class="main-collection-classic__sort" role="group" aria-label="Sort products">
                {%- if s.show_sort_label -%}
                  <label class="main-collection-classic__sort-label" for="MainCollectionClassicSortTop">{{ s.sort_label | escape }}</label>
                {%- endif -%}
                <select
                  id="MainCollectionClassicSortTop"
                  name="sort_by"
                  class="main-collection-classic__sort-select"
                  aria-label="Sort by"
                  onchange="this.form.submit()"
                >
                  {%- for option in collection.sort_options -%}
                    <option value="{{ option.value | escape }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                      {{ option.name | escape }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endif -%}
          </div>

          {{ active_filters_markup }}
        {%- endif -%}

        <div class="main-collection-classic__layout">
          {%- liquid
            assign show_desktop_sidebar = false
            if filters_enabled and has_filters
              if layout == 'two_column_sidebar'
                assign show_desktop_sidebar = true
              elsif layout == 'top_controls' and s.filters_desktop_mode == 'sidebar'
                assign show_desktop_sidebar = true
              endif
            endif
          -%}

          {%- if show_desktop_sidebar -%}
            <aside class="main-collection-classic__sidebar" aria-label="Filters">
              <div class="main-collection-classic__filters">
                {{ filters_markup }}
              </div>
            </aside>
          {%- endif -%}

          <div class="main-collection-classic__main" aria-label="Collection results">
            {%- if layout == 'grid' or layout == 'two_column_sidebar' -%}
              <div class="main-collection-classic__controls" role="region" aria-label="Collection controls">
                {%- if filters_enabled and has_filters and s.show_filters_button -%}
                  <details class="main-collection-classic__drawer main-collection-classic__drawer--mobile">
                    <summary class="main-collection-classic__drawer-toggle" aria-label="Open filters">
                      {{ s.filters_button_label | escape }}
                    </summary>
                    <div class="main-collection-classic__drawer-panel">
                      <div class="main-collection-classic__filters" aria-label="Collection filters">
                        {{ filters_markup }}
                      </div>
                    </div>
                  </details>
                {%- endif -%}

                {%- if sorting_enabled and s.show_sort -%}
                  <div class="main-collection-classic__sort" role="group" aria-label="Sort products">
                    {%- if s.show_sort_label -%}
                      <label class="main-collection-classic__sort-label" for="MainCollectionClassicSort">{{ s.sort_label | escape }}</label>
                    {%- endif -%}
                    <select
                      id="MainCollectionClassicSort"
                      name="sort_by"
                      class="main-collection-classic__sort-select"
                      aria-label="Sort by"
                      onchange="this.form.submit()"
                    >
                      {%- for option in collection.sort_options -%}
                        <option value="{{ option.value | escape }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                          {{ option.name | escape }}
                        </option>
                      {%- endfor -%}
                    </select>
                  </div>
                {%- endif -%}
              </div>

              {{ active_filters_markup }}
            {%- endif -%}

            {%- if collection.products_count == 0 -%}
              <p class="main-collection-classic__empty" role="status">{{ s.empty_label | escape }}</p>
            {%- else -%}
              <div class="main-collection-classic__grid" role="list" aria-label="Product grid">
                {%- comment -%}
                  CRITICAL FIX: iterate collection.products inside paginate, not paginate.items
                {%- endcomment -%}
                {%- for product in collection.products -%}
                  {%- liquid
                    assign show_badge = false
                    assign badge_text = ''
                    assign badge_kind = ''

                    if s.badges_enabled
                      assign custom_badge = blank

                      if s.badge_source == 'tag' and s.badge_tag != blank
                        if product.tags contains s.badge_tag
                          assign custom_badge = s.badge_tag_text
                        endif
                      elsif s.badge_source == 'metafield'
                        assign mf_ns = s.badge_metafield_namespace | default: 'custom'
                        assign mf_key = s.badge_metafield_key | default: 'badge'
                        assign mf_drop = product.metafields[mf_ns][mf_key]
                        if mf_drop != blank
                          assign custom_badge = mf_drop.value
                        endif
                      endif

                      if custom_badge != blank
                        assign show_badge = true
                        assign badge_text = custom_badge
                        assign badge_kind = 'custom'
                      elsif s.badge_show_sold_out and product.available == false
                        assign show_badge = true
                        assign badge_text = s.badge_sold_out_text
                        assign badge_kind = 'soldout'
                      elsif s.badge_show_sale and product.compare_at_price_max > product.price
                        assign show_badge = true
                        assign badge_text = s.badge_sale_text
                        assign badge_kind = 'sale'
                      endif
                    endif
                  -%}

                  <div class="main-collection-classic__item" role="listitem">
                    {%- if show_badge -%}
                      <span class="main-collection-classic__badge main-collection-classic__badge--{{ badge_kind }}">
                        {{ badge_text | escape }}
                      </span>
                    {%- endif -%}

                    {% render 'product-card',
                      product: product,
                      enable_quick_add: pc_enable_quick_add,
                      enable_quick_view: pc_enable_quick_view,
                      quick_add_mode: pc_quick_add_mode,
                      quick_view_mode: pc_quick_view_mode,
                      show_action_row: pc_show_action_row,
                      show_secondary_row_cta: pc_show_secondary_row_cta,
                      show_row_quick_view: pc_show_row_quick_view,
                      quick_view_placement: pc_quick_view_placement,
                      primary_cta_label: pc_primary_cta_label,
                      secondary_cta_label: pc_secondary_cta_label,
                      label_select_options: pc_label_select_options,
                      label_sold_out: pc_label_sold_out,
                      qv_label: pc_qv_label,
                      button_style: pc_button_style,
                      button_size: pc_button_size,
                      button_full_width: pc_button_full_width,
                      button_hover_strength: pc_button_hover_strength
                    %}
                  </div>
                {%- endfor -%}
              </div>

              {%- if paginate.pages > 1 -%}
                <nav class="main-collection-classic__pagination" role="navigation" aria-label="Pagination">
                  {%- if pagination_type == 'infinite_scroll' -%}
                    {%- if paginate.next -%}
                      <a
                        class="main-collection-classic__page-link"
                        data-infinite-next
                        href="{{ paginate.next.url }}"
                        rel="next"
                        aria-label="Load more products"
                      >
                        {{ s.load_more_label | escape }}
                      </a>
                      <div class="main-collection-classic__infinite-status" data-infinite-status aria-live="polite"></div>
                    {%- endif -%}

                  {%- elsif pagination_type == 'prev_next' -%}
                    <div class="main-collection-classic__pager">
                      {%- if paginate.previous -%}
                        <a class="main-collection-classic__page-link" href="{{ paginate.previous.url }}" rel="prev" aria-label="Previous page">
                          {{ s.prev_label | escape }}
                        </a>
                      {%- endif -%}
                      {%- if paginate.next -%}
                        <a class="main-collection-classic__page-link" href="{{ paginate.next.url }}" rel="next" aria-label="Next page">
                          {{ s.next_label | escape }}
                        </a>
                      {%- endif -%}
                    </div>

                  {%- else -%}
                    <div class="main-collection-classic__pager" role="list" aria-label="Page list">
                      {%- if paginate.previous -%}
                        <a class="main-collection-classic__page-link" href="{{ paginate.previous.url }}" rel="prev" aria-label="Previous page">
                          {{ s.prev_label | escape }}
                        </a>
                      {%- endif -%}

                      {%- for part in paginate.parts -%}
                        {%- if part.is_link -%}
                          <a class="main-collection-classic__page-link" href="{{ part.url }}" role="listitem" aria-label="Page {{ part.title | escape }}">
                            {{ part.title }}
                          </a>
                        {%- else -%}
                          {%- if part.title == '…' -%}
                            <span aria-hidden="true">…</span>
                          {%- else -%}
                            <span class="main-collection-classic__page-current" role="listitem" aria-current="page">
                              {{ part.title }}
                            </span>
                          {%- endif -%}
                        {%- endif -%}
                      {%- endfor -%}

                      {%- if paginate.next -%}
                        <a class="main-collection-classic__page-link" href="{{ paginate.next.url }}" rel="next" aria-label="Next page">
                          {{ s.next_label | escape }}
                        </a>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </nav>
              {%- endif -%}
            {%- endif -%}

            {%- if show_description and description_position == 'below_grid' and collection.description != blank -%}
              <div class="main-collection-classic__description rte">
                {%- if description_collapse -%}
                  <details class="main-collection-classic__desc-details">
                    <summary class="main-collection-classic__desc-summary" aria-label="Toggle collection description">
                      {{ s.description_toggle_label | escape }}
                    </summary>
                    <div class="main-collection-classic__desc-content">
                      {{ collection.description }}
                    </div>
                  </details>
                {%- else -%}
                  {{ collection.description }}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      </form>
    </div>

    {%- if pagination_type == 'infinite_scroll' -%}
      <script>
        (function(){
          var root = document.getElementById('main-collection-classic');
          if(!root) return;
          if(root.dataset.pagination !== 'infinite_scroll') return;

          var nextLink = root.querySelector('[data-infinite-next]');
          var statusEl = root.querySelector('[data-infinite-status]');
          var grid = root.querySelector('.main-collection-classic__grid');
          if(!nextLink || !grid) return;

          var loading = false;

          function setStatus(msg){
            if(statusEl) statusEl.textContent = msg || '';
          }

          async function loadNext(){
            if(loading) return;
            if(!nextLink || !nextLink.href) return;

            loading = true;
            setStatus('Loading…');

            try{
              var res = await fetch(nextLink.href, { credentials: 'same-origin' });
              if(!res.ok) throw new Error('Request failed');

              var html = await res.text();
              var doc = new DOMParser().parseFromString(html, 'text/html');
              var newGrid = doc.querySelector('#main-collection-classic .main-collection-classic__grid');
              var newNext = doc.querySelector('#main-collection-classic [data-infinite-next]');

              if(newGrid){
                var items = newGrid.children;
                for(var i=0;i<items.length;i++){
                  grid.appendChild(items[i].cloneNode(true));
                }
              }

              if(newNext && newNext.href){
                nextLink.href = newNext.href;
                setStatus('');
              } else {
                nextLink.remove();
                nextLink = null;
                setStatus('No more products.');
                if(observer) observer.disconnect();
              }
            } catch(e){
              setStatus('Could not load more. Please use pagination.');
            } finally {
              loading = false;
            }
          }

          var observer = null;
          if('IntersectionObserver' in window){
            observer = new IntersectionObserver(function(entries){
              entries.forEach(function(entry){
                if(entry.isIntersecting){
                  loadNext();
                }
              });
            }, { rootMargin: '600px 0px' });

            observer.observe(nextLink);
          }

          nextLink.addEventListener('click', function(e){
            e.preventDefault();
            loadNext();
          });
        })();
      </script>
    {%- endif -%}
  </section>
{%- endpaginate -%}

{% schema %}
{
  "name": "Main collection classic",
  "tag": "section",
  "class": "section main-collection-classic-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "two_column_sidebar", "label": "Two column (sidebar)" },
        { "value": "top_controls", "label": "Top controls" }
      ]
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "page",
      "options": [
        { "value": "page", "label": "Page" },
        { "value": "full", "label": "Full width" }
      ]
    },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 0, "max": 96, "step": 1, "default": 32 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 0, "max": 96, "step": 1, "default": 32 },

    { "type": "header", "content": "Header content" },
    { "type": "checkbox", "id": "show_title", "label": "Show title", "default": true },
    {
      "type": "select",
      "id": "title_size",
      "label": "Title size",
      "default": "md",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": false },
    {
      "type": "select",
      "id": "description_position",
      "label": "Description position",
      "default": "above_grid",
      "options": [
        { "value": "above_grid", "label": "Above grid" },
        { "value": "below_grid", "label": "Below grid" }
      ]
    },
    { "type": "checkbox", "id": "description_collapse", "label": "Collapse description (Read more)", "default": false },
    { "type": "text", "id": "description_toggle_label", "label": "Description toggle label", "default": "Read more" },

    { "type": "header", "content": "Filters" },
    { "type": "checkbox", "id": "filters_enabled", "label": "Enable filters", "default": true },
    {
      "type": "select",
      "id": "filters_desktop_mode",
      "label": "Desktop filters mode",
      "default": "sidebar",
      "options": [
        { "value": "sidebar", "label": "Sidebar" },
        { "value": "drawer", "label": "Drawer" }
      ]
    },
    { "type": "checkbox", "id": "show_filters_button", "label": "Show filters button", "default": true },
    { "type": "checkbox", "id": "show_active_filters", "label": "Show active filter chips", "default": true },
    { "type": "checkbox", "id": "show_count", "label": "Show option counts", "default": true },
    { "type": "checkbox", "id": "show_clear_all", "label": "Show clear all", "default": true },

    { "type": "text", "id": "filters_button_label", "label": "Filters button label", "default": "Filters" },
    { "type": "text", "id": "apply_filters_label", "label": "Apply filters label", "default": "Apply" },
    { "type": "text", "id": "clear_all_label", "label": "Clear all label", "default": "Clear all" },
    { "type": "text", "id": "active_filters_label", "label": "Active filters label", "default": "Active:" },

    { "type": "text", "id": "price_min_label", "label": "Price min label", "default": "Min" },
    { "type": "text", "id": "price_max_label", "label": "Price max label", "default": "Max" },
    { "type": "text", "id": "boolean_filter_label", "label": "Boolean option label", "default": "Enabled" },
    { "type": "text", "id": "unsupported_filter_label", "label": "Unsupported filter label", "default": "This filter type isn't supported in Classic yet." },

    { "type": "header", "content": "Sorting" },
    { "type": "checkbox", "id": "sorting_enabled", "label": "Enable sorting", "default": true },
    { "type": "checkbox", "id": "show_sort", "label": "Show sort dropdown", "default": true },
    { "type": "checkbox", "id": "show_sort_label", "label": "Show sort label", "default": true },
    { "type": "text", "id": "sort_label", "label": "Sort label", "default": "Sort" },

