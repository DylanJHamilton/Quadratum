{%- comment -%}
  Collection Modern — Facets
  File: snippets/collection-modern-facets.liquid
  Liquid-first filter form. JS may enhance drawer UI only.
{%- endcomment -%}

{%- if filters == blank or filters.size == 0 -%}{%- break -%}{%- endif -%}

{%- assign is_drawer = false -%}
{%- if placement == 'drawer' -%}{%- assign is_drawer = true -%}{%- endif -%}

{%- if is_drawer -%}
  <div class="qcm__drawer" data-qcm-drawer aria-hidden="true">
    <div class="qcm__drawerBackdrop" data-qcm-drawer-backdrop></div>
    <div class="qcm__drawerPanel" role="dialog" aria-modal="true" aria-label="Filters">
      <div class="qcm__drawerHead">
        <strong>Filters</strong>
        <button class="qcm__btn qcm__btn--ghost" type="button" data-qcm-close-drawer>Close</button>
      </div>

      <div class="qcm__facets">
        {%- render 'collection-modern-facets',
          section: section,
          s: s,
          is_search_context: is_search_context,
          results_url: results_url,
          terms_q: terms_q,
          filters: filters,
          placement: 'sidebar'
        -%}
      </div>
    </div>
  </div>

{%- else -%}
  <div class="qcm__facets" data-qcm-facets>
    <form method="get" action="{{ results_url }}">
      {%- if is_search_context and terms_q != blank -%}
        <input type="hidden" name="q" value="{{ terms_q | escape }}">
      {%- endif -%}

      {%- for f in filters -%}
        <details class="qcm__facet" {% if f.active_values != blank and f.active_values.size > 0 %}open{% endif %}>
          <summary>{{ f.label }}</summary>
          <div class="qcm__facetBody">
            {%- if f.type == 'price_range' -%}
              <div class="qcm__facetRow">
                <label class="qcm__facetLabel">
                  <span>Min</span>
                  <input
                    type="number"
                    name="{{ f.min_value.param_name }}"
                    value="{{ f.min_value.value | default: '' }}"
                    min="0"
                    inputmode="numeric"
                  >
                </label>
              </div>
              <div class="qcm__facetRow">
                <label class="qcm__facetLabel">
                  <span>Max</span>
                  <input
                    type="number"
                    name="{{ f.max_value.param_name }}"
                    value="{{ f.max_value.value | default: '' }}"
                    min="0"
                    inputmode="numeric"
                  >
                </label>
              </div>

              <div class="qcm__facetRow">
                <button class="qcm__btn qcm__btn--ghost" type="submit">Apply</button>
                {%- if f.min_value.value != blank or f.max_value.value != blank -%}
                  <a class="qcm__btn qcm__btn--ghost" href="{{ f.url_to_remove }}">Clear</a>
                {%- endif -%}
              </div>

            {%- else -%}
              {%- for v in f.values -%}
                <div class="qcm__facetRow">
                  <label class="qcm__facetLabel">
                    <input
                      type="checkbox"
                      name="{{ v.param_name }}"
                      value="{{ v.value }}"
                      {% if v.active %}checked{% endif %}
                      {% if v.count == 0 and v.active == false %}disabled{% endif %}
                    >
                    <span>{{ v.label }}</span>
                  </label>
                  <span class="qcm__facetCount">{{ v.count }}</span>
                </div>
              {%- endfor -%}

              <div class="qcm__facetRow">
                <button class="qcm__btn qcm__btn--ghost" type="submit">Apply</button>
                {%- if f.active_values != blank and f.active_values.size > 0 -%}
                  <a class="qcm__btn qcm__btn--ghost" href="{{ f.url_to_remove }}">Clear</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </details>
      {%- endfor -%}
    </form>
  </div>
{%- endif -%}