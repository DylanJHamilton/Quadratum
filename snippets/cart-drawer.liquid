{%- liquid
  assign drawer_title = 'Cart'
  assign compact = true
  assign context = 'drawer'
-%}
{{ 'cart-shared.css' | asset_url | stylesheet_tag }}
<div
  id="QtmCartDrawer"
  class="qtm-cart-drawer"
  data-cart-drawer
  hidden
>
  <div class="qtm-cart-drawer__overlay" data-cart-drawer-close></div>

  <div
    class="qtm-cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="QtmCartDrawerTitle"
    tabindex="-1"
    data-cart-drawer-panel
  >
    <div class="qtm-cart-drawer__inner" data-cart-drawer-content>
      <header class="qtm-cart-drawer__header">
        <div class="qtm-cart-drawer__header-main">
          <h2 id="QtmCartDrawerTitle" class="qtm-cart-drawer__title">{{ drawer_title }}</h2>
          <div class="qtm-cart-drawer__count">
            <span data-cart-count>{{ cart.item_count }}</span>
            <span>{% if cart.item_count == 1 %}item{% else %}items{% endif %}</span>
          </div>
        </div>

        <button
          type="button"
          class="qtm-cart-drawer__close"
          aria-label="Close cart"
          data-cart-drawer-close
        >
          ×
        </button>
      </header>

      {%- if cart.item_count > 0 -%}
        <div class="qtm-cart-drawer__body">
          <div class="qtm-cart-drawer__items">
            {%- render 'cart-progress-bar',
              cart: cart,
              context: context,
              compact: compact
            -%}

            <div class="qtm-cart-drawer__items-list">
              {%- for item in cart.items -%}
                {%- render 'cart-line-item',
                  item: item,
                  line_index: forloop.index,
                  context: context,
                  compact: compact,
                  section_id: 'drawer'
                -%}
              {%- endfor -%}
            </div>

            {%- render 'cart-progress-rewards',
              cart: cart,
              context: context,
              compact: compact
            -%}

            {%- render 'cart-addons',
              context: context,
              compact: compact
            -%}
          </div>

          <div class="qtm-cart-drawer__footer">
            {%- render 'cart-summary',
              cart: cart,
              context: context,
              compact: compact,
              continue_shopping_url: routes.all_products_collection_url
            -%}
          </div>
        </div>
      {%- else -%}
        <div class="qtm-cart-drawer__empty">
          <div class="qtm-cart-drawer__empty-title">Your cart is empty</div>
          <div class="qtm-cart-drawer__empty-text">
            Add something to your cart to see it here.
          </div>
          <a href="{{ routes.all_products_collection_url }}" class="qtm-cart-drawer__empty-link">
            Continue shopping
          </a>

          {%- render 'cart-addons',
            context: context,
            compact: compact
          -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>