{%- comment -%}
  Quadratum — Collection List (MVP)
  File: sections/collection-list.liquid

  Notes:
  - Scoped CSS root: #QtmCollectionList-{{ section.id }}
  - JS only when layout == 'carousel'
  - Uses ONE snippet: snippets/collection-list-card.liquid
{%- endcomment -%}

{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}
{%- if section.settings.layout == 'carousel' -%}
  <script src="{{ 'section-collection-list.js' | asset_url }}" defer></script>
{%- endif -%}

{%- liquid
  assign s = section.settings

  assign has_items = false

  if s.source_mode == 'manual'
    for block in section.blocks
      if block.type == 'collection' and block.settings.collection != blank
        assign has_items = true
        break
      endif
    endfor
  else
    for pair in collections
      assign c0 = pair[1]
      if c0 != blank
        assign has_items = true
        break
      endif
    endfor
  endif
-%}

{%- capture qcl_vars -%}
  --qcl-gap: {{ s.gap | append: 'px' }};
  --qcl-radius: {{ s.card_radius | append: 'px' }};
  --qcl-card-bg: {{ s.card_bg }};
  --qcl-card-border: {{ s.card_border_color }};
  --qcl-title-color: {{ s.title_color }};
  --qcl-text-color: {{ s.text_color }};
  --qcl-btn-bg: {{ s.button_bg }};
  --qcl-btn-text: {{ s.button_text }};
  --qcl-btn-border: {{ s.button_border }};
  --qcl-btn-bg-hover: {{ s.button_bg_hover }};
  --qcl-btn-text-hover: {{ s.button_text_hover }};
  --qcl-cols-d: {{ s.columns_desktop }};
  --qcl-cols-t: {{ s.columns_tablet }};
  --qcl-cols-m: {{ s.columns_mobile }};
  --qcl-pad-y: {{ s.padding_y | append: 'px' }};
{%- endcapture -%}

<section
  id="QtmCollectionList-{{ section.id }}"
  class="q-collection-list qcl"
  style="{{ qcl_vars | strip }}"
  data-qcl
  data-layout="{{ s.layout }}"
  data-max-width="{{ s.max_width }}"
  data-peek="{% if s.peek %}true{% else %}false{% endif %}"
>
  {%- if has_items == false -%}
    <div class="qcl__empty">No collections to show.</div>
  {%- else -%}
    <div class="qcl__inner">
      {%- if s.title != blank or s.subheading != blank -%}
        <header class="qcl__header">
          {%- if s.title != blank -%}
            <h2 class="qcl__title">{{ s.title }}</h2>
          {%- endif -%}
          {%- if s.subheading != blank -%}
            <div class="qcl__subheading rte">{{ s.subheading }}</div>
          {%- endif -%}
        </header>
      {%- endif -%}

      {%- if s.layout == 'carousel' -%}
        <div class="qcl__carouselWrap">
          {%- if s.show_arrows -%}
            <button type="button" class="qcl__arrow qcl__arrow--prev" aria-label="Previous collections" data-qcl-prev>
              <span aria-hidden="true">‹</span>
            </button>
            <button type="button" class="qcl__arrow qcl__arrow--next" aria-label="Next collections" data-qcl-next>
              <span aria-hidden="true">›</span>
            </button>
          {%- endif -%}

          <div class="qcl__carousel" data-qcl-carousel tabindex="0">
            <div class="qcl__track">
              {%- liquid assign shown = 0 -%}

              {%- if s.source_mode == 'manual' -%}
                {%- for block in section.blocks -%}
                  {%- if block.type != 'collection' or block.settings.collection == blank -%}{%- continue -%}{%- endif -%}
                  {%- assign c = block.settings.collection -%}
                  {%- assign shown = shown | plus: 1 -%}

                  {%- render 'collection-list-card',
                    s: s,
                    c: c,
                    img_override: block.settings.image_override,
                    title_override: block.settings.title_override,
                    shopify_attributes: block.shopify_attributes
                  -%}
                {%- endfor -%}
              {%- else -%}
                {%- for pair in collections -%}
                  {%- assign c = pair[1] -%}
                  {%- if c == blank -%}{%- continue -%}{%- endif -%}
                  {%- assign shown = shown | plus: 1 -%}
                  {%- if shown > s.max_items -%}{%- break -%}{%- endif -%}

                  {%- render 'collection-list-card',
                    s: s,
                    c: c,
                    img_override: blank,
                    title_override: blank,
                    shopify_attributes: ''
                  -%}
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        </div>

      {%- else -%}
        <div class="qcl__grid">
          {%- liquid assign shown = 0 -%}

          {%- if s.source_mode == 'manual' -%}
            {%- for block in section.blocks -%}
              {%- if block.type != 'collection' or block.settings.collection == blank -%}{%- continue -%}{%- endif -%}
              {%- assign c = block.settings.collection -%}

              {%- render 'collection-list-card',
                s: s,
                c: c,
                img_override: block.settings.image_override,
                title_override: block.settings.title_override,
                shopify_attributes: block.shopify_attributes
              -%}
            {%- endfor -%}
          {%- else -%}
            {%- for pair in collections -%}
              {%- assign c = pair[1] -%}
              {%- if c == blank -%}{%- continue -%}{%- endif -%}
              {%- assign shown = shown | plus: 1 -%}
              {%- if shown > s.max_items -%}{%- break -%}{%- endif -%}

              {%- render 'collection-list-card',
                s: s,
                c: c,
                img_override: blank,
                title_override: blank,
                shopify_attributes: ''
              -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>
  {% schema %}
  {
    "name": "Collection list",
    "tag": "section",
    "class": "q-section q-section--collection-list",
    "settings": [
      { "type": "header", "content": "Content" },
      { "type": "text", "id": "title", "label": "Title", "default": "Shop collections" },
      { "type": "richtext", "id": "subheading", "label": "Subheading" },

      {
        "type": "select",
        "id": "source_mode",
        "label": "Source mode",
        "default": "manual",
        "options": [
          { "value": "manual", "label": "Manual (blocks)" },
          { "value": "all", "label": "All collections" }
        ]
      },
      { "type": "range", "id": "max_items", "label": "Max items (auto)", "min": 2, "max": 24, "step": 1, "default": 8 },

      {
        "type": "select",
        "id": "layout",
        "label": "Layout",
        "default": "grid",
        "options": [
          { "value": "grid", "label": "Grid" },
          { "value": "carousel", "label": "Carousel" }
        ]
      },

      { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
      { "type": "range", "id": "columns_tablet", "label": "Columns (tablet)", "min": 1, "max": 4, "step": 1, "default": 2 },
      { "type": "range", "id": "columns_mobile", "label": "Columns (mobile)", "min": 1, "max": 3, "step": 1, "default": 1 },

      {
        "type": "select",
        "id": "image_ratio",
        "label": "Image ratio",
        "default": "landscape",
        "options": [
          { "value": "adapt", "label": "Adapt" },
          { "value": "square", "label": "Square" },
          { "value": "landscape", "label": "Landscape" },
          { "value": "portrait", "label": "Portrait" }
        ]
      },

      { "type": "checkbox", "id": "show_image", "label": "Show image", "default": true },
      { "type": "checkbox", "id": "show_title", "label": "Show title", "default": true },
      { "type": "checkbox", "id": "show_count", "label": "Show product count", "default": false },
      { "type": "checkbox", "id": "show_description", "label": "Show description", "default": false },
      { "type": "range", "id": "description_truncate", "label": "Description truncate", "min": 40, "max": 220, "step": 10, "default": 120 },

      { "type": "checkbox", "id": "show_button", "label": "Show button", "default": true },
      { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop collection" },

      { "type": "header", "content": "Style" },
      {
        "type": "select",
        "id": "max_width",
        "label": "Max width",
        "default": "contained",
        "options": [
          { "value": "contained", "label": "Contained" },
          { "value": "full", "label": "Full width" }
        ]
      },

      { "type": "range", "id": "card_radius", "label": "Card radius", "min": 0, "max": 28, "step": 1, "default": 16 },
      { "type": "color", "id": "card_border_color", "label": "Card border color", "default": "#00000026" },
      { "type": "color", "id": "card_bg", "label": "Card background", "default": "#FFFFFF" },
      { "type": "color", "id": "title_color", "label": "Title color", "default": "#000000" },
      { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },

      { "type": "color", "id": "button_bg", "label": "Button background", "default": "#111111" },
      { "type": "color", "id": "button_text", "label": "Button text", "default": "#FFFFFF" },
      { "type": "color", "id": "button_border", "label": "Button border", "default": "#00000026" },
      { "type": "color", "id": "button_bg_hover", "label": "Button background (hover)", "default": "#000000" },
      { "type": "color", "id": "button_text_hover", "label": "Button text (hover)", "default": "#FFFFFF" },

      { "type": "header", "content": "Spacing" },
      { "type": "range", "id": "gap", "label": "Gap", "min": 0, "max": 32, "step": 1, "default": 16 },
      { "type": "range", "id": "padding_y", "label": "Padding Y", "min": 0, "max": 80, "step": 2, "default": 40 },

      { "type": "header", "content": "Carousel" },
      { "type": "checkbox", "id": "show_arrows", "label": "Show arrows", "default": true },
      { "type": "checkbox", "id": "peek", "label": "Peek next card on mobile", "default": true }
    ],
    "blocks": [
      {
        "type": "collection",
        "name": "Collection",
        "settings": [
          { "type": "collection", "id": "collection", "label": "Collection" },
          { "type": "image_picker", "id": "image_override", "label": "Image override" },
          { "type": "text", "id": "title_override", "label": "Title override" }
        ]
      }
    ],
    "presets": [
      {
        "name": "Collection list",
        "category": "Collections",
        "blocks": [
          { "type": "collection" },
          { "type": "collection" },
          { "type": "collection" },
          { "type": "collection" }
        ]
      }
    ]
  }
  {% endschema %}
