{%- comment -%}
  Quadratum — Collection Modern Product Card
  File: snippets/collection-modern-product-card.liquid
{%- endcomment -%}

{%- liquid
  assign p = product
  if p == blank
    break
  endif

  assign show_vendor     = s.show_vendor
  assign show_price      = s.show_price
  assign show_badges     = s.show_badges
  assign show_rating     = s.show_rating
  assign show_quick_add  = s.show_quick_add
  assign show_second     = s.show_second_image
  assign show_buy_now    = s.show_buy_now

  assign add_label       = s.add_to_cart_label | default: 'Add to cart'
  assign opts_label      = s.choose_options_label | default: 'Choose options'
  assign buy_label       = s.buy_now_label | default: 'Buy now'
  assign image_ratio     = s.image_ratio | default: 'adapt'

  assign media_mode = s.media_mode | default: 'hover'

  assign has_one_variant = false
  if p.variants.size == 1
    assign has_one_variant = true
  endif

  assign v = p.selected_or_first_available_variant

  assign sold_out = false
  if p.available == false
    assign sold_out = true
  endif

  assign on_sale = false
  if v != blank
    if v.compare_at_price > v.price
      if p.available
        assign on_sale = true
      endif
    endif
  endif

  assign featured = p.featured_media
  if featured == blank
    assign featured = p.featured_image
  endif

  assign second_image = blank
  if show_second
    if p.media != blank and p.media.size > 1
      assign m2 = p.media[1]
      if m2.media_type == 'image'
        assign second_image = m2
      endif
    endif
  endif

  assign ratio_style = ''
  if image_ratio == 'square'
    assign ratio_style = 'aspect-ratio: 1 / 1;'
  elsif image_ratio == 'portrait'
    assign ratio_style = 'aspect-ratio: 4 / 5;'
  elsif image_ratio == 'landscape'
    assign ratio_style = 'aspect-ratio: 5 / 4;'
  endif

  assign disable_other_ctas = false
  if show_buy_now and has_one_variant and p.available
    assign disable_other_ctas = true
  endif
-%}

<article
  class="qcmc"
  data-qcmc
  data-media-mode="{{ media_mode }}"
  data-product-handle="{{ p.handle }}"
  data-product-url="{{ p.url }}"
  data-product-title="{{ p.title | escape }}"
  data-product-id="{{ p.id }}"
  {%- if v != blank -%}data-variant-id="{{ v.id }}"{%- endif -%}
>
  <div class="qcmc__media" style="{{ ratio_style }}">
    {%- if show_badges -%}
      {%- if on_sale or sold_out -%}
        <div class="qcmc__badges" aria-hidden="true">
          {%- if on_sale -%}
            <span class="qcmc__badge qcmc__badge--sale">Sale</span>
          {%- endif -%}
          {%- if sold_out -%}
            <span class="qcmc__badge qcmc__badge--soldout">Sold out</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if media_mode == 'slider' -%}
      <div class="qcmc__slider" data-qcmc-slider data-qcmc-index="0">
        <a class="qcmc__mediaLink" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
          <div class="qcmc__track" data-qcmc-track>
            {%- assign slide_limit = s.slider_image_limit | default: 5 -%}
            {%- assign slide_count = 0 -%}
            {%- if p.media != blank -%}
              {%- for m in p.media -%}
                {%- if m.media_type == 'image' -%}
                  {%- assign slide_count = slide_count | plus: 1 -%}
                  <img
                    class="qcmc__img qcmc__img--slide"
                    src="{{ m | image_url: width: 900 }}"
                    alt="{{ m.alt | default: p.title | escape }}"
                    loading="lazy"
                  >
                  {%- if slide_count >= slide_limit -%}{%- break -%}{%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}

            {%- if slide_count == 0 -%}
              {%- if featured != blank -%}
                <img class="qcmc__img qcmc__img--slide" src="{{ featured | image_url: width: 900 }}" alt="{{ featured.alt | default: p.title | escape }}" loading="lazy">
              {%- else -%}
                <div class="qcmc__img qcmc__img--placeholder" aria-hidden="true"></div>
              {%- endif -%}
            {%- endif -%}
          </div>
        </a>

        <button class="qcmc__arrow qcmc__arrow--prev" type="button" data-qcmc-prev aria-label="Previous image">‹</button>
        <button class="qcmc__arrow qcmc__arrow--next" type="button" data-qcmc-next aria-label="Next image">›</button>
      </div>
    {%- else -%}
      <a class="qcmc__mediaLink" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
        {%- if featured != blank -%}
          <img class="qcmc__img qcmc__img--primary" src="{{ featured | image_url: width: 900 }}" alt="{{ featured.alt | default: p.title | escape }}" loading="lazy">
        {%- else -%}
          <div class="qcmc__img qcmc__img--placeholder" aria-hidden="true"></div>
        {%- endif -%}

        {%- if second_image != blank -%}
          <img class="qcmc__img qcmc__img--second" src="{{ second_image | image_url: width: 900 }}" alt="{{ second_image.alt | default: p.title | escape }}" loading="lazy">
        {%- endif -%}
      </a>
    {%- endif -%}
  </div>

  <div class="qcmc__body">
    {%- if show_vendor and p.vendor != blank -%}
      <div class="qcmc__vendor">{{ p.vendor }}</div>
    {%- endif -%}

    <h3 class="qcmc__title">
      <a href="{{ p.url }}">{{ p.title }}</a>
    </h3>

    {%- if show_price and v != blank -%}
      <div class="qcmc__price">
        <span class="qcmc__priceNow">{{ v.price | money }}</span>
        {%- if v.compare_at_price > v.price -%}
          <span class="qcmc__priceWas"><s>{{ v.compare_at_price | money }}</s></span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="qcmc__actions">
      {%- if disable_other_ctas -%}
        <button
          type="button"
          class="qcmc__btn"
          data-qcm-buy-now
          data-variant-id="{{ v.id }}"
        >
          {{ buy_label }}
        </button>
      {%- else -%}
        {%- if show_quick_add -%}
          {%- if has_one_variant and v != blank -%}
            {%- form 'product', p, class: 'qcmc__form' -%}
              <input type="hidden" name="id" value="{{ v.id }}">
              <button class="qcmc__btn" type="submit" name="add">{{ add_label }}</button>
            {%- endform -%}
          {%- else -%}
            <a class="qcmc__btn qcmc__btn--ghost" href="{{ p.url }}">{{ opts_label }}</a>
          {%- endif -%}
        {%- endif -%}

        {%- if s.enable_quick_view -%}
          <button type="button" class="qcmc__btn qcmc__btn--ghost" data-qcm-quick-view>
            {{ s.quick_view_label | default: 'Quick view' }}
          </button>
        {%- endif -%}

        {%- if s.enable_compare -%}
          <button
            class="qcmc__btn qcmc__btn--ghost"
            type="button"
            data-qcm-compare-toggle
            data-label-select="{{ s.compare_label | default: 'Select' | escape }}"
            data-label-selected="{{ s.compare_selected_label | default: 'Selected' | escape }}"
            aria-label="{{ s.compare_label | default: 'Select' }}: {{ p.title | escape }}"
          >
            {{ s.compare_label | default: 'Select' }}
          </button>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</article>