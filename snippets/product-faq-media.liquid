{%- comment -%}
  product-faq-media.liquid (section helper)
  Inputs:
  - media_type: 'image' | 'video' | 'external_video' | 'model'
  - image: ImageDrop
  - video: VideoDrop
  - external_url: string/url
  - model: MediaDrop OR (fallback) product reference (optional)
  - poster: ImageDrop (optional)
  - alt: string
  - sizes: string
  - widths: string
  - aspect_ratio: 'adapt' | '1/1' | '4/3' | '16/9' | '3/4'
  - fit: 'cover' | 'contain'
  - radius: number (px)
  - enable_zoom: boolean (image only)
{%- endcomment -%}

{%- liquid
  assign t = media_type | default: 'none'
  assign ratio = aspect_ratio | default: 'adapt'
  assign obj_fit = fit | default: 'cover'
  assign r = radius | default: 12

  assign alt_text = alt | default: ''
  assign use_ratio = true
  if ratio == 'adapt'
    assign use_ratio = false
  endif
-%}

<div
  class="q-pfaqMedia"
  style="--q-pfaq-radius: {{ r }}px; --q-pfaq-fit: {{ obj_fit }};"
  data-pfaq-media
  data-type="{{ t }}"
>
  {%- if t == 'image' and image != blank -%}
    <div class="q-pfaqMedia__frame {% if use_ratio %}q-pfaqMedia__frame--ratio{% endif %}" {% if use_ratio %}style="--q-pfaq-ratio: {{ ratio }};"{% endif %}>
      {{ image | image_url: width: 1440 | image_tag:
        loading: 'lazy',
        decoding: 'async',
        sizes: sizes,
        widths: widths,
        alt: alt_text,
        class: 'q-pfaqMedia__img'
      }}
      {%- if enable_zoom -%}
        <button class="q-pfaqMedia__zoom" type="button" aria-label="Zoom image" data-pfaq-zoom>
          <span aria-hidden="true">+</span>
        </button>
      {%- endif -%}
    </div>

  {%- elsif t == 'video' and video != blank -%}
    <div class="q-pfaqMedia__frame {% if use_ratio %}q-pfaqMedia__frame--ratio{% endif %}" {% if use_ratio %}style="--q-pfaq-ratio: {{ ratio }};"{% endif %}>
      {{ video | video_tag:
        controls: true,
        muted: false,
        autoplay: false,
        loop: false,
        preload: 'metadata',
        class: 'q-pfaqMedia__video',
        poster: poster
      }}
    </div>

  {%- elsif t == 'external_video' and external_url != blank -%}
    <div class="q-pfaqMedia__frame {% if use_ratio %}q-pfaqMedia__frame--ratio{% endif %}" {% if use_ratio %}style="--q-pfaq-ratio: {{ ratio }};"{% endif %}>
      <iframe
        class="q-pfaqMedia__iframe"
        src="{{ external_url | escape }}"
        title="{{ alt_text | escape }}"
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>

  {%- elsif t == 'model' and model != blank -%}
    <div class="q-pfaqMedia__frame {% if use_ratio %}q-pfaqMedia__frame--ratio{% endif %}" {% if use_ratio %}style="--q-pfaq-ratio: {{ ratio }};"{% endif %}>
      {%- comment -%}
        Prefer a MediaDrop model if provided (file_reference).
        If a product reference was provided, merchant should attach a 3D model to that product and your
        theme’s global model-viewer assets should handle it. If not available, this safely degrades.
      {%- endcomment -%}
      {%- if model.media_type == 'model' -%}
        {{ model | media_tag: class: 'q-pfaqMedia__model', image_size: '900x' }}
      {%- else -%}
        <div class="q-pfaqMedia__modelFallback" role="img" aria-label="{{ alt_text | escape }}"></div>
      {%- endif -%}
    </div>

  {%- else -%}
    <div class="q-pfaqMedia__empty" aria-hidden="true"></div>
  {%- endif -%}
</div>