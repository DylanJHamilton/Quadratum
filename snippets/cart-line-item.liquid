<article
  class="qtm-cart-line-item"
  data-cart-item
  data-key="{{ item.key }}"
  data-line="{{ line_index }}"
>
  <div class="qtm-cart-line-item__media">
    <a
      href="{{ item.url }}"
      class="qtm-cart-line-item__image-link"
      aria-label="{{ item.product.title | escape }}"
    >
      {%- if item.image -%}
        {{
          item.image
          | image_url: width: 320
          | image_tag:
            loading: 'lazy',
            widths: '120,160,240,320',
            class: 'qtm-cart-line-item__image',
            alt: item.image.alt | escape
        }}
      {%- else -%}
        <div class="qtm-cart-line-item__image-placeholder"></div>
      {%- endif -%}
    </a>
  </div>

  <div class="qtm-cart-line-item__content">
    <div class="qtm-cart-line-item__top">
      <div class="qtm-cart-line-item__details">
        <h2 class="qtm-cart-line-item__title">
          <a href="{{ item.url }}">{{ item.product.title }}</a>
        </h2>

        {%- unless item.product.has_only_default_variant -%}
          <div class="qtm-cart-line-item__variant">
            {{ item.variant.title }}
          </div>
        {%- endunless -%}

        {%- assign has_properties = false -%}
        {%- for property in item.properties -%}
          {%- assign property_key_first_char = property.first | slice: 0 -%}
          {%- if property.last != blank and property_key_first_char != '_' -%}
            {%- assign has_properties = true -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_properties -%}
          <dl class="qtm-cart-line-item__properties">
            {%- for property in item.properties -%}
              {%- assign property_key_first_char = property.first | slice: 0 -%}
              {%- if property.last != blank and property_key_first_char != '_' -%}
                <div class="qtm-cart-line-item__property">
                  <dt>{{ property.first }}:</dt>
                  <dd>
                    {%- if property.last contains '/uploads/' -%}
                      <a href="{{ property.last }}">{{ property.last | split: '/' | last }}</a>
                    {%- else -%}
                      {{ property.last }}
                    {%- endif -%}
                  </dd>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </dl>
        {%- endif -%}

        {%- if item.line_level_discount_allocations.size > 0 -%}
          <ul class="qtm-cart-line-item__discounts" role="list">
            {%- for discount_allocation in item.line_level_discount_allocations -%}
              <li class="qtm-cart-line-item__discount">
                {{ discount_allocation.discount_application.title }}
                <span>-{{ discount_allocation.amount | money }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="qtm-cart-line-item__pricing">
        <div class="qtm-cart-line-item__price-block">
          <span class="qtm-cart-line-item__price-label">Each</span>
          <div class="qtm-cart-line-item__price-values">
            {%- if item.original_price > item.final_price -%}
              <span class="qtm-cart-line-item__compare-price">
                {{ item.original_price | money }}
              </span>
            {%- endif -%}
            <span class="qtm-cart-line-item__unit-price">
              {{ item.final_price | money }}
            </span>
          </div>
        </div>

        <div class="qtm-cart-line-item__price-block">
          <span class="qtm-cart-line-item__price-label">Total</span>
          <div class="qtm-cart-line-item__price-values">
            {%- if item.original_line_price > item.final_line_price -%}
              <span class="qtm-cart-line-item__compare-price">
                {{ item.original_line_price | money }}
              </span>
            {%- endif -%}
            <span class="qtm-cart-line-item__line-price" data-line-price>
              {{ item.final_line_price | money }}
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="qtm-cart-line-item__bottom">
      <div class="qtm-cart-line-item__qty-wrap">
        <label class="visually-hidden" for="CartQty-{{ section_id }}-{{ item.key }}">
          Quantity for {{ item.product.title | escape }}
        </label>

        <div class="qtm-cart-line-item__qty" data-cart-qty>
          <button
            type="button"
            class="qtm-cart-line-item__qty-btn"
            data-qty-decrease
            aria-label="Decrease quantity for {{ item.product.title | escape }}"
          >
            −
          </button>

          <input
            id="CartQty-{{ section_id }}-{{ item.key }}"
            class="qtm-cart-line-item__qty-input"
            type="number"
            name="updates[]"
            min="0"
            step="1"
            inputmode="numeric"
            value="{{ item.quantity }}"
            data-line="{{ line_index }}"
            data-key="{{ item.key }}"
          >

          <button
            type="button"
            class="qtm-cart-line-item__qty-btn"
            data-qty-increase
            aria-label="Increase quantity for {{ item.product.title | escape }}"
          >
            +
          </button>
        </div>
      </div>

      <form action="{{ routes.cart_change_url }}" method="post" class="qtm-cart-line-item__remove-form">
        <input type="hidden" name="id" value="{{ item.key }}">
        <input type="hidden" name="quantity" value="0">
        <button
          type="submit"
          class="qtm-cart-line-item__remove"
          data-cart-remove
          data-key="{{ item.key }}"
          aria-label="Remove {{ item.product.title | escape }} from cart"
        >
          Remove
        </button>
      </form>
    </div>
  </div>
</article>