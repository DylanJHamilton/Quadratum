{%- comment -%}
  SECTION: product-meta-panels.liquid
  Read-only structured product details (specs, ingredients, dimensions, warranty, supplier info).
  Independent, stackable PDP section. No cart/form interactions.
{%- endcomment -%}

{% stylesheet %}
  .q-pmp{
    padding-top:var(--q-pmp-pt);
    padding-bottom:var(--q-pmp-pb);
    background:var(--q-pmp-section-bg);
    color:var(--q-pmp-section-text);
  }
  .q-pmp__inner{
    max-width:var(--page-width,1200px);
    margin:0 auto;
    padding-left:var(--q-pad-x,1.25rem);
    padding-right:var(--q-pad-x,1.25rem);
  }
  .q-pmp__header{margin-bottom:1rem}
  .q-pmp__title{margin:0;font:inherit;font-size:1.25rem;line-height:1.2}
  .q-pmp__subheading{margin-top:.5rem}
  .q-pmp__subheading :where(p){margin:.25rem 0}

  /* Tabs (CSS-only, radio driven) */
  .q-pmp__tabs{
    border-width:var(--q-pmp-tabs-border-width);
    border-style:var(--q-pmp-tabs-border-style);
    border-color:var(--q-pmp-tabs-border);
    border-radius:.75rem;
    overflow:hidden;
    background:var(--q-pmp-inner-bg);
    color:var(--q-pmp-inner-text);
  }
  .q-pmp__radios{position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden}
  .q-pmp__tablist{
    display:flex;
    flex-wrap:wrap;
    gap:.25rem;
    padding:.5rem;
    border-bottom:1px solid var(--q-pmp-tabs-divider);
    background:var(--q-pmp-tabs-bar-bg);
  }
  .q-pmp__tabbtn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:.5rem .75rem;
    border-radius:.5rem;
    cursor:pointer;
    user-select:none;
    line-height:1.2;
    color:var(--q-pmp-tab-text);
    background:var(--q-pmp-tab-bg);
    border-width:var(--q-pmp-tab-border-width);
    border-style:var(--q-pmp-tab-border-style);
    border-color:var(--q-pmp-tab-border);
    transition:background .12s ease, color .12s ease, border-color .12s ease;
  }
  .q-pmp__tabbtn:focus-visible{outline:2px solid currentColor;outline-offset:2px}

  .q-pmp__panelwrap{
    padding:.75rem;
    background:var(--q-pmp-inner-bg);
    color:var(--q-pmp-inner-text);
  }
  .q-pmp__panel{display:none}
  .q-pmp__panel :where(p){margin:.5rem 0}
  .q-pmp__panel :where(ul,ol){margin:.5rem 0 .75rem 1.25rem}

  /* Cards */
  .q-pmp__cards{display:grid;gap:1rem}
  @media (min-width: 750px){
    .q-pmp__cards{grid-template-columns:repeat(2,minmax(0,1fr))}
  }
  .q-pmp__card{
    border-width:var(--q-pmp-tabs-border-width);
    border-style:var(--q-pmp-tabs-border-style);
    border-color:var(--q-pmp-tabs-border);
    border-radius:.75rem;
    padding:1rem;
    background:var(--q-pmp-inner-bg);
    color:var(--q-pmp-inner-text);
  }
  .q-pmp__card-title{margin:0 0 .5rem 0;font:inherit;font-size:1rem;line-height:1.2}
  .q-pmp__card-body :where(p){margin:.5rem 0}

  /* Table */
  .q-pmp__table-wrap{
    border-width:var(--q-pmp-tabs-border-width);
    border-style:var(--q-pmp-tabs-border-style);
    border-color:var(--q-pmp-tabs-border);
    border-radius:.75rem;
    overflow:hidden;
    background:var(--q-pmp-inner-bg);
    color:var(--q-pmp-inner-text);
  }
  .q-pmp__table{width:100%;border-collapse:collapse}
  .q-pmp__table th,.q-pmp__table td{
    padding:.75rem;
    vertical-align:top;
    border-top:1px solid var(--q-pmp-tabs-divider);
    text-align:left;
  }
  .q-pmp__table tr:first-child th,.q-pmp__table tr:first-child td{border-top:none}
  .q-pmp__table th{width:38%;font-weight:600}
  .q-pmp__table td :where(p){margin:.5rem 0}

  /* Metaobject DL */
  .q-pmp__dl{margin:0}
  .q-pmp__dl-row{
    display:grid;
    grid-template-columns:1fr;
    gap:.25rem;
    padding:.5rem 0;
    border-top:1px solid rgba(0,0,0,.10);
  }
  .q-pmp__dl-row:first-child{border-top:none;padding-top:0}
  @media (min-width: 750px){
    .q-pmp__dl-row{grid-template-columns:220px 1fr;gap:1rem}
  }
  .q-pmp__dl-term{margin:0;font-weight:600}
  .q-pmp__dl-def{margin:0}
{% endstylesheet %}

{%- liquid
  assign s = section.settings
  assign product_obj = product
  if product_obj == blank
    assign product_obj = s.fallback_product
  endif

  assign layout = s.layout
  if layout == blank
    assign layout = 'tabs'
  endif

  assign pt = s.padding_top
  assign pb = s.padding_bottom
  if pt == blank
    assign pt = 24
  endif
  if pb == blank
    assign pb = 24
  endif

  assign section_label = s.title | strip_html | strip
  if section_label == blank
    assign section_label = 'More details'
  endif

  assign has_any = false
  assign resolved_count = 0

  for block in section.blocks
    if block.type != 'meta_panel'
      continue
    endif

    assign b = block.settings
    assign resolved_html = ''

    case b.source_type
      when 'manual'
        assign resolved_html = b.content
      when 'metafield'
        assign ns = b.namespace | strip
        assign ky = b.key | strip
        if product_obj != blank and ns != blank and ky != blank
          assign mf = product_obj.metafields[ns][ky]
          if mf != blank
            capture resolved_html
              if mf.type contains 'rich_text'
                echo mf | metafield_tag
              elsif mf.type contains 'json'
                echo mf.value | json
              else
                if mf.value == blank
                  echo mf | metafield_tag
                else
                  echo mf.value | escape | newline_to_br
                endif
              endif
            endcapture
          endif
        endif
      when 'metaobject'
        assign mo = b.metaobject_reference
        if mo != blank
          capture resolved_html
            assign any_field = false
            for f in mo.fields
              assign fv = f.value
              if fv == blank
                continue
              endif
              assign any_field = true
              break
            endfor

            if any_field
              echo '<dl class="q-pmp__dl">'
              for f in mo.fields
                assign fv = f.value
                if fv == blank
                  continue
                endif

                echo '<div class="q-pmp__dl-row">'
                  echo '<dt class="q-pmp__dl-term">' | append: f.name | escape | append: '</dt>'
                  echo '<dd class="q-pmp__dl-def">'

                    capture fv_out
                      if f.type contains 'rich_text'
                        echo fv
                      elsif f.type contains 'json'
                        echo fv | json
                      else
                        echo fv | json
                      endif
                    endcapture

                    assign fv_out_stripped = fv_out | strip
                    assign fv_len = fv_out_stripped.size

                    if fv_len > 1
                      assign first_char = fv_out_stripped | slice: 0, 1
                      assign last_idx = fv_len | minus: 1
                      assign last_char = fv_out_stripped | slice: last_idx, 1
                      if first_char == '"' and last_char == '"'
                        echo fv_out_stripped | remove_first: '"' | remove_last: '"'
                      else
                        echo fv_out
                      endif
                    else
                      echo fv_out
                    endif

                  echo '</dd>'
                echo '</div>'
              endfor
              echo '</dl>'
            endif
          endcapture
        endif
    endcase

    assign resolved_text = resolved_html | strip_html | strip
    if resolved_html != blank and resolved_text != blank
      assign has_any = true
      assign resolved_count = resolved_count | plus: 1
    endif
  endfor

  capture css_vars
    echo '--q-pmp-pt:' | append: pt | append: 'px;'
    echo '--q-pmp-pb:' | append: pb | append: 'px;'

    echo '--q-pmp-section-bg:' | append: s.section_bg | append: ';'
    echo '--q-pmp-section-text:' | append: s.section_text | append: ';'

    echo '--q-pmp-tabs-bar-bg:' | append: s.tabs_bar_bg | append: ';'
    echo '--q-pmp-tabs-divider:' | append: s.tabs_divider | append: ';'

    echo '--q-pmp-tabs-border:' | append: s.tabs_border_color | append: ';'
    echo '--q-pmp-tabs-border-style:' | append: s.tabs_border_style | append: ';'
    echo '--q-pmp-tabs-border-width:' | append: s.tabs_border_width | append: 'px;'

    echo '--q-pmp-tab-text:' | append: s.tab_text | append: ';'
    echo '--q-pmp-tab-bg:' | append: s.tab_bg | append: ';'
    echo '--q-pmp-tab-border:' | append: s.tab_border_color | append: ';'
    echo '--q-pmp-tab-border-style:' | append: s.tab_border_style | append: ';'
    echo '--q-pmp-tab-border-width:' | append: s.tab_border_width | append: 'px;'

    echo '--q-pmp-tab-text-active:' | append: s.tab_text_active | append: ';'
    echo '--q-pmp-tab-bg-active:' | append: s.tab_bg_active | append: ';'
    echo '--q-pmp-tab-border-active:' | append: s.tab_border_color_active | append: ';'

    echo '--q-pmp-inner-bg:' | append: s.inner_bg | append: ';'
    echo '--q-pmp-inner-text:' | append: s.inner_text | append: ';'
  endcapture
-%}

{%- if has_any -%}
<section
  id="product-meta-panels"
  class="q-pmp"
  style="{{ css_vars | strip }}"
  aria-label="{{ section_label | escape }}"
>
  <div class="q-pmp__inner">
    {%- if s.title != blank or s.subheading != blank -%}
      <header class="q-pmp__header">
        {%- if s.title != blank -%}
          <h2 class="q-pmp__title">{{ s.title | escape }}</h2>
        {%- endif -%}
        {%- if s.subheading != blank -%}
          <div class="q-pmp__subheading rte">{{ s.subheading }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- case layout -%}
      {%- when 'tabs' -%}
        <div class="q-pmp__tabs" aria-label="{{ section_label | escape }}" style="position:relative;">
          {%- comment -%}
            CRITICAL FIX:
            Radios MUST be direct children of .q-pmp__tabs (siblings of .q-pmp__panelwrap),
            otherwise "#radio:checked ~ .q-pmp__panelwrap" will NEVER match.
          {%- endcomment -%}

          {%- assign resolved_i = 0 -%}
          {%- capture tabs_radios -%}{%- endcapture -%}
          {%- capture tabs_buttons -%}{%- endcapture -%}
          {%- capture tabs_panels -%}{%- endcapture -%}

          {%- for block in section.blocks -%}
            {%- if block.type != 'meta_panel' -%}{%- continue -%}{%- endif -%}

            {%- liquid
              assign b = block.settings
              assign resolved_html = ''

              case b.source_type
                when 'manual'
                  assign resolved_html = b.content
                when 'metafield'
                  assign ns = b.namespace | strip
                  assign ky = b.key | strip
                  if product_obj != blank and ns != blank and ky != blank
                    assign mf = product_obj.metafields[ns][ky]
                    if mf != blank
                      capture resolved_html
                        if mf.type contains 'rich_text'
                          echo mf | metafield_tag
                        elsif mf.type contains 'json'
                          echo mf.value | json
                        else
                          if mf.value == blank
                            echo mf | metafield_tag
                          else
                            echo mf.value | escape | newline_to_br
                          endif
                        endif
                      endcapture
                    endif
                  endif
                when 'metaobject'
                  assign mo = b.metaobject_reference
                  if mo != blank
                    capture resolved_html
                      assign any_field = false
                      for f in mo.fields
                        assign fv = f.value
                        if fv == blank
                          continue
                        endif
                        assign any_field = true
                        break
                      endfor

                      if any_field
                        echo '<dl class="q-pmp__dl">'
                        for f in mo.fields
                          assign fv = f.value
                          if fv == blank
                            continue
                          endif

                          echo '<div class="q-pmp__dl-row">'
                            echo '<dt class="q-pmp__dl-term">' | append: f.name | escape | append: '</dt>'
                            echo '<dd class="q-pmp__dl-def">'

                              capture fv_out
                                if f.type contains 'rich_text'
                                  echo fv
                                elsif f.type contains 'json'
                                  echo fv | json
                                else
                                  echo fv | json
                                endif
                              endcapture

                              assign fv_out_stripped = fv_out | strip
                              assign fv_len = fv_out_stripped.size

                              if fv_len > 1
                                assign first_char = fv_out_stripped | slice: 0, 1
                                assign last_idx = fv_len | minus: 1
                                assign last_char = fv_out_stripped | slice: last_idx, 1
                                if first_char == '"' and last_char == '"'
                                  echo fv_out_stripped | remove_first: '"' | remove_last: '"'
                                else
                                  echo fv_out
                                endif
                              else
                                echo fv_out
                              endif

                            echo '</dd>'
                          echo '</div>'
                        endfor
                        echo '</dl>'
                      endif
                    endcapture
                  endif
              endcase

              assign resolved_text = resolved_html | strip_html | strip
            -%}

            {%- if resolved_html == blank or resolved_text == blank -%}
              {%- continue -%}
            {%- endif -%}

            {%- assign resolved_i = resolved_i | plus: 1 -%}
            {%- assign rid = 'q-pmp-' | append: section.id | append: '-' | append: resolved_i -%}
            {%- assign pid = 'q-pmp-panel-' | append: section.id | append: '-' | append: resolved_i -%}
            {%- assign tab_title = b.title | strip | strip_html -%}
            {%- if tab_title == blank -%}{%- assign tab_title = 'Details' -%}{%- endif -%}

            {%- capture tabs_radios -%}{{ tabs_radios }}
              <input class="q-pmp__radios" type="radio" name="q-pmp-tabs-{{ section.id }}" id="{{ rid }}" {% if resolved_i == 1 %}checked{% endif %}>
            {%- endcapture -%}

            {%- capture tabs_buttons -%}{{ tabs_buttons }}
              <label class="q-pmp__tabbtn" for="{{ rid }}">{{ tab_title | escape }}</label>
            {%- endcapture -%}

            {%- capture tabs_panels -%}{{ tabs_panels }}
              <div id="{{ pid }}" class="q-pmp__panel rte" aria-label="{{ tab_title | escape }}">
                {{ resolved_html }}
              </div>
            {%- endcapture -%}
          {%- endfor -%}

          {{ tabs_radios }}

          <div class="q-pmp__tablist" aria-label="Product detail tabs">
            {{ tabs_buttons }}
          </div>

          <div class="q-pmp__panelwrap">
            {{ tabs_panels }}
          </div>

          <style>
            {%- comment -%}Active tab colors + panel visibility mapping (scoped to this section instance){%- endcomment -%}
            {%- for i in (1..resolved_i) -%}
              {%- assign rid = 'q-pmp-' | append: section.id | append: '-' | append: i -%}
              #{{ rid }}:checked ~ .q-pmp__tablist label[for="{{ rid }}"]{
                color:var(--q-pmp-tab-text-active);
                background:var(--q-pmp-tab-bg-active);
                border-color:var(--q-pmp-tab-border-active);
              }
              #{{ rid }}:checked ~ .q-pmp__panelwrap #q-pmp-panel-{{ section.id }}-{{ i }}{display:block;}
            {%- endfor -%}
          </style>
        </div>

      {%- when 'cards' -%}
        <div class="q-pmp__cards" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type != 'meta_panel' -%}{%- continue -%}{%- endif -%}

            {%- liquid
              assign b = block.settings
              assign resolved_html = ''

              case b.source_type
                when 'manual'
                  assign resolved_html = b.content
                when 'metafield'
                  assign ns = b.namespace | strip
                  assign ky = b.key | strip
                  if product_obj != blank and ns != blank and ky != blank
                    assign mf = product_obj.metafields[ns][ky]
                    if mf != blank
                      capture resolved_html
                        if mf.type contains 'rich_text'
                          echo mf | metafield_tag
                        elsif mf.type contains 'json'
                          echo mf.value | json
                        else
                          if mf.value == blank
                            echo mf | metafield_tag
                          else
                            echo mf.value | escape | newline_to_br
                          endif
                        endif
                      endcapture
                    endif
                  endif
                when 'metaobject'
                  assign mo = b.metaobject_reference
                  if mo != blank
                    capture resolved_html
                      assign any_field = false
                      for f in mo.fields
                        assign fv = f.value
                        if fv == blank
                          continue
                        endif
                        assign any_field = true
                        break
                      endfor

                      if any_field
                        echo '<dl class="q-pmp__dl">'
                        for f in mo.fields
                          assign fv = f.value
                          if fv == blank
                            continue
                          endif

                          echo '<div class="q-pmp__dl-row">'
                            echo '<dt class="q-pmp__dl-term">' | append: f.name | escape | append: '</dt>'
                            echo '<dd class="q-pmp__dl-def">'

                              capture fv_out
                                if f.type contains 'rich_text'
                                  echo fv
                                elsif f.type contains 'json'
                                  echo fv | json
                                else
                                  echo fv | json
                                endif
                              endcapture

                              assign fv_out_stripped = fv_out | strip
                              assign fv_len = fv_out_stripped.size

                              if fv_len > 1
                                assign first_char = fv_out_stripped | slice: 0, 1
                                assign last_idx = fv_len | minus: 1
                                assign last_char = fv_out_stripped | slice: last_idx, 1
                                if first_char == '"' and last_char == '"'
                                  echo fv_out_stripped | remove_first: '"' | remove_last: '"'
                                else
                                  echo fv_out
                                endif
                              else
                                echo fv_out
                              endif

                            echo '</dd>'
                          echo '</div>'
                        endfor
                        echo '</dl>'
                      endif
                    endcapture
                  endif
              endcase

              assign resolved_text = resolved_html | strip_html | strip
            -%}

            {%- if resolved_html == blank or resolved_text == blank -%}
              {%- continue -%}
            {%- endif -%}

            {%- assign card_title = b.title | strip | strip_html -%}
            {%- if card_title == blank -%}{%- assign card_title = 'Details' -%}{%- endif -%}

            <article class="q-pmp__card" role="listitem" {{ block.shopify_attributes }}>
              <h3 class="q-pmp__card-title">{{ card_title | escape }}</h3>
              <div class="q-pmp__card-body rte">
                {{ resolved_html }}
              </div>
            </article>
          {%- endfor -%}
        </div>

      {%- when 'table' -%}
        <div class="q-pmp__table-wrap">
          <table class="q-pmp__table">
            <tbody>
              {%- for block in section.blocks -%}
                {%- if block.type != 'meta_panel' -%}{%- continue -%}{%- endif -%}

                {%- liquid
                  assign b = block.settings
                  assign resolved_html = ''

                  case b.source_type
                    when 'manual'
                      assign resolved_html = b.content
                    when 'metafield'
                      assign ns = b.namespace | strip
                      assign ky = b.key | strip
                      if product_obj != blank and ns != blank and ky != blank
                        assign mf = product_obj.metafields[ns][ky]
                        if mf != blank
                          capture resolved_html
                            if mf.type contains 'rich_text'
                              echo mf | metafield_tag
                            elsif mf.type contains 'json'
                              echo mf.value | json
                            else
                              if mf.value == blank
                                echo mf | metafield_tag
                              else
                                echo mf.value | escape | newline_to_br
                              endif
                            endif
                          endcapture
                        endif
                      endif
                    when 'metaobject'
                      assign mo = b.metaobject_reference
                      if mo != blank
                        capture resolved_html
                          assign any_field = false
                          for f in mo.fields
                            assign fv = f.value
                            if fv == blank
                              continue
                            endif
                            assign any_field = true
                            break
                          endfor

                          if any_field
                            echo '<dl class="q-pmp__dl">'
                            for f in mo.fields
                              assign fv = f.value
                              if fv == blank
                                continue
                              endif

                              echo '<div class="q-pmp__dl-row">'
                                echo '<dt class="q-pmp__dl-term">' | append: f.name | escape | append: '</dt>'
                                echo '<dd class="q-pmp__dl-def">'

                                  capture fv_out
                                    if f.type contains 'rich_text'
                                      echo fv
                                    elsif f.type contains 'json'
                                      echo fv | json
                                    else
                                      echo fv | json
                                    endif
                                  endcapture

                                  assign fv_out_stripped = fv_out | strip
                                  assign fv_len = fv_out_stripped.size

                                  if fv_len > 1
                                    assign first_char = fv_out_stripped | slice: 0, 1
                                    assign last_idx = fv_len | minus: 1
                                    assign last_char = fv_out_stripped | slice: last_idx, 1
                                    if first_char == '"' and last_char == '"'
                                      echo fv_out_stripped | remove_first: '"' | remove_last: '"'
                                    else
                                      echo fv_out
                                    endif
                                  else
                                    echo fv_out
                                  endif

                                echo '</dd>'
                              echo '</div>'
                            endfor
                            echo '</dl>'
                          endif
                        endcapture
                      endif
                  endcase

                  assign resolved_text = resolved_html | strip_html | strip
                -%}

                {%- if resolved_html == blank or resolved_text == blank -%}
                  {%- continue -%}
                {%- endif -%}

                {%- assign row_title = b.title | strip | strip_html -%}
                {%- if row_title == blank -%}{%- assign row_title = 'Details' -%}{%- endif -%}

                <tr {{ block.shopify_attributes }}>
                  <th scope="row">{{ row_title | escape }}</th>
                  <td class="rte">{{ resolved_html }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
    {%- endcase -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Product meta panels",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title" },
    { "type": "richtext", "id": "subheading", "label": "Subheading" },

    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "tabs",
      "options": [
        { "value": "tabs", "label": "Tabs" },
        { "value": "cards", "label": "Cards" },
        { "value": "table", "label": "Table" }
      ]
    },

    { "type": "header", "content": "Section colors" },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "section_text", "label": "Section text", "default": "#111111" },

    { "type": "header", "content": "Tabs bar" },
    { "type": "color", "id": "tabs_bar_bg", "label": "Tabs bar background", "default": "#ffffff" },
    { "type": "color", "id": "tabs_divider", "label": "Tabs divider color", "default": "#e6e6e6" },

    { "type": "header", "content": "Tabs container border" },
    { "type": "color", "id": "tabs_border_color", "label": "Border color", "default": "#e6e6e6" },
    {
      "type": "select",
      "id": "tabs_border_style",
      "label": "Border style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
