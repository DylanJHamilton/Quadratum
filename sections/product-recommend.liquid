{% comment %}
  Quadratum — Product Recommended
  File: sections/product-recommended.liquid

  Card rule (non-negotiable):
  {% render 'product-card', product: product %}
{% endcomment %}

{%- liquid
  assign s = section.settings

  if product == blank
    break
  endif

  assign max_products = s.max_products | default: 4
  assign mode = s.mode | default: 'dynamic'
  assign layout = s.layout | default: 'grid'
  assign intent = s.intent | default: 'related'

  assign is_endpoint_render = false
  if recommendations != blank
    assign is_endpoint_render = true
  endif

  assign recos_url = routes.product_recommendations_url
  assign recos_url = recos_url | append: '?section_id=product-recommended'
  assign recos_url = recos_url | append: '&product_id=' | append: product.id
  assign recos_url = recos_url | append: '&limit=' | append: max_products
  assign recos_url = recos_url | append: '&intent=' | append: intent

  comment
    Per-section pass-through controls to product-card snippet.
  endcomment
  assign pr_enable_quick_add = s.enable_quick_add
  assign pr_enable_quick_view = s.enable_quick_view
  assign pr_quick_add_mode = s.quick_add_mode
  assign pr_quick_view_mode = s.quick_view_mode
  assign pr_show_action_row = s.show_action_row
  assign pr_show_secondary_row_cta = s.show_secondary_row_cta
  assign pr_show_row_quick_view = s.show_row_quick_view
  assign pr_quick_view_placement = s.quick_view_placement

  assign pr_primary_cta_label = s.primary_cta_label
  assign pr_secondary_cta_label = s.secondary_cta_label
  assign pr_label_select_options = s.label_select_options
  assign pr_label_sold_out = s.label_sold_out
  assign pr_qv_label = s.qv_label

  assign pr_button_style = s.button_style
  assign pr_button_size = s.button_size
  assign pr_button_full_width = s.button_full_width
  assign pr_button_hover_strength = s.button_hover_strength

  comment
    Scoped style variables for card button theming and sizing.
  endcomment
  assign pr_style = ''
  if s.btn_bg != blank
    assign pr_style = pr_style | append: '--q-btn-bg:' | append: s.btn_bg | append: ';'
  endif
  if s.btn_text != blank
    assign pr_style = pr_style | append: '--q-btn-text:' | append: s.btn_text | append: ';'
  endif
  if s.btn_border != blank
    assign pr_style = pr_style | append: '--q-btn-border:' | append: s.btn_border | append: ';'
  endif
  if s.btn_bg_hover != blank
    assign pr_style = pr_style | append: '--q-btn-bg-hover:' | append: s.btn_bg_hover | append: ';'
  endif
  if s.btn_text_hover != blank
    assign pr_style = pr_style | append: '--q-btn-text-hover:' | append: s.btn_text_hover | append: ';'
  endif
  if s.btn_radius != blank
    assign pr_style = pr_style | append: '--pr-btn-radius:' | append: s.btn_radius | append: 'px;'
  endif
  if s.btn_font_size != blank
    assign pr_style = pr_style | append: '--pr-btn-font-size:' | append: s.btn_font_size | append: 'px;'
  endif
  if s.btn_padding_y != blank
    assign pr_style = pr_style | append: '--pr-btn-pad-y:' | append: s.btn_padding_y | append: 'px;'
  endif
  if s.btn_padding_x != blank
    assign pr_style = pr_style | append: '--pr-btn-pad-x:' | append: s.btn_padding_x | append: 'px;'
  endif
-%}

{%- if mode == 'dynamic' -%}
  <script src="{{ 'section-product-recommended.js' | asset_url }}" defer></script>
{%- endif -%}

{%- capture items_markup -%}
  {%- liquid
    assign seen = ''
    assign rendered_count = 0
  -%}

  {%- if mode == 'dynamic' and is_endpoint_render -%}
    {%- if recommendations.products_count > 0 -%}
      {%- for rp in recommendations.products -%}
        {%- if rendered_count >= max_products -%}{%- break -%}{%- endif -%}
        {%- if rp == blank -%}{%- continue -%}{%- endif -%}
        {%- if rp.id == product.id -%}{%- continue -%}{%- endif -%}
        {%- assign token = '||' | append: rp.id | append: '||' -%}
        {%- if seen contains token -%}{%- continue -%}{%- endif -%}
        {%- assign seen = seen | append: token -%}
        <div class="product-recommended__item">
          {% render 'product-card',
            product: rp,
            enable_quick_add: pr_enable_quick_add,
            enable_quick_view: pr_enable_quick_view,
            quick_add_mode: pr_quick_add_mode,
            quick_view_mode: pr_quick_view_mode,
            show_action_row: pr_show_action_row,
            show_secondary_row_cta: pr_show_secondary_row_cta,
            show_row_quick_view: pr_show_row_quick_view,
            quick_view_placement: pr_quick_view_placement,
            primary_cta_label: pr_primary_cta_label,
            secondary_cta_label: pr_secondary_cta_label,
            label_select_options: pr_label_select_options,
            label_sold_out: pr_label_sold_out,
            qv_label: pr_qv_label,
            button_style: pr_button_style,
            button_size: pr_button_size,
            button_full_width: pr_button_full_width,
            button_hover_strength: pr_button_hover_strength
          %}
        </div>
        {%- assign rendered_count = rendered_count | plus: 1 -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if rendered_count == 0 and s.collection != blank and s.collection.products_count > 0 -%}
      {%- for cp in s.collection.products -%}
        {%- if rendered_count >= max_products -%}{%- break -%}{%- endif -%}
        {%- if cp == blank -%}{%- continue -%}{%- endif -%}
        {%- if cp.id == product.id -%}{%- continue -%}{%- endif -%}
        {%- assign token = '||' | append: cp.id | append: '||' -%}
        {%- if seen contains token -%}{%- continue -%}{%- endif -%}
        {%- assign seen = seen | append: token -%}
        <div class="product-recommended__item">
          {% render 'product-card',
            product: cp,
            enable_quick_add: pr_enable_quick_add,
            enable_quick_view: pr_enable_quick_view,
            quick_add_mode: pr_quick_add_mode,
            quick_view_mode: pr_quick_view_mode,
            show_action_row: pr_show_action_row,
            show_secondary_row_cta: pr_show_secondary_row_cta,
            show_row_quick_view: pr_show_row_quick_view,
            quick_view_placement: pr_quick_view_placement,
            primary_cta_label: pr_primary_cta_label,
            secondary_cta_label: pr_secondary_cta_label,
            label_select_options: pr_label_select_options,
            label_sold_out: pr_label_sold_out,
            qv_label: pr_qv_label,
            button_style: pr_button_style,
            button_size: pr_button_size,
            button_full_width: pr_button_full_width,
            button_hover_strength: pr_button_hover_strength
          %}
        </div>
        {%- assign rendered_count = rendered_count | plus: 1 -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if rendered_count == 0 -%}
      {%- for block in section.blocks -%}
        {%- if rendered_count >= max_products -%}{%- break -%}{%- endif -%}
        {%- if block.type != 'product_reference' -%}{%- continue -%}{%- endif -%}
        {%- assign mp = block.settings.product -%}
        {%- if mp == blank -%}{%- continue -%}{%- endif -%}
        {%- if mp.id == product.id -%}{%- continue -%}{%- endif -%}
        {%- assign token = '||' | append: mp.id | append: '||' -%}
        {%- if seen contains token -%}{%- continue -%}{%- endif -%}
        {%- assign seen = seen | append: token -%}
        <div class="product-recommended__item">
          {% render 'product-card',
            product: mp,
            enable_quick_add: pr_enable_quick_add,
            enable_quick_view: pr_enable_quick_view,
            quick_add_mode: pr_quick_add_mode,
            quick_view_mode: pr_quick_view_mode,
            show_action_row: pr_show_action_row,
            show_secondary_row_cta: pr_show_secondary_row_cta,
            show_row_quick_view: pr_show_row_quick_view,
            quick_view_placement: pr_quick_view_placement,
            primary_cta_label: pr_primary_cta_label,
            secondary_cta_label: pr_secondary_cta_label,
            label_select_options: pr_label_select_options,
            label_sold_out: pr_label_sold_out,
            qv_label: pr_qv_label,
            button_style: pr_button_style,
            button_size: pr_button_size,
            button_full_width: pr_button_full_width,
            button_hover_strength: pr_button_hover_strength
          %}
        </div>
        {%- assign rendered_count = rendered_count | plus: 1 -%}
      {%- endfor -%}
    {%- endif -%}

  {%- elsif mode == 'collection' -%}
    {%- if s.collection != blank and s.collection.products_count > 0 -%}
      {%- for cp in s.collection.products -%}
        {%- if rendered_count >= max_products -%}{%- break -%}{%- endif -%}
        {%- if cp == blank -%}{%- continue -%}{%- endif -%}
        {%- if cp.id == product.id -%}{%- continue -%}{%- endif -%}
        {%- assign token = '||' | append: cp.id | append: '||' -%}
        {%- if seen contains token -%}{%- continue -%}{%- endif -%}
        {%- assign seen = seen | append: token -%}
        <div class="product-recommended__item">
          {% render 'product-card',
            product: cp,
            enable_quick_add: pr_enable_quick_add,
            enable_quick_view: pr_enable_quick_view,
            quick_add_mode: pr_quick_add_mode,
            quick_view_mode: pr_quick_view_mode,
            show_action_row: pr_show_action_row,
            show_secondary_row_cta: pr_show_secondary_row_cta,
            show_row_quick_view: pr_show_row_quick_view,
            quick_view_placement: pr_quick_view_placement,
            primary_cta_label: pr_primary_cta_label,
            secondary_cta_label: pr_secondary_cta_label,
            label_select_options: pr_label_select_options,
            label_sold_out: pr_label_sold_out,
            qv_label: pr_qv_label,
            button_style: pr_button_style,
            button_size: pr_button_size,
            button_full_width: pr_button_full_width,
            button_hover_strength: pr_button_hover_strength
          %}
        </div>
        {%- assign rendered_count = rendered_count | plus: 1 -%}
      {%- endfor -%}
    {%- endif -%}

  {%- elsif mode == 'manual' -%}
    {%- for block in section.blocks -%}
      {%- if rendered_count >= max_products -%}{%- break -%}{%- endif -%}
      {%- if block.type != 'product_reference' -%}{%- continue -%}{%- endif -%}
      {%- assign mp = block.settings.product -%}
      {%- if mp == blank -%}{%- continue -%}{%- endif -%}
      {%- if mp.id == product.id -%}{%- continue -%}{%- endif -%}
      {%- assign token = '||' | append: mp.id | append: '||' -%}
      {%- if seen contains token -%}{%- continue -%}{%- endif -%}
      {%- assign seen = seen | append: token -%}
      <div class="product-recommended__item">
        {% render 'product-card',
          product: mp,
          enable_quick_add: pr_enable_quick_add,
          enable_quick_view: pr_enable_quick_view,
          quick_add_mode: pr_quick_add_mode,
          quick_view_mode: pr_quick_view_mode,
          show_action_row: pr_show_action_row,
          show_secondary_row_cta: pr_show_secondary_row_cta,
          show_row_quick_view: pr_show_row_quick_view,
          quick_view_placement: pr_quick_view_placement,
          primary_cta_label: pr_primary_cta_label,
          secondary_cta_label: pr_secondary_cta_label,
          label_select_options: pr_label_select_options,
          label_sold_out: pr_label_sold_out,
          qv_label: pr_qv_label,
          button_style: pr_button_style,
          button_size: pr_button_size,
          button_full_width: pr_button_full_width,
          button_hover_strength: pr_button_hover_strength
        %}
      </div>
      {%- assign rendered_count = rendered_count | plus: 1 -%}
    {%- endfor -%}
  {%- endif -%}
{%- endcapture -%}

{%- liquid
  assign has_items = false
  if items_markup contains 'product-recommended__item'
    assign has_items = true
  endif

  if mode == 'collection' or mode == 'manual'
    if has_items == false
      break
    endif
  endif
-%}

<section
  class="product-recommended"
  id="product-recommended"
  data-section-id="{{ section.id }}"
  style="{{ pr_style }}"
  {% if mode == 'dynamic' and is_endpoint_render == false %}data-dynamic="true"{% endif %}
>
  {%- if s.title != blank or s.subheading != blank -%}
    <header class="product-recommended__header">
      {%- if s.title != blank -%}
        <h2 class="product-recommended__title">{{ s.title | escape }}</h2>
      {%- endif -%}
      {%- if s.subheading != blank -%}
        <div class="product-recommended__subheading rte">
          {{ s.subheading }}
        </div>
      {%- endif -%}
    </header>
  {%- endif -%}

  {%- if layout == 'carousel' -%}
    <div
      class="product-recommended__items product-recommended__items--carousel"
      {% if mode == 'dynamic' and is_endpoint_render == false %}data-recommendations-url="{{ recos_url }}"{% endif %}
      aria-label="{{ s.title | default: 'Recommended products' | strip_html | escape }}"
      tabindex="0"
    >
      {{ items_markup }}
    </div>
  {%- else -%}
    <div
      class="product-recommended__items product-recommended__items--grid"
      style="--cols-mobile: {{ s.columns_mobile }}; --cols-tablet: {{ s.columns_tablet }}; --cols-desktop: {{ s.columns_desktop }};"
      {% if mode == 'dynamic' and is_endpoint_render == false %}data-recommendations-url="{{ recos_url }}"{% endif %}
    >
      {{ items_markup }}
    </div>
  {%- endif -%}

  {% stylesheet %}
    .product-recommended{ width:100%; }
    .product-recommended__header{ margin: 0 0 1rem 0; }
    .product-recommended__title{ margin:0; font-size: 1.35rem; line-height: 1.2; }
    .product-recommended__subheading{ margin-top: .5rem; opacity: .9; }

    .product-recommended__items--grid{
      display:grid;
      gap:1rem;
      grid-template-columns: repeat(var(--cols-mobile, 2), minmax(0, 1fr));
    }
    @media (min-width: 750px){
      .product-recommended__items--grid{
        grid-template-columns: repeat(var(--cols-tablet, 3), minmax(0, 1fr));
      }
    }
    @media (min-width: 990px){
      .product-recommended__items--grid{
        grid-template-columns: repeat(var(--cols-desktop, 4), minmax(0, 1fr));
      }
    }

    .product-recommended__items--carousel{
      display:flex;
      gap:1rem;
      overflow-x:auto;
      scroll-snap-type:x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: .25rem;
      outline: none;
    }
    .product-recommended__item{
      scroll-snap-align:start;
      flex: 0 0 auto;
      width: min(320px, 80%);
    }
    @media (min-width: 750px){
      .product-recommended__item{ width: 280px; }
    }

    /* Scoped button styling controls (affects card CTAs only within this section) */
    .product-recommended .q-product-card__action,
    .product-recommended .q-product-card__rowbtn,
    .product-recommended .q-product-card__below-qv{
      border-radius: var(--pr-btn-radius, 12px);
      font-size: var(--pr-btn-font-size, inherit);
      padding: var(--pr-btn-pad-y, 9px) var(--pr-btn-pad-x, 12px);
    }
  {% endstylesheet %}
</section>

{% schema %}
{
  "name": "Product recommended",
  "tag": "section",
  "class": "section product-recommended-section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Recommended for you" },
    { "type": "richtext", "id": "subheading", "label": "Subheading" },

    {
      "type": "select",
      "id": "mode",
      "label": "Mode",
      "default": "dynamic",
      "options": [
        { "value": "dynamic", "label": "Dynamic" },
        { "value": "collection", "label": "Collection" },
        { "value": "manual", "label": "Manual" }
      ]
    },

    {
      "type": "collection",
      "id": "collection",
      "label": "Collection fallback",
      "info": "Used when Mode is Collection, or as fallback when Dynamic returns no products."
    },

    { "type": "range", "id": "max_products", "label": "Max products", "min": 2, "max": 12, "step": 1, "default": 4 },

    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ]
    },

    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet", "label": "Columns (tablet)", "min": 1, "max": 4, "step": 1, "default": 3 },

    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },

    {
      "type": "select",
      "id": "intent",
      "label": "Intent",
      "default": "related",
      "options": [
        { "value": "related", "label": "Related" },
        { "value": "complementary", "label": "Complementary" }
      ]
    },

    { "type": "header", "content": "Card actions" },

    { "type": "checkbox", "id": "enable_quick_add", "label": "Enable add to cart (quick add)", "default": true },

    {
      "type": "select",
      "id": "quick_add_mode",
      "label": "Quick add mode",
      "default": "button",
      "options": [
        { "value": "button", "label": "Button" },
        { "value": "dropdown", "label": "Variant dropdown" },
        { "value": "sizes", "label": "Sizes (if Size option exists)" }
      ]
    },

    { "type": "checkbox", "id": "enable_quick_view", "label": "Enable quick view", "default": false },

    {
      "type": "select",
      "id": "quick_view_mode",
      "label": "Quick view mode",
      "default": "drawer",
      "options": [
        { "value": "drawer", "label": "Drawer" },
        { "value": "modal", "label": "Modal" }
      ]
    },

    {
      "type": "select",
      "id": "quick_view_placement",
      "label": "Quick view placement",
      "default": "overlay",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "below_content", "label": "Below content" },
        { "value": "both", "label": "Both" }
      ]
    },

    { "type": "checkbox", "id": "show_action_row", "label": "Show action row below card", "default": false },
    { "type": "checkbox", "id": "show_secondary_row_cta", "label": "Show secondary row CTA", "default": true },
    { "type": "checkbox", "id": "show_row_quick_view", "label": "Show quick view in row", "default": true },

    { "type": "text", "id": "primary_cta_label", "label": "Add to cart label", "default": "Add to cart" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label", "default": "Learn more" },
    { "type": "text", "id": "label_select_options", "label": "Select options label", "default": "Select options" },
    { "type": "text", "id": "label_sold_out", "label": "Sold out label", "default": "Sold out" },
    { "type": "text", "id": "qv_label", "label": "Quick view label", "default": "Quick view" },

    { "type": "header", "content": "Button styling (this section only)" },

    { "type": "select", "id": "button_style", "label": "Button style", "default": "filled", "options": [
      { "value": "filled", "label": "Filled" },
      { "value": "outline", "label": "Outline" },
      { "value": "ghost", "label": "Ghost" }
    ]},

    { "type": "select", "id": "button_size", "label": "Button size", "default": "md", "options": [
      { "value": "sm", "label": "Small" },
      { "value": "md", "label": "Medium" },
      { "value": "lg", "label": "Large" }
    ]},

    { "type": "checkbox", "id": "button_full_width", "label": "Full width buttons", "default": false },
    { "type": "range", "id": "button_hover_strength", "label": "Hover strength", "min": 0, "max": 100, "step": 1, "default": 40 },

    { "type": "color", "id": "btn_bg", "label": "Button background", "default": "#111111" },
    { "type": "color", "id": "btn_text", "label": "Button text", "default": "#FFFFFF" },
    { "type": "color", "id": "btn_bg_hover", "label": "Button background (hover)", "default": "#000000" },
    { "type": "color", "id": "btn_text_hover", "label": "Button text (hover)", "default": "#FFFFFF" },
    { "type": "color", "id": "btn_border", "label": "Button border color", "default": "rgba(0,0,0,0.15)" },

    { "type": "range", "id": "btn_radius", "label": "Button radius (px)", "min": 0, "max": 24, "step": 1, "default": 12 },
    { "type": "range", "id": "btn_font_size", "label": "Button font size (px)", "min": 12, "max": 20, "step": 1, "default": 14 },
    { "type": "range", "id": "btn_padding_y", "label": "Button padding Y (px)", "min": 6, "max": 18, "step": 1, "default": 9 },
    { "type": "range", "id": "btn_padding_x", "label": "Button padding X (px)", "min": 8, "max": 24, "step": 1, "default": 12 }
  ],
  "blocks": [
    {
      "type": "product_reference",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    { "name": "Product recommended" }
  ],
  "templates": ["product"]
}
{% endschema %}