{{ 'predictive-search.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign layout = settings.search_results_layout | default: 'grid'
  assign per_page = settings.search_results_per_page | default: 16
  assign show_products = settings.search_src_products
  assign show_articles = settings.search_src_articles
  assign show_pages = settings.search_src_pages
  assign show_collections = settings.search_src_collections
  assign empty_message = settings.search_empty_message | default: 'No results found. Try searching for something else.'
  assign page_placeholder = settings.search_page_placeholder | default: 'Search products, articles, and pages'
  assign submit_label = settings.search_submit_label | default: 'Search'
  assign view_all_label = settings.search_view_all_label | default: 'View all results'
  assign section_padding_top = settings.section_padding_top | default: 48
  assign section_padding_bottom = settings.section_padding_bottom | default: 48
  assign button_radius = settings.button_radius | default: 12
-%}

<style>
  #QtmMainSearch-{{ section.id }} {
    --qtm-search-pad-top: {{ section_padding_top }}px;
    --qtm-search-pad-bottom: {{ section_padding_bottom }}px;
    --qtm-search-bg: {{ settings.bg_base | default: '#ffffff' }};
    --qtm-search-surface: {{ settings.bg_contrast | default: '#f6f7f8' }};
    --qtm-search-text: {{ settings.text_base | default: '#111111' }};
    --qtm-search-muted: {{ settings.text_muted | default: '#6b7280' }};
    --qtm-search-border: rgba(0,0,0,0.10);
    --qtm-search-accent: {{ settings.color_primary | default: '#2563eb' }};
    --qtm-search-accent-hover: {{ settings.color_secondary | default: '#111827' }};
    --qtm-search-radius: {{ button_radius }}px;
    --qtm-search-container: {{ settings.container_lg | default: 1152 }}px;
  }

  #QtmMainSearch-{{ section.id }} {
    padding-top: var(--qtm-search-pad-top);
    padding-bottom: var(--qtm-search-pad-bottom);
    background: var(--qtm-search-bg);
    color: var(--qtm-search-text);
  }

  #QtmMainSearch-{{ section.id }} .qtm-search {
    max-width: var(--qtm-search-container);
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__header {
    margin-bottom: 32px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__title {
    margin: 0 0 10px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__meta {
    color: var(--qtm-search-muted);
    margin-bottom: 20px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__form {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: end;
    margin-bottom: 28px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__field {
    flex: 1 1 320px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__label {
    display: block;
    margin-bottom: 8px;
    font-size: 0.95rem;
    font-weight: 600;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__input {
    width: 100%;
    min-height: 52px;
    border-radius: var(--qtm-search-radius);
    border: 1px solid var(--qtm-search-border);
    background: var(--qtm-search-bg);
    color: var(--qtm-search-text);
    padding: 0 16px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__actions .button,
  #QtmMainSearch-{{ section.id }} .qtm-search__actions button {
    min-height: 52px;
    padding: 0 18px;
    border-radius: var(--qtm-search-radius);
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__predictive {
    margin-bottom: 28px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-results--grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 20px;
  }

  @media (min-width: 768px) {
    #QtmMainSearch-{{ section.id }} .qtm-search-results--grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    #QtmMainSearch-{{ section.id }} .qtm-search-results--grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-results--list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result {
    min-width: 0;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__card {
    height: 100%;
    border: 1px solid var(--qtm-search-border);
    border-radius: 18px;
    background: var(--qtm-search-surface);
    overflow: hidden;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__link {
    display: block;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__media {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--qtm-search-bg);
    overflow: hidden;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__body {
    padding: 16px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__type {
    display: inline-block;
    margin-bottom: 10px;
    font-size: 0.8rem;
    color: var(--qtm-search-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__title {
    margin: 0 0 8px;
    font-size: 1.05rem;
    line-height: 1.3;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__excerpt {
    color: var(--qtm-search-muted);
    margin: 0;
    line-height: 1.5;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result--list-card .qtm-search-result__link {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: 0;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-results--list .qtm-search-result__media {
    aspect-ratio: 1 / 1;
    min-height: 100%;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search-result__link:hover .qtm-search-result__title {
    color: var(--qtm-search-accent-hover);
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__empty {
    border: 1px solid var(--qtm-search-border);
    border-radius: 18px;
    padding: 28px;
    background: var(--qtm-search-surface);
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__empty-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid var(--qtm-search-border);
    background: var(--qtm-search-surface);
    color: var(--qtm-search-text);
    text-decoration: none;
    font-size: 0.92rem;
  }

  #QtmMainSearch-{{ section.id }} .qtm-search__pagination {
    margin-top: 32px;
  }

  #QtmMainSearch-{{ section.id }} .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  @media (max-width: 767px) {
    #QtmMainSearch-{{ section.id }} .qtm-search-results--list .qtm-search-result__link {
      grid-template-columns: 1fr;
    }

    #QtmMainSearch-{{ section.id }} .qtm-search-results--list .qtm-search-result__media {
      aspect-ratio: 4 / 3;
    }
  }
</style>

<section id="QtmMainSearch-{{ section.id }}">
  <div class="qtm-search">
    <header class="qtm-search__header">
      <h1 class="qtm-search__title">
        {%- if search.performed and search.terms != blank -%}
          Search results for “{{ search.terms | escape }}”
        {%- else -%}
          Search
        {%- endif -%}
      </h1>

      {%- if search.performed -%}
        <div class="qtm-search__meta">
          {{ search.results_count }} result{%- if search.results_count != 1 -%}s{%- endif -%}
        </div>
      {%- endif -%}

      {%- if settings.search_mode == 'predictive' -%}
        <div class="qtm-search__predictive">
          {% render 'predictive-search',
            context: 'search-page',
            input_id: 'QtmSearchPredictiveInput-' | append: section.id,
            panel_id: 'QtmSearchPredictivePanel-' | append: section.id,
            placeholder: settings.search_page_placeholder
          %}
        </div>
      {%- else -%}
        <form class="qtm-search__form" action="{{ routes.search_url }}" method="get" role="search">
          <div class="qtm-search__field">
            <label class="qtm-search__label" for="QtmSearchInput-{{ section.id }}">Search store</label>
            <input
              id="QtmSearchInput-{{ section.id }}"
              class="qtm-search__input"
              type="search"
              name="q"
              value="{{ search.terms | escape }}"
              placeholder="{{ page_placeholder | escape }}"
              aria-label="Search store"
            >
          </div>

          <div class="qtm-search__actions">
            <button class="button" type="submit">{{ submit_label }}</button>
          </div>
        </form>
      {%- endif -%}
    </header>

    {%- if search.performed -%}
      {% paginate search.results by per_page %}
        {%- if search.results_count > 0 -%}
          <div class="qtm-search-results qtm-search-results--{{ layout }}">
            {%- for result in search.results -%}
              {%- case result.object_type -%}

                {%- when 'product' -%}
                  {%- if show_products -%}
                    <div class="qtm-search-result qtm-search-result--product">
                      {%- if layout == 'grid' -%}
                        {%- render 'product-card',
                          product: result,
                          card_preset: 'catalog',
                          media_mode: 'single',
                          media_fit: 'cover',
                          media_ratio: 125,
                          image_zoom: true,
                          hover_treatment: 'overlay_actions',
                          hover_overlay_opacity: 15,
                          hover_actions_visibility: 'desktop_only',
                          actions_layout: 'stack',
                          enable_quick_add: settings.pcard_quick_add,
                          enable_quick_view: true,
                          quick_add_mode: 'button',
                          quick_view_mode: 'drawer',
                          show_badges: settings.pcard_show_badges,
                          badge_sale: settings.pcard_show_badges,
                          text_align: 'left',
                          title_size: 16,
                          title_weight: '600',
                          price_size: 15,
                          price_weight: '600',
                          badge_style: 'pill',
                          badge_fill: 'filled',
                          badge_position: 'top_left',
                          button_style: 'filled',
                          button_size: 'md',
                          button_full_width: true,
                          button_hover_strength: 40,
                          show_action_row: false,
                          show_secondary_row_cta: false,
                          show_row_quick_view: false,
                          quick_view_placement: 'overlay',
                          primary_cta_label: 'Add to cart',
                          secondary_cta_label: 'Learn more',
                          qv_label: 'Quick view',
                          label_select_options: 'Select options',
                          label_sold_out: 'Sold out'
                        -%}
                      {%- else -%}
                        {%- render 'collection-simple-product-card',
                          product: result,
                          s: section.settings
                        -%}
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                {%- when 'article' -%}
                  {%- if show_articles -%}
                    <article class="qtm-search-result qtm-search-result--article{% if layout == 'list' %} qtm-search-result--list-card{% endif %}">
                      <div class="qtm-search-result__card">
                        <a class="qtm-search-result__link" href="{{ result.url }}">
                          <div class="qtm-search-result__media">
                            {%- if result.image != blank -%}
                              {{
                                result.image
                                | image_url: width: 900
                                | image_tag:
                                  widths: '320,480,640,900',
                                  sizes: '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw',
                                  loading: 'lazy',
                                  alt: result.title
                              }}
                            {%- endif -%}
                          </div>
                          <div class="qtm-search-result__body">
                            <span class="qtm-search-result__type">Article</span>
                            <h2 class="qtm-search-result__title">{{ result.title }}</h2>
                            {%- if result.excerpt != blank -%}
                              <p class="qtm-search-result__excerpt">{{ result.excerpt | strip_html | truncate: 160 }}</p>
                            {%- elsif result.content != blank -%}
                              <p class="qtm-search-result__excerpt">{{ result.content | strip_html | truncate: 160 }}</p>
                            {%- endif -%}
                          </div>
                        </a>
                      </div>
                    </article>
                  {%- endif -%}

                {%- when 'page' -%}
                  {%- if show_pages -%}
                    <article class="qtm-search-result qtm-search-result--page">
                      <div class="qtm-search-result__card">
                        <a class="qtm-search-result__link" href="{{ result.url }}">
                          <div class="qtm-search-result__body">
                            <span class="qtm-search-result__type">Page</span>
                            <h2 class="qtm-search-result__title">{{ result.title }}</h2>
                            {%- if result.content != blank -%}
                              <p class="qtm-search-result__excerpt">{{ result.content | strip_html | truncate: 180 }}</p>
                            {%- endif -%}
                          </div>
                        </a>
                      </div>
                    </article>
                  {%- endif -%}

                {%- when 'collection' -%}
                  {%- if show_collections -%}
                    <article class="qtm-search-result qtm-search-result--collection{% if layout == 'list' %} qtm-search-result--list-card{% endif %}">
                      <div class="qtm-search-result__card">
                        <a class="qtm-search-result__link" href="{{ result.url }}">
                          <div class="qtm-search-result__media">
                            {%- if result.featured_image != blank -%}
                              {{
                                result.featured_image
                                | image_url: width: 900
                                | image_tag:
                                  widths: '320,480,640,900',
                                  sizes: '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw',
                                  loading: 'lazy',
                                  alt: result.title
                              }}
                            {%- endif -%}
                          </div>
                          <div class="qtm-search-result__body">
                            <span class="qtm-search-result__type">Collection</span>
                            <h2 class="qtm-search-result__title">{{ result.title }}</h2>
                            {%- if result.description != blank -%}
                              <p class="qtm-search-result__excerpt">{{ result.description | strip_html | truncate: 180 }}</p>
                            {%- endif -%}
                          </div>
                        </a>
                      </div>
                    </article>
                  {%- endif -%}

              {%- endcase -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <div class="qtm-search__pagination">
              {{ paginate | default_pagination }}
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="qtm-search__empty">
            <h2>No results</h2>
            <p>{{ empty_message }}</p>

            {%- if settings.search_mode == 'predictive' -%}
              <div class="qtm-search__predictive">
                {% render 'predictive-search',
                  context: 'search-page-empty',
                  input_id: 'QtmSearchEmptyPredictiveInput-' | append: section.id,
                  panel_id: 'QtmSearchEmptyPredictivePanel-' | append: section.id,
                  placeholder: settings.search_page_placeholder
                %}
              </div>
            {%- else -%}
              <form class="qtm-search__form" action="{{ routes.search_url }}" method="get" role="search">
                <div class="qtm-search__field">
                  <label class="qtm-search__label" for="QtmSearchEmptyInput-{{ section.id }}">Search store</label>
                  <input
                    id="QtmSearchEmptyInput-{{ section.id }}"
                    class="qtm-search__input"
                    type="search"
                    name="q"
                    placeholder="{{ page_placeholder | escape }}"
                    aria-label="Search store"
                  >
                </div>
                <div class="qtm-search__actions">
                  <button class="button" type="submit">{{ submit_label }}</button>
                </div>
              </form>
            {%- endif -%}

            {%- if settings.search_empty_recommendations -%}
              <div class="qtm-search__empty-actions">
                <a class="qtm-search__chip" href="{{ routes.all_products_collection_url }}">Browse all products</a>
                <a class="qtm-search__chip" href="/blogs/news">Read articles</a>
                <a class="qtm-search__chip" href="{{ routes.root_url }}">{{ view_all_label }}</a>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {% endpaginate %}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main Search",
  "settings": [],
  "presets": [
    {
      "name": "Main Search"
    }
  ]
}
{% endschema %}