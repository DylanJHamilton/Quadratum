{% comment %}
  Section: main-account-login.liquid
  Theme:   Quadratum
  Purpose: Customer account entry — Login, Recover Password, Success state
  Notes:   Progressive enhancement. All states work without JS.
           JS enhances panel toggling only. No external dependencies.
{% endcomment %}

{%- liquid
  assign section_layout   = section.settings.layout
  assign show_card        = section.settings.show_card
  assign bg_color         = section.settings.background_color
  assign show_image_panel = section.settings.show_image_panel
  assign image_panel_img  = section.settings.image_panel_image
  assign image_panel_head = section.settings.image_panel_heading
  assign image_panel_sub  = section.settings.image_panel_subtext
  assign image_panel_tag  = section.settings.image_panel_tag
  assign show_logo        = section.settings.show_logo
  assign show_register    = section.settings.show_register_prompt
  assign eyebrow_text     = section.settings.eyebrow_text
  assign login_heading    = section.settings.login_heading
  assign login_subtext    = section.settings.login_subtext
  assign recover_heading  = section.settings.recover_heading
  assign recover_subtext  = section.settings.recover_subtext
  assign section_pt       = section.settings.padding_top
  assign section_pb       = section.settings.padding_bottom
-%}

<section
  id="shopify-section-{{ section.id }}"
  class="q-account-login q-layout--{{ section_layout }}{% if show_card %} q-has-card{% else %} q-no-card{% endif %}"
  data-section-id="{{ section.id }}"
  style="
    --q-section-pt: {{ section_pt }}px;
    --q-section-pb: {{ section_pb }}px;
    {% if bg_color != blank %}background-color: {{ bg_color }};{% endif %}
  "
>

  {%- if section_layout == 'twocol' and show_image_panel -%}
    <div class="q-image-panel">
      {%- if image_panel_img != blank -%}
        <div class="q-image-panel__media">
          {{
            image_panel_img
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              class: 'q-image-panel__img',
              widths: '600, 800, 1000, 1200',
              sizes: '50vw'
          }}
        </div>
      {%- endif -%}
      <div class="q-image-panel__overlay"></div>
      <div class="q-image-panel__content">
        {%- if image_panel_tag != blank -%}
          <span class="q-image-panel__tag">{{ image_panel_tag }}</span>
        {%- endif -%}
        {%- if image_panel_head != blank -%}
          <h2 class="q-image-panel__heading">{{ image_panel_head }}</h2>
        {%- endif -%}
        {%- if image_panel_sub != blank -%}
          <p class="q-image-panel__sub">{{ image_panel_sub }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="q-form-col">
    <div class="q-form-wrap">
      <div class="q-card-shell">

        {%- comment -%} ── Card Header ── {%- endcomment -%}
        <div class="q-card-top">
          {%- if show_logo and shop.brand.logo != blank -%}
            <div class="q-logo-mark q-logo-mark--image">
              {{
                shop.brand.logo
                | image_url: width: 120
                | image_tag:
                  loading: 'eager',
                  class: 'q-logo-mark__img',
                  widths: '60, 90, 120',
                  alt: shop.name
              }}
            </div>
          {%- elsif show_logo -%}
            <div class="q-logo-mark q-logo-mark--text" aria-hidden="true">
              <span>{{ shop.name | slice: 0 }}</span>
            </div>
          {%- endif -%}

          <div class="q-card-header-text" id="q-header-{{ section.id }}">
            {%- if eyebrow_text != blank -%}
              <p class="q-eyebrow">{{ eyebrow_text }}</p>
            {%- endif -%}
            <h1 class="q-title">{{ login_heading | default: 'Welcome back' }}</h1>
            <p class="q-subtitle">{{ login_subtext | default: 'Sign in to continue to your account' }}</p>
          </div>
        </div>

        {%- comment -%} ── Card Body ── {%- endcomment -%}
        <div class="q-card-body">

          {%- comment -%} LOGIN PANEL {%- endcomment -%}
          <div
            class="q-panel q-panel--login"
            id="q-panel-login-{{ section.id }}"
            data-panel="login"
            aria-hidden="false"
          >
            {%- form 'customer_login', id: 'CustomerLoginForm', class: 'q-form' -%}
              {%- if form.errors -%}
                <div class="q-form-errors" role="alert">
                  <p class="q-form-error-msg">
                    {{ form.errors | default_errors }}
                  </p>
                </div>
              {%- endif -%}

              <div class="q-field">
                <label class="q-label" for="CustomerEmail-{{ section.id }}">
                  Email address
                </label>
                <input
                  class="q-input"
                  type="email"
                  name="customer[email]"
                  id="CustomerEmail-{{ section.id }}"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  placeholder="{{ 'customer.login.email' | t | default: 'you@example.com' }}"
                  spellcheck="false"
                  autofocus
                  {%- if form.errors contains 'form' -%}aria-invalid="true"{%- endif -%}
                >
              </div>

              <div class="q-field">
                <label class="q-label" for="CustomerPassword-{{ section.id }}">
                  Password
                </label>
                <input
                  class="q-input"
                  type="password"
                  name="customer[password]"
                  id="CustomerPassword-{{ section.id }}"
                  autocomplete="current-password"
                  placeholder="••••••••"
                  {%- if form.errors contains 'form' -%}aria-invalid="true"{%- endif -%}
                >
              </div>

              <button type="submit" class="q-btn">
                {{ 'customer.login.sign_in' | t | default: 'Sign in' }}
              </button>

              <div class="q-meta">
                <span class="q-meta-label">Forgot your password?</span>
                <button
                  type="button"
                  class="q-ghost-btn"
                  data-toggle-panel="recover"
                  aria-controls="q-panel-recover-{{ section.id }}"
                >
                  Reset it here
                </button>
              </div>
            {%- endform -%}
          </div>

          {%- comment -%} RECOVER PANEL {%- endcomment -%}
          <div
            class="q-panel q-panel--recover"
            id="q-panel-recover-{{ section.id }}"
            data-panel="recover"
            aria-hidden="true"
          >
            <button
              type="button"
              class="q-back-btn"
              data-toggle-panel="login"
              aria-controls="q-panel-login-{{ section.id }}"
            >
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"
                stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="8 2 4 6 8 10"/>
              </svg>
              Back to sign in
            </button>

            <div class="q-alert" role="note">
              Enter your email address and we will send you a link to reset your password.
            </div>

            {%- form 'recover_customer_password', id: 'RecoverPasswordForm', class: 'q-form' -%}
              {%- if form.posted_successfully? -%}
                <script>
                  document.addEventListener('DOMContentLoaded', function () {
                    window.__qShowPanel_{{ section.id | handleize }}('success');
                  });
                </script>
              {%- endif -%}

              <div class="q-field">
                <label class="q-label" for="RecoverEmail-{{ section.id }}">
                  Email address
                </label>
                <input
                  class="q-input"
                  type="email"
                  name="email"
                  id="RecoverEmail-{{ section.id }}"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  placeholder="{{ 'customer.login.email' | t | default: 'you@example.com' }}"
                  spellcheck="false"
                >
              </div>

              <button type="submit" class="q-btn">
                {{ 'customer.recover_password.submit' | t | default: 'Send reset link' }}
              </button>
            {%- endform -%}
          </div>

          {%- comment -%} SUCCESS PANEL {%- endcomment -%}
          <div
            class="q-panel q-panel--success"
            id="q-panel-success-{{ section.id }}"
            data-panel="success"
            aria-hidden="true"
          >
            <div class="q-success-wrap">
              <div class="q-check-circle" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <p class="q-title q-title--sm">Check your inbox</p>
              <p class="q-subtitle q-subtitle--spaced">
                A password reset link has been sent. Check your spam folder if it doesn't arrive within a few minutes.
              </p>
              <button
                type="button"
                class="q-outline-btn"
                data-toggle-panel="login"
              >
                Back to sign in
              </button>
            </div>
          </div>

        </div>

        {%- comment -%} ── Register Prompt ── {%- endcomment -%}
        {%- if show_register -%}
          <div class="q-register">
            <p>{{ section.settings.register_text | default: "Don't have an account yet?" }}</p>
            <a href="{{ routes.account_register_url }}" class="q-outline-btn">
              {{ section.settings.register_cta | default: 'Create account' }}
            </a>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

</section>

{% comment %} ============================================================
   STYLES
   ============================================================ {% endcomment %}
<style>
  #shopify-section-{{ section.id }} {
    --q-radius:        {{ section.settings.border_radius }}px;
    --q-radius-input:  {{ section.settings.input_radius }}px;
    --q-radius-btn:    {{ section.settings.button_radius }}px;
    --q-max-width:     {{ section.settings.form_max_width }}px;
    --q-transition:    0.22s cubic-bezier(0.4, 0, 0.2, 1);
    --q-input-height:  48px;
    --q-btn-height:    48px;
  }

  .q-account-login {
    display: flex;
    align-items: stretch;
    min-height: var(--q-section-min-height, 100vh);
    padding-top: var(--q-section-pt);
    padding-bottom: var(--q-section-pb);
  }

  .q-layout--centered {
    align-items: center;
    justify-content: center;
  }

  .q-layout--fullbleed {
    align-items: center;
    justify-content: center;
  }

  .q-layout--twocol {
    align-items: stretch;
  }

  .q-image-panel {
    flex: 1;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    min-height: 500px;
    background: #111;
  }

  .q-image-panel__media {
    position: absolute;
    inset: 0;
  }

  .q-image-panel__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .q-image-panel__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.12) 60%, transparent 100%);
  }

  .q-image-panel__content {
    position: relative;
    z-index: 1;
    padding: 2.5rem;
  }

  .q-image-panel__tag {
    display: inline-block;
    background: rgba(255,255,255,0.12);
    border: 0.5px solid rgba(255,255,255,0.22);
    border-radius: 100px;
    padding: 4px 14px;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .q-image-panel__heading {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 500;
    color: #fff;
    line-height: 1.25;
    margin-bottom: 0.5rem;
  }

  .q-image-panel__sub {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    max-width: 280px;
  }

  .q-form-col {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }

  .q-layout--centered .q-form-col,
  .q-layout--fullbleed .q-form-col {
    min-height: 100%;
  }

  .q-form-wrap {
    width: 100%;
    max-width: var(--q-max-width);
  }

  .q-has-card .q-card-shell {
    background: var(--color-background-primary, #fff);
    border: 0.5px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
    border-radius: var(--q-radius);
    overflow: hidden;
  }

  .q-no-card .q-card-shell {
    background: transparent;
    border: none;
    border-radius: 0;
  }

  .q-card-top {
    padding: 2rem 2rem 1.5rem;
  }

  .q-no-card .q-card-top {
    padding: 0 0 1.5rem;
  }

  .q-logo-mark {
    margin-bottom: 1.5rem;
  }

  .q-logo-mark--text {
    width: 34px;
    height: 34px;
    background: var(--color-text-primary, #111);
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .q-logo-mark--text span {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-background-primary, #fff);
  }

  .q-logo-mark--image .q-logo-mark__img {
    height: 32px;
    width: auto;
    display: block;
  }

  .q-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary, rgba(0,0,0,0.4));
    margin-bottom: 6px;
  }

  .q-title {
    font-size: 22px;
    font-weight: 500;
    color: var(--color-text-primary, #111);
    line-height: 1.25;
    margin-bottom: 4px;
  }

  .q-title--sm {
    font-size: 18px;
    margin-bottom: 8px;
  }

  .q-subtitle {
    font-size: 13px;
    color: var(--color-text-secondary, rgba(0,0,0,0.55));
    line-height: 1.55;
  }

  .q-subtitle--spaced {
    margin-bottom: 1.5rem;
  }

  .q-card-body {
    padding: 0 2rem 2rem;
  }

  .q-no-card .q-card-body {
    padding: 0;
  }

  .q-panel {
    display: none;
  }

  .q-panel[aria-hidden="false"] {
    display: block;
  }

  .q-field {
    margin-bottom: 14px;
  }

  .q-label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-secondary, rgba(0,0,0,0.55));
    margin-bottom: 6px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .q-input {
    width: 100%;
    height: var(--q-input-height);
    background: var(--color-background-secondary, rgba(0,0,0,0.04));
    border: 0.5px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
    border-radius: var(--q-radius-input);
    padding: 0 14px;
    font-size: 14px;
    color: var(--color-text-primary, #111);
    font-family: inherit;
    outline: none;
    transition: border var(--q-transition), background var(--q-transition);
    appearance: none;
    -webkit-appearance: none;
  }

  .q-input:focus {
    border: 1px solid var(--color-border-primary, rgba(0,0,0,0.35));
    background: var(--color-background-primary, #fff);
  }

  .q-input::placeholder {
    color: var(--color-text-tertiary, rgba(0,0,0,0.3));
  }

  .q-input[aria-invalid="true"] {
    border-color: var(--color-border-danger, #e24b4a);
  }

  .q-btn {
    display: block;
    width: 100%;
    height: var(--q-btn-height);
    background: var(--color-text-primary, #111);
    color: var(--color-background-primary, #fff);
    border: none;
    border-radius: var(--q-radius-btn);
    font-size: 14px;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    margin-top: 4px;
    transition: opacity var(--q-transition), transform var(--q-transition);
    text-align: center;
    line-height: var(--q-btn-height);
    padding: 0;
  }

  .q-btn:hover { opacity: 0.82; }
  .q-btn:active { transform: scale(0.99); }

  .q-outline-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 1.25rem;
    background: transparent;
    border: 0.5px solid var(--color-border-secondary, rgba(0,0,0,0.2));
    border-radius: var(--q-radius-btn);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-primary, #111);
    font-family: inherit;
    cursor: pointer;
    text-decoration: none;
    transition: background var(--q-transition), border-color var(--q-transition);
  }

  .q-outline-btn:hover {
    background: var(--color-background-secondary, rgba(0,0,0,0.04));
    border-color: var(--color-border-primary, rgba(0,0,0,0.35));
  }

  .q-ghost-btn {
    background: none;
    border: none;
    font-size: 12px;
    color: var(--color-text-secondary, rgba(0,0,0,0.55));
    font-family: inherit;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--color-border-secondary, rgba(0,0,0,0.2));
    transition: color var(--q-transition);
  }

  .q-ghost-btn:hover { color: var(--color-text-primary, #111); }

  .q-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 14px;
  }

  .q-meta-label {
    font-size: 12px;
    color: var(--color-text-tertiary, rgba(0,0,0,0.35));
  }

  .q-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: var(--color-text-secondary, rgba(0,0,0,0.55));
    background: none;
    border: none;
    font-family: inherit;
    cursor: pointer;
    padding: 0;
    margin-bottom: 1.25rem;
    transition: color var(--q-transition);
  }

  .q-back-btn:hover { color: var(--color-text-primary, #111); }

  .q-alert {
    background: var(--color-background-secondary, rgba(0,0,0,0.04));
    border: 0.5px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
    border-radius: var(--q-radius-input);
    padding: 12px 14px;
    font-size: 13px;
    color: var(--color-text-secondary, rgba(0,0,0,0.55));
    margin-bottom: 16px;
    line-height: 1.55;
  }

  .q-form-errors {
    background: var(--color-background-danger, #fcebeb);
    border: 0.5px solid var(--color-border-danger, rgba(226,75,74,0.3));
    border-radius: var(--q-radius-input);
    padding: 11px 14px;
    margin-bottom: 16px;
  }

  .q-form-error-msg {
    font-size: 13px;
    color: var(--color-text-danger, #a32d2d);
    line-height: 1.5;
    margin: 0;
  }

  .q-success-wrap {
    text-align: center;
    padding: 1rem 0 0.5rem;
  }

  .q-check-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 0.5px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: var(--color-text-primary, #111);
  }

  .q-register {
    text-align: center;
    padding: 1.25rem 2rem 1.75rem;
    border-top: 0.5px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
  }

  .q-no-card .q-register {
    padding: 1.25rem 0 0;
  }

  .q-register p {
    font-size: 12px;
    color: var(--color-text-secondary, rgba(0,0,0,0.55));
    margin-bottom: 10px;
  }

  @media (max-width: 767px) {
    .q-layout--twocol {
      flex-direction: column;
    }

    .q-image-panel {
      min-height: 240px;
      flex: none;
    }

    .q-card-top,
    .q-card-body {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .q-register {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
  }
</style>

<script>
(function () {
  'use strict';

  var sectionId = {{ section.id | json }};

  function getPanel(name) {
    return document.getElementById('q-panel-' + name + '-' + sectionId);
  }

  function showPanel(name) {
    var panels = ['login', 'recover', 'success'];
    panels.forEach(function (p) {
      var el = getPanel(p);
      if (!el) return;
      el.setAttribute('aria-hidden', p !== name ? 'true' : 'false');
    });

    var titles = {
      login:   { title: {{ login_heading | default: 'Welcome back' | json }}, sub: {{ login_subtext | default: 'Sign in to continue to your account' | json }} },
      recover: { title: {{ recover_heading | default: 'Reset password' | json }}, sub: {{ recover_subtext | default: 'We will send a reset link to your email' | json }} },
      success: { title: 'Email on its way', sub: 'Check your inbox to complete the reset' }
    };

    var header = document.getElementById('q-header-' + sectionId);
    if (header && titles[name]) {
      var titleEl = header.querySelector('.q-title');
      var subEl   = header.querySelector('.q-subtitle');
      if (titleEl) titleEl.textContent = titles[name].title;
      if (subEl)   subEl.textContent   = titles[name].sub;
    }

    if (history.replaceState) {
      history.replaceState(null, '', name === 'recover' ? '#recover' : window.location.pathname);
    }
  }

  window['__qShowPanel_' + sectionId.toString().replace(/-/g, '_')] = showPanel;

  document.addEventListener('DOMContentLoaded', function () {
    var section = document.getElementById('shopify-section-' + sectionId);
    if (!section) return;

    section.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-toggle-panel]');
      if (!btn) return;
      e.preventDefault();
      showPanel(btn.getAttribute('data-toggle-panel'));
    });

    if (window.location.hash === '#recover') {
      showPanel('recover');
    }
  });
})();
</script>

{% schema %}
{
  "name": "Account Login",
  "tag": "section",
  "class": "q-section q-section--account-login",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Section layout",
      "options": [
        { "value": "centered",  "label": "Centered" },
        { "value": "twocol",    "label": "Two column" },
        { "value": "fullbleed", "label": "Full bleed" }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "show_card",
      "label": "Show card container",
      "default": true,
      "info": "Wrap the form in a bordered card. Disable for a floating / no-container look."
    },
    {
      "type": "range",
      "id": "form_max_width",
      "label": "Form max width",
      "min": 320,
      "max": 600,
      "step": 10,
