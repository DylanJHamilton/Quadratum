{%- liquid
  assign form_context = form_context | default: 'site'
  assign input_id = input_id | default: 'QtmStaticSearchInput'
  assign placeholder = placeholder | default: settings.search_placeholder | default: 'Search products, articles, and pages'
  assign submit_label = submit_label | default: settings.search_submit_label | default: 'Search'
  assign form_action = form_action | default: routes.search_url
  assign query_value = query_value | default: search.terms
  assign extra_class = extra_class | default: ''
  assign show_button = show_button
  if show_button == nil
    assign show_button = true
  endif
-%}

<div class="qtm-search-form qtm-search-form--static {{ extra_class }}" data-qtm-search-form="static">
  <form
    class="qtm-search-form__form"
    action="{{ form_action }}"
    method="get"
    role="search"
    data-search-context="{{ form_context }}"
  >
    <label class="visually-hidden" for="{{ input_id }}">Search store</label>

    <div class="qtm-search-form__field">
      <input
        id="{{ input_id }}"
        class="qtm-search-form__input"
        type="search"
        name="q"
        value="{{ query_value | escape }}"
        placeholder="{{ placeholder | escape }}"
        aria-label="Search store"
        autocomplete="off"
      >
    </div>

    {%- if show_button -%}
      <div class="qtm-search-form__actions">
        <button class="qtm-search-form__submit button" type="submit">
          {{ submit_label }}
        </button>
      </div>
    {%- endif -%}
  </form>
</div>