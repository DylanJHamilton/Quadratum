{%- liquid
  assign p = product
  if p == blank
    assign p = nil
  endif

  assign btn_size = s.button_size | default: 'md'
  assign card_style = s.card_style | default: 'glass'

  if p != nil
    assign featured_media = p.featured_media
  else
    assign featured_media = nil
  endif

  assign img_ratio = s.image_ratio | default: 'adapt'
  assign ratio_pct = 100
  if img_ratio == 'square'
    assign ratio_pct = 100
  elsif img_ratio == 'portrait'
    assign ratio_pct = 125
  elsif img_ratio == 'landscape'
    assign ratio_pct = 70
  endif

  assign second_media = nil
  if p != nil and s.show_second_image and p.media.size > 1
    assign second_media = p.media[1]
  endif

  assign available = false
  if p != nil
    assign available = p.available
  endif

  assign on_sale = false
  if p != nil and p.compare_at_price > p.price
    assign on_sale = true
  endif
-%}

{%- if p == nil -%}
  {%- comment -%} No product passed to card {%- endcomment -%}
{%- else -%}
  <!-- KEEP YOUR EXISTING CARD HTML BELOW (unchanged) -->
{%- endif -%}


<style>
  .q-collection-simple .qcmCard{
    border-radius: var(--qcm-radius);
    border: 1px solid var(--qcm-card-border, rgba(0,0,0,.12));
    border-style: var(--qcm-card-border-style, solid);
    overflow: hidden;
    background: var(--qcm-card-bg, #fff);
    max-width: 100%;
  }
  .q-collection-simple .qcmCard--none{ border: none; background: transparent; }
  .q-collection-simple .qcmCard--outline{ background: transparent; }
  .q-collection-simple .qcmCard--solid{ background: var(--qcm-card-bg, #fff); }
  .q-collection-simple .qcmCard--glass{
    background: color-mix(in srgb, var(--qcm-card-bg, #fff) 80%, transparent);
    backdrop-filter: blur(10px);
  }

  .q-collection-simple.hover-lift .qcmCard{ transition: transform .18s ease; }
  .q-collection-simple.hover-lift .qcmCard:hover{ transform: translateY(-2px); }
  .q-collection-simple.hover-glow .qcmCard{ transition: box-shadow .18s ease; }
  .q-collection-simple.hover-glow .qcmCard:hover{ box-shadow: var(--qcm-shadow, 0 10px 30px rgba(0,0,0,.12)); }

  @media (prefers-reduced-motion: reduce){
    .q-collection-simple.hover-lift .qcmCard,
    .q-collection-simple.hover-glow .qcmCard{ transition:none; transform:none; }
  }

  .q-collection-simple .qcmCard__media{ position: relative; display:block; overflow:hidden; }
  .q-collection-simple .qcmCard__media::before{ content:""; display:block; padding-top: {{ ratio_pct }}%; }
  .q-collection-simple .qcmCard__mediaInner{ position:absolute; inset:0; }
  .q-collection-simple .qcmCard__img{ width:100%; height:100%; object-fit: cover; display:block; }
  .q-collection-simple .qcmCard__img--second{ position:absolute; inset:0; opacity:0; transition: opacity .18s ease; }
  .q-collection-simple .qcmCard:hover .qcmCard__img--second{ opacity:1; }
  @media (prefers-reduced-motion: reduce){ .q-collection-simple .qcmCard__img--second{ transition:none; } }

  .q-collection-simple .qcmCard__badges{ position:absolute; left:10px; top:10px; display:flex; gap:8px; flex-wrap:wrap; }
  .q-collection-simple .qcmBadge{ font-size: 12px; padding: 6px 8px; border-radius: 999px; border: 1px solid var(--qcm-btn-border, rgba(0,0,0,.15)); background: rgba(255,255,255,.85); }

  .q-collection-simple .qcmCard__content{ padding: var(--qcm-card-pad, 14px); display:grid; gap: 8px; min-width: 0; }
  .q-collection-simple .qcmCard__vendor{ color: var(--qcm-vendor-color, inherit); font-size: var(--qcm-vendor-size-set, 12px); opacity:.85; }
  .q-collection-simple .qcmCard__title{ margin:0; color: var(--qcm-title-color, inherit); font-size: var(--qcm-title-size-set, 16px); line-height:1.25; min-width: 0; }
  .q-collection-simple .qcmCard__title a{ color:inherit; text-decoration:none; display:inline-block; max-width:100%; }
  .q-collection-simple .qcmCard__title a:hover{ text-decoration:underline; }

  .q-collection-simple .qcmCard__price{
    color: var(--qcm-price-color, inherit);
    font-size: var(--qcm-price-size-set, 16px);
    display:flex; gap:10px; align-items:baseline; flex-wrap:wrap;
  }
  .q-collection-simple .qcmPrice--compare{ opacity:.7; text-decoration: line-through; }

  .q-collection-simple .qcmCard__actions{ margin-top: 6px; display:grid; gap: 10px; }
  .q-collection-simple .qcmCard__btn{
    display:flex; align-items:center; justify-content:center;
    width:100%; max-width:100%;
    border: 1px solid var(--qcm-btn-border, rgba(0,0,0,.15));
    border-radius: calc(var(--qcm-radius) * 0.75);
    padding: 10px 12px;
    background: var(--qcm-btn-bg, transparent);
    color: var(--qcm-btn-text, inherit);
    text-decoration:none;
    cursor:pointer;
    font: inherit;
    line-height: 1.1;
    min-width: 0;
    white-space: normal;
    text-align:center;
  }
  .q-collection-simple .qcmCard__btn:hover{
    background: var(--qcm-btn-bg-hover, var(--qcm-btn-bg, transparent));
    color: var(--qcm-btn-text-hover, var(--qcm-btn-text, inherit));
  }
  .q-collection-simple .qcmCard__btn--sm{ padding: 8px 10px; font-size: .92em; }
  .q-collection-simple .qcmCard__btn--md{ padding: 10px 12px; font-size: 1em; }
  .q-collection-simple .qcmCard__btn--lg{ padding: 12px 14px; font-size: 1.05em; }

  .q-collection-simple .qcmCard__metaRow{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
  .q-collection-simple .qcmIconBtn{
    display:inline-flex; align-items:center; justify-content:center;
    width: 40px; height: 40px;
    border-radius: 999px;
    border: 1px solid var(--qcm-btn-border, rgba(0,0,0,.15));
    background: transparent;
    cursor:pointer;
    text-decoration:none;
    color: inherit;
  }
  .q-collection-simple .qcmIconBtn.is-active{ background: rgba(0,0,0,.06); }

  .q-collection-simple .qcmSwatches{ display:flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
  .q-collection-simple .qcmSwatch{
    width: 18px; height: 18px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.18);
    background: rgba(0,0,0,.12);
    cursor:pointer;
  }
  .q-collection-simple .qcmSwatch[aria-current="true"]{
    outline: 2px solid rgba(0,0,0,.2);
    outline-offset: 2px;
  }
</style>

<article class="qcmCard qcmCard--{{ card_style }}" data-qcm-card>
  <a class="qcmCard__media" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
    <span class="qcmCard__mediaInner">
      {%- if featured_media != blank -%}
        {{ featured_media | image_url: width: 900 | image_tag: class: 'qcmCard__img', loading: 'lazy', widths: '240,360,480,600,720,900', sizes: '(min-width: 990px) 25vw, (min-width: 680px) 33vw, 50vw', attributes: 'data-qcm-card-image' }}
      {%- endif -%}
      {%- if second_media != blank -%}
        {{ second_media | image_url: width: 900 | image_tag: class: 'qcmCard__img qcmCard__img--second', loading: 'lazy', widths: '240,360,480,600,720,900', sizes: '(min-width: 990px) 25vw, (min-width: 680px) 33vw, 50vw' }}
      {%- endif -%}

      {%- if show_badges -%}
        <span class="qcmCard__badges" aria-hidden="true">
          {%- if available == false -%}
            <span class="qcmBadge">Sold out</span>
          {%- elsif on_sale -%}
            <span class="qcmBadge">Sale</span>
          {%- endif -%}
        </span>
      {%- endif -%}
    </span>
  </a>

  <div class="qcmCard__content">
    <div class="qcmCard__metaRow">
      {%- if show_vendor and p.vendor != blank -%}
        <div class="qcmCard__vendor">{{ p.vendor }}</div>
      {%- endif -%}

      {%- if s.enable_wishlist -%}
        <button type="button" class="qcmIconBtn" data-qcm-wish-toggle data-handle="{{ p.handle }}" aria-pressed="false" aria-label="Save">♥</button>
      {%- endif -%}

      {%- if s.enable_compare -%}
        <button type="button" class="qcmIconBtn" data-qcm-compare-toggle data-handle="{{ p.handle }}" data-title="{{ p.title | escape }}" aria-pressed="false" aria-label="Compare">≋</button>
      {%- endif -%}
    </div>

    <h3 class="qcmCard__title">
      <a href="{{ p.url }}">{{ p.title }}</a>
    </h3>

    {%- if show_price -%}
      <div class="qcmCard__price">
        {%- if on_sale -%}
          <span>{{ p.price | money }}</span>
          <span class="qcmPrice--compare">{{ p.compare_at_price | money }}</span>
        {%- else -%}
          <span>{{ p.price | money }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if show_rating -%}
      <div style="opacity:.7; font-size: .92em;">★★★★★ <span style="opacity:.6">(rating)</span></div>
    {%- endif -%}

    {%- if has_swatches -%}
      <div class="qcmSwatches" aria-label="Swatches">
        {%- assign rendered = 0 -%}
        {%- assign seen = '' -%}
        {%- assign first_set = false -%}

        {%- for v in p.variants -%}
          {%- if rendered >= swatch_limit -%}{%- break -%}{%- endif -%}

          {%- liquid
            assign opt_val = ''
            if swatch_index == 1
              assign opt_val = v.option1
            elsif swatch_index == 2
              assign opt_val = v.option2
            elsif swatch_index == 3
              assign opt_val = v.option3
            endif
          -%}

          {%- if opt_val == blank -%}{%- continue -%}{%- endif -%}

          {%- assign token = '|' | append: opt_val | append: '|' -%}
          {%- if seen contains token -%}{%- continue -%}{%- endif -%}
          {%- assign seen = seen | append: token -%}

          {%- assign img = '' -%}
          {%- if v.featured_image != blank -%}
            {%- assign img = v.featured_image | image_url: width: 900 -%}
          {%- endif -%}

          {%- assign is_current = false -%}
          {%- if first_set == false -%}
            {%- assign is_current = true -%}
            {%- assign first_set = true -%}
          {%- endif -%}

          <button
            type="button"
            class="qcmSwatch"
            data-qcm-swatch
            data-variant-id="{{ v.id }}"
            data-image="{{ img }}"
            aria-current="{% if is_current %}true{% else %}false{% endif %}"
            aria-label="{{ opt_val | escape }}"
          ></button>

          {%- assign rendered = rendered | plus: 1 -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="qcmCard__actions">
      {%- if s.enable_quick_view -%}
        <button type="button" class="qcmCard__btn qcmCard__btn--{{ btn_size }}" data-qcm-quickview data-handle="{{ p.handle }}" data-url="{{ p.url }}">
          Quick view
        </button>
      {%- endif -%}

      {%- if show_quick_add -%}
        {%- if p.available == false -%}
          <button class="qcmCard__btn qcmCard__btn--{{ btn_size }}" type="button" disabled style="opacity:.6;cursor:not-allowed;">Sold out</button>
        {%- elsif p.has_only_default_variant -%}
          {%- if show_buy_now -%}
            <a class="qcmCard__btn qcmCard__btn--{{ btn_size }}" href="/cart/{{ p.selected_or_first_available_variant.id }}:1?checkout">
              {{ buy_now_label }}
            </a>
          {%- else -%}
            <form method="post" action="{{ routes.cart_add_url }}">
              <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}" data-qcm-variant-id>
              <button class="qcmCard__btn qcmCard__btn--{{ btn_size }}" type="submit">{{ atc_label }}</button>
            </form>
          {%- endif -%}
        {%- else -%}
          <a class="qcmCard__btn qcmCard__btn--{{ btn_size }}" href="{{ p.url }}">{{ choose_label }}</a>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</article>