{%- comment -%}
  Quadratum — Collection Modern — Quick Filters
  File: snippets/collection-modern-quick-filters.liquid
  Liquid-first: uses real filter.value url_to_add/url_to_remove
{%- endcomment -%}

{%- liquid
  assign root_id = root_id
  assign s = s
  assign filters = filters
  assign show = false
  if s.enable_quick_filters and section.blocks.size > 0 and filters != blank
    assign show = true
  endif
-%}

{%- if show -%}
  <div class="qcm__quickFilters" data-qcm-quickfilters>
    <div class="qcm__quickFiltersInner">
      {%- for block in section.blocks -%}
        {%- if block.type != 'quick_filter' -%}{% continue %}{%- endif -%}

        {%- liquid
          assign target_filter = nil
          assign target_value = nil

          assign want_f = block.settings.filter_label | downcase | strip
          assign want_v = block.settings.value_label | downcase | strip

          for f in filters
            if f.label != blank and f.label | downcase | strip == want_f
              assign target_filter = f
              break
            endif
          endfor

          if target_filter != nil
            for v in target_filter.values
              if v.label != blank and v.label | downcase | strip == want_v
                assign target_value = v
                break
              endif
            endfor
          endif

          assign is_active = false
          assign href = ''
          if target_value != nil
            if target_value.active
              assign is_active = true
              assign href = target_value.url_to_remove
            else
              assign href = target_value.url_to_add
            endif
          endif
        -%}

        {%- if target_value == nil or href == blank -%}
          {%- continue -%}
        {%- endif -%}

        <a
          class="qcm__qf qcm__qf--{{ block.settings.chip_style }}{% if is_active %} is-active{% endif %}"
          href="{{ href }}"
          {% if is_active %}aria-current="true"{% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="qcm__qfLabel">{{ target_value.label }}</span>
          {%- if is_active -%}
            <span class="qcm__qfX" aria-hidden="true">×</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}