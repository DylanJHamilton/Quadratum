{% liquid
  assign s = section.settings
  assign main_menu = linklists[s.menu]
%}

<header id="HeaderOne-{{ section.id }}" class="q-header-one">
  
<style>
#HeaderOne-{{ section.id }}{
  --q-h1-bg: {{ s.bg_color }};
  --q-h1-text: {{ s.text_color }};
  --q-h1-border: {{ s.border_color }};
  --q-h1-link: {{ s.link_color }};
  --q-h1-link-hover: {{ s.link_hover_color }};
  --q-h1-max: {{ s.max_width }};
}

#HeaderOne-{{ section.id }}{
  background: var(--q-h1-bg);
  color: var(--q-h1-text);
  border-bottom: 1px solid var(--q-h1-border);
}

#HeaderOne-{{ section.id }} *{
  box-sizing: border-box;
}

#HeaderOne-{{ section.id }} .qh1-inner{
  max-width: var(--q-h1-max);
  margin: 0 auto;
  padding: 14px 20px;
}

#HeaderOne-{{ section.id }} .qh1-bar{
  display:grid;
  grid-template-columns:auto 1fr auto;
  align-items:center;
  gap:20px;
}

.qh1-brand{
  display:flex;
  align-items:center;
  gap:10px;
  text-decoration:none;
  color:inherit;
}

.qh1-logo{
  max-height:36px;
  width:auto;
}

.qh1-title{
  font-weight:700;
  font-size:1.1rem;
}

.qh1-nav{
  display:flex;
  justify-content:center;
  gap:26px;
}

.qh1-nav a{
  text-decoration:none;
  color:var(--q-h1-link);
  font-size:.95rem;
}

.qh1-nav a:hover{
  color:var(--q-h1-link-hover);
}

.qh1-actions{
  display:flex;
  align-items:center;
  gap:14px;
}

.qh1-cart{
  position:relative;
  cursor:pointer;
  background:none;
  border:none;
  font-size:20px;
}

.qh1-cart-count{
  position:absolute;
  top:-6px;
  right:-8px;
  background:#000;
  color:#fff;
  font-size:11px;
  padding:2px 6px;
  border-radius:999px;
}

.qh1-mobile-toggle{
  display:none;
  background:none;
  border:none;
  font-size:22px;
}

.qh1-mobile{
  display:none;
  border-top:1px solid var(--q-h1-border);
}

.qh1-mobile a{
  display:block;
  padding:12px 20px;
  text-decoration:none;
  color:var(--q-h1-link);
}

.qh1-mobile a:hover{
  background:rgba(0,0,0,.04);
}

@media (max-width: 900px){

  .qh1-nav{
    display:none;
  }

  .qh1-mobile-toggle{
    display:block;
  }

}
</style>


<div class="qh1-inner">

  <div class="qh1-bar">

    <!-- Mobile toggle -->
    <button class="qh1-mobile-toggle" onclick="document.getElementById('qh1-mobile-{{ section.id }}').classList.toggle('open')">
      ☰
    </button>


    <!-- Brand -->
    <a class="qh1-brand" href="{{ routes.root_url }}">

      {% if s.logo %}
        <img
          src="{{ s.logo | image_url: width: 300 }}"
          alt="{{ shop.name }}"
          class="qh1-logo"
        >
      {% endif %}

      {% if s.show_store_name %}
        <span class="qh1-title">{{ shop.name }}</span>
      {% endif %}

    </a>


    <!-- Desktop menu -->
    <nav class="qh1-nav">

      {% for link in main_menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}

    </nav>


    <!-- Actions -->
    <div class="qh1-actions">

      <!-- Cart button -->
      <button
        class="qh1-cart"
        data-cart-drawer-open
        aria-label="Open cart"
      >
        🛒

        <span class="qh1-cart-count" data-cart-count>
          {{ cart.item_count }}
        </span>

      </button>

    </div>

  </div>

</div>


<!-- Mobile Menu -->
<div id="qh1-mobile-{{ section.id }}" class="qh1-mobile">

  {% for link in main_menu.links %}
    <a href="{{ link.url }}">{{ link.title }}</a>
  {% endfor %}

</div>

</header>



{% schema %}
{
  "name": "Header One",
  "settings": [

    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu"
    },

    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },

    {
      "type": "checkbox",
      "id": "show_store_name",
      "label": "Show store name",
      "default": true
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },

    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e5e5e5"
    },

    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#111111"
    },

    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#555555"
    },

    {
      "type": "text",
      "id": "max_width",
      "label": "Max width",
      "default": "1400px"
    }

  ],
  "presets": [
    {
      "name": "Header One"
    }
  ]
}
{% endschema %}