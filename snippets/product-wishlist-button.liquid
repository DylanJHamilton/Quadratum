{%- comment -%}
  Q ADD-ON: Wishlist Button (Classic)
  Inputs:
    - product
    - variant
    - style: 'icon' | 'button'
    - label
    - section_id (optional)
{%- endcomment -%}

{%- liquid
  assign p = product
  assign v = variant
  assign style_mode = style | default: 'icon'
  assign btn_label = label | default: 'Add to wishlist'
  assign sid = section_id | default: ''
-%}

<button
  type="button"
  class="q-wishlist q-wishlist--{{ style_mode }}"
  data-wishlist-button
  data-product-id="{{ p.id }}"
  data-variant-id="{{ v.id }}"
  aria-label="{{ btn_label | escape }}"
  {%- if sid != blank -%} data-section-id="{{ sid }}"{%- endif -%}
>
  <span class="q-wishlist__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="20" height="20" focusable="false" aria-hidden="true">
      <path d="M12 21s-7.2-4.6-9.6-8.4C.6 9.7 2.3 6 6.3 6c2 0 3.2 1.1 3.7 1.8.5-.7 1.7-1.8 3.7-1.8 4 0 5.7 3.7 3.9 6.6C19.2 16.4 12 21 12 21z" fill="currentColor"></path>
    </svg>
  </span>

  {%- if style_mode == 'button' -%}
    <span class="q-wishlist__label">{{ btn_label }}</span>
  {%- else -%}
    <span class="q-visually-hidden">{{ btn_label }}</span>
  {%- endif -%}
</button>