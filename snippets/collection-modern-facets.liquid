{%- comment -%}
  Minimal facets renderer for Collection Modern Simple
  File: snippets/collection-modern-simple-facets.liquid

  Uses Shopify collection.filters.
  HTML-first, GET form, works without JS.
{%- endcomment -%}

{%- liquid
  assign c = target_collection
  if c == blank
    assign c = collection
  endif
-%}

<form method="get" action="{{ c.url }}" class="qcmFacets">
  {%- for qp in request.query_params -%}
    {%- assign k = qp[0] -%}
    {%- assign v = qp[1] -%}
    {%- unless k == 'page' -%}
      {%- if v != blank -%}
        <input type="hidden" name="{{ k | escape }}" value="{{ v | escape }}">
      {%- endif -%}
    {%- endunless -%}
  {%- endfor -%}

  {%- for filter in c.filters -%}
    <details class="qcmFacet" {% if filter.active_values.size > 0 %}open{% endif %}>
      <summary class="qcmFacet__summary">
        <span>{{ filter.label }}</span>
        {%- if filter.active_values.size > 0 -%}
          <span class="qcmFacet__count">{{ filter.active_values.size }}</span>
        {%- endif -%}
      </summary>

      <div class="qcmFacet__body">
        {%- if filter.type == 'list' -%}
          <ul class="qcmFacet__list" role="list">
            {%- for v in filter.values -%}
              <li class="qcmFacet__item">
                <label class="qcmCheck">
                  <input type="checkbox"
                    name="{{ v.param_name }}"
                    value="{{ v.value }}"
                    {% if v.active %}checked{% endif %}
                    {% if v.count == 0 and v.active == false %}disabled{% endif %}>
                  <span>{{ v.label }}</span>
                  <small class="qcmMuted">{{ v.count }}</small>
                </label>
              </li>
            {%- endfor -%}
          </ul>
        {%- elsif filter.type == 'price_range' -%}
          <div class="qcmPriceRange">
            <label class="qcmField">
              <span class="qcmMuted">Min</span>
              <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}" inputmode="numeric">
            </label>
            <label class="qcmField">
              <span class="qcmMuted">Max</span>
              <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}" inputmode="numeric">
            </label>
          </div>
        {%- endif -%}
      </div>
    </details>
  {%- endfor -%}

  <div class="qcmFacet__actions">
    <button type="submit" class="qcmBtn">Apply</button>
    <a class="qcmBtn qcmBtn--ghost" href="{{ c.url }}">Reset</a>
  </div>
</form>