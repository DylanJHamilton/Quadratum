{% liquid
  assign main_menu = linklists[settings.desktop_menu]
  assign announce_text = settings.header_announce_text | default: settings.announcement_text
%}

{% if settings.header_announce_enable and announce_text != blank %}
  <div id="HeaderOneAnnounce-{{ section.id }}" class="q-h1a">
    <div class="q-h1a__inner">
      <p class="q-h1a__text">{{ announce_text }}</p>
    </div>
  </div>
{% endif %}

<details
  id="HeaderOne-{{ section.id }}"
  class="q-header-one{% if settings.header_sticky %} q-header-one--sticky{% endif %}"
>
  <style>
    #HeaderOne-{{ section.id }}{
      --qh1-bg: {{ section.settings.bg_color }};
      --qh1-bg-soft: {{ section.settings.bg_soft_color }};
      --qh1-text: {{ section.settings.text_color }};
      --qh1-border: {{ section.settings.border_color }};
      --qh1-link: {{ section.settings.link_color }};
      --qh1-link-hover: {{ section.settings.link_hover_color }};
      --qh1-icon-bg: {{ section.settings.icon_bg }};
      --qh1-icon-bg-hover: {{ section.settings.icon_bg_hover }};
      --qh1-icon-color: {{ section.settings.icon_color }};
      --qh1-radius: {{ section.settings.radius }}px;
      --qh1-logo-desktop: {{ section.settings.logo_height_desktop }}px;
      --qh1-logo-mobile: {{ section.settings.logo_height_mobile }}px;
      --qh1-cart-count-bg: {{ section.settings.cart_count_bg }};
      --qh1-cart-count-text: {{ section.settings.cart_count_text }};
      --qh1-shadow: 0 10px 30px rgba(0,0,0,.06);
    }

    #HeaderOneAnnounce-{{ section.id }}{
      width: 100%;
      background: {{ section.settings.announce_bg }};
      color: {{ section.settings.announce_text }};
      border-bottom: 1px solid {{ section.settings.border_color }};
    }

    #HeaderOneAnnounce-{{ section.id }} .q-h1a__inner{
      width: 100%;
      margin: 0;
      padding: 10px 0;
      text-align: center;
    }

    #HeaderOneAnnounce-{{ section.id }} .q-h1a__text{
      margin: 0;
      font-size: .9rem;
      line-height: 1.3;
    }

    #HeaderOne-{{ section.id }}{
      position: relative;
      z-index: 40;
      width: 100%;
      background: var(--qh1-bg);
      color: var(--qh1-text);
      border-bottom: 1px solid var(--qh1-border);
      box-shadow: var(--qh1-shadow);
    }

    #HeaderOne-{{ section.id }}.q-header-one--sticky{
      position: sticky;
      top: 0;
    }

    #HeaderOne-{{ section.id }} *{
      box-sizing: border-box;
    }

    #HeaderOne-{{ section.id }} summary{
      list-style: none;
    }

    #HeaderOne-{{ section.id }} summary::-webkit-details-marker{
      display: none;
    }

    #HeaderOne-{{ section.id }} .qh1__shell{
      width: 100%;
      margin: 0;
      padding: 0;
    }

    #HeaderOne-{{ section.id }} .qh1__bar{
      width: 100%;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 18px;
      min-height: 72px;
      padding: 0 24px;
    }

    #HeaderOne-{{ section.id }} .qh1__brand{
      display: inline-flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      color: inherit;
      min-width: 0;
    }

    #HeaderOne-{{ section.id }} .qh1__logo-wrap{
      display: inline-flex;
      align-items: center;
      min-width: 0;
    }

    #HeaderOne-{{ section.id }} .qh1__logo{
      display: block;
      width: auto;
      height: var(--qh1-logo-desktop);
      max-width: 100%;
      object-fit: contain;
    }

    #HeaderOne-{{ section.id }} .qh1__brand-text{
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -.01em;
      color: inherit;
      line-height: 1.1;
      white-space: nowrap;
    }

    #HeaderOne-{{ section.id }} .qh1__nav{
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      min-width: 0;
      flex-wrap: wrap;
    }

    #HeaderOne-{{ section.id }} .qh1__nav a{
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 10px 14px;
      border-radius: calc(var(--qh1-radius) - 4px);
      text-decoration: none;
      color: var(--qh1-link);
      font-size: .96rem;
      font-weight: 500;
      transition: background .18s ease, color .18s ease, transform .18s ease;
    }

    #HeaderOne-{{ section.id }} .qh1__nav a:hover{
      background: var(--qh1-bg-soft);
      color: var(--qh1-link-hover);
      transform: translateY(-1px);
    }

    #HeaderOne-{{ section.id }} .qh1__actions{
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 10px;
    }

    #HeaderOne-{{ section.id }} .qh1__icon-btn{
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border: 1px solid var(--qh1-border);
      border-radius: 999px;
      background: var(--qh1-icon-bg);
      color: var(--qh1-icon-color);
      cursor: pointer;
      text-decoration: none;
      transition: background .18s ease, transform .18s ease, border-color .18s ease;
    }

    #HeaderOne-{{ section.id }} .qh1__icon-btn:hover{
      background: var(--qh1-icon-bg-hover);
      transform: translateY(-1px);
    }

    #HeaderOne-{{ section.id }} .qh1__icon{
      width: 20px;
      height: 20px;
      display: block;
    }

    #HeaderOne-{{ section.id }} .qh1__cart-count{
      position: absolute;
      top: -4px;
      right: -4px;
      min-width: 20px;
      height: 20px;
      padding: 0 5px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 700;
      line-height: 1;
      background: var(--qh1-cart-count-bg);
      color: var(--qh1-cart-count-text);
      border: 1px solid var(--qh1-bg);
    }

    #HeaderOne-{{ section.id }} .qh1__mobile-panel{
      display: none;
      width: 100%;
      border-top: 1px solid var(--qh1-border);
      background: var(--qh1-bg);
      padding: 10px 24px 16px;
    }

    #HeaderOne-{{ section.id }}[open] .qh1__mobile-panel{
      display: none;
    }

    #HeaderOne-{{ section.id }} .qh1__mobile-menu{
      display: grid;
      gap: 6px;
    }

    #HeaderOne-{{ section.id }} .qh1__mobile-menu a{
      display: block;
      padding: 12px 14px;
      border-radius: calc(var(--qh1-radius) - 4px);
      text-decoration: none;
      color: var(--qh1-link);
      background: transparent;
      transition: background .18s ease, color .18s ease;
    }

    #HeaderOne-{{ section.id }} .qh1__mobile-menu a:hover{
      background: var(--qh1-bg-soft);
      color: var(--qh1-link-hover);
    }

    #HeaderOne-{{ section.id }} .qh1__mobile-toggle{
      display: none;
    }

    @media (max-width: 989px){
      #HeaderOne-{{ section.id }} .qh1__bar{
        grid-template-columns: auto 1fr auto;
      }

      #HeaderOne-{{ section.id }} .qh1__nav{
        display: none;
      }

      #HeaderOne-{{ section.id }} .qh1__mobile-toggle{
        display: inline-flex;
      }

      #HeaderOne-{{ section.id }} .qh1__logo{
        height: var(--qh1-logo-mobile);
      }

      #HeaderOne-{{ section.id }} .qh1__brand-text{
        font-size: 1rem;
      }

      #HeaderOne-{{ section.id }}[open] .qh1__mobile-panel{
        display: block;
      }
    }

    @media (max-width: 640px){
      #HeaderOne-{{ section.id }} .qh1__bar{
        gap: 12px;
        min-height: 64px;
        padding-left: 14px;
        padding-right: 14px;
      }

      #HeaderOne-{{ section.id }} .qh1__mobile-panel{
        padding-left: 14px;
        padding-right: 14px;
      }

      #HeaderOne-{{ section.id }} .qh1__brand-text{
        max-width: 140px;
        overflow: hidden;
        text-overflow: ellipsis;
      }
    }

    {{ settings.header_custom_css }}
  </style>

  <div class="qh1__shell">
    <div class="qh1__bar">

      <summary class="qh1__icon-btn qh1__mobile-toggle" aria-label="Open mobile menu">
        <svg class="qh1__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7H20M4 12H20M4 17H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </summary>

      <a class="qh1__brand" href="{{ routes.root_url }}">
        <span class="qh1__logo-wrap">
          {% if settings.logo_primary != blank %}
            <img
              class="qh1__logo"
              src="{{ settings.logo_primary | image_url: width: 500 }}"
              alt="{{ shop.name | escape }}"
              loading="eager"
            >
          {% elsif settings.logo_mobile != blank %}
            <img
              class="qh1__logo"
              src="{{ settings.logo_mobile | image_url: width: 500 }}"
              alt="{{ shop.name | escape }}"
              loading="eager"
            >
          {% endif %}
        </span>

        {% if settings.header_show_store_name %}
          <span class="qh1__brand-text">{{ shop.name }}</span>
        {% endif %}
      </a>

      <nav class="qh1__nav" aria-label="Primary navigation">
        {% if main_menu != blank %}
          {% for link in main_menu.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% endif %}
      </nav>

      <div class="qh1__actions">
        <button
          type="button"
          class="qh1__icon-btn"
          data-cart-drawer-open
          aria-label="Open cart"
        >
          <svg class="qh1__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 7H21L19.5 15H8L6 7Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M6 7L5.4 4.8C5.17 3.98 4.43 3.4 3.58 3.4H2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="9.5" cy="19" r="1.2" fill="currentColor"/>
            <circle cx="18" cy="19" r="1.2" fill="currentColor"/>
          </svg>

          <span class="qh1__cart-count" data-cart-count>
            {{ cart.item_count }}
          </span>
        </button>
      </div>

    </div>

    <div class="qh1__mobile-panel">
      <nav class="qh1__mobile-menu" aria-label="Mobile navigation">
        {% if main_menu != blank %}
          {% for link in main_menu.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% endif %}
      </nav>
    </div>
  </div>
</details>

{% schema %}
{
  "name": "Header One",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Radius",
      "min": 0,
      "max": 28,
      "step": 1,
      "default": 16,
      "unit": "px"
    },

    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "range",
      "id": "logo_height_desktop",
      "label": "Logo height desktop",
      "min": 20,
      "max": 120,
      "step": 2,
      "default": 38,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Logo height mobile",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 30,
      "unit": "px"
    },

    {
      "type": "header",
      "content": "Header colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bg_soft_color",
      "label": "Soft hover background",
      "default": "#f5f7fa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#2563eb"
    },

    {
      "type": "header",
      "content": "Icon buttons"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_bg_hover",
      "label": "Icon background hover",
      "default": "#f5f7fa"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "cart_count_bg",
      "label": "Cart count background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "cart_count_text",
      "label": "Cart count text",
      "default": "#ffffff"
    },

    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "color",
      "id": "announce_bg",
      "label": "Announcement background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "announce_text",
      "label": "Announcement text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Header One"
    }
  ]
}
{% endschema %}