{%- liquid
  assign placement = placement | default: 'sidebar'
  assign autosubmit = 'true'
  if s.enable_ajax == false
    assign autosubmit = 'false'
  endif
-%}

{%- if placement == 'drawer' -%}
  <div class="qcmDrawer" data-qcm-drawer hidden aria-hidden="true">
    <div class="qcmDrawer__overlay" data-qcm-drawer-close></div>
    <div class="qcmDrawer__panel" data-qcm-drawer-panel tabindex="-1">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;">
        <strong>Filters</strong>
        <button type="button" class="qcmBtn" data-qcm-drawer-close aria-label="Close filters">Close</button>
      </div>

      <div style="margin-top:14px;">
        {%- comment -%} FIX: call SIMPLE facets, not modern facets {%- endcomment -%}
        {% render 'collection-simple-facets',
          section: section,
          s: s,
          is_search: is_search,
          results_url: results_url,
          terms_q: terms_q,
          filters: filters,
          placement: 'sidebar'
        %}
      </div>
    </div>
  </div>
{%- endif -%}

<form
  method="get"
  action="{{ results_url }}"
  class="qcmFacetForm"
  data-qcm-facets-form
  data-qcm-autosubmit="{{ autosubmit }}"
>
  {%- if is_search and terms_q != blank -%}
    <input type="hidden" name="q" value="{{ terms_q | escape }}">
  {%- endif -%}

  {%- for f in filters -%}
    <details class="qcmFacet" {% if f.type != 'price_range' and f.active_values.size > 0 %}open{% endif %}>
      <summary>{{ f.label }}</summary>

      {%- if f.type == 'price_range' -%}
        <div class="qcmFacet__price">
          <input name="{{ f.min_value.param_name }}" type="number" inputmode="numeric" placeholder="Min" value="{{ f.min_value.value }}">
          <input name="{{ f.max_value.param_name }}" type="number" inputmode="numeric" placeholder="Max" value="{{ f.max_value.value }}">
          <button type="submit" class="qcmBtn">Apply</button>
        </div>

        {%- if f.min_value.value != blank or f.max_value.value != blank -%}
          <div style="margin-top:10px;">
            <a class="qcmBtn qcmBtn--ghost" href="{{ f.url_to_remove }}" data-qcm-ajax-link>Clear</a>
          </div>
        {%- endif -%}

      {%- else -%}
        <div class="qcmFacet__list">
          {%- for v in f.values -%}
            <label class="qcmFacet__row">
              <input
                type="checkbox"
                name="{{ v.param_name }}"
                value="{{ v.value }}"
                {% if v.active %}checked{% endif %}
                {% if v.count == 0 and v.active == false %}disabled{% endif %}
              >
              <span>{{ v.label }}</span>
              <span style="opacity:.65;">({{ v.count }})</span>
            </label>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </details>
  {%- endfor -%}

  <noscript>
    <button type="submit" class="qcmBtn" style="margin-top:12px;">Apply filters</button>
  </noscript>
</form>