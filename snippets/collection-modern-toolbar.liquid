{%- comment -%}
  Collection Modern — Toolbar
  File: snippets/collection-modern-toolbar.liquid
{%- endcomment -%}

{%- liquid
  assign toolbar_sticky = false
  if sticky_toolbar
    assign toolbar_sticky = true
  endif
-%}

<div class="qcm__toolbar {% if toolbar_sticky %}is-sticky{% endif %}" data-qcm-toolbar>
  <div class="qcm__toolbarTop">
    <div class="qcm__titleWrap">
      {%- if s.show_title -%}
        <h1 class="qcm__title">{{ results_title }}</h1>
      {%- endif -%}

      {%- if s.show_description and results_description != blank -%}
        <div class="qcm__descWrap">
          <div
            class="qcm__desc {% if s.description_style == 'full' %}is-full{% endif %}"
            data-qcm-desc
          >
            {{ results_description }}
          </div>

          {%- if s.description_style == 'truncated' -%}
            <button class="qcm__btn qcm__btn--ghost" type="button" data-qcm-desc-toggle aria-expanded="false">
              Toggle description
            </button>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="qcm__toolbarActions">
      {%- if s.show_result_count -%}
        <div class="qcm__count" aria-label="Results count">
          {%- if is_search_context -%}
            {{ search.results_count }} results
          {%- else -%}
            {{ collection.products_count }} products
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if s.show_sort -%}
        {% render 'collection-modern-sort',
          section: section,
          s: s,
          sort_options: sort_options,
          sort_by: sort_by,
          default_sort_by: default_sort_by
        %}
      {%- endif -%}

      {%- if has_filters and filter_mode == 'drawer' -%}
        <button class="qcm__btn qcm__btn--ghost" type="button" data-qcm-open-drawer>
          Filters
        </button>
      {%- endif -%}
    </div>
  </div>

  {%- if s.show_active_filters and has_filters -%}
    {% render 'collection-modern-active-filters',
      section: section,
      s: s,
      filters: filters,
      results_url: results_url,
      is_search_context: is_search_context,
      terms_q: terms_q
    %}
  {%- endif -%}
</div>