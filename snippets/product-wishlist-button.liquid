{%- comment -%}
  Q ADD-ON: Wishlist Button (Classic)
  Inputs:
    - product
    - variant
    - style: 'icon' | 'button'
    - label
    - section_id (optional)
{%- endcomment -%}

{%- liquid
  assign p = product
  assign v = variant
  assign style_mode = style | default: 'icon'
  assign btn_label = label | default: 'Add to wishlist'
  assign sid = section_id | default: ''
-%}

{%- comment -%} PRODUCT ADD-ON: Wishlist Button (SVG ONLY) {%- endcomment -%}
{%- liquid
  assign _label = label | default: 'Add to wishlist'
  assign _style = style | default: 'icon'
-%}

<button
  type="button"
  class="p-wl {% if _style == 'button' %}p-wl--button{% else %}p-wl--icon{% endif %}"
  data-wishlist-button
  data-product-id="{{ product.id }}"
  data-variant-id="{{ variant.id }}"
  aria-label="{{ _label | escape }}"
  aria-pressed="false"
>
  <span class="p-wl__icon" aria-hidden="true">
    <svg class="p-wl__svg" viewBox="0 0 24 24" width="20" height="20" role="presentation" focusable="false" aria-hidden="true">
      <path
        d="M20.8 4.6c-1.7-1.7-4.5-1.7-6.2 0L12 7.2 9.4 4.6c-1.7-1.7-4.5-1.7-6.2 0s-1.7 4.5 0 6.2L12 21.6l8.8-10.8c1.7-1.7 1.7-4.5 0-6.2z"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </span>

  {%- if _style == 'button' -%}
    <span class="p-wl__label">{{ _label }}</span>
  {%- endif -%}
</button>