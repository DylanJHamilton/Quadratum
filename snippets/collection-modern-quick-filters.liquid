{%- comment -%}
  Quadratum — Collection Modern: Quick Filter Chips
  File: snippets/collection-modern-quick-filters.liquid

  Uses blocks:
  - filter_label must match Shopify filter label (case-insensitive)
  - value_label must match filter value label (case-insensitive)

  Requires:
  - filters passed in render: {% render 'collection-modern-quick-filters', section: section, s: s, filters: filters %}
{%- endcomment -%}

{%- if section == blank or filters == blank -%}{% break %}{%- endif -%}

{%- assign has_blocks = false -%}
{%- for b in section.blocks -%}
  {%- if b.type == 'quick_filter' -%}
    {%- assign has_blocks = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}
{%- if has_blocks == false -%}{% break %}{%- endif -%}

<div class="qcm__quickFilters" data-qcm-quick-filters>
  {%- for block in section.blocks -%}
    {%- if block.type != 'quick_filter' -%}{% continue %}{%- endif -%}

    {%- liquid
      assign want_f_raw = block.settings.filter_label | default: ''
      assign want_v_raw = block.settings.value_label | default: ''

      assign want_f = want_f_raw | downcase | strip
      assign want_v = want_v_raw | downcase | strip

      assign chip_url = blank
      assign chip_active = false
      assign chip_text = block.settings.value_label | default: block.settings.filter_label | default: 'Filter'
    -%}

    {%- if want_f != blank and want_v != blank -%}
      {%- for f in filters -%}
        {%- assign f_label_norm = f.label | default: '' | downcase | strip -%}
        {%- if f_label_norm == want_f -%}
          {%- for v in f.values -%}
            {%- assign v_label_norm = v.label | default: '' | downcase | strip -%}
            {%- if v_label_norm == want_v -%}
              {%- if v.active -%}
                {%- assign chip_active = true -%}
                {%- assign chip_url = v.url_to_remove -%}
              {%- else -%}
                {%- assign chip_active = false -%}
                {%- assign chip_url = v.url_to_add -%}
              {%- endif -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- if chip_url != blank -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if chip_url != blank -%}
      <a
        href="{{ chip_url }}"
        class="qcm__pill{% if chip_active %} is-active{% endif %}"
        aria-current="{% if chip_active %}true{% else %}false{% endif %}"
        {{ block.shopify_attributes }}
      >
        {{ chip_text }}
      </a>
    {%- endif -%}
  {%- endfor -%}
</div>