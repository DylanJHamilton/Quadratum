{{ 'section-main-cart.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-main-cart.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign continue_shopping_url = section.settings.continue_shopping_url
  if continue_shopping_url == blank
    assign continue_shopping_url = routes.all_products_collection_url
  endif
-%}

<section
  id="QtmMainCart-{{ section.id }}"
  class="qtm-main-cart qtm-main-cart--{{ section.settings.cart_style }}"
  data-section-id="{{ section.id }}"
  style="
    --qcart-title-size: {{ section.settings.title_font_size }}px;
    --qcart-price-size: {{ section.settings.price_font_size }}px;
    --qcart-meta-size: {{ section.settings.meta_font_size }}px;
    --qcart-button-bg: {{ section.settings.checkout_button_color }};
    --qcart-button-text: {{ section.settings.checkout_button_text_color }};
    --qcart-button-border-width: {{ section.settings.checkout_button_border_width }}px;
    --qcart-button-radius: {{ section.settings.checkout_button_radius }}px;
    --qcart-button-padding-y: {{ section.settings.checkout_button_padding }}px;
    --qcart-item-gap: {{ section.settings.cart_item_spacing }}px;
    --qcart-section-padding-y: {{ section.settings.section_padding }}px;
  "
>
  <div class="qtm-main-cart__inner">
    {%- if section.settings.show_cart_title -%}
      <header class="qtm-main-cart__header">
        <h1 class="qtm-main-cart__title">Your Cart</h1>
      </header>
    {%- endif -%}

    <div class="qtm-main-cart__live-region visually-hidden" aria-live="polite" data-cart-live-region></div>

    {%- if cart.item_count > 0 -%}
      <div class="qtm-main-cart__layout">
        <div class="qtm-main-cart__items">
          <form action="{{ routes.cart_url }}" method="post" novalidate class="qtm-main-cart__form" data-cart-form>
            <div class="qtm-main-cart__items-list">
              {%- for item in cart.items -%}
                {% render 'cart-line-item',
                  item: item,
                  line_index: forloop.index,
                  section_id: section.id
                %}
              {%- endfor -%}
            </div>

            <div class="qtm-main-cart__fallback-actions">
              <button type="submit" name="update" class="qtm-main-cart__update-button">
                Update cart
              </button>
            </div>
          </form>
        </div>

        <aside class="qtm-main-cart__summary" aria-label="Cart summary">
          {% render 'cart-summary',
            cart: cart,
            section: section,
            section_id: section.id,
            continue_shopping_url: continue_shopping_url
          %}
        </aside>
      </div>

      <div class="qtm-main-cart__secondary">
        {% render 'cart-progress-rewards',
          cart: cart,
          section: section,
          section_id: section.id
        %}

        {% render 'cart-addons',
          section: section,
          section_id: section.id
        %}
      </div>
    {%- else -%}
      <div class="qtm-main-cart__empty">
        <div class="qtm-main-cart__empty-inner">
          <h2 class="qtm-main-cart__empty-title">Your cart is empty</h2>

          {%- if section.settings.empty_cart_message != blank -%}
            <div class="qtm-main-cart__empty-text rte">
              {{ section.settings.empty_cart_message }}
            </div>
          {%- endif -%}

          <a href="{{ continue_shopping_url }}" class="qtm-main-cart__continue-button">
            Continue shopping
          </a>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main Cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_cart_title",
      "label": "Show cart title",
      "default": true
    },
    {
      "type": "text",
      "id": "shipping_notice",
      "label": "Shipping notice",
      "default": "Shipping calculated at checkout."
    },
    {
      "type": "url",
      "id": "continue_shopping_url",
      "label": "Continue shopping URL"
    },
    {
      "type": "richtext",
      "id": "empty_cart_message",
      "label": "Empty cart message",
      "default": "<p>Looks like you have not added anything yet.</p>"
    },
    {
      "type": "header",
      "content": "Layout style"
    },
    {
      "type": "select",
      "id": "cart_style",
      "label": "Cart style",
      "default": "clean",
      "options": [
        {
          "value": "clean",
          "label": "Clean"
        },
        {
          "value": "soft",
          "label": "Soft"
        },
        {
          "value": "outline",
          "label": "Outline"
        }
      ]
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 20,
      "max": 60,
      "step": 1,
      "default": 34
    },
    {
      "type": "range",
      "id": "price_font_size",
      "label": "Price font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "meta_font_size",
      "label": "Meta font size",
      "min": 11,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "select",
      "id": "checkout_button_style",
      "label": "Checkout button style",
      "default": "solid",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "outline",
          "label": "Outline"
        },
        {
          "value": "soft",
          "label": "Soft"
        }
      ]
    },
    {
      "type": "color",
      "id": "checkout_button_color",
      "label": "Checkout button color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "checkout_button_text_color",
      "label": "Checkout button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "checkout_button_border_width",
      "label": "Checkout button border width",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "checkout_button_radius",
      "label": "Checkout button radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "checkout_button_padding",
      "label": "Checkout button vertical padding",
      "min": 8,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "cart_item_spacing",
      "label": "Cart item spacing",
      "min": 8,
      "max": 48,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "reward_tier",
      "name": "Reward tier",
      "settings": [
        {
          "type": "number",
          "id": "threshold_amount",
          "label": "Threshold amount",
          "default": 50
        },
        {
          "type": "text",
          "id": "locked_text",
          "label": "Locked text",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "unlocked_text",
          "label": "Unlocked text",
          "default": "Free Shipping unlocked"
        },
        {
          "type": "select",
          "id": "reward_type",
          "label": "Reward type",
          "default": "shipping",
          "options": [
            {
              "value": "shipping",
              "label": "Free shipping"
            },
            {
              "value": "gift",
              "label": "Free gift"
            },
            {
              "value": "bonus",
              "label": "Bonus item"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon text",
          "default": "★"
        }
      ]
    },
    {
      "type": "addon_product",
      "name": "Add-on product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_label",
          "label": "Custom label"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main Cart"
    }
  ]
}
{% endschema %}