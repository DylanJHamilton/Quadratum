<div class="qtm-cart-summary" data-cart-summary aria-live="polite">
  <h2 class="qtm-cart-summary__title">Summary</h2>

  <div class="qtm-cart-summary__rows">
    <div class="qtm-cart-summary__row">
      <span class="qtm-cart-summary__label">Subtotal</span>
      <span class="qtm-cart-summary__value" data-cart-subtotal>
        {{ cart.total_price | money }}
      </span>
    </div>

    {%- if cart.cart_level_discount_applications.size > 0 -%}
      {%- for discount in cart.cart_level_discount_applications -%}
        <div class="qtm-cart-summary__row qtm-cart-summary__row--discount">
          <span class="qtm-cart-summary__label">{{ discount.title }}</span>
          <span class="qtm-cart-summary__value">
            -{{ discount.total_allocated_amount | money }}
          </span>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if section.settings.shipping_notice != blank -%}
    <div class="qtm-cart-summary__notice qtm-cart-summary__notice--shipping">
      {{ section.settings.shipping_notice }}
    </div>
  {%- endif -%}

  <div class="qtm-cart-summary__notice qtm-cart-summary__notice--tax">
    Taxes calculated at checkout.
  </div>

  <div class="qtm-cart-summary__actions">
    <a href="/checkout" class="qtm-cart-summary__checkout-button">
      Checkout
    </a>

    {%- if continue_shopping_url != blank -%}
      <a href="{{ continue_shopping_url }}" class="qtm-cart-summary__continue-link">
        Continue shopping
      </a>
    {%- endif -%}
  </div>
</div>