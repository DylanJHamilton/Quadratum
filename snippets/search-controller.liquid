<script>
  (function () {
    document.documentElement.dataset.searchMode = {{ settings.search_mode | json }};
    window.QTM_SEARCH = {
      mode: {{ settings.search_mode | json }},
      sources: {
        products: {{ settings.search_src_products | json }},
        collections: {{ settings.search_src_collections | json }},
        articles: {{ settings.search_src_articles | json }},
        pages: {{ settings.search_src_pages | json }}
      },
      limits: {
        products: {{ settings.predictive_search_products_limit | default: settings.search_results_limit | json }},
        collections: {{ settings.predictive_search_collections_limit | default: settings.search_results_limit | json }},
        articles: {{ settings.predictive_search_articles_limit | default: settings.search_results_limit | json }},
        pages: {{ settings.predictive_search_pages_limit | default: settings.search_results_limit | json }}
      },
      minChars: {{ settings.predictive_search_min_chars | default: 2 | json }},
      debounce: {{ settings.predictive_search_debounce | default: 250 | json }}
    };
  })();
</script>