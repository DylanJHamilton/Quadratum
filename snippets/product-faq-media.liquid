{%- comment -%}
  Snippet: product-faq-media.liquid
  Inputs:
  - section (required for settings)
  - media_type: image | video | external_video | model
  - image, video, model (objects)
  - external_url (string)
  - poster (image object, optional)
  - alt (string)
  - sizes, widths
  - mode: 'inline' | 'stage'
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign m_type = media_type | default: 'none'
  assign fit = s.media_fit | default: 'cover'
  assign radius = s.media_radius | default: 12
  assign zoom = s.media_enable_zoom
  assign ar = s.media_aspect_ratio | default: 'adapt'
  assign ar_style = ''

  if ar != 'adapt'
    assign ar_style = 'aspect-ratio:' | append: ar | append: ';'
  endif

  assign wrap_classes = 'q-pfaq__media'
  if zoom
    assign wrap_classes = wrap_classes | append: ' q-pfaq__media--zoom'
  endif

  assign alt_text = alt | default: ''
-%}

<div class="{{ wrap_classes }}" style="{{ ar_style }} border-radius: {{ radius }}px;">
  {%- case m_type -%}
    {%- when 'image' -%}
      {%- if image != blank -%}
        {{ image
          | image_url: width: 1600
          | image_tag:
            widths: widths,
            sizes: sizes,
            loading: 'lazy',
            class: 'q-pfaq__img',
            alt: alt_text
        }}
      {%- endif -%}

    {%- when 'video' -%}
      {%- if video != blank -%}
        {{ video | video_tag: class: 'q-pfaq__video', controls: true, preload: 'metadata' }}
      {%- endif -%}

    {%- when 'external_video' -%}
      {%- if external_url != blank -%}
        <div class="q-pfaq__ext">
          <iframe
            class="q-pfaq__iframe"
            src="{{ external_url | escape }}"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title="{{ alt_text | escape }}"
          ></iframe>
        </div>
      {%- endif -%}

    {%- when 'model' -%}
      {%- if model != blank -%}
        {%- comment -%}
          Minimal safe fallback: if model is actually a product reference, attempt first 3D model.
        {%- endcomment -%}
        {%- assign model_media = blank -%}
        {%- if model.media != blank -%}
          {%- for pm in model.media -%}
            {%- if pm.media_type == 'model' -%}
              {%- assign model_media = pm -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- if model_media != blank -%}
          {{ model_media | model_viewer_tag: class: 'q-pfaq__model', reveal: 'interaction', toggleable: true }}
        {%- elsif poster != blank -%}
          {{ poster | image_url: width: 1600 | image_tag: widths: widths, sizes: sizes, loading: 'lazy', class: 'q-pfaq__img', alt: alt_text }}
        {%- endif -%}
      {%- endif -%}
  {%- endcase -%}
</div>

<style>
  /* Fit applies across image/video/iframe/model inside wrapper */
  #ProductFAQ-{{ section.id }} .q-pfaq__img,
  #ProductFAQ-{{ section.id }} .q-pfaq__video,
  #ProductFAQ-{{ section.id }} .q-pfaq__iframe,
  #ProductFAQ-{{ section.id }} .q-pfaq__model {
    width: 100%;
    height: 100%;
    border-radius: inherit;
    display: block;
  }
  #ProductFAQ-{{ section.id }} .q-pfaq__img,
  #ProductFAQ-{{ section.id }} .q-pfaq__video,
  #ProductFAQ-{{ section.id }} .q-pfaq__iframe {
    object-fit: {{ s.media_fit | default: 'cover' }};
  }
</style>