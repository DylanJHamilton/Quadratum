{%- comment -%}
  Quadratum — Main Collection Simple
  File: sections/main-collection-simple.liquid

  Self-contained:
  - assets/section-collection-simple.css
  - assets/section-collection-simple.js
  - snippets/collection-simple-* (local)

  Supports:
  - Collection context (collection)
  - Search context (search results; product-only skip)
  - Optional alternate collection override
  - Filters/Sorting/Pagination (Liquid-first)
  - AJAX enhancement (optional)
  - Quick filters via blocks (optional)
  - Quick View Lite (optional)
  - Compare (optional)
  - Wishlist (optional)
  - Swatches on card (optional)
{%- endcomment -%}

{{ 'section-collection-simple.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings

  assign is_search = false
  if request.page_type == 'search' and search != blank
    assign is_search = true
  endif

  assign use_alt = false
  if s.use_alt_collection and s.alt_collection != blank
    assign use_alt = true
  endif

  assign results_title = ''
  assign results_url = ''
  assign results_description = ''
  assign terms_q = ''

  assign filters_obj = nil
  assign sort_options_obj = nil
  assign sort_by_val = ''
  assign default_sort_by_val = ''

  if use_alt
    assign c = s.alt_collection
    assign filters_obj = c.filters
    assign sort_options_obj = c.sort_options
    assign sort_by_val = c.sort_by
    assign default_sort_by_val = c.default_sort_by
    assign results_title = c.title
    assign results_url = c.url
    assign results_description = c.description
  elsif is_search
    assign filters_obj = search.filters
    assign sort_options_obj = search.sort_options
    assign sort_by_val = search.sort_by
    assign default_sort_by_val = search.default_sort_by
    assign results_title = s.search_title | default: 'Search results'
    assign results_url = routes.search_url
    assign results_description = ''
    assign terms_q = search.terms | default: ''
  else
    assign c = collection
    assign filters_obj = c.filters
    assign sort_options_obj = c.sort_options
    assign sort_by_val = c.sort_by
    assign default_sort_by_val = c.default_sort_by
    assign results_title = c.title
    assign results_url = c.url
    assign results_description = c.description
  endif

  assign layout = s.layout_preset | default: 'modern_grid'
  assign filter_mode = s.filter_presentation | default: 'sidebar'
  assign per_page = s.products_per_page | default: 24
  assign pagination_style = s.pagination_style | default: 'numbered'

  assign root_id = 'QtmCollectionSimple-' | append: section.id

  assign cols_d = s.columns_desktop | default: 4
  assign cols_t = s.columns_tablet  | default: 3
  assign cols_m = s.columns_mobile  | default: 2

  assign has_filters = false
  if s.show_filters and filters_obj != blank and filters_obj.size > 0
    assign has_filters = true
  endif

  assign effective_filter_mode = filter_mode
  if has_filters == false
    assign effective_filter_mode = 'none'
  endif

  assign sticky_toolbar = false
  if has_filters and effective_filter_mode == 'bar' and s.sticky_filter_bar
    assign sticky_toolbar = true
  endif

  assign enable_drawer = false
  if has_filters and effective_filter_mode == 'drawer'
    assign enable_drawer = true
  endif

  assign enable_ajax = false
  if s.enable_ajax
    assign enable_ajax = true
  endif

  assign enable_quick_filters = false
  if s.show_quick_filters
    assign enable_quick_filters = true
  endif

  assign card_engine = s.card_engine | default: 'default_theme_card'

  assign enable_quick_view = false
  if s.enable_quick_view
    assign enable_quick_view = true
  endif

  assign enable_compare = false
  if s.enable_compare
    assign enable_compare = true
  endif

  assign enable_wishlist = false
  if s.enable_wishlist
    assign enable_wishlist = true
  endif

  assign enable_swatches = false
  if s.enable_card_swatches
    assign enable_swatches = true
  endif

  assign ajax_str = enable_ajax | json
  assign drawer_str = enable_drawer | json
  assign qv_str = enable_quick_view | json
  assign compare_str = enable_compare | json
  assign wish_str = enable_wishlist | json
  assign swatches_str = enable_swatches | json
-%}

<section
  id="{{ root_id }}"
  class="q-collection-simple qcm layout-{{ layout }} density-{{ s.card_density }} cardstyle-{{ s.card_style }} hover-{{ s.hover_effects }} reveal-{{ s.reveal_animation }} scheme-{{ s.color_scheme }}"
  data-section-id="{{ section.id }}"
  data-enable-ajax="{{ ajax_str }}"
  data-filter-mode="{{ effective_filter_mode }}"
  data-enable-drawer="{{ drawer_str }}"
  data-pagination-style="{{ pagination_style }}"
  data-enable-quickview="{{ qv_str }}"
  data-enable-compare="{{ compare_str }}"
  data-enable-wishlist="{{ wish_str }}"
  data-enable-swatches="{{ swatches_str }}"
  data-wishlist-key="{{ s.wishlist_key | escape }}"
  data-compare-key="{{ s.compare_key | escape }}"
  data-compare-max="{{ s.compare_max }}"
>
  <style>
    #{{ root_id }}{
      --qcm-maxw: {{ s.max_width }};
      --qcm-gap: {{ s.gap }}px;
      --qcm-radius: {{ s.border_radius }}px;

      --qcm-cols-d: {{ cols_d }};
      --qcm-cols-t: {{ cols_t }};
      --qcm-cols-m: {{ cols_m }};

      --qcm-truncate-lines: {{ s.truncated_lines }};

      --qcm-vendor-color: {{ s.vendor_color }};
      --qcm-title-color: {{ s.title_color }};
      --qcm-price-color: {{ s.price_color }};

      --qcm-vendor-size-set: {{ s.vendor_font_size }}px;
      --qcm-title-size-set: {{ s.title_font_size }}px;
      --qcm-price-size-set: {{ s.price_font_size }}px;

      --qcm-card-bg: {{ s.card_bg }};
      --qcm-card-border: {{ s.card_border }};
      --qcm-card-border-style: {{ s.card_border_style }};

      --qcm-btn-bg: {{ s.button_bg }};
      --qcm-btn-text: {{ s.button_text }};
      --qcm-btn-bg-hover: {{ s.button_bg_hover }};
      --qcm-btn-text-hover: {{ s.button_text_hover }};
      --qcm-btn-border: {{ s.button_border }};

      --qcm-toolbar-gap: {{ s.toolbar_gap }}px;
    }
  </style>

  <div class="qcm__container {% if s.max_width_toggle == 'contained' %}qcm__container--contained{% endif %}">

    {%- if enable_quick_filters -%}
      <div class="qcmQuickFilters" data-qcm-quickfilters>
        {%- for block in section.blocks -%}
          {%- if block.type == 'quick_filter_group' -%}
            {%- liquid
              assign g_title = block.settings.title
              assign g_style = block.settings.style | default: 'pills'
              assign raw_items = block.settings.items | default: ''
              assign items_lines = raw_items | newline_to_br | split: '<br />'
            -%}
            {%- if g_title != blank and raw_items != blank -%}
              <div class="qcmQF qcmQF--{{ g_style }}" {{ block.shopify_attributes }}>
                <div class="qcmQF__title">{{ g_title }}</div>
                <div class="qcmQF__items" role="list">
                  {%- for line in items_lines -%}
                    {%- liquid
                      assign l = line | strip
                      if l == blank
                        continue
                      endif

                      assign parts = l | split: '|'
                      assign lbl = parts[0] | default: '' | strip
                      assign param = parts[1] | default: '' | strip
                      assign val = parts[2] | default: '' | strip
                      assign sw = ''
                      if parts.size > 3
                        assign sw = parts[3] | strip
                      endif

                      if lbl == blank or param == blank or val == blank
                        continue
                      endif

                      assign href = results_url
                      assign glue = '?'
                      if href contains '?'
                        assign glue = '&'
                      endif

                      if is_search and terms_q != blank
                        assign href = routes.search_url | append: '?q=' | append: terms_q | url_encode
                        assign glue = '&'
                      endif

                      assign href = href | append: glue | append: param | append: '=' | append: val | url_encode
                    -%}

                    <a class="qcmQF__item" href="{{ href }}" data-qcm-ajax-link role="listitem" aria-label="{{ lbl | escape }}">
                      {%- if g_style == 'swatches' and sw != blank -%}
                        <span class="qcmQF__sw" style="--qcm-sw: {{ sw }};"></span>
                      {%- endif -%}
                      <span class="qcmQF__lbl">{{ lbl }}</span>
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {% render 'collection-simple-toolbar',
      section: section,
      s: s,
      is_search: is_search,
      results_title: results_title,
      results_url: results_url,
      results_description: results_description,
      terms_q: terms_q,
      has_filters: has_filters,
      filters: filters_obj,
      sort_options: sort_options_obj,
      sort_by: sort_by_val,
      default_sort_by: default_sort_by_val,
      sticky_toolbar: sticky_toolbar,
      filter_mode: effective_filter_mode
    %}

    <div class="qcm__body qcm__body--mode-{{ effective_filter_mode }}">
      {%- if has_filters and effective_filter_mode == 'sidebar' -%}
        <aside class="qcm__sidebar" aria-label="Filters" data-qcm-facets>
          {% render 'collection-simple-facets',
            section: section,
            s: s,
            is_search: is_search,
            results_url: results_url,
            terms_q: terms_q,
            filters: filters_obj,
            placement: 'sidebar'
          %}
        </aside>
      {%- endif -%}

      <div class="qcm__main">
        {%- if has_filters and effective_filter_mode == 'drawer' -%}
          <div data-qcm-facets>
            {% render 'collection-simple-facets',
              section: section,
              s: s,
              is_search: is_search,
              results_url: results_url,
              terms_q: terms_q,
              filters: filters_obj,
              placement: 'drawer'
            %}
          </div>

          <noscript>
            <details class="qcm__drawerNoscript">
              <summary class="qcm__btn">Filters</summary>
              {% render 'collection-simple-facets',
                section: section,
                s: s,
                is_search: is_search,
                results_url: results_url,
                terms_q: terms_q,
                filters: filters_obj,
                placement: 'drawer_noscript'
              %}
            </details>
          </noscript>
        {%- endif -%}

        {%- comment -%}
          IMPORTANT:
          Paginate MUST use the source object directly (not an assigned array var),
          otherwise Shopify can treat it as non-paginatable.
        {%- endcomment -%}

        {%- if use_alt -%}
          {%- paginate c.products by per_page -%}
            {% render 'collection-simple-grid',
              section: section,
              s: s,
              is_search: false,
              products_source: paginate.items,
              card_engine: card_engine,
              pagination_style: pagination_style,
              results_url: results_url
            %}

            {%- if s.show_pagination -%}
              <div data-qcm-pagination>
                {% render 'collection-simple-pagination',
                  section: section,
                  s: s,
                  paginate: paginate,
                  pagination_style: pagination_style
                %}
              </div>
            {%- endif -%}
          {%- endpaginate -%}

        {%- elsif is_search -%}
          {%- paginate search.results by per_page -%}
            {% render 'collection-simple-grid',
              section: section,
              s: s,
              is_search: true,
              products_source: paginate.items,
              card_engine: card_engine,
              pagination_style: pagination_style
            %}

            {%- if s.show_pagination -%}
              <div data-qcm-pagination>
                {% render 'collection-simple-pagination',
                  section: section,
                  s: s,
                  paginate: paginate,
                  pagination_style: pagination_style
                %}
              </div>
            {%- endif -%}
          {%- endpaginate -%}

        {%- else -%}
          {%- paginate collection.products by per_page -%}
            {% render 'collection-simple-grid',
              section: section,
              s: s,
              is_search: false,
              products_source: paginate.items,
              card_engine: card_engine,
              pagination_style: pagination_style
            %}

            {%- if s.show_pagination -%}
              <div data-qcm-pagination>
                {% render 'collection-simple-pagination',
                  section: section,
                  s: s,
                  paginate: paginate,
                  pagination_style: pagination_style
                %}
              </div>
            {%- endif -%}
          {%- endpaginate -%}
        {%- endif -%}

        {%- if enable_compare -%}
          <div class="qcmCompare" data-qcm-compare hidden>
            <div class="qcmCompare__inner">
              <div class="qcmCompare__left">
                <strong class="qcmCompare__title">{{ s.compare_title }}</strong>
                <span class="qcmCompare__count" data-qcm-compare-count>0</span>
              </div>
              <div class="qcmCompare__items" data-qcm-compare-items></div>
              <div class="qcmCompare__actions">
                <button type="button" class="qcm__btn" data-qcm-compare-clear>{{ s.compare_clear_label }}</button>
                <a class="qcm__btn" href="{{ s.compare_url }}" data-qcm-compare-go>{{ s.compare_cta_label }}</a>
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if enable_quick_view -%}
          <div class="qcmModal" data-qcm-modal hidden aria-hidden="true">
            <div class="qcmModal__overlay" data-qcm-modal-close></div>
            <div class="qcmModal__panel" role="dialog" aria-modal="true" aria-label="{{ s.quick_view_title }}">
              <button type="button" class="qcmModal__close" data-qcm-modal-close aria-label="Close">×</button>
              <div class="qcmModal__body" data-qcm-modal-body>
                <div class="qcmModal__loading">{{ s.loading_label }}</div>
              </div>
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

  <script src="{{ 'section-collection-simple.js' | asset_url }}" defer></script>
</section>

{%- comment -%}
  We introduced a helper snippet 'collection-simple-grid' below.
  If you already have a grid loop in your section, you can inline it instead.
{%- endcomment -%}

{% schema %}
{
  "name": "Main Collection Simple",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "checkbox", "id": "show_title", "label": "Show title", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": false },
    {
      "type": "select",
      "id": "description_style",
      "label": "Description style",
      "default": "truncated",
      "options": [
        { "value": "full", "label": "Full" },
        { "value": "truncated", "label": "Truncated" }
      ]
    },
    { "type": "range", "id": "truncated_lines", "label": "Truncated lines", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "search_title", "label": "Search title (when used on search)", "default": "Search results" },
    { "type": "text", "id": "empty_title", "label": "Empty state title", "default": "No products found." },

    { "type": "header", "content": "Data" },
    { "type": "checkbox", "id": "use_alt_collection", "label": "Use alternate collection", "default": false },
    { "type": "collection", "id": "alt_collection", "label": "Alternate collection" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout_preset",
      "label": "Layout preset",
      "default": "modern_grid",
      "options": [
        { "value": "modern_grid", "label": "Modern grid" },
        { "value": "editorial_grid", "label": "Editorial grid" },
        { "value": "split_feature", "label": "Split feature" },
        { "value": "minimal_grid", "label": "Minimal grid" },
        { "value": "cardless_list", "label": "Cardless list" },
        { "value": "masonry_lite", "label": "Masonry lite (CSS columns)" }
      ]
    },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet", "label": "Columns (tablet)", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_mobile", "label": "Columns (mobile)", "min": 1, "max": 3, "step": 1, "default": 2 },

    {
      "type": "select",
      "id": "card_engine",
      "label": "Card engine",
      "default": "modern_card",
      "options": [
        { "value": "default_theme_card", "label": "Default theme card" },
        { "value": "modern_card", "label": "Modern card (included)" }
      ]
    },

    {
      "type": "select",
      "id": "card_density",
      "label": "Card density",
      "default": "normal",
      "options": [
        { "value": "roomy", "label": "Roomy" },
        { "value": "normal", "label": "Normal" },
        { "value": "compact", "label": "Compact" }
      ]
    },

    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "default": "glass",
      "options": [
        { "value": "glass", "label": "Glass" },
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" },
        { "value": "none", "label": "None" }
      ]
    },

    {
      "type": "select",
      "id": "hover_effects",
      "label": "Hover effects",
      "default": "lift",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "lift", "label": "Lift" },
        { "value": "glow", "label": "Glow" },
        { "value": "tilt_lite", "label": "Tilt-lite" }
      ]
    },

    {
      "type": "select",
      "id": "reveal_animation",
      "label": "Reveal animation",
      "default": "off",
      "options": [
        { "value": "off", "label": "Off" },
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" }
      ]
    },

    { "type": "header", "content": "Discovery" },
    { "type": "checkbox", "id": "show_filters", "label": "Show filters", "default": true },
    {
      "type": "select",
      "id": "filter_presentation",
      "label": "Filter presentation",
      "default": "sidebar",
      "options": [
        { "value": "sidebar", "label": "Sidebar" },
        { "value": "drawer", "label": "Drawer" },
        { "value": "bar", "label": "Bar (toolbar)" }
      ]
    },
    { "type": "checkbox", "id": "sticky_filter_bar", "label": "Sticky filter bar (bar only)", "default": false },

    { "type": "checkbox", "id": "show_sort", "label": "Show sort", "default": true },
    {
      "type": "select",
      "id": "sort_style",
      "label": "Sort style",
      "default": "dropdown",
      "options": [
        { "value": "dropdown", "label": "Dropdown" },
        { "value": "pills", "label": "Pills" }
      ]
    },
    { "type": "textarea", "id": "sort_label_overrides", "label": "Sort label overrides (value|Label per line)", "default": "best-selling|Top Sellers\ncreated-descending|New Drops\nprice-ascending|Price: Low → High" },
    { "type": "textarea", "id": "sort_hide_values", "label": "Sort hide values (one per line)" },

    { "type": "checkbox", "id": "show_result_count", "label": "Show result count", "default": true },
    { "type": "checkbox", "id": "show_active_filters", "label": "Show active filters chips", "default": true },
    { "type": "checkbox", "id": "show_clear_all", "label": "Show clear all", "default": true },
    { "type": "text", "id": "clear_all_label", "label": "Clear all label", "default": "Clear all" },

    { "type": "header", "content": "AJAX (Progressive enhancement)" },
    { "type": "checkbox", "id": "enable_ajax", "label": "Enable AJAX updates (filters/sort/pagination)", "default": true },

    { "type": "header", "content": "Quick Filters (Blocks)" },
    { "type": "checkbox", "id": "show_quick_filters", "label": "Show quick filters", "default": true },

    { "type": "header", "content": "Wishlist" },
    { "type": "checkbox", "id": "enable_wishlist", "label": "Enable wishlist", "default": true },
    { "type": "text", "id": "wishlist_key", "label": "Wishlist storage key", "default": "qtm_wishlist" },

    { "type": "header", "content": "Compare" },
    { "type": "checkbox", "id": "enable_compare", "label": "Enable compare", "default": true },
    { "type": "text", "id": "compare_key", "label": "Compare storage key", "default": "qtm_compare" },
    { "type": "range", "id": "compare_max", "label": "Compare max items", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "text", "id": "compare_title", "label": "Compare bar title", "default": "Compare" },
    { "type": "text", "id": "compare_clear_label", "label": "Clear compare label", "default": "Clear" },
    { "type": "text", "id": "compare_cta_label", "label": "Compare CTA label", "default": "Compare now" },
    { "type": "url", "id": "compare_url", "label": "Compare page URL", "default": "/" },

    { "type": "header", "content": "Quick View" },
    { "type": "checkbox", "id": "enable_quick_view", "label": "Enable quick view", "default": true },
    { "type": "text", "id": "quick_view_title", "label": "Quick view modal label", "default": "Quick view" },
    { "type": "text", "id": "loading_label", "label": "Loading label", "default": "Loading…" },

    { "type": "header", "content": "Pagination" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 1, "default": 24 },
    { "type": "checkbox", "id": "show_pagination", "label": "Show pagination", "default": true },
    {
      "type": "select",
      "id": "pagination_style",
      "label": "Pagination style",
      "default": "numbered",
      "options": [
        { "value": "numbered", "label": "Numbered" },
        { "value": "load_more", "label": "Load more (JS)" },
        { "value": "infinite_scroll", "label": "Infinite scroll (JS)" }
      ]
    },

    { "type": "header", "content": "Design tokens + spacing" },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit" },
        { "value": "surface", "label": "Surface" },
        { "value": "contrast", "label": "Contrast" }
      ]
    },
    {
      "type": "select",
      "id": "max_width_toggle",
      "label": "Max width",
      "default": "contained",
      "options": [
        { "value": "contained", "label": "Contained" },
        { "value": "full", "label": "Full width" }
      ]
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "Contained max width token",
      "default": "var(--qtm-page-maxw, 1200px)",
      "options": [
        { "value": "var(--qtm-page-maxw, 1200px)", "label": "Page max" },
        { "value": "var(--qtm-page-maxw-wide, 1440px)", "label": "Wide" },
        { "value": "var(--qtm-page-maxw-narrow, 960px)", "label": "Narrow" }
      ]
    },
    { "type": "range", "id": "gap", "label": "Grid gap (px)", "min": 0, "max": 40, "step": 1, "default": 18 },
    { "type": "range", "id": "border_radius", "label": "Border radius (px)", "min": 0, "max": 32, "step": 1, "default": 16 },
    { "type": "range", "id": "toolbar_gap", "label": "Toolbar gap (px)", "min": 6, "max": 28, "step": 1, "default": 12 }
  ],
  "blocks": [
    {
      "type": "quick_filter_group",
      "name": "Quick filter group",
      "settings": [
        { "type": "text", "id": "title", "label": "Group title", "default": "Shop by" },
        {
          "type": "select",
