{%- comment -%}
  QUADRATUM — PRODUCT FAQ
  File: sections/product-faq.liquid

  Behaviors:
  - Inline accordion toggles (JS required)
  - Split accordion toggles + media stage updates per item (JS required)
  - Manual + Metafields (JSON + Metaobject list) sources
  - Custom colors/typography (no color_scheme)
  - Section-only assets

  Requires:
  - assets/section-product-faq.css
  - assets/section-product-faq.js
  - snippets/product-faq-media.liquid
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign product_obj = product | default: nil

  assign source = s.source | default: 'manual'
  assign layout = s.layout | default: 'accordion_inline'
  assign split_mode = false
  if layout == 'accordion_split'
    assign split_mode = true
  endif

  assign open_first = s.open_first_item

  assign media_gate = s.media_display | default: 'mixed'
  assign media_enabled = true
  if media_gate == 'none'
    assign media_enabled = false
  endif

  assign widths = '360,540,720,900,1080,1440'
  assign sizes_inline = '(min-width: 990px) 520px, 100vw'
  assign sizes_split = '(min-width: 990px) 44vw, 100vw'

  assign wrapper_width_class = 'q-maxw'
  if s.content_width == 'content-full-width'
    assign wrapper_width_class = 'q-maxw--full'
  endif

  assign pad_top = s.padding_top | default: 48
  assign pad_bottom = s.padding_bottom | default: 48

  assign has_items = false
  assign item_count = 0
  assign first_media_index = -1

  assign accordion_items_markup = ''
  assign stage_media_markup = ''
-%}

{{ 'section-product-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-product-faq.js' | asset_url }}" defer></script>

{%- capture header_markup -%}
  {%- if s.title != blank or s.subheading != blank -%}
    <header class="q-pfaq__header">
      {%- if s.title != blank -%}
        <h2 class="q-pfaq__title">{{ s.title | escape }}</h2>
      {%- endif -%}
      {%- if s.subheading != blank -%}
        <div class="q-pfaq__subheading rte">
          {{ s.subheading }}
        </div>
      {%- endif -%}
    </header>
  {%- endif -%}
{%- endcapture -%}

{%- comment -%} =========================
  SOURCE: MANUAL (BLOCKS)
========================= {%- endcomment -%}
{%- if source == 'manual' -%}
  {%- for block in section.blocks -%}
    {%- if block.type != 'faq_item' -%}{% continue %}{%- endif -%}

    {%- liquid
      assign q = block.settings.question
      assign a_html = block.settings.answer

      assign m_type = block.settings.media_type | default: 'none'
      assign img = block.settings.image
      assign vid = block.settings.video
      assign ext = block.settings.external_video_url
      assign mdl = block.settings.model
      assign poster = block.settings.poster_image

      assign item_has_media = false

      if media_enabled == false or m_type == 'none'
        assign item_has_media = false
      else
        case m_type
          when 'image'
            if img != blank
              if media_gate == 'mixed' or media_gate == 'image'
                assign item_has_media = true
              endif
            endif
          when 'video'
            if vid != blank
              if media_gate == 'mixed' or media_gate == 'video'
                assign item_has_media = true
              endif
            endif
          when 'external_video'
            if ext != blank
              if media_gate == 'mixed' or media_gate == 'video'
                assign item_has_media = true
              endif
            endif
          when 'model'
            if mdl != blank
              if media_gate == 'mixed'
                assign item_has_media = true
              endif
            endif
        endcase
      endif

      assign idx0 = forloop.index0

      assign is_open = false
      if open_first and idx0 == 0
        assign is_open = true
      endif

      if q != blank and a_html != blank
        assign has_items = true
      endif

      assign item_count = item_count | plus: 1

      if item_has_media and first_media_index == -1
        assign first_media_index = idx0
      endif
    -%}

    {%- capture one_item -%}
      <div class="q-pfaq__item" {{ block.shopify_attributes }}>
        <h3 class="q-pfaq__q">
          <button
            class="q-pfaq__btn"
            type="button"
            id="faq-button-{{ section.id }}-{{ idx0 }}"
            aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
            aria-controls="faq-panel-{{ section.id }}-{{ idx0 }}"
            data-faq-index="{{ idx0 }}"
          >
            <span class="q-pfaq__qtext">{{ q | default: 'Question' | escape }}</span>
            <span class="q-pfaq__icon" aria-hidden="true"></span>
          </button>
        </h3>

        <div
          class="q-pfaq__panel rte"
          id="faq-panel-{{ section.id }}-{{ idx0 }}"
          role="region"
          aria-labelledby="faq-button-{{ section.id }}-{{ idx0 }}"
          {% unless is_open %}hidden{% endunless %}
          data-faq-panel
        >
          {%- if a_html != blank -%}
            {{ a_html }}
          {%- endif -%}

          {%- if split_mode == false and item_has_media -%}
            <div class="q-pfaq__inlineMedia" data-faq-inline-media>
              {%- render 'product-faq-media',
                section: section,
                media_type: m_type,
                image: img,
                video: vid,
                external_url: ext,
                model: mdl,
                poster: poster,
                alt: q,
                sizes: sizes_inline,
                widths: widths,
                mode: 'inline'
              -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endcapture -%}

    {%- assign accordion_items_markup = accordion_items_markup | append: one_item -%}

    {%- if split_mode and media_enabled -%}
      {%- capture stage_node -%}
        <div
          class="q-pfaq__stageNode"
          data-faq-stage-node
          data-faq-index="{{ idx0 }}"
          data-has-media="{% if item_has_media %}true{% else %}false{% endif %}"
        >
          {%- if item_has_media -%}
            {%- render 'product-faq-media',
              section: section,
              media_type: m_type,
              image: img,
              video: vid,
              external_url: ext,
              model: mdl,
              poster: poster,
              alt: q,
              sizes: sizes_split,
              widths: widths,
              mode: 'stage'
            -%}
          {%- else -%}
            <div class="q-pfaq__stageEmpty" aria-hidden="true"></div>
          {%- endif -%}
        </div>
      {%- endcapture -%}

      {%- assign stage_media_markup = stage_media_markup | append: stage_node -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%} =========================
  SOURCE: METAFIELDS (JSON OR METAOBJECT LIST)
========================= {%- endcomment -%}
{%- if source == 'metafields' and product_obj != nil -%}
  {%- liquid
    assign mf_json = product_obj.metafields[s.faq_json_namespace][s.faq_json_key]
    assign mf_mo = product_obj.metafields[s.faq_metaobject_namespace][s.faq_metaobject_key]

    assign json_items = blank
    if mf_json != blank
      assign json_items = mf_json.value
    endif

    assign mo_items = blank
    if mf_mo != blank
      assign mo_items = mf_mo.value
    endif

    assign use_json = false
    if json_items != blank
      assign use_json = true
    endif
  -%}

  {%- if use_json -%}
    {%- liquid
      assign parsed = json_items
      assign parsed_try = blank

      if parsed != blank
        assign parsed_try = parsed | parse_json
        if parsed_try != blank
          assign parsed = parsed_try
        endif
      endif
    -%}

    {%- if parsed != blank -%}
      {%- for it in parsed -%}
        {%- liquid
          assign q = it.question
          assign a_html = it.answer_html

          assign m = it.media
          assign m_type = 'none'
          assign m_alt = ''
          assign m_url = ''

          if m != blank
            assign m_type = m.type | default: 'none'
            assign m_alt = m.alt | default: q
            assign m_url = m.id_or_url | default: ''
          endif

          assign item_has_media = false
          if media_enabled == false or m_type == 'none'
            assign item_has_media = false
          else
            case m_type
              when 'image'
                if m_url != blank
                  if media_gate == 'mixed' or media_gate == 'image'
                    assign item_has_media = true
                  endif
                endif
              when 'video'
                if m_url != blank
                  if media_gate == 'mixed' or media_gate == 'video'
                    assign item_has_media = true
                  endif
                endif
              when 'external_video'
                if m_url != blank
                  if media_gate == 'mixed' or media_gate == 'video'
                    assign item_has_media = true
                  endif
                endif
              when 'model'
                if m_url != blank
                  if media_gate == 'mixed'
                    assign item_has_media = true
                  endif
                endif
            endcase
          endif

          assign idx0 = forloop.index0

          assign is_open = false
          if open_first and idx0 == 0
            assign is_open = true
          endif

          if q != blank and a_html != blank
            assign has_items = true
          endif

          assign item_count = item_count | plus: 1
          if item_has_media and first_media_index == -1
            assign first_media_index = idx0
          endif
        -%}

        {%- capture one_item -%}
          <div class="q-pfaq__item">
            <h3 class="q-pfaq__q">
              <button
                class="q-pfaq__btn"
                type="button"
                id="faq-button-{{ section.id }}-{{ idx0 }}"
                aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
                aria-controls="faq-panel-{{ section.id }}-{{ idx0 }}"
                data-faq-index="{{ idx0 }}"
              >
                <span class="q-pfaq__qtext">{{ q | default: 'Question' | escape }}</span>
                <span class="q-pfaq__icon" aria-hidden="true"></span>
              </button>
            </h3>

            <div
              class="q-pfaq__panel rte"
              id="faq-panel-{{ section.id }}-{{ idx0 }}"
              role="region"
              aria-labelledby="faq-button-{{ section.id }}-{{ idx0 }}"
              {% unless is_open %}hidden{% endunless %}
              data-faq-panel
            >
              {%- if a_html != blank -%}{{ a_html }}{%- endif -%}

              {%- if split_mode == false and item_has_media -%}
                <div class="q-pfaq__inlineMedia" data-faq-inline-media>
                  {%- render 'product-faq-media',
                    section: section,
                    media_type: m_type,
                    external_url: m_url,
                    alt: m_alt,
                    sizes: sizes_inline,
                    widths: widths,
                    mode: 'inline'
                  -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endcapture -%}

        {%- assign accordion_items_markup = accordion_items_markup | append: one_item -%}

        {%- if split_mode and media_enabled -%}
          {%- capture stage_node -%}
            <div
              class="q-pfaq__stageNode"
              data-faq-stage-node
              data-faq-index="{{ idx0 }}"
              data-has-media="{% if item_has_media %}true{% else %}false{% endif %}"
            >
              {%- if item_has_media -%}
                {%- render 'product-faq-media',
                  section: section,
                  media_type: m_type,
                  external_url: m_url,
                  alt: m_alt,
                  sizes: sizes_split,
                  widths: widths,
                  mode: 'stage'
                -%}
              {%- else -%}
                <div class="q-pfaq__stageEmpty" aria-hidden="true"></div>
              {%- endif -%}
            </div>
          {%- endcapture -%}
          {%- assign stage_media_markup = stage_media_markup | append: stage_node -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

  {%- elsif mo_items != blank -%}
    {%- assign list = mo_items -%}
    {%- if list.value != blank -%}
      {%- assign list = list.value -%}
    {%- endif -%}

    {%- for obj in list -%}
      {%- liquid
        assign q = obj.question | default: obj.fields.question.value
        assign a_rte = obj.answer | default: obj.fields.answer.value

        assign m_type = obj.media_type | default: obj.fields.media_type.value | default: 'none'
        assign media_field = obj.media | default: obj.fields.media.value

        assign img = blank
        assign vid = blank
        assign mdl = blank
        assign ext = blank

        if media_field != blank
          if media_field.media_type != blank
            case media_field.media_type
              when 'image'
                assign img = media_field
                if m_type == 'none'
                  assign m_type = 'image'
                endif
              when 'video'
                assign vid = media_field
                if m_type == 'none'
                  assign m_type = 'video'
                endif
              when 'model'
                assign mdl = media_field
                if m_type == 'none'
                  assign m_type = 'model'
                endif
              else
                assign img = media_field
                if m_type == 'none'
                  assign m_type = 'image'
                endif
            endcase
          else
            assign ext = media_field
            if m_type == 'none'
              assign m_type = 'external_video'
            endif
          endif
        endif

        assign item_has_media = false
        if media_enabled == false or m_type == 'none'
          assign item_has_media = false
        else
          case m_type
            when 'image'
              if img != blank
                if media_gate == 'mixed' or media_gate == 'image'
                  assign item_has_media = true
                endif
              endif
            when 'video'
              if vid != blank
                if media_gate == 'mixed' or media_gate == 'video'
                  assign item_has_media = true
                endif
              endif
            when 'external_video'
              if ext != blank
                if media_gate == 'mixed' or media_gate == 'video'
                  assign item_has_media = true
                endif
              endif
            when 'model'
              if mdl != blank
                if media_gate == 'mixed'
                  assign item_has_media = true
                endif
              endif
          endcase
        endif

        assign idx0 = forloop.index0

        assign is_open = false
        if open_first and idx0 == 0
          assign is_open = true
        endif

        if q != blank and a_rte != blank
          assign has_items = true
        endif

        assign item_count = item_count | plus: 1
        if item_has_media and first_media_index == -1
          assign first_media_index = idx0
        endif
      -%}

      {%- capture one_item -%}
        <div class="q-pfaq__item">
          <h3 class="q-pfaq__q">
            <button
              class="q-pfaq__btn"
              type="button"
              id="faq-button-{{ section.id }}-{{ idx0 }}"
              aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
              aria-controls="faq-panel-{{ section.id }}-{{ idx0 }}"
              data-faq-index="{{ idx0 }}"
            >
              <span class="q-pfaq__qtext">{{ q | default: 'Question' | escape }}</span>
              <span class="q-pfaq__icon" aria-hidden="true"></span>
            </button>
          </h3>

          <div
            class="q-pfaq__panel rte"
            id="faq-panel-{{ section.id }}-{{ idx0 }}"
            role="region"
            aria-labelledby="faq-button-{{ section.id }}-{{ idx0 }}"
            {% unless is_open %}hidden{% endunless %}
            data-faq-panel
          >
            {%- if a_rte != blank -%}{{ a_rte }}{%- endif -%}

            {%- if split_mode == false and item_has_media -%}
              <div class="q-pfaq__inlineMedia" data-faq-inline-media>
                {%- render 'product-faq-media',
                  section: section,
                  media_type: m_type,
                  image: img,
                  video: vid,
                  external_url: ext,
                  model: mdl,
                  alt: q,
                  sizes: sizes_inline,
                  widths: widths,
                  mode: 'inline'
                -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endcapture -%}

      {%- assign accordion_items_markup = accordion_items_markup | append: one_item -%}

      {%- if split_mode and media_enabled -%}
        {%- capture stage_node -%}
          <div
            class="q-pfaq__stageNode"
            data-faq-stage-node
            data-faq-index="{{ idx0 }}"
            data-has-media="{% if item_has_media %}true{% else %}false{% endif %}"
          >
            {%- if item_has_media -%}
              {%- render 'product-faq-media',
                section: section,
                media_type: m_type,
                image: img,
                video: vid,
                external_url: ext,
                model: mdl,
                alt: q,
                sizes: sizes_split,
                widths: widths,
                mode: 'stage'
              -%}
            {%- else -%}
              <div class="q-pfaq__stageEmpty" aria-hidden="true"></div>
            {%- endif -%}
          </div>
        {%- endcapture -%}
        {%- assign stage_media_markup = stage_media_markup | append: stage_node -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} EMPTY STATE (theme editor only) {%- endcomment -%}
{%- if has_items == false and request.design_mode -%}
  {%- assign has_items = true -%}
  {%- assign accordion_items_markup = '' -%}
  {%- assign stage_media_markup = '' -%}

  {%- capture p0 -%}
    <div class="q-pfaq__item">
      <h3 class="q-pfaq__q">
        <button class="q-pfaq__btn" type="button" id="faq-button-{{ section.id }}-0" aria-expanded="true" aria-controls="faq-panel-{{ section.id }}-0" data-faq-index="0">
          <span class="q-pfaq__qtext">Do you ship?</span><span class="q-pfaq__icon" aria-hidden="true"></span>
        </button>
      </h3>
      <div class="q-pfaq__panel rte" id="faq-panel-{{ section.id }}-0" role="region" aria-labelledby="faq-button-{{ section.id }}-0" data-faq-panel>
        <p>Yes — we ship to most locations. Shipping times vary by region and product availability.</p>
      </div>
    </div>
  {%- endcapture -%}

  {%- capture p1 -%}
    <div class="q-pfaq__item">
      <h3 class="q-pfaq__q">
        <button class="q-pfaq__btn" type="button" id="faq-button-{{ section.id }}-1" aria-expanded="false" aria-controls="faq-panel-{{ section.id }}-1" data-faq-index="1">
          <span class="q-pfaq__qtext">What’s the return policy?</span><span class="q-pfaq__icon" aria-hidden="true"></span>
        </button>
      </h3>
      <div class="q-pfaq__panel rte" id="faq-panel-{{ section.id }}-1" role="region" aria-labelledby="faq-button-{{ section.id }}-1" hidden data-faq-panel>
        <p>Returns are accepted within the return window as long as the item is unused and in original packaging.</p>
      </div>
    </div>
  {%- endcapture -%}

  {%- assign accordion_items_markup = accordion_items_markup | append: p0 | append: p1 -%}

  {%- if split_mode and media_enabled -%}
    {%- capture st -%}
      <div class="q-pfaq__stageNode" data-faq-stage-node data-faq-index="0" data-has-media="false">
        <div class="q-pfaq__stageEmpty" aria-hidden="true"></div>
      </div>
    {%- endcapture -%}
    {%- assign stage_media_markup = stage_media_markup | append: st -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} Determine default stage index AFTER we know first_media_index {%- endcomment -%}
{%- liquid
  assign stage_default_index = 0
  if first_media_index != -1
    assign stage_default_index = first_media_index
  endif
-%}

{%- if split_mode and media_enabled and stage_media_markup != blank -%}
  {%- comment -%}
    Normalize stage node visibility: only default is visible.
    We can’t easily rewrite existing markup, so we wrap with CSS/JS logic:
    JS will show correct node on init; CSS will allow hidden attr to control.
  {%- endcomment -%}
{%- endif -%}

{%- if has_items -%}
  <section
    id="ProductFAQ-{{ section.id }}"
    class="q-pfaq {% if split_mode %}q-pfaq--split{% else %}q-pfaq--inline{% endif %}"
    data-product-faq
    data-layout="{{ layout }}"
    data-open-first="{{ open_first | json }}"
    data-media-enabled="{{ media_enabled | json }}"
    data-first-media-index="{{ first_media_index }}"
    data-stage-default-index="{{ stage_default_index }}"
    data-media-position="{{ s.split_media_position | default: 'right' }}"
    style="
      padding-top: {{ pad_top }}px;
      padding-bottom: {{ pad_bottom }}px;

      --q-pfaq-bg: {{ s.section_bg }};
      --q-pfaq-title-color: {{ s.title_color }};
      --q-pfaq-title-size: {{ s.title_size }}px;
      --q-pfaq-title-weight: {{ s.title_weight }};

      --q-pfaq-tab-bg: {{ s.tab_bg }};
      --q-pfaq-tab-color: {{ s.tab_color }};
      --q-pfaq-tab-size: {{ s.tab_size }}px;
      --q-pfaq-tab-weight: {{ s.tab_weight }};

      --q-pfaq-content-bg: {{ s.content_bg }};
      --q-pfaq-content-color: {{ s.content_color }};
      --q-pfaq-content-size: {{ s.content_size }}px;
      --q-pfaq-content-line: {{ s.content_line_height }};

      --q-pfaq-media-radius: {{ s.media_radius }}px;
      --q-pfaq-inline-max: {{ s.inline_media_max_width }}px;
      --q-pfaq-stage-max: {{ s.stage_media_max_height }}px;
    "
  >
    <div class="q-pfaq__wrap {{ wrapper_width_class }}">
      {{ header_markup }}

      <div class="q-pfaq__body {% if split_mode and media_enabled %}q-pfaq__body--hasStage{% endif %}">
        <div class="q-pfaq__col q-pfaq__col--accordion">
          <div class="q-pfaq__accordion" role="presentation">
            {{ accordion_items_markup }}
          </div>
        </div>

        {%- if split_mode and media_enabled -%}
          <div class="q-pfaq__col q-pfaq__col--stage {% if s.split_media_sticky %}q-pfaq__col--sticky{% endif %}">
            <div class="q-pfaq__stage" aria-label="{{ s.title | default: 'Frequently asked questions' | escape }}">
              {%- comment -%}
                We render all stage nodes. JS will:
                - hide all
                - show default node (stage_default_index or first media)
                - swap on click
              {%- endcomment -%}
              {{ stage_media_markup }}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "q-section q-section--product-faq",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Frequently asked questions" },
    { "type": "richtext", "id": "subheading", "label": "Subheading" },

    {
      "type": "select",
      "id": "source",
      "label": "Source",
      "default": "manual",
      "options": [
        { "value": "manual", "label": "Manual (blocks)" },
        { "value": "metafields", "label": "Metafields (JSON or Metaobjects)" }
      ]
    },

    { "type": "header", "content": "Metafields — JSON format (A)" },
    { "type": "text", "id": "faq_json_namespace", "label": "JSON metafield namespace", "default": "custom" },
    { "type": "text", "id": "faq_json_key", "label": "JSON metafield key", "default": "faq" },

    { "type": "header", "content": "Metafields — Metaobject list (B)" },
    { "type": "text", "id": "faq_metaobject_namespace", "label": "Metaobject list metafield namespace", "default": "custom" },
    { "type": "text", "id": "faq_metaobject_key", "label": "Metaobject list metafield key", "default": "faq_items" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "accordion_inline",
      "options": [
