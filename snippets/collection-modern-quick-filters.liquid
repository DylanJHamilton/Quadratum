{%- comment -%}
  Quadratum — Collection Modern Quick Filters (Sort Pills)
  File: snippets/collection-modern-quick-filters.liquid

  Purpose:
  - Render sort options as "pills"
  - Preserve existing query params (filters/search q/etc) while swapping sort_by
  - Provide "Undo" to revert to default_sort_by

  Inputs expected (passed from toolbar):
  - section, s
  - is_search_context
  - results_url
  - sort_options
  - sort_by
  - default_sort_by
{%- endcomment -%}

{%- liquid
  if sort_options == blank or sort_options.size == 0
    break
  endif

  assign base_url = results_url

  # Preserve current query params EXCEPT sort_by + page
  assign qs = request.query_string | default: ''
  assign kept = ''

  if qs != blank
    assign parts = qs | split: '&'
    for part in parts
      assign p0 = part | split: '=' | first | default: ''
      if p0 == 'sort_by' or p0 == 'page'
        continue
      endif
      if kept == ''
        assign kept = part
      else
        assign kept = kept | append: '&' | append: part
      endif
    endfor
  endif

  assign current_sort = sort_by | default: ''
  assign default_sort = default_sort_by | default: ''

  # Determine whether we are "default" (so Undo can just remove sort_by)
  assign is_default_sort = false
  if current_sort == blank and default_sort == blank
    assign is_default_sort = true
  elsif current_sort == default_sort
    assign is_default_sort = true
  endif

  # Helper: builds URL with kept params + sort_by
  # We do this inline per option to avoid Liquid function limitations.
-%}

<nav class="qcm__sortPills" aria-label="Sort options">
  {%- for opt in sort_options -%}
    {%- liquid
      assign opt_value = opt.value | default: ''
      assign opt_name  = opt.name  | default: opt_value

      # active?
      assign is_active = false
      if current_sort == opt_value
        assign is_active = true
      elsif current_sort == blank and default_sort != blank and default_sort == opt_value
        assign is_active = true
      elsif current_sort == blank and default_sort == blank and forloop.first
        # if nothing is set anywhere, consider first option "active"
        assign is_active = true
      endif

      # Build URL: base + kept + sort_by=opt_value
      assign url = base_url
      assign glue = '?'
      if kept != blank
        assign url = url | append: '?' | append: kept
        assign glue = '&'
      endif

      if opt_value != blank
        assign url = url | append: glue | append: 'sort_by=' | append: opt_value
      endif
    -%}

    <a
      class="qcm__pill{% if is_active %} is-active{% endif %}"
      href="{{ url }}"
      {% if is_active %}aria-current="true"{% endif %}
    >
      {{ opt_name }}
    </a>
  {%- endfor -%}

  {%- comment -%} Undo pill: revert to default by removing sort_by (and page) {%- endcomment -%}
  {%- if is_default_sort == false -%}
    {%- liquid
      assign undo_url = base_url
      if kept != blank
        assign undo_url = undo_url | append: '?' | append: kept
      endif
    -%}
    <a class="qcm__pill" href="{{ undo_url }}">Undo</a>
  {%- endif -%}
</nav>