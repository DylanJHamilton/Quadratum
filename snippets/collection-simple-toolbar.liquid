{%- liquid
  assign s = s
  assign filter_mode = filter_mode | default: 'none'

  assign show_title = s.show_title
  assign show_desc = s.show_description
  assign desc_style = s.description_style | default: 'truncated'
  assign show_sort = s.show_sort
  assign sort_style = s.sort_style | default: 'dropdown'
  assign show_count = s.show_result_count
  assign show_chips = s.show_active_filters
  assign show_clear = s.show_clear_all

  assign sticky = false
  if sticky_toolbar
    assign sticky = true
  endif

  assign overrides = s.sort_label_overrides | default: ''
  assign override_lines = overrides | newline_to_br | split: '<br />'

  assign hide_vals = s.sort_hide_values | default: ''
  assign hide_lines = hide_vals | newline_to_br | split: '<br />'

  assign current_sort = sort_by
  if current_sort == blank
    assign current_sort = default_sort_by
  endif

  assign drawer_mode = false
  if has_filters and filter_mode == 'drawer'
    assign drawer_mode = true
  endif

  assign bar_mode = false
  if has_filters and filter_mode == 'bar'
    assign bar_mode = true
  endif

  assign active_count = 0
  if filters != blank
    for f in filters
      if f.type == 'price_range'
        if f.min_value.value != blank or f.max_value.value != blank
          assign active_count = active_count | plus: 1
        endif
      else
        assign active_count = active_count | plus: f.active_values.size
      endif
    endfor
  endif
-%}

<div class="qcmToolbar {% if sticky %}qcmToolbar--sticky{% endif %}" data-qcm-toolbar>
  <div class="qcmToolbar__top">
    <div>
      {%- if show_title and results_title != blank -%}
        <h1 class="qcmToolbar__title">{{ results_title }}</h1>
      {%- endif -%}

      {%- if show_desc and results_description != blank -%}
        <p class="qcmToolbar__desc {% if desc_style == 'truncated' %}qcmToolbar__desc--trunc{% endif %}">
          {{ results_description }}
        </p>
      {%- endif -%}
    </div>

    <div class="qcmToolbar__controls">
      {%- if show_count -%}
        <span style="opacity:.8;">{{ active_count }} filters</span>
      {%- endif -%}

      {%- if drawer_mode -%}
        <button type="button" class="qcm__btn" data-qcm-drawer-open aria-label="Open filters">Filters</button>
      {%- endif -%}

      {%- if show_sort and sort_options != blank and sort_options.size > 0 -%}
        {%- if sort_style == 'dropdown' -%}
          <label style="display:flex; gap:8px; align-items:center;">
            <span style="opacity:.85;">Sort</span>
            <select data-qcm-sort>
              {%- for opt in sort_options -%}
                {%- liquid
                  assign hidden = false
                  for h in hide_lines
                    assign hv = h | strip
                    if hv != blank and hv == opt.value
                      assign hidden = true
                    endif
                  endfor
                  if hidden
                    continue
                  endif

                  assign label = opt.name
                  for ol in override_lines
                    assign row = ol | strip
                    if row == blank
                      continue
                    endif

                    assign parts = row | split: '|'
                    assign key = ''
                    assign val = ''
                    if parts.size >= 2
                      assign key = parts[0] | strip
                      assign val = parts[1] | strip
                    endif

                    if key != blank and key == opt.value and val != blank
                      assign label = val
                    endif
                  endfor

                  assign href = results_url
                  assign glue = '?'
                  if href contains '?'
                    assign glue = '&'
                  endif
                  if is_search and terms_q != blank
                    assign href = routes.search_url | append: '?q=' | append: terms_q | url_encode
                    assign glue = '&'
                  endif
                  assign href = href | append: glue | append: 'sort_by=' | append: opt.value
                -%}
                <option value="{{ href }}" {% if opt.value == current_sort %}selected{% endif %}>{{ label }}</option>
              {%- endfor -%}
            </select>
          </label>
        {%- else -%}
          <div class="qcmSortPills" role="list">
            {%- for opt in sort_options -%}
              {%- liquid
                assign hidden = false
                for h in hide_lines
                  assign hv = h | strip
                  if hv != blank and hv == opt.value
                    assign hidden = true
                  endif
                endfor
                if hidden
                  continue
                endif

                assign label = opt.name
                for ol in override_lines
                  assign row = ol | strip
                  if row == blank
                    continue
                  endif

                  assign parts = row | split: '|'
                  assign key = ''
                  assign val = ''
                  if parts.size >= 2
                    assign key = parts[0] | strip
                    assign val = parts[1] | strip
                  endif

                  if key != blank and key == opt.value and val != blank
                    assign label = val
                  endif
                endfor

                assign href = results_url
                assign glue = '?'
                if href contains '?'
                  assign glue = '&'
                endif
                if is_search and terms_q != blank
                  assign href = routes.search_url | append: '?q=' | append: terms_q | url_encode
                  assign glue = '&'
                endif
                assign href = href | append: glue | append: 'sort_by=' | append: opt.value
              -%}
              <a class="qcm__btn qcmSortPill" href="{{ href }}" data-qcm-ajax-link role="listitem" aria-current="{% if opt.value == current_sort %}true{% else %}false{% endif %}">
                {{ label }}
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- if show_chips and filters != blank and active_count > 0 -%}
    <div class="qcmChips" aria-label="Active filters">
      {%- for f in filters -%}
        {%- if f.type == 'price_range' -%}
          {%- if f.min_value.value != blank or f.max_value.value != blank -%}
            <a class="qcmChip" href="{{ f.url_to_remove }}" data-qcm-ajax-link aria-label="Remove price filter">
              Price
              <span class="qcmChip__x" aria-hidden="true">×</span>
            </a>
          {%- endif -%}
        {%- else -%}
          {%- for av in f.active_values -%}
            <a class="qcmChip" href="{{ av.url_to_remove }}" data-qcm-ajax-link aria-label="Remove {{ av.label | escape }}">
              {{ av.label }}
              <span class="qcmChip__x" aria-hidden="true">×</span>
            </a>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if show_clear -%}
        <a class="qcm__btn qcm__btn--link" href="{{ results_url }}" data-qcm-ajax-link>{{ s.clear_all_label | default: 'Clear all' }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>