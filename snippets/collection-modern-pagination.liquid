{%- comment -%}
  Collection Modern — Pagination
  File: snippets/collection-modern-pagination.liquid

  Inputs:
  - section, s
  - paginate (Liquid paginate object)
  - pagination_style: numbered | load_more | infinite_scroll

  Requirements:
  - Numbered works without JS
  - load_more/infinite_scroll: JS fetch next page and append; still keeps fallback links
{%- endcomment -%}

{%- liquid
  assign style = pagination_style | default: 'numbered'
-%}

<div class="qcm__pagination" data-qcm-pagination>
  {%- if paginate.pages > 1 -%}
    <nav aria-label="Pagination">
      <ul class="qcm__paginationList">
        {%- if paginate.previous -%}
          <li><a href="{{ paginate.previous.url }}" aria-label="Previous page">‹</a></li>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <li><a href="{{ part.url }}">{{ part.title }}</a></li>
          {%- else -%}
            <li>
              <span {% if part.title == paginate.current_page %}aria-current="page"{% endif %}>
                {{ part.title }}
              </span>
            </li>
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.next -%}
          <li><a href="{{ paginate.next.url }}" aria-label="Next page" data-qcm-next-link>›</a></li>
        {%- endif -%}
      </ul>
    </nav>

    {%- if style == 'load_more' or style == 'infinite_scroll' -%}
      <div class="qcm__enhancedPaging" aria-label="Load more controls">
        <button type="button" class="qcm__btn" data-qcm-load-more {% if paginate.next == blank %}disabled{% endif %}>
          Load more
        </button>
        <div class="qcm__status" data-qcm-status aria-live="polite"></div>
        <div data-qcm-sentinel aria-hidden="true"></div>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>