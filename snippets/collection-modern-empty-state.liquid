{% comment %}
  Quadratum — Collection Modern Empty State
  File: snippets/collection-modern-empty-state.liquid
{% endcomment %}

<div class="qcm__empty" role="status">
  <p class="qcm__emptyTitle">No products found.</p>
  {%- if s.show_clear_all -%}
    {%- if is_search_context and terms_q != blank -%}
      <a class="qcm__btn qcm__btn--link" href="{{ routes.search_url }}?q={{ terms_q | url_encode }}&type=product&options[prefix]=last">Clear filters</a>
    {%- else -%}
      <a class="qcm__btn qcm__btn--link" href="{{ results_url }}">Clear filters</a>
    {%- endif -%}
  {%- endif -%}
</div>