{% comment %}
  Quadratum — Product Cross Sell
  File: sections/product-cross-sell.liquid

  Role:
  - Related / complementary products near bottom of PDP
  - Modes: manual, collection, dynamic (v1 safe fallback)
  - Cards: MUST render via {% render 'product-card', product: product %}

  Styling additions (scoped):
  - Header alignment
  - Title/subheading colors + typography (size/weight)
{% endcomment %}

{%- liquid
  assign s = section.settings
  assign current = product

  assign max_products = s.max_products | default: 4

  assign resolved = ''
  assign items = ''
  assign count = 0

  assign mode_effective = s.mode | default: 'manual'

  if mode_effective == 'dynamic'
    if s.collection != blank
      assign mode_effective = 'collection'
    else
      assign mode_effective = 'manual'
    endif
  endif

  if mode_effective == 'manual'
    for block in section.blocks
      if count >= max_products
        break
      endif

      assign p = block.settings.product
      if p == blank
        continue
      endif

      if current != blank and p.id == current.id
        continue
      endif

      assign token = '|' | append: p.id | append: '|'
      if resolved contains token
        continue
      endif

      assign resolved = resolved | append: token
      assign items = items | append: '|' | append: p.handle | append: '|'
      assign count = count | plus: 1
    endfor

  elsif mode_effective == 'collection'
    if s.collection != blank and s.collection.products_count > 0
      for p in s.collection.products limit: 50
        if count >= max_products
          break
        endif

        if p == blank
          continue
        endif

        if current != blank and p.id == current.id
          continue
        endif

        assign token = '|' | append: p.id | append: '|'
        if resolved contains token
          continue
        endif

        assign resolved = resolved | append: token
        assign items = items | append: '|' | append: p.handle | append: '|'
        assign count = count | plus: 1
      endfor
    endif
  endif

  if count == 0
    break
  endif

  assign items_class = 'product-cross-sell__items'
  if s.layout == 'carousel'
    assign items_class = items_class | append: ' product-cross-sell__items--carousel'
  endif

  assign cols_desktop = s.columns_desktop | default: 4
  assign cols_tablet = s.columns_tablet | default: 2
  assign cols_mobile = s.columns_mobile | default: 1

  assign header_align = s.header_alignment | default: 'left'

  assign title_size = s.title_size | default: 28
  assign title_weight = s.title_weight | default: 700
  assign sub_size = s.subheading_size | default: 16
  assign sub_weight = s.subheading_weight | default: 400
-%}

{% stylesheet %}
  .product-cross-sell { width: 100%; margin: 0; }

  .product-cross-sell__inner { width: 100%; }

  .product-cross-sell__header { margin-bottom: 1rem; text-align: var(--pcs-header-align, left); }
  .product-cross-sell__title {
    margin: 0;
    color: var(--pcs-title-color, inherit);
    font-size: var(--pcs-title-size, 28px);
    font-weight: var(--pcs-title-weight, 700);
    line-height: 1.2;
  }
  .product-cross-sell__subheading {
    margin-top: .5rem;
    color: var(--pcs-sub-color, inherit);
    font-size: var(--pcs-sub-size, 16px);
    font-weight: var(--pcs-sub-weight, 400);
  }

  /* Grid layout (mobile-first) */
  .product-cross-sell__items {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(var(--pcs-cols-mobile, 1), minmax(0, 1fr));
  }
  @media (min-width: 750px) {
    .product-cross-sell__items {
      grid-template-columns: repeat(var(--pcs-cols-tablet, 2), minmax(0, 1fr));
    }
  }
  @media (min-width: 990px) {
    .product-cross-sell__items {
      grid-template-columns: repeat(var(--pcs-cols-desktop, 4), minmax(0, 1fr));
    }
  }

  /* Carousel (no JS) */
  .product-cross-sell__items--carousel {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    padding-bottom: .25rem;
  }
  .product-cross-sell__items--carousel > .product-cross-sell__item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    width: min(78vw, 360px);
  }
  @media (min-width: 750px) {
    .product-cross-sell__items--carousel > .product-cross-sell__item {
      width: min(44vw, 360px);
    }
  }
  @media (min-width: 990px) {
    .product-cross-sell__items--carousel > .product-cross-sell__item {
      width: min(24vw, 360px);
    }
  }
{% endstylesheet %}

<section
  class="product-cross-sell"
  id="product-cross-sell"
  style="
    --pcs-cols-desktop: {{ cols_desktop }};
    --pcs-cols-tablet: {{ cols_tablet }};
    --pcs-cols-mobile: {{ cols_mobile }};
    --pcs-header-align: {{ header_align }};
    --pcs-title-color: {{ s.title_color }};
    --pcs-sub-color: {{ s.subheading_color }};
    --pcs-title-size: {{ title_size }}px;
    --pcs-title-weight: {{ title_weight }};
    --pcs-sub-size: {{ sub_size }}px;
    --pcs-sub-weight: {{ sub_weight }};
  "
  aria-label="{% if s.title != blank %}{{ s.title | strip_html | escape }}{% else %}You may also like{% endif %}"
>
  <div class="product-cross-sell__inner">
    {%- if s.title != blank or s.subheading != blank -%}
      <header class="product-cross-sell__header">
        {%- if s.title != blank -%}
          <h2 class="product-cross-sell__title">{{ s.title }}</h2>
        {%- endif -%}
        {%- if s.subheading != blank -%}
          <div class="product-cross-sell__subheading rte">{{ s.subheading }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="{{ items_class }}">
      {%- assign handles = items | split: '|' -%}
      {%- for h in handles -%}
        {%- if h == blank -%}{%- continue -%}{%- endif -%}
        {%- assign p = all_products[h] -%}
        {%- if p == blank -%}{%- continue -%}{%- endif -%}
        <div class="product-cross-sell__item">
          {% render 'product-card', product: p %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product cross sell",
  "tag": "section",
  "class": "section product-cross-sell-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "title", "label": "Title", "default": "You may also like" },
    { "type": "richtext", "id": "subheading", "label": "Subheading" },

    { "type": "header", "content": "Mode" },
    {
      "type": "select",
      "id": "mode",
      "label": "Mode",
      "default": "manual",
      "options": [
        { "value": "manual", "label": "Manual" },
        { "value": "collection", "label": "Collection" },
        { "value": "dynamic", "label": "Dynamic (v1 fallback)" }
      ]
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used when mode is Collection. In Dynamic mode (v1), this is used as the first fallback."
    },

    { "type": "header", "content": "Limits" },
    { "type": "range", "id": "max_products", "label": "Max products", "min": 2, "max": 12, "step": 1, "default": 4 },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ]
    },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet", "label": "Columns (tablet)", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "columns_mobile", "label": "Columns (mobile)", "min": 1, "max": 3, "step": 1, "default": 1 },

    { "type": "header", "content": "Heading style" },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    { "type": "color", "id": "title_color", "label": "Title color" },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 14, "max": 48, "step": 1, "default": 28 },
    { "type": "range", "id": "title_weight", "label": "Title weight", "min": 300, "max": 900, "step": 100, "default": 700 },

    { "type": "header", "content": "Subheading style" },
    { "type": "color", "id": "subheading_color", "label": "Subheading color" },
    { "type": "range", "id": "subheading_size", "label": "Subheading size", "min": 12, "max": 28, "step": 1, "default": 16 },
    { "type": "range", "id": "subheading_weight", "label": "Subheading weight", "min": 300, "max": 900, "step": 100, "default": 400 }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    { "name": "Product cross sell" }
  ]
}
{% endschema %}