{%- liquid
  assign qtm_404_heading = settings['404_heading'] | default: 'Page Not Found'
  assign qtm_404_message = settings['404_message'] | default: "The page you are looking for doesn't exist or has been moved."
  assign qtm_404_show_search = settings['404_show_search']
  assign qtm_404_home_button_label = settings['404_home_button_label'] | default: 'Return Home'
  assign qtm_404_shop_button_label = settings['404_shop_button_label'] | default: 'Continue Shopping'
-%}

<section
  id="QtmMain404-{{ section.id }}"
  class="qtm404"
  aria-labelledby="QtmMain404Heading-{{ section.id }}"
>
  <div class="qtm404__inner page-width">
    <div class="qtm404__content">
      <h1 id="QtmMain404Heading-{{ section.id }}" class="qtm404__heading">
        {{ qtm_404_heading }}
      </h1>

      <div class="qtm404__message rte">
        <p>{{ qtm_404_message }}</p>
      </div>

      <div class="qtm404__actions">
        <a href="{{ routes.root_url }}" class="button button--primary qtm404__button">
          {{ qtm_404_home_button_label }}
        </a>

        <a href="/collections" class="button button--secondary qtm404__button">
          {{ qtm_404_shop_button_label }}
        </a>
      </div>

      {%- if qtm_404_show_search -%}
        <div class="qtm404__search">
          <form action="{{ routes.search_url }}" method="get" role="search" class="qtm404__search-form">
            <label class="visually-hidden" for="Qtm404Search-{{ section.id }}">
              Search store
            </label>

            <div class="qtm404__search-field">
              <input
                id="Qtm404Search-{{ section.id }}"
                class="field__input qtm404__search-input"
                type="search"
                name="q"
                value=""
                placeholder="Search our store"
                aria-label="Search store"
                autocorrect="off"
                autocomplete="off"
                autocapitalize="off"
                spellcheck="false"
              >

              <button
                type="submit"
                class="button button--secondary qtm404__search-button"
                aria-label="Submit search"
              >
                Search
              </button>
            </div>
          </form>
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <nav class="qtm404__links" aria-label="Helpful links">
          <ul class="qtm404__links-list" role="list">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '404_link' -%}
                  {%- if block.settings.label != blank and block.settings.url != blank -%}
                    <li class="qtm404__links-item" {{ block.shopify_attributes }}>
                      <a href="{{ block.settings.url }}" class="qtm404__link">
                        {{ block.settings.label }}
                      </a>
                    </li>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main 404",
  "tag": "section",
  "class": "qtm-main-404",
  "blocks": [
    {
      "type": "404_link",
      "name": "404 Link",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop All"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main 404",
      "blocks": []
    }
  ]
}
{% endschema %}