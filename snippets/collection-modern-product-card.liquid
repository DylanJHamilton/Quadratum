{%- comment -%}
  Quadratum — Collection Modern Product Card
  File: snippets/collection-modern-product-card.liquid
  Scoped classes: qcmc*
{%- endcomment -%}

{%- liquid
  assign p = product
  if p == blank
    break
  endif

  assign u = p.url

  assign featured = p.featured_media
  assign has_media = false
  if featured != blank
    assign has_media = true
  endif

  assign sold_out = false
  if p.available == false
    assign sold_out = true
  endif

  assign on_sale = false
  if p.compare_at_price > p.price
    assign on_sale = true
  endif

  assign show_badges = false
  if s.show_badges
    assign show_badges = true
  endif

  assign show_vendor = false
  if s.show_vendor
    assign show_vendor = true
  endif

  assign show_price = false
  if s.show_price
    assign show_price = true
  endif

  assign show_second = false
  if s.show_second_image and p.media.size > 1
    assign show_second = true
  endif

  assign can_quick_add = false
  if s.show_quick_add and p.available and p.variants.size == 1
    assign can_quick_add = true
  endif

  assign needs_options = false
  if p.variants.size > 1
    assign needs_options = true
  endif

  assign enable_qv = false
  if s.enable_quick_view
    assign enable_qv = true
  endif

  assign enable_compare = false
  if s.enable_compare
    assign enable_compare = true
  endif

  assign variant_id = p.selected_or_first_available_variant.id
-%}

<div class="qcmc" data-qcmc data-handle="{{ p.handle }}" data-variant-id="{{ variant_id }}">
  <div class="qcmc__media">
    {%- if show_badges and (on_sale or sold_out) -%}
      <div class="qcmc__badges">
        {%- if sold_out -%}
          <span class="qcmc__badge qcmc__badge--soldout">Sold out</span>
        {%- elsif on_sale -%}
          <span class="qcmc__badge qcmc__badge--sale">Sale</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <a class="qcmc__mediaLink" href="{{ u }}">
      {%- if has_media -%}
        {{ featured | image_url: width: 900 | image_tag: class: 'qcmc__img qcmc__img--primary', loading: 'lazy' }}
        {%- if show_second -%}
          {%- assign second_media = p.media[1] -%}
          {{ second_media | image_url: width: 900 | image_tag: class: 'qcmc__img qcmc__img--second', loading: 'lazy' }}
        {%- endif -%}
      {%- else -%}
        <div class="qcmc__img--placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </a>

    {%- if enable_qv or enable_compare -%}
      <div class="qcmc__overlay">
        {%- if enable_qv -%}
          <button class="qcmc__overlayBtn" type="button" data-qcm-quickview>{{ s.quick_view_label }}</button>
        {%- endif -%}
        {%- if enable_compare -%}
          <button class="qcmc__overlayBtn" type="button" data-qcm-compare-toggle aria-pressed="false">Select</button>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="qcmc__body">
    {%- if show_vendor and p.vendor != blank -%}
      <div class="qcmc__vendor">{{ p.vendor }}</div>
    {%- endif -%}

    <h3 class="qcmc__title">
      <a href="{{ u }}" data-qcm-title>{{ p.title }}</a>
    </h3>

    {%- if show_price -%}
      <div class="qcmc__price" data-qcm-price>
        {%- if on_sale -%}
          <span class="qcmc__priceNow">{{ p.price | money }}</span>
          <s class="qcmc__priceWas">{{ p.compare_at_price | money }}</s>
        {%- else -%}
          <span class="qcmc__priceNow">{{ p.price | money }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="qcmc__actions">
      {%- if can_quick_add -%}
        <button class="qcmc__btn" type="button" data-qcm-quickadd>
          {{ s.add_to_cart_label }}
        </button>
      {%- else -%}
        <a class="qcmc__btn qcmc__btn--ghost" href="{{ u }}">
          {%- if needs_options -%}{{ s.choose_options_label }}{%- else -%}View product{%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>