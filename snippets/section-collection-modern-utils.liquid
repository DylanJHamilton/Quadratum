{%- comment -%}
  Quadratum — Collection Modern Utils
  File: snippets/collection-modern-utils.liquid
  Purpose: safe URL helpers for clear-all base URLs
{%- endcomment -%}

{%- liquid
  assign out_base_url = results_url

  if is_search_context
    if terms_q != blank
      assign out_base_url = routes.search_url | append: '?q=' | append: terms_q | url_encode
    else
      assign out_base_url = routes.search_url
    endif
  endif
-%}

{%- assign qcm_base_url = out_base_url -%}