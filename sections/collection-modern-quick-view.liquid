{%- comment -%}
  Quadratum — Collection Modern Quick View
  File: sections/collection-modern-quick-view.liquid

  Rendered via:
  /products/:handle?section_id=collection-modern-quick-view

  IMPORTANT:
  - This section is NOT placed on a template.
  - Styling + behavior are controlled by the Collection section that injects it.
  - JS sets: [data-qcm-qv-fragment][data-qcm-qv-mode="slider|hover"]
{%- endcomment -%}

{%- liquid
  assign p = product
  if p == blank
    break
  endif

  assign v = p.selected_or_first_available_variant
  assign has_one_variant = false
  if p.variants.size == 1
    assign has_one_variant = true
  endif

  assign featured = p.featured_media
  if featured == blank
    assign featured = p.featured_image
  endif

  assign max_imgs = 8
-%}

<div class="qcmQv" data-qcm-qv-fragment data-qcm-qv-mode="slider">
  <div class="qcmQv__grid">
    <div class="qcmQv__media">
      {%- comment -%} SLIDER MODE (default) {%- endcomment -%}
      <div class="qcmQv__slider" data-qcm-qv-slider data-qcmc-index="0">
        <div class="qcmQv__track" data-qcm-qv-track>
          {%- assign count = 0 -%}
          {%- if p.media != blank -%}
            {%- for m in p.media -%}
              {%- if m.media_type == 'image' -%}
                {%- assign count = count | plus: 1 -%}
                <img
                  class="qcmQv__img qcmQv__img--slide"
                  src="{{ m | image_url: width: 1200 }}"
                  alt="{{ m.alt | default: p.title | escape }}"
                  loading="eager"
                >
                {%- if count >= max_imgs -%}{%- break -%}{%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}

          {%- if count == 0 -%}
            {%- if featured != blank -%}
              <img class="qcmQv__img qcmQv__img--slide" src="{{ featured | image_url: width: 1200 }}" alt="{{ featured.alt | default: p.title | escape }}" loading="eager">
            {%- else -%}
              <div class="qcmQv__placeholder" aria-hidden="true"></div>
            {%- endif -%}
          {%- endif -%}
        </div>

        <button class="qcmQv__arrow qcmQv__arrow--prev" type="button" data-qcm-qv-prev aria-label="Previous image">‹</button>
        <button class="qcmQv__arrow qcmQv__arrow--next" type="button" data-qcm-qv-next aria-label="Next image">›</button>
      </div>

      {%- comment -%} HOVER MODE (first + second image) {%- endcomment -%}
      {%- assign second_image = blank -%}
      {%- if p.media != blank and p.media.size > 1 -%}
        {%- assign m2 = p.media[1] -%}
        {%- if m2.media_type == 'image' -%}
          {%- assign second_image = m2 -%}
        {%- endif -%}
      {%- endif -%}

      <a class="qcmQv__hoverLink" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
        {%- if featured != blank -%}
          <img class="qcmQv__img qcmQv__img--primary" src="{{ featured | image_url: width: 1200 }}" alt="{{ featured.alt | default: p.title | escape }}" loading="eager">
        {%- else -%}
          <div class="qcmQv__placeholder" aria-hidden="true"></div>
        {%- endif -%}

        {%- if second_image != blank -%}
          <img class="qcmQv__img qcmQv__img--second" src="{{ second_image | image_url: width: 1200 }}" alt="{{ second_image.alt | default: p.title | escape }}" loading="eager">
        {%- endif -%}
      </a>
    </div>

    <div class="qcmQv__info">
      <h3 class="qcmQv__title"><a href="{{ p.url }}">{{ p.title }}</a></h3>

      {%- if v != blank -%}
        <div class="qcmQv__price">
          <span class="qcmQv__priceNow">{{ v.price | money }}</span>
          {%- if v.compare_at_price > v.price -%}
            <span class="qcmQv__priceWas"><s>{{ v.compare_at_price | money }}</s></span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if p.description != blank -%}
        <div class="qcmQv__desc">
          {{ p.description | strip_html | truncate: 260 }}
        </div>
      {%- endif -%}

      {%- if p.variants.size > 1 and v != blank -%}
        <label class="qcmQv__label" for="QcmQvVar-{{ p.id }}">Options</label>
        <select class="qcmQv__select" id="QcmQvVar-{{ p.id }}" data-qcm-qv-variant>
          {%- for vr in p.variants -%}
            <option value="{{ vr.id }}" {% if vr.id == v.id %}selected{% endif %} {% unless vr.available %}disabled{% endunless %}>
              {{ vr.title }}
            </option>
          {%- endfor -%}
        </select>
      {%- endif -%}

      <div class="qcmQv__actions">
        {%- comment -%} The collection section decides which buttons show via CSS/visibility {%- endcomment -%}

        {%- if v != blank -%}
          {%- form 'product', p, class: 'qcmQv__form', data-qcm-qv-form: 'true' -%}
            <input type="hidden" name="id" value="{{ v.id }}" data-qcm-qv-id>
            <button class="qcmQv__btn qcmQv__btn--atc" type="submit" name="add">Add to cart</button>
          {%- endform -%}

          {%- if p.variants.size == 1 and p.available -%}
            {%- form 'product', p, class: 'qcmQv__form qcmQv__form--buy', data-qcm-qv-form: 'true' -%}
              <input type="hidden" name="id" value="{{ v.id }}" data-qcm-qv-id>
              <button class="qcmQv__btn qcmQv__btn--buy" type="submit" name="checkout">Buy now</button>
            {%- endform -%}
          {%- endif -%}
        {%- endif -%}

        <a class="qcmQv__btn qcmQv__btn--view" href="{{ p.url }}">View product</a>
      </div>

      <div class="qcmQv__status" aria-live="polite" data-qcm-qv-status></div>
    </div>
  </div>
</div>

{% schema %}
{ "name": "Collection Quick View", "settings": [], "presets": [{ "name": "Collection Modern Quick View" }] }
{% endschema %}