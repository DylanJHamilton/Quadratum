{%- comment -%}
  Q ADD-ON: Variant UI Enhancements (Classic)
  - Does NOT modify existing picker markup
  - Mirrors options and sets the existing variant <select name="id"> value
  Inputs:
    - product
    - section
    - current_variant
{%- endcomment -%}

{%- liquid
  assign p = product
  assign s = section.settings
  assign v = current_variant

  assign ui_style = s.variant_ui_style | default: 'default'
  if ui_style == 'default'
    break
  endif

  assign target_csv = s.variant_ui_target_options | default: ''
  assign label_mode = s.variant_label_mode | default: 'show_selected_value'
  assign swatch_source = s.variant_swatch_source | default: 'variant_image'

  assign mf_ns = s.variant_swatch_metafield_namespace | default: ''
  assign mf_key = s.variant_swatch_metafield_key | default: ''

  assign select_id = 'q-variant-' | append: section.id
-%}

<div
  class="q-variant-ui"
  data-product-variant-ui
  data-product-section-id="{{ section.id }}"
  data-product-select-id="{{ select_id }}"
  data-product-style="{{ ui_style }}"
  data-product-label-mode="{{ label_mode }}"
  data-product-target-options="{{ target_csv | escape }}"
  data-product-swatch-source="{{ swatch_source }}"
  data-product-mf-ns="{{ mf_ns | escape }}"
  data-product-mf-key="{{ mf_key | escape }}"
>
  {%- if s.variant_size_guide_enable and s.variant_size_guide_url != blank -%}
    <div class="q-variant-ui__sizeguide">
      <a class="q-variant-ui__sizeguide-link" href="{{ s.variant_size_guide_url }}" target="_blank" rel="noopener">
        Size guide
      </a>
    </div>
  {%- endif -%}

  {%- for opt in p.options_with_values -%}
    {%- assign opt_index = forloop.index -%}
    {%- assign opt_name = opt.name | default: '' -%}

    <div class="q-variant-ui__group" data-product-option-index="{{ opt_index }}" aria-label="{{ opt_name | escape }}">
      {%- if label_mode != 'hide' -%}
        <div class="q-variant-ui__label">
          <span class="q-variant-ui__label-name">{{ opt_name }}</span>
          <span class="q-variant-ui__label-value" data-product-selected-value>
            {%- case opt_index -%}
              {%- when 1 -%}{{ v.option1 }}
              {%- when 2 -%}{{ v.option2 }}
              {%- when 3 -%}{{ v.option3 }}
            {%- endcase -%}
          </span>
        </div>
      {%- endif -%}

      <div
        class="q-variant-ui__controls"
        role="radiogroup"
        aria-label="{{ opt_name | escape }}"
        data-product-controls
      >
        {%- for val in opt.values -%}
          {%- assign display_value = val -%}
          <button
            type="button"
            class="q-variant-ui__item"
            data-product-option-value="{{ display_value | escape }}"
            aria-pressed="{% if opt_index == 1 and v.option1 == display_value %}true{% elsif opt_index == 2 and v.option2 == display_value %}true{% elsif opt_index == 3 and v.option3 == display_value %}true{% else %}false{% endif %}"
          >
            <span class="q-variant-ui__swatch" aria-hidden="true"></span>
            <span class="q-variant-ui__text">{{ display_value }}</span>
          </button>
        {%- endfor -%}
      </div>
    </div>
  {%- endfor -%}

  <script type="application/json" data-product-variants-json>
    {{ p.variants | json }}
  </script>
</div>