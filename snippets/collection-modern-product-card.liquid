{%- liquid
  assign s = s
  assign p = product
  if p == blank
    break
  endif

  assign show_vendor = s.show_vendor
  assign show_price = s.show_price
  assign show_badges = s.show_badges
  assign show_rating = s.show_rating
  assign show_quick_add = s.show_quick_add
  assign show_second = s.show_second_image

  assign atc_label = s.add_to_cart_label | default: 'Add to cart'
  assign choose_label = s.choose_options_label | default: 'Choose options'
  assign show_buy_now = s.show_buy_now
  assign buy_now_label = s.buy_now_label | default: 'Buy now'
  assign btn_size = s.button_size | default: 'md'

  assign card_style = s.card_style | default: 'glass'

  assign featured_media = p.featured_media
  assign img_ratio = s.image_ratio | default: 'adapt'
  assign ratio_pct = 100
  if img_ratio == 'square'
    assign ratio_pct = 100
  elsif img_ratio == 'portrait'
    assign ratio_pct = 125
  elsif img_ratio == 'landscape'
    assign ratio_pct = 70
  endif

  assign second_media = nil
  if show_second and p.media.size > 1
    assign second_media = p.media[1]
  endif

  assign available = p.available
  assign on_sale = false
  if p.compare_at_price > p.price
    assign on_sale = true
  endif
-%}

<style>
  .q-collection-modern .qcmCard{
    border-radius: var(--qcm-radius);
    border: 1px solid var(--qcm-card-border, rgba(0,0,0,.12));
    border-style: var(--qcm-card-border-style, solid);
    overflow: hidden;
    background: var(--qcm-card-bg, #fff);
    max-width: 100%;
  }
  .q-collection-modern .qcmCard--none{ border: none; background: transparent; }
  .q-collection-modern .qcmCard--outline{ background: transparent; }
  .q-collection-modern .qcmCard--solid{ background: var(--qcm-card-bg, #fff); }
  .q-collection-modern .qcmCard--glass{
    background: color-mix(in srgb, var(--qcm-card-bg, #fff) 80%, transparent);
    backdrop-filter: blur(10px);
  }

  /* Hover effects apply to card only */
  .q-collection-modern.hover-lift .qcmCard{ transition: transform .18s ease; }
  .q-collection-modern.hover-lift .qcmCard:hover{ transform: translateY(-2px); }

  .q-collection-modern.hover-glow .qcmCard{ transition: box-shadow .18s ease; }
  .q-collection-modern.hover-glow .qcmCard:hover{ box-shadow: var(--qcm-shadow, 0 10px 30px rgba(0,0,0,.12)); }

  @media (prefers-reduced-motion: reduce){
    .q-collection-modern.hover-lift .qcmCard,
    .q-collection-modern.hover-glow .qcmCard{ transition:none; transform:none; }
  }

  .q-collection-modern .qcmCard__media{
    position: relative;
    display:block;
    overflow:hidden;
  }
  .q-collection-modern .qcmCard__media::before{
    content:"";
    display:block;
    padding-top: {{ ratio_pct }}%;
  }
  .q-collection-modern .qcmCard__mediaInner{
    position:absolute;
    inset:0;
  }
  .q-collection-modern .qcmCard__img{
    width:100%;
    height:100%;
    object-fit: cover;
    display:block;
  }
  .q-collection-modern .qcmCard__img--second{
    position:absolute;
    inset:0;
    opacity:0;
    transition: opacity .18s ease;
  }
  .q-collection-modern .qcmCard:hover .qcmCard__img--second{
    opacity:1;
  }
  @media (prefers-reduced-motion: reduce){
    .q-collection-modern .qcmCard__img--second{ transition:none; }
  }

  .q-collection-modern .qcmCard__badges{
    position:absolute;
    left:10px;
    top:10px;
    display:flex;
    gap:8px;
    flex-wrap:wrap;
  }
  .q-collection-modern .qcmBadge{
    font-size: 12px;
    padding: 6px 8px;
    border-radius: 999px;
    border: 1px solid var(--qcm-btn-border, rgba(0,0,0,.15));
    background: rgba(255,255,255,.85);
  }

  .q-collection-modern .qcmCard__content{
    padding: var(--qcm-card-pad, 14px);
    display:grid;
    gap: 8px;
    min-width: 0;
  }

  .q-collection-modern .qcmCard__vendor{
    color: var(--qcm-vendor-color, inherit);
    font-size: var(--qcm-vendor-size-set, var(--qcm-vendor-size, .9em));
    opacity:.85;
  }

  .q-collection-modern .qcmCard__title{
    margin:0;
    color: var(--qcm-title-color, inherit);
    font-size: var(--qcm-title-size-set, var(--qcm-title-size, 1em));
    line-height:1.25;
    min-width: 0;
  }
  .q-collection-modern .qcmCard__title a{
    color:inherit;
    text-decoration:none;
    display:inline-block;
    max-width:100%;
  }
  .q-collection-modern .qcmCard__title a:hover{ text-decoration:underline; }

  .q-collection-modern .qcmCard__price{
    color: var(--qcm-price-color, inherit);
    font-size: var(--qcm-price-size-set, var(--qcm-price-size, 1em));
    display:flex;
    gap:10px;
    align-items:baseline;
    flex-wrap:wrap;
  }
  .q-collection-modern .qcmPrice--compare{ opacity:.7; text-decoration: line-through; }

  .q-collection-modern .qcmCard__actions{
    margin-top: 6px;
    display:grid;
    gap: 10px;
  }

  .q-collection-modern .qcmCard__btn{
    display:flex;
    align-items:center;
    justify-content:center;
    width:100%;
    max-width:100%;
    border: 1px solid var(--qcm-btn-border, rgba(0,0,0,.15));
    border-radius: calc(var(--qcm-radius) * 0.75);
    padding: 10px 12px;
    background: var(--qcm-btn-bg, transparent);
    color: var(--qcm-btn-text, inherit);
    text-decoration:none;
    cursor:pointer;
    font: inherit;
    line-height: 1.1;
    min-width: 0;
    white-space: normal;
    text-align:center;
  }

  .q-collection-modern .qcmCard__btn:hover{
    background: var(--qcm-btn-bg-hover, var(--qcm-btn-bg, transparent));
    color: var(--qcm-btn-text-hover, var(--qcm-btn-text, inherit));
  }

  .q-collection-modern .qcmCard__btn--sm{ padding: 8px 10px; font-size: .92em; }
  .q-collection-modern .qcmCard__btn--md{ padding: 10px 12px; font-size: 1em; }
  .q-collection-modern .qcmCard__btn--lg{ padding: 12px 14px; font-size: 1.05em; }

  .q-collection-modern .qcmCard__btn--disabled{ opacity:.6; cursor:not-allowed; }
</style>

<article class="qcmCard qcmCard--{{ card_style }}">
  <a class="qcmCard__media" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
    <span class="qcmCard__mediaInner">
      {%- if featured_media != blank -%}
        {{ featured_media | image_url: width: 900 | image_tag: class: 'qcmCard__img', loading: 'lazy', widths: '240,360,480,600,720,900', sizes: '(min-width: 990px) 25vw, (min-width: 680px) 33vw, 50vw' }}
      {%- endif -%}
      {%- if second_media != blank -%}
        {{ second_media | image_url: width: 900 | image_tag: class: 'qcmCard__img qcmCard__img--second', loading: 'lazy', widths: '240,360,480,600,720,900', sizes: '(min-width: 990px) 25vw, (min-width: 680px) 33vw, 50vw' }}
      {%- endif -%}

      {%- if show_badges -%}
        <span class="qcmCard__badges" aria-hidden="true">
          {%- if available == false -%}
            <span class="qcmBadge">Sold out</span>
          {%- elsif on_sale -%}
            <span class="qcmBadge">Sale</span>
          {%- endif -%}
        </span>
      {%- endif -%}
    </span>
  </a>

  <div class="qcmCard__content">
    {%- if show_vendor and p.vendor != blank -%}
      <div class="qcmCard__vendor">{{ p.vendor }}</div>
    {%- endif -%}

    <h3 class="qcmCard__title">
      <a href="{{ p.url }}">{{ p.title }}</a>
    </h3>

    {%- if show_price -%}
      <div class="qcmCard__price">
        {%- if on_sale -%}
          <span>{{ p.price | money }}</span>
          <span class="qcmPrice--compare">{{ p.compare_at_price | money }}</span>
        {%- else -%}
          <span>{{ p.price | money }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if show_rating -%}
      <div style="opacity:.7; font-size: .92em;">★★★★★ <span style="opacity:.6">(rating)</span></div>
    {%- endif -%}

    {%- if show_quick_add -%}
      <div class="qcmCard__actions">
        {%- if p.available == false -%}
          <button class="qcmCard__btn qcmCard__btn--{{ btn_size }} qcmCard__btn--disabled" type="button" disabled>Sold out</button>
        {%- elsif p.has_only_default_variant -%}
          <form method="post" action="{{ routes.cart_add_url }}">
            <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
            <button class="qcmCard__btn qcmCard__btn--{{ btn_size }}" type="submit">{{ atc_label }}</button>
          </form>

          {%- if show_buy_now -%}
            <a class="qcmCard__btn qcmCard__btn--{{ btn_size }}" href="/cart/{{ p.selected_or_first_available_variant.id }}:1?checkout">
              {{ buy_now_label }}
            </a>
          {%- endif -%}
        {%- else -%}
          <a class="qcmCard__btn qcmCard__btn--{{ btn_size }}" href="{{ p.url }}">{{ choose_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</article>