{%- comment -%}
  Quadratum — Collection Modern Toolbar
  File: snippets/collection-modern-toolbar.liquid

  - Works in collection and search contexts via `mode`
  - Sort works:
    - dropdown: GET form submit, preserves query params (filters)
    - pills: links (simple + robust)
  - Overrides (pass via render):
    force_hide_active: true/false
    force_hide_clear:  true/false
    force_sort_style:  'dropdown'/'pills'
{%- endcomment -%}

{%- liquid
  assign s = section.settings

  assign mode = mode | default: 'collection'
  assign filter_mode = filter_mode | default: 'sidebar'

  assign has_filters = false
  if s.show_filters
    assign has_filters = true
  endif

  assign show_sort = false
  if s.show_sort
    assign show_sort = true
  endif

  assign show_count = false
  if s.show_result_count
    assign show_count = true
  endif

  assign show_active = false
  if s.show_active_filters
    assign show_active = true
  endif

  assign show_clear = false
  if s.show_clear_all
    assign show_clear = true
  endif

  if force_hide_active
    assign show_active = false
  endif
  if force_hide_clear
    assign show_clear = false
  endif

  assign sort_style = s.sort_style | default: 'dropdown'
  if force_sort_style != blank
    assign sort_style = force_sort_style
  endif

  assign title_text = ''
  assign desc_html = ''
  assign results_count_text = ''

  if mode == 'search'
    assign title_text = 'Search'
    if search.terms != blank
      assign title_text = 'Search: ' | append: search.terms
    endif
    assign desc_html = ''
    assign results_count_text = search.results_count | append: ' results'
  else
    assign title_text = collection.title
    assign desc_html = collection.description
    assign results_count_text = collection.products_count | append: ' products'
  endif

  assign hide_raw = s.sort_hide_values | default: ''
  assign rename_raw = s.sort_rename_values | default: ''
  assign hide_lines = hide_raw | newline_to_br | split: '<br />'
  assign rename_lines = rename_raw | newline_to_br | split: '<br />'

  assign sort_by_value = ''
  assign sort_default = ''
  if mode == 'search'
    assign sort_by_value = search.sort_by
    assign sort_default = search.default_sort_by
  else
    assign sort_by_value = collection.sort_by
    assign sort_default = collection.default_sort_by
  endif
  if sort_by_value == blank
    assign sort_by_value = sort_default
  endif

  assign sort_options = collection.sort_options
  if mode == 'search'
    assign sort_options = search.sort_options
  endif
-%}

<div class="qcmToolbar" data-qcm-toolbar>
  <div class="qcmToolbar__top">
    <div class="qcmToolbar__heading">
      {%- if s.show_title -%}
        <h1 class="qcmTitle">{{ title_text }}</h1>
      {%- endif -%}

      {%- if s.show_description and desc_html != blank -%}
        {%- if s.description_style == 'truncated' -%}
          <div class="qcmDesc qcmDesc--truncated" style="--qcm-desc-lines: {{ s.truncated_lines | default: 3 }};">
            {{ desc_html }}
          </div>
        {%- else -%}
          <div class="qcmDesc">
            {{ desc_html }}
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- if show_count -%}
        <div class="qcmCount" aria-live="polite">{{ results_count_text }}</div>
      {%- endif -%}
    </div>

    <div class="qcmToolbar__controls">
      {%- if has_filters and filter_mode == 'drawer' -%}
        <button
          type="button"
          class="qcmBtn qcmBtn--ghost"
          data-qcm-drawer-open
          aria-label="Open filters"
          aria-controls="qcmFacetsDrawer-{{ section.id }}"
          aria-expanded="false">
          Filters
        </button>
      {%- endif -%}

      {%- if show_sort -%}
        {%- if sort_style == 'pills' -%}
          <div class="qcmSortPills" role="list" aria-label="Sort options">
            {%- for opt in sort_options -%}
              {%- assign hidden = false -%}
              {%- assign label_override = blank -%}

              {%- for h in hide_lines -%}
                {%- assign hv = h | strip -%}
                {%- if hv == blank or hv == '_' -%}{%- continue -%}{%- endif -%}
                {%- if hv == opt.value -%}{%- assign hidden = true -%}{%- endif -%}
              {%- endfor -%}

              {%- for r in rename_lines -%}
                {%- assign rv = r | strip -%}
                {%- if rv == blank or rv == '_' -%}{%- continue -%}{%- endif -%}
                {%- assign parts = rv | split: '|' -%}
                {%- if parts.size >= 2 -%}
                  {%- assign key = parts[0] | strip -%}
                  {%- assign val = parts[1] | strip -%}
                  {%- if key == opt.value and val != blank -%}{%- assign label_override = val -%}{%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- unless hidden -%}
                {%- assign opt_label = opt.name -%}
                {%- if label_override != blank -%}{%- assign opt_label = label_override -%}{%- endif -%}

                {%- assign is_active = false -%}
                {%- if sort_by_value == opt.value -%}{%- assign is_active = true -%}{%- endif -%}

                {%- capture sort_url -%}
                  {%- if mode == 'search' -%}
                    {{ routes.search_url }}?q={{ search.terms | url_encode }}&sort_by={{ opt.value }}
                  {%- else -%}
                    {{ collection.url }}?sort_by={{ opt.value }}
                  {%- endif -%}
                {%- endcapture -%}

                <a
                  role="listitem"
                  class="qcmPill{% if is_active %} is-active{% endif %}"
                  href="{{ sort_url | strip }}"
                  aria-label="Sort by {{ opt_label | escape }}">
                  {{ opt_label }}
                </a>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- else -%}
          <form class="qcmSort" method="get" action="{% if mode == 'search' %}{{ routes.search_url }}{% else %}{{ collection.url }}{% endif %}">
            {%- if mode == 'search' and search.terms != blank -%}
              <input type="hidden" name="q" value="{{ search.terms | escape }}">
            {%- endif -%}

            {%- for qp in request.query_params -%}
              {%- assign k = qp[0] -%}
              {%- assign v = qp[1] -%}
              {%- unless k == 'sort_by' or k == 'page' or k == 'q' -%}
                {%- if v != blank -%}
                  <input type="hidden" name="{{ k | escape }}" value="{{ v | escape }}">
                {%- endif -%}
              {%- endunless -%}
            {%- endfor -%}

            <label class="qcmVisuallyHidden" for="qcmSortSelect-{{ section.id }}">Sort</label>
            <select
              id="qcmSortSelect-{{ section.id }}"
              class="qcmSelect"
              name="sort_by"
              onchange="this.form.submit()">

              {%- for opt in sort_options -%}
                {%- assign hidden = false -%}
                {%- assign label_override = blank -%}

                {%- for h in hide_lines -%}
                  {%- assign hv = h | strip -%}
                  {%- if hv == blank or hv == '_' -%}{%- continue -%}{%- endif -%}
                  {%- if hv == opt.value -%}{%- assign hidden = true -%}{%- endif -%}
                {%- endfor -%}

                {%- for r in rename_lines -%}
                  {%- assign rv = r | strip -%}
                  {%- if rv == blank or rv == '_' -%}{%- continue -%}{%- endif -%}
                  {%- assign parts = rv | split: '|' -%}
                  {%- if parts.size >= 2 -%}
                    {%- assign key = parts[0] | strip -%}
                    {%- assign val = parts[1] | strip -%}
                    {%- if key == opt.value and val != blank -%}{%- assign label_override = val -%}{%- endif -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- unless hidden -%}
                  {%- assign opt_label = opt.name -%}
                  {%- if label_override != blank -%}{%- assign opt_label = label_override -%}{%- endif -%}

                  <option value="{{ opt.value }}" {% if sort_by_value == opt.value %}selected{% endif %}>
                    {{ opt_label }}
                  </option>
                {%- endunless -%}
              {%- endfor -%}
            </select>
          </form>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- if show_active or show_clear -%}
    <div class="qcmToolbar__active" data-qcm-active>
      {%- if show_active -%}
        <div class="qcmActiveChips" data-qcm-active-chips></div>
      {%- endif -%}

      {%- if show_clear -%}
        {%- if mode == 'search' -%}
          <a class="qcmBtn qcmBtn--ghost" href="{{ routes.search_url }}?q={{ search.terms | url_encode }}">Clear all</a>
        {%- else -%}
          <a class="qcmBtn qcmBtn--ghost" href="{{ collection.url }}">Clear all</a>
        {%- endif -%}
      {%- endif -%}
    </div>
  {%- endif -%}
</div>