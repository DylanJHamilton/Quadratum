{{ 'section-main-blog-collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign page_layout = section.settings.page_layout | default: 'full_width'
  assign posts_layout = section.settings.posts_layout | default: 'grid'
  assign sidebar_width = section.settings.sidebar_width | default: 'medium'

  assign columns_desktop = section.settings.columns_desktop | default: 3
  assign columns_tablet = section.settings.columns_tablet | default: 2
  assign columns_mobile = section.settings.columns_mobile | default: 1

  assign show_title = section.settings.show_title
  assign show_description = section.settings.show_description

  assign show_image = section.settings.show_image
  assign show_author = section.settings.show_author
  assign show_date = section.settings.show_date
  assign show_read_time = section.settings.show_read_time
  assign show_tags = section.settings.show_tags
  assign show_excerpt = section.settings.show_excerpt
  assign show_read_more = section.settings.show_read_more

  assign card_bg = section.settings.card_bg | default: '#ffffff'
  assign card_border_color = section.settings.card_border_color | default: 'rgba(0,0,0,0.12)'
  assign card_border_width = section.settings.card_border_width | default: 1
  assign card_border_style = section.settings.card_border_style | default: 'solid'
  assign card_radius = section.settings.card_radius | default: 16
  assign card_padding = section.settings.card_padding | default: 16

  assign title_color = section.settings.title_color | default: '#111111'
  assign title_font_size = section.settings.title_font_size | default: 28
  assign title_font_weight = section.settings.title_font_weight | default: '600'

  assign meta_color = section.settings.meta_color | default: '#666666'
  assign meta_font_size = section.settings.meta_font_size | default: 14

  assign excerpt_color = section.settings.excerpt_color | default: '#444444'
  assign excerpt_font_size = section.settings.excerpt_font_size | default: 16
  assign excerpt_lines = section.settings.excerpt_lines | default: 3

  assign read_more_label = section.settings.read_more_label | default: 'Read more'
  assign button_bg = section.settings.button_bg | default: '#111111'
  assign button_text = section.settings.button_text | default: '#ffffff'
  assign button_border_color = section.settings.button_border_color | default: '#111111'
  assign button_border_width = section.settings.button_border_width | default: 1
  assign button_border_style = section.settings.button_border_style | default: 'solid'
  assign button_radius = section.settings.button_radius | default: 999
  assign button_font_size = section.settings.button_font_size | default: 14
  assign button_padding_x = section.settings.button_padding_x | default: 16
  assign button_padding_y = section.settings.button_padding_y | default: 10
  assign button_bg_hover = section.settings.button_bg_hover | default: '#222222'
  assign button_text_hover = section.settings.button_text_hover | default: '#ffffff'
  assign button_border_hover = section.settings.button_border_hover | default: '#222222'

  assign sidebar_bg = section.settings.sidebar_bg | default: '#ffffff'
  assign sidebar_border_color = section.settings.sidebar_border_color | default: 'rgba(0,0,0,0.12)'
  assign sidebar_border_width = section.settings.sidebar_border_width | default: 1
  assign sidebar_border_style = section.settings.sidebar_border_style | default: 'solid'
  assign sidebar_radius = section.settings.sidebar_radius | default: 16
  assign sidebar_padding = section.settings.sidebar_padding | default: 20
  assign sidebar_gap = section.settings.sidebar_gap | default: 20
  assign sidebar_heading_color = section.settings.sidebar_heading_color | default: '#111111'
  assign sidebar_text_color = section.settings.sidebar_text_color | default: '#444444'

  assign section_gap = section.settings.gap | default: 24
  assign section_padding_top = section.settings.padding_top | default: 48
  assign section_padding_bottom = section.settings.padding_bottom | default: 48

  assign has_sidebar = false
  if page_layout == 'sidebar'
    assign has_sidebar = true
  endif
-%}

<section
  id="QtmMainBlogCollection-{{ section.id }}"
  class="qtm-main-blog-collection qtm-main-blog-collection--{{ posts_layout }}{% if has_sidebar %} qtm-main-blog-collection--has-sidebar{% else %} qtm-main-blog-collection--full{% endif %} qtm-main-blog-collection--sidebar-{{ sidebar_width }}"
  style="
    --qtm-mbc-gap: {{ section_gap }}px;
    --qtm-mbc-columns-desktop: {{ columns_desktop }};
    --qtm-mbc-columns-tablet: {{ columns_tablet }};
    --qtm-mbc-columns-mobile: {{ columns_mobile }};

    --qtm-mbc-card-bg: {{ card_bg }};
    --qtm-mbc-card-border-color: {{ card_border_color }};
    --qtm-mbc-card-border-width: {{ card_border_width }}px;
    --qtm-mbc-card-border-style: {{ card_border_style }};
    --qtm-mbc-card-radius: {{ card_radius }}px;
    --qtm-mbc-card-padding: {{ card_padding }}px;

    --qtm-mbc-title-color: {{ title_color }};
    --qtm-mbc-title-size: {{ title_font_size }}px;
    --qtm-mbc-title-weight: {{ title_font_weight }};

    --qtm-mbc-meta-color: {{ meta_color }};
    --qtm-mbc-meta-size: {{ meta_font_size }}px;

    --qtm-mbc-excerpt-color: {{ excerpt_color }};
    --qtm-mbc-excerpt-size: {{ excerpt_font_size }}px;
    --qtm-mbc-excerpt-lines: {{ excerpt_lines }};

    --qtm-mbc-button-bg: {{ button_bg }};
    --qtm-mbc-button-text: {{ button_text }};
    --qtm-mbc-button-border-color: {{ button_border_color }};
    --qtm-mbc-button-border-width: {{ button_border_width }}px;
    --qtm-mbc-button-border-style: {{ button_border_style }};
    --qtm-mbc-button-radius: {{ button_radius }}px;
    --qtm-mbc-button-font-size: {{ button_font_size }}px;
    --qtm-mbc-button-padding-x: {{ button_padding_x }}px;
    --qtm-mbc-button-padding-y: {{ button_padding_y }}px;
    --qtm-mbc-button-bg-hover: {{ button_bg_hover }};
    --qtm-mbc-button-text-hover: {{ button_text_hover }};
    --qtm-mbc-button-border-hover: {{ button_border_hover }};

    --qtm-mbc-sidebar-bg: {{ sidebar_bg }};
    --qtm-mbc-sidebar-border-color: {{ sidebar_border_color }};
    --qtm-mbc-sidebar-border-width: {{ sidebar_border_width }}px;
    --qtm-mbc-sidebar-border-style: {{ sidebar_border_style }};
    --qtm-mbc-sidebar-radius: {{ sidebar_radius }}px;
    --qtm-mbc-sidebar-padding: {{ sidebar_padding }}px;
    --qtm-mbc-sidebar-gap: {{ sidebar_gap }}px;
    --qtm-mbc-sidebar-heading-color: {{ sidebar_heading_color }};
    --qtm-mbc-sidebar-text-color: {{ sidebar_text_color }};

    --qtm-mbc-padding-top: {{ section_padding_top }}px;
    --qtm-mbc-padding-bottom: {{ section_padding_bottom }}px;

    --q-surface: {{ card_bg }};
    --q-border: {{ card_border_color }};
    --q-radius-md: {{ card_radius }}px;
    --q-gap-md: {{ card_padding }}px;
    --q-gap-sm: {{ card_padding | at_most: 16 }}px;
    --q-gap-xs: {{ button_padding_y | at_most: 12 }}px;
    --q-fs-lg: {{ title_font_size }}px;
    --q-fs-sm: {{ meta_font_size }}px;
    --q-fs-base: {{ excerpt_font_size }}px;
  "
>
  <div class="qtm-main-blog-collection__inner">
    <header class="qtm-main-blog-collection__header">
      {%- if show_title -%}
        <h1 class="qtm-main-blog-collection__title">{{ blog.title }}</h1>
      {%- endif -%}

      {%- if show_description and blog.description != blank -%}
        <div class="qtm-main-blog-collection__description rte">
          {{ blog.description }}
        </div>
      {%- endif -%}
    </header>

    <div class="qtm-main-blog-collection__layout">
      <div class="qtm-main-blog-collection__main">
        {%- paginate blog.articles by section.settings.articles_per_page -%}
          {%- if blog.articles_count > 0 -%}
            <div
              class="qtm-main-blog-collection__posts qtm-main-blog-collection__posts--{{ posts_layout }}"
              aria-live="polite"
            >
              {%- for article in blog.articles -%}
                <div class="qtm-main-blog-collection__post">
                  {% render 'blog-card',
                    article: article,
                    heading_level: 2,
                    show_image: show_image,
                    show_author: show_author,
                    show_date: show_date,
                    show_read_time: show_read_time,
                    show_tags: show_tags,
                    show_excerpt: show_excerpt,
                    cta_label: read_more_label
                  %}
                </div>
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              <nav class="qtm-main-blog-collection__pagination" aria-label="Blog pagination">
                <ul class="qtm-main-blog-collection__pagination-list" role="list">
                  {%- if paginate.previous -%}
                    <li class="qtm-main-blog-collection__pagination-item">
                      <a href="{{ paginate.previous.url }}" class="qtm-main-blog-collection__pagination-link qtm-main-blog-collection__pagination-link--prev">
                        <span aria-hidden="true">←</span>
                        <span>Previous</span>
                      </a>
                    </li>
                  {%- endif -%}

                  {%- for part in paginate.parts -%}
                    <li class="qtm-main-blog-collection__pagination-item">
                      {%- if part.is_link -%}
                        <a href="{{ part.url }}" class="qtm-main-blog-collection__pagination-link" aria-label="Go to page {{ part.title }}">
                          {{ part.title }}
                        </a>
                      {%- else -%}
                        {%- if part.title == paginate.current_page -%}
                          <span class="qtm-main-blog-collection__pagination-link is-current" aria-current="page">
                            {{ part.title }}
                          </span>
                        {%- else -%}
                          <span class="qtm-main-blog-collection__pagination-ellipsis" aria-hidden="true">
                            {{ part.title }}
                          </span>
                        {%- endif -%}
                      {%- endif -%}
                    </li>
                  {%- endfor -%}

                  {%- if paginate.next -%}
                    <li class="qtm-main-blog-collection__pagination-item">
                      <a href="{{ paginate.next.url }}" class="qtm-main-blog-collection__pagination-link qtm-main-blog-collection__pagination-link--next">
                        <span>Next</span>
                        <span aria-hidden="true">→</span>
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              </nav>
            {%- endif -%}
          {%- else -%}
            <div class="qtm-main-blog-collection__empty rte">
              <p>No articles found in this blog.</p>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>

      {%- if has_sidebar -%}
        <aside class="qBlogSidebar" aria-label="Blog sidebar">
          <div class="qBlogSidebar__inner">
            {%- for block in section.blocks -%}
              <div class="qBlogSidebar__block qBlogSidebar__block--{{ block.type }}" {{ block.shopify_attributes }}>
                {%- case block.type -%}
                  {%- when 'tags' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="qBlogSidebar__heading">{{ block.settings.heading }}</h2>
                    {%- endif -%}

                    {%- if blog.all_tags.size > 0 -%}
                      <ul class="qBlogSidebar__tag-list" role="list">
                        {%- for tag in blog.all_tags -%}
                          <li class="qBlogSidebar__tag-item">
                            <a
                              class="qBlogSidebar__tag-link"
                              href="{{ blog.url }}/tagged/{{ tag | handleize }}"
                            >
                              <span>{{ tag }}</span>
                              {%- if block.settings.show_count -%}
                                {%- comment -%}
                                  Count output intentionally omitted in v1 to avoid inaccurate or expensive archive-wide counting.
                                  Setting is preserved for forward compatibility.
                                {%- endcomment -%}
                              {%- endif -%}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                  {%- when 'promo_banner' -%}
                    <div class="qBlogSidebar__promo{% if block.settings.overlay %} qBlogSidebar__promo--overlay{% endif %}">
                      {%- if block.settings.image != blank -%}
                        <div class="qBlogSidebar__promo-media">
                          {{
                            block.settings.image
                            | image_url: width: 1200
                            | image_tag:
                              loading: 'lazy',
                              widths: '320, 480, 720, 960, 1200',
                              sizes: '(min-width: 990px) 320px, 100vw',
                              class: 'qBlogSidebar__promo-image'
                          }}
                        </div>
                      {%- endif -%}

                      <div class="qBlogSidebar__promo-content">
                        {%- if block.settings.heading != blank -%}
                          <h2 class="qBlogSidebar__heading">{{ block.settings.heading }}</h2>
                        {%- endif -%}

                        {%- if block.settings.text != blank -%}
                          <div class="qBlogSidebar__text rte">{{ block.settings.text }}</div>
                        {%- endif -%}

                        {%- if block.settings.button_label != blank and block.settings.button_url != blank -%}
                          <a class="qBlogSidebar__button" href="{{ block.settings.button_url }}">
                            {{ block.settings.button_label }}
                          </a>
                        {%- endif -%}
                      </div>
                    </div>

                  {%- when 'custom_code' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="qBlogSidebar__heading">{{ block.settings.heading }}</h2>
                    {%- endif -%}

                    {%- if block.settings.custom_liquid != blank -%}
                      <div class="qBlogSidebar__text">
                        {{ block.settings.custom_liquid }}
                      </div>
                    {%- endif -%}

                  {%- when 'rich_text' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="qBlogSidebar__heading">{{ block.settings.heading }}</h2>
                    {%- endif -%}

                    {%- if block.settings.body != blank -%}
                      <div class="qBlogSidebar__text rte">{{ block.settings.body }}</div>
                    {%- endif -%}

                  {%- when 'recent_posts' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="qBlogSidebar__heading">{{ block.settings.heading }}</h2>
                    {%- endif -%}

                    {%- if blog.articles_count > 0 -%}
                      <ul class="qBlogSidebar__recent-list" role="list">
                        {%- for recent_article in blog.articles limit: block.settings.max_posts -%}
                          <li class="qBlogSidebar__recent-item">
                            <a class="qBlogSidebar__recent-link" href="{{ recent_article.url }}">
                              {{ recent_article.title }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                  {%- when 'menu' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="qBlogSidebar__heading">{{ block.settings.heading }}</h2>
                    {%- endif -%}

                    {%- if block.settings.menu != blank -%}
                      <ul class="qBlogSidebar__menu" role="list">
                        {%- for link in block.settings.menu.links -%}
                          <li class="qBlogSidebar__menu-item">
                            <a class="qBlogSidebar__menu-link" href="{{ link.url }}">
                              {{ link.title }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
        </aside>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Blog Collection",
  "tag": "section",
  "class": "section section-main-blog-collection",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show blog title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show blog description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show featured image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_read_time",
      "label": "Show read time",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show article tags",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_read_more",
      "label": "Show read more button",
      "default": true
    },
    {
      "type": "text",
      "id": "read_more_label",
      "label": "Read more label",
      "default": "Read more"
    },

    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "page_layout",
      "label": "Page layout",
      "default": "full_width",
      "options": [
        { "value": "full_width", "label": "Full width" },
        { "value": "sidebar", "label": "Sidebar" }
      ]
    },
    {
      "type": "select",
      "id": "posts_layout",
      "label": "Posts layout",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "masonry", "label": "Masonry" },
        { "value": "list", "label": "List" }
      ]
    },
    {
      "type": "select",
      "id": "sidebar_width",
      "label": "Sidebar width",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 8,
      "max": 48,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 3,
      "max": 24,
      "step": 1,
      "default": 9
    },

    {
      "type": "header",
      "content": "Card styling"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#E5E5E5"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Card border width",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 1
    },
    {
      "type": "select",
      "id": "card_border_style",
      "label": "Card border style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "double", "label": "Double" }
      ]
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 8,
      "max": 40,
      "step": 1,
      "default": 16
    },

    {
      "type": "header",
      "content": "Title styling"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 16,
      "max": 40,
      "step": 1,
      "default": 28
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title font weight",
      "default": "600",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" }
      ]
    },

    {
      "type": "header",
      "content": "Meta styling"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "meta_font_size",
      "label": "Meta font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14
    },

    {
      "type": "header",
      "content": "Excerpt styling"
    },
    {
      "type": "color",
      "id": "excerpt_color",
      "label": "Excerpt color",
      "default": "#444444"
    },
    {
      "type": "range",
      "id": "excerpt_font_size",
      "label": "Excerpt font size",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "excerpt_lines",
      "label": "Excerpt lines",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    },

    {
      "type": "header",
      "content": "Read more button styling"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Button border width",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 1
    },
    {
      "type": "select",
      "id": "button_border_style",
      "label": "Button border style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "double", "label": "Double" }
      ]
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "label": "Button horizontal padding",
      "min": 6,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "label": "Button vertical padding",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 10
    },
    {
      "type": "color",
